	partition DW_Tenant_Monthly_Charges-744782ad-fde7-4ab5-a2e0-9abfbadf8d8e = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   TENANT MONTHLY CHARGES DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per active recurring tenant charge (anchor#(lf)            TENANTCHARGEHISTORIES TCH via MC_Temp), with GL remap, community#(lf)            max-charge lookup, and charge grouping. Final output is#(lf)            SELECT * FROM MC_Final.#(lf)   CTE chain: MC_Temp, MC_Revised, MC_Community, MC_Final, MC_GROUP -> SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  The single ORGANIZATION_KEY / ORGANIZATION_NAME CASE block (in#(lf)             MC_Temp) was updated from the three-group form (+58,59 -> 'Hudson#(lf)             Oak') to the full six-group roll-up that mirrors the master PROPERTY#(lf)             script. DELIBERATE OUTPUT CHANGE limited to the organization columns.#(lf)     [FLAG]  MC_Final references Organization_Key = 1 in the Smart-Lock#(lf)             community-charge override. Org 1 is not produced by either the old#(lf)             or the new CASE (both roll the -1.. group to -1, and 1 is not in any#(lf)             member list), so this branch was already dead and remains unchanged.#(lf)             Noted only so the value is on the record.#(lf)     No CTEs or joins dropped. MC_GROUP is defined-but-unused (final SELECT reads#(lf)             MC_Final) and preserved as-is.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output):#(lf)        added 66                  -> 27 / 'RB DRC'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH MC_Temp AS (#(lf)#(lf)SELECT #(lf)TCH.TENANTCHARGEID#(lf),P.Property_key#(lf),P.EntityID#(lf),P.Address#(lf),T.Tenant_key#(lf),T.Tenant_Status#(lf),T.CURRENT_RENT#(lf),CASE WHEN to_date(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY,TLA.LEASE_TO_DATE_KEY)::TEXT,'yyyymmdd') < GETDATE() THEN 'Y'#(lf)#(tab)  ELSE COALESCE(T.MONTH_TO_MONTH,'N')#(lf)#(tab)  END AS MONTH_TO_MONTH#(lf),to_date(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY,TLA.LEASE_TO_DATE_KEY)::TEXT,'yyyymmdd') AS LEASE_EXP#(lf),T.Lease_ID#(lf),R.REGION_NAME#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)      #(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf),PUS.PORTFOLIO_KEY#(lf),PO.PORTFOLIO_NAME#(lf),P.Subdivision#(lf),CASE WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased' #(lf)      WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)      ELSE PUS.Occupancy_Status END AS Occupancy_Status#(lf),TCH.UNITID#(lf),TCH.TENANTINFORMATIONID#(lf)#(lf),TCH.GLACCOUNTID AS GLAccountID#(lf),GL.Accountnumber AS GLAccountNO#(lf),GL.Description AS GLDescription#(lf)#(lf),CASE WHEN TCH.GLAccountID IN (12,82) THEN 12 #(lf)#(tab)  WHEN TCH.GLAccountID IN (395,403) THEN 395#(lf)#(tab)  WHEN TCH.GLAccountID IN (83,378) THEN 378#(lf)#(tab)  WHEN TCH.GLAccountID IN (408,379) THEN 379#(lf)#(tab)  WHEN TCH.GLAccountID IN (316) AND Amount = 4 THEN 410 #(lf)      ELSE TCH.GLAccountID#(lf)      END AS Revised_GLAccountID#(lf)#(lf),TCH.ISDEBIT#(lf),TCH.CHARGEDESCRIPTION#(lf),TCH.ISMOVEOUTSPECIFIC#(lf),TCH.ONETIMECHARGES#(lf)#(lf),TCH.AMOUNT#(lf),TCH.LASTBILLEDON#(lf),TCH.STARTDATE#(lf),TCH.ENDDATE#(lf),CASE WHEN TCH.STARTDATE <= DATEADD(DAY,1,LAST_DAY(GETDATE())) AND (last_Day(TCH.ENDDATE) >= LAST_DAY(GETDATE()) OR TCH.ENDDATE IS NULL) THEN 'Yes' ELSE 'No' END AS IS_ACTIVE#(lf)--,LAST_DAY(GETDATE()) AS TEST#(lf)#(lf)  FROM  PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES PM_P ON PM_P.PROPERTYID = P.HBPM_PROPERTY_ID AND PM_P.""_FIVETRAN_DELETED"" = 'N'#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_PA ON PM_PA.PROPERTYID = PM_P.PROPERTYID AND PM_PA.""_FIVETRAN_DELETED"" = 'N'#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY  #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)   #(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTCHARGEHISTORIES TCH ON TCH.UNITID = PM_PA.UnitID AND TCH._FIVETRAN_DELETED = 'N'#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.GLACCOUNTS GL ON GL.GLACCOUNTID = TCH.GLACCOUNTID #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T ON T.Tenant_Information_ID = TCH.TENANTINFORMATIONID AND T.CURRENT_FLAG = 'Y'#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)   #(lf)WHERE 1=1#(lf) AND ONETIMECHARGES = 0#(lf) AND ISDEBIT = 'Y'#(lf) AND (ISMOVEOUTSPECIFIC = 'N' OR ISMOVEOUTSPECIFIC IS NULL)#(lf) AND TCH.CHARGEDESCRIPTION NOT LIKE '%Prorate%'#(lf) AND TCH._FIVETRAN_DELETED = 'N'#(lf) AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54)#(lf) AND PUS.Organization_KEY not IN (16,17)#(lf) AND PO.IS_Active_AM = 'Y'#(lf) AND PO.Current_Flag = 'Y'#(lf) AND P.Current_Flag = 'Y'#(lf) AND PU.Current_Flag = 'Y'#(lf) AND PUS.Occupancy_Status NOT IN ('Not Managed','Property SOLD')#(lf))#(lf)#(lf)--*******************************************************************************************#(lf)#(lf),MC_Revised AS (SELECT #(lf) MC_Temp.*#(lf) ,GL.Accountnumber AS Revised_GLAccountNO#(lf),GL.Description AS Revised_GLDescripton#(lf) FROM  MC_Temp#(tab)#(lf) LEFT JOIN PROD_REPLICA.HBPM_DBO.GLACCOUNTS GL ON GL.GLACCOUNTID = MC_Temp. Revised_GLAccountID#(lf)#(lf)WHERE 1=1#(lf)AND Occupancy_Status IN ('Tenant Leased', 'Trustee Leased')#(lf)AND (Tenant_Status <> 'Past' OR Tenant_Status IS NULL)#(lf))#(lf)#(lf)--*******************************************************************************************#(lf),MC_Community AS (#(lf)SELECT #(lf)MC_Revised.Subdivision#(lf),MC_Revised.Revised_GLAccountID#(lf),MAX(AMOUNT) Max_Communtiy_GL_Charge#(lf)FROM MC_Revised#(lf)WHERE #(lf)MC_Revised.Subdivision IS NOT NULL#(lf)AND Revised_GLAccountID IN (395,379,410,420)#(lf)GROUP BY #(lf)MC_Revised.Subdivision#(lf),MC_Revised.Revised_GLAccountID#(lf))#(lf)--*******************************************************************************************#(lf),MC_Final AS (#(lf)#(lf)SELECT #(lf)MCR.*#(lf),CASE WHEN Organization_Key =1 AND MCR.Revised_GLAccountID = 410 THEN 4#(lf)#(tab)ELSE Max_Communtiy_GL_Charge#(lf)#(tab)END AS Max_Communtiy_GL_Charge#(lf),CASE WHEN GLACCOUNTID IN (12,82) THEN 'Rent'#(lf)#(tab)  WHEN GLACCOUNTID IN (83,378) THEN 'Pet'#(lf)#(tab)  WHEN GLACCOUNTID IN (68) THEN 'MTM'#(lf)#(tab)  WHEN GLACCOUNTID IN (410,316) AND AMOUNT = 4 THEN 'Smart Lock'#(lf)#(tab)  ELSE NULL#(lf)#(tab)  END AS CHARGE_GROUP#(lf)#(lf)FROM MC_Revised MCR#(lf)LEFT JOIN MC_Community MCC ON MCC.Subdivision = MCR.Subdivision AND MCC.Revised_GLAccountID = MCR.Revised_GLAccountID#(lf))#(lf)--*******************************************************************************************#(lf)#(lf),MC_GROUP AS (#(lf)#(lf)SELECT #(lf)TENANT_KEY#(lf),SUM(CASE WHEN CHARGE_GROUP = 'Rent' THEN AMOUNT ELSE NULL END) AS  MC_Rent#(lf),SUM(CASE WHEN CHARGE_GROUP = 'MTM' THEN AMOUNT ELSE NULL END) AS  MC_MTM#(lf),SUM(CASE WHEN CHARGE_GROUP = 'Smart Lock' THEN AMOUNT ELSE NULL END) AS  MC_Smart_Lock#(lf),SUM(CASE WHEN CHARGE_GROUP = 'Pet' THEN AMOUNT ELSE NULL END) AS  MC_Pet#(lf)#(lf)FROM MC_FINAL #(lf)GROUP BY TENANT_KEY#(lf))#(lf)--*******************************************************************************************#(lf)SELECT * FROM MC_Final #(lf)--SELECT * FROM MC_GROUP", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

