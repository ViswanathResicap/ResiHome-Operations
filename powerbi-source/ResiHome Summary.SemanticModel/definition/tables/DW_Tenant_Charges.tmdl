table DW_Tenant_Charges
	lineageTag: 13ff813a-d2df-467e-91de-59b76731228a

	measure '0_Collection %' = ```
			IF(SUM(DW_Tenant_Charges[Charge_Amount])>0, min(COALESCE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),0) /SUM(DW_Tenant_Charges[Charge_Amount]), 1), min(DIVIDE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]), SUM(DW_Tenant_Charges[Charge_Amount]), BLANK()), 1))
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c4ea72c1-ab3c-4479-b743-1fdd73aeb7cf

		changedProperty = FormatString

	measure '0_Collection_FORMAT %' = IF(MAX(DW_Tenant_Charges[Charge_Date_BOM])=DATE(YEAR(TODAY()),MONTH(TODAY()),1),BLANK(),DW_Tenant_Charges[0_Collection %])
		lineageTag: feef845c-a294-46b4-8fc5-ff3f15b4412d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 0_Concessions = ```
			CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),FILTER(DW_Tenant_Receipts,DW_Tenant_Receipts[CREDITTYPEID]=1))
			            
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 4a348a60-8cdc-4808-b256-4c62011e89b6

		changedProperty = FormatString

	measure 0_Collections_Net =
			IF(SUM(DW_Tenant_Charges[Charge_Amount])>0,
			                 min(COALESCE((SUM(DW_Tenant_Receipts[PAID_AMOUNT]) -[0_Concessions]),0) / (SUM(DW_Tenant_Charges[Charge_Amount]) - [0_Concessions]), 1),
			                 min((SUM(DW_Tenant_Receipts[PAID_AMOUNT]) - [0_Concessions]) /(SUM(DW_Tenant_Charges[Charge_Amount])- [0_Concessions]), 1))
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d6dd22b5-7479-4b38-aa88-5fcd86b74a38

		changedProperty = FormatString

	measure 0_Collections_Switch = IF(SELECTEDVALUE(SEL_Collections_Type[Value])="Net (x-Concessions)",[0_Collections_Net],[0_Collection %])
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 219f1cff-2148-4db5-9cc2-1a2b606f887f

		changedProperty = FormatString

	measure 0_Unpaid = SUM(DW_Tenant_Charges[Charge_Amount]) - SUM(DW_Tenant_Receipts[PAID_AMOUNT])
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: e0d64107-83b8-46e9-a191-a7b0f81e1455

		changedProperty = FormatString

	measure 0_Delinquency = IF(DW_Tenant_Charges[0_Charges]>0, 1 - [0_Collections_Switch], BLANK())
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 49d393dd-d469-4336-b09d-7663c224e9e2

		changedProperty = FormatString

	measure 0_Charges = (SUM(DW_Tenant_Charges[Charge_Amount]) - IF(SELECTEDVALUE(SEL_Collections_Type[Value])="Gross",BLANK(),[0_Concessions]))
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: c3fdfad6-2ce5-490e-95eb-614e06d07f33

		changedProperty = FormatString

