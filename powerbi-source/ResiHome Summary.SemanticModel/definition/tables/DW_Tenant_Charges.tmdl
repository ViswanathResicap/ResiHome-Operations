	column '1_Days Aged' = IF((DW_Tenant_Charges[Balance]>1||DW_Tenant_Charges[Balance]<-1)&&DW_Tenant_Charges[1_Balance_Cumulative]>1,max((TODAY()-DW_Tenant_Charges[Charge_Date]+1),0),BLANK())
		dataType: int64
		formatString: 0
		lineageTag: 546fddae-1553-4e90-a840-53a63e57b706
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column '1_Balance Age Category' =
			IF(DW_Tenant_Charges[1_Days Aged]=BLANK(),BLANK(),
			                        IF(DW_Tenant_Charges[1_Days Aged]<30," <30",
			                        IF(DW_Tenant_Charges[1_Days Aged]<=60," 30-60",
			                        IF(DW_Tenant_Charges[1_Days Aged]<=90," 60-90",
			                        IF(DW_Tenant_Charges[1_Days Aged]>90,"+90",
			                        BLANK())))))
		lineageTag: 8fab9bbd-298b-40d4-b703-6713ab58b462
		summarizeBy: none

