	column 1_Balance_Cumulative = ```
			CALCULATE(SUM(DW_Tenant_Charges[Balance]),filter(ALLEXCEPT(DW_Tenant_Charges,DW_Tenant_Charges[TENANT_KEY],DW_Tenant_Charges[PROPERTY_KEY]),DW_Tenant_Charges[Charge_Date]<=TODAY())) -
			
			CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),FILTER(DW_Tenant_Receipts,DW_Tenant_Receipts[TENANT_KEY]=DW_Tenant_Charges[TENANT_KEY]&&DW_Tenant_Receipts[RECEIVABLE_ID]=BLANK()&&DW_Tenant_Charges[Charge_Date]<=TODAY()&&DW_Tenant_Receipts[RECEIPT_STATUS]="Active"))
			
