table DW_Deals
	lineageTag: 080d11ee-36fd-4f56-8b06-fa48b7781404

	measure '0_Deal Count' = ```
			DISTINCTCOUNT(DW_Deals[EMAIL]) + 0 
			```
		formatString: 0
		lineageTag: 64991d52-62f8-4514-90ec-35b5697cac70

		changedProperty = FormatString

	measure '0_Rent Var (HF)' = ```
			CALCULATE(DIVIDE(SUM(DW_Deals[CURRENTLISTPRICE]), SUM(DW_Deals[1_ASM_Blended]), BLANK()),FILTER(DW_Deals,DW_Deals[CURRENT_DEAL_STATUS]<>"Closed Lost"&&DW_Deals[CURRENTLISTPRICE]<>BLANK()&&DW_Deals[1_ASM_Blended]<>blank())) - 1
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: de9ba171-8dfb-4945-809c-f56a02340255

		changedProperty = FormatString

	measure '0_Deal Count (Raw)' = DISTINCTCOUNT(DW_Deals[EMAIL])
		formatString: #,0
		lineageTag: c83ef08c-93fe-4029-bcc5-5bc16e3c7cb5

		changedProperty = FormatString

	measure '0_Deal W/W' = ```
			VAR thisWeek = CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]), DW_Deals[APPLICATION_SUBMIT_DATE] >= TODAY()-7, DW_Deals[APPLICATION_SUBMIT_DATE] <= TODAY()-1)
			VAR lastWeek = CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]), DW_Deals[APPLICATION_SUBMIT_DATE] >= TODAY()-14, DW_Deals[APPLICATION_SUBMIT_DATE] <= TODAY()-8)
			RETURN DIVIDE(thisWeek, lastWeek)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 9e2d43d4-fa4a-4f0c-b986-44230d6c56a3

		changedProperty = FormatString

	measure '0_Deal Count FORMAT' = IF(max(DW_Deals[HF (BOM)])=DATE(YEAR(TODAY()),MONTH(TODAY()),1),BLANK(),DISTINCTCOUNT(DW_Deals[EMAIL]) )
		formatString: 0
		lineageTag: 0e674306-442a-4138-85fd-5ceaa812a249

	measure 0_HF_Net = CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]),FILTER(DW_Deals,DW_Deals[CURRENT_DEAL_STATUS]<>"Closed Lost"&&DW_Deals[CURRENT_DEAL_STATUS]<>"Property Listed"&&DW_Deals[CURRENT_DEAL_STATUS]<>"Deal Lost"&&DW_Deals[CURRENT_DEAL_STATUS]<>"Deal On Hold"&&DW_Deals[CURRENT_DEAL_STATUS]<>"Rejected"))
		formatString: #,0
		lineageTag: 3962ff37-e060-4791-8f0b-f51f92fac86a

	measure 0_HF_Gross = CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]))
		formatString: 0
		lineageTag: 930ae2b2-4c49-4362-b112-63137f3d69e3

	measure 0_Approval = ```
			
			 
			 CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]),FILTER(DW_Deals,DW_Deals[APPLICATION_APPROVED_DATE]<>BLANK()&&DW_Deals[APPLICATION_SUBMIT_DATE]<>BLANK()&&DW_Deals[APP_STAGE]<>"Under Review"&&DW_Deals[PRIMARY_LEAD_ID]=BLANK()))
			 /
			  CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]),FILTER(DW_Deals,DW_Deals[APPLICATION_SUBMIT_DATE]<>BLANK()&&DW_Deals[APP_STAGE]<>"Under Review"&&DW_Deals[PRIMARY_LEAD_ID]=BLANK()))
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 914c7d67-e78b-484f-8209-ac8cbd95062a

	measure 0_App_IP = CALCULATE(DISTINCTCOUNT(DW_Deals[EMAIL]),FILTER(DW_Deals,DW_Deals[APP_STAGE]="Aplication Started"&&DW_Deals[DAYS_SINCE_APP_SUBMIT]<=30))
		formatString: 0
		lineageTag: 99705ff0-a64b-4f29-9b5a-2fd29dae824d

