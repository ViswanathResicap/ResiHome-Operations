	partition DW_Deals-a9df0631-2bda-422c-bfa8-e890b4a2557f = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   DEALS DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:      One row per deal (DIM_DEAL), enriched with lead, property,#(lf)               security-deposit / holding-fee transactions, Findigs application,#(lf)               the HubSpot application+deal pipeline stage (HUB_DEAL), and the#(lf)               matched rental listing.#(lf)   Anchor:     PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL (D)#(lf)   Branches off the property foundation; shares its property-eligibility WHERE#(lf)   filters and organization roll-up logic.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  ORGANIZATION_KEY / ORGANIZATION_NAME CASE blocks updated to mirror#(lf)             the master PROPERTY script (source of truth). DELIBERATE OUTPUT#(lf)             CHANGE — see ""ORG SYNC IMPACT"".#(lf)     [FIX 1] DROPPED unused join: AM_CONS (HBAM_DBO.CONSTRUCTIONS) — referenced#(lf)             only in its own ON clause, never selected/filtered. Single-row#(lf)             lookup, so removal is output-identical.#(lf)     [FIX 2] DROPPED unused join: SUB (DIM_SUBDIVISION) — same situation.#(lf)#(lf)   DELIBERATELY KEPT (look unused but are load-bearing):#(lf)     - CHG (charges subquery) is never SELECTed, but the PAY join depends on it#(lf)       via ""PAY.Amount = CHG.Amount"". Removing CHG would change PAY, which feeds#(lf)       HOLDING_FEE_DATE_NEW and REFUNDED_FLAG. KEPT.#(lf)     - PU is never SELECTed but is filtered in WHERE (PU.Current_Flag = 'Y').#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original deals output):#(lf)     Deals tied to these orgs previously fell through to ELSE (raw key +#(lf)     unmapped O.ORGANIZATION_NAME); after the sync they roll up:#(lf)        66                  -> 27 / 'RB DRC'#(lf)        62,63,64,65,68,69   -> 62 / 'Rocklyn Homes'#(lf)        61,70               -> 61 / 'ROI Property Group'#(lf)        67                  -> 67 / 'Newstar'#(lf)     An EXCEPT diff vs. the old output will show rows ONLY for these orgs.#(lf)#(lf)   KNOWN FRAGILITIES (flagged, not changed):#(lf)     - FINDIGS.* and Deals.* are star-expanded; upstream column changes alter#(lf)       output shape.#(lf)     - PAY / CHG subqueries are hard-pinned to RECEIVABLE_ID = 1739849 in their#(lf)       WHERE clauses (looks like leftover debug scoping). Preserved as-is — VERIFY#(lf)       whether that filter is intentional, since it constrains the whole#(lf)       holding-fee/refund branch to one receivable.#(lf)     - ""App Submit (BOM)"" / ""1_Lead (BOM)"" etc. mix naming conventions; left as-is.#(lf)   ============================================================================= */#(lf)#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: FINDIGS#(lf)   Most recent Findigs application per applicant. Star-expanded into DEALS via#(lf)   FINDIGS.* — adding columns here changes the final output shape.#(lf)   ----------------------------------------------------------------------------- */#(lf)WITH FINDIGS AS (#(lf)    SELECT#(lf)         FINDIGS_APP_ID#(lf)        ,FINDIGS_APPLICANT_ID#(lf)        ,FINDIGS_GROUP_ID#(lf)        ,APPLICATION_TOPICS_TOTAL#(lf)        ,APPLICATION_TOPICS_PROGRESS#(lf)        ,COALESCE(APPLICATION_TOPICS_PROGRESS / APPLICATION_TOPICS_TOTAL, 0) AS FINDIGS_APPLICATION_PERCENT_COMPLETE#(lf)        ,TO_DATE(GROUP_SUBMITTED_AT::TEXT, 'AUTO') AS FINDIGS_APPLICATION_SUBMITTED#(lf)        ,GROUP_STATUS          AS FINDIGS_APPLICATION_STATUS#(lf)        ,GROUP_WORKFLOW_STATUS AS FINDIGS_APPLICATION_WORKFLOW_STATUS#(lf)        ,TO_DATE(GROUP_DECISIONED_AT::TEXT,     'AUTO') AS FINDIGS_GROUP_DECISIONED_AT#(lf)        ,TO_DATE(GROUP_PENDING_REVIEW_AT::TEXT, 'AUTO') AS FINDIGS_GROUP_PENDING_REVIEW_AT#(lf)        ,APPLICANT_EMPLOYMENT_EMPLOYER_NAME#(lf)        ,APPLICANT_EMPLOYMENT_JOB_TITLE#(lf)        ,APPLICANT_EMPLOYMENT_START_DATE#(lf)        ,APPLICANT_EMPLOYMENT_STATUS#(lf)        ,APPLICANT_CURRENT_HOUSING_ADDRESS_LINE_1#(lf)        ,APPLICANT_CURRENT_HOUSING_CITY#(lf)        ,APPLICANT_CURRENT_HOUSING_STATE#(lf)        ,APPLICANT_CURRENT_HOUSING_ZIP#(lf)        ,APPLICANT_CURRENT_HOUSING_ADDRESS_LINE_1 || ', ' || APPLICANT_CURRENT_HOUSING_CITY || ', '#(lf)            || APPLICANT_CURRENT_HOUSING_STATE || ', ' || APPLICANT_CURRENT_HOUSING_ZIP AS APPLICANT_CURRENT_HOUSING_FULL_ADDRESS#(lf)        ,APPLICANT_CURRENT_HOUSING_TYPE#(lf)        ,APPLICANT_CURRENT_HOUSING_PAYMENT_AMOUNT#(lf)        ,APPLICANT_DESIRED_MOVE_IN_DATE#(lf)        ,APPLICANT_HOUSEHOLD_NUM_DEPENDENTS#(lf)        ,APPLICANT_HOUSEHOLD_NUM_PETS#(lf)        ,APPLICANT_HOUSEHOLD_NUM_VEHICLES#(lf)        ,RANK() OVER (PARTITION BY FINDIGS_APPLICANT_ID ORDER BY APPLICATION_LAST_UPDATED_AT DESC) AS FINDIGS_RECENT_RANK#(lf)    FROM SHARE_FINDIGS_RESICAP.PUBLIC.APPLICATIONS_RESICAP#(lf)    QUALIFY FINDIGS_RECENT_RANK = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: DEALS#(lf)   The core deal row. Resolves property via a COALESCE across the payment,#(lf)   deal-status, and tenant-leasing sources, then applies property-eligibility#(lf)   filters.#(lf)   ----------------------------------------------------------------------------- */#(lf),DEALS AS (#(lf)    SELECT#(lf)         P.PROPERTY_KEY#(lf)#(lf)        -- [SYNC] organization roll-up — mirrors master PROPERTY script.#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)            ELSE P.ORGANIZATION_KEY#(lf)         END AS ORGANIZATION_KEY#(lf)#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)            ELSE O.ORGANIZATION_NAME#(lf)         END AS ORGANIZATION_NAME#(lf)#(lf)        ,P.HBPM_PROPERTY_ID#(lf)        ,P.EntityID#(lf)        ,PUS.Under_written_rent#(lf)        ,REC.RECEIEVABLE_ID#(lf)        ,PO.PORTFOLIO_NAME#(lf)        ,R.REGION_NAME#(lf)#(lf)        -- ---- Deal core ----#(lf)        ,D.SECURITY_DEPOSIT_ID#(lf)        ,D.DEAL_KEY#(lf)        ,D.DEAL_ID#(lf)        ,COALESCE(D.CURRENT_DEAL_STATUS, HUB_DEAL.DEAL_STAGE) AS CURRENT_DEAL_STATUS#(lf)        ,HUB_DEAL.APP_ID#(lf)        ,HUB_DEAL.APP_STAGE AS APP_STAGE#(lf)        ,D.COMBINED_INCOME * 12 AS COMBINED_INCOME#(lf)        ,DSH.LEAD_KEY#(lf)#(lf)        -- ---- Application timing ----#(lf)        ,D.APPLICATION_SUBMITTED_DATE::date AS Application_Submit_Date#(lf)        ,DATE_TRUNC('month', D.APPLICATION_SUBMITTED_DATE::date) AS ""App Submit (BOM)""#(lf)        ,CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE::date) AS Application_Started_Date#(lf)        ,DATE_TRUNC('month', CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE)::date) AS App_Started_BOM#(lf)        ,DATEDIFF(DAY,#(lf)            COALESCE(D.APPLICATION_SUBMITTED_DATE,#(lf)                     TO_DATE(L.Application_SUBMIT_Date_KEY::TEXT, 'yyyymmdd'),#(lf)                     CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE::date),#(lf)                     TO_DATE(DSH.DEAL_CREATE_DATE_KEY::TEXT, 'yyyymmdd')),#(lf)            GETDATE()) AS DAYS_SINCE_APP_SUBMIT#(lf)#(lf)        -- ---- Lead identity ----#(lf)        ,L.First_Name || ' ' || L.Last_Name AS Lead_Name#(lf)        ,L.PRIMARY_LEAD_ID#(lf)        ,D.EMail#(lf)        ,L.PHONE#(lf)        ,TO_DATE(L.CREATED_DATE_KEY::TEXT, 'yyyymmdd') AS Lead_Created_Date#(lf)        ,DATE_TRUNC('month', TO_DATE(L.CREATED_DATE_KEY::TEXT, 'yyyymmdd')) AS ""1_Lead (BOM)""#(lf)#(lf)        -- ---- Deal lifecycle dates ----#(lf)        ,TO_DATE(DSH.DEAL_CREATE_DATE_KEY::TEXT,          'yyyymmdd') AS DEAL_CREATE_DATE#(lf)        ,TO_DATE(DSH.APPLICATION_APPROVED_DATE_KEY::TEXT, 'yyyymmdd') AS APPLICATION_APPROVED_DATE#(lf)        ,TO_DATE(DSH.DEAL_WON_DATE_KEY::TEXT,             'yyyymmdd') AS DEAL_WON_DATE#(lf)        ,COALESCE(HUB_DEAL.PROPERTY_HOLDING_FEE_TRANSACTION_DATE,#(lf)                  TO_DATE(PAY.HOLDING_FEE_DATE_NEW::TEXT,        'yyyymmdd'),#(lf)                  TO_DATE(DSH.HOLDING_FEE_PAID_DATE_KEY::TEXT,   'yyyymmdd')) AS HOLDING_FEE_DATE_NEW#(lf)        ,TO_DATE(DSH.LEASE_SIGNED_DATE_KEY::TEXT,        'yyyymmdd') AS LEASE_SIGNED_DATE#(lf)        ,TO_DATE(DSH.CONVERT_TO_RESIDENT_DATE_KEY::TEXT, 'yyyymmdd') AS CONVERT_TO_RESIDENT_DATE#(lf)        ,TO_DATE(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,    'yyyymmdd') AS EXPECTED_MOVE_IN_DATE#(lf)        ,COALESCE(TO_DATE(DSH.LEASE_START_DATE_KEY::TEXT,     'yyyymmdd'),#(lf)                  TO_DATE(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT, 'yyyymmdd')) AS LEASE_START_DATE#(lf)        ,TO_DATE(DSH.LEASE_END_DATE_KEY::TEXT, 'yyyymmdd') AS LEASE_END_DATE#(lf)        ,U.USER_KEY#(lf)        ,TLA.Tenant_key#(lf)        ,COALESCE(TO_DATE(TLA.INITIAL_LEASE_FROM_DATE_KEY::TEXT, 'yyyymmdd'),#(lf)                  TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT,         'yyyymmdd')) AS TENANT_MOVE_IN#(lf)#(lf)        -- ---- Ownership / score / source ----#(lf)        ,D.DEAL_OWNER AS DEAL_OWNER#(lf)        ,L.CONTACT_OWNER#(lf)        ,D.AVERAGE_CREDIT_SCORE#(lf)        ,L.SOURCE#(lf)        ,'https://app.hubspot.com/contacts/22536354/record/0-3/' || D.DEAL_ID AS URL_HUBSPOT#(lf)#(lf)        -- Net HF if converted to resident; otherwise the payment refund flag#(lf)        ,CASE WHEN DSH.CONVERT_TO_RESIDENT_DATE_KEY IS NOT NULL#(lf)              THEN 'Net HF'#(lf)              ELSE COALESCE(PAY.REFUNDED_FLAG, 'Net HF')#(lf)         END AS REFUNDED_FLAG#(lf)#(lf)        ,PM_AI.MOVEINREADY AS PM_MIR#(lf)        ,DSH.LISTING_KEY#(lf)#(lf)        -- ---- HubSpot deal/application pipeline detail (HUB_DEAL) ----#(lf)        ,HUB_DEAL.PROPERTY_LEASE_DRAFTING_STATUS    AS LEASE_DRAFTING_STATUS#(lf)        ,HUB_DEAL.PROPERTY_MOVE_IN_FEE_PAYMENT_LINK AS MOVE_IN_FEE_PAYMENT_LINK#(lf)        ,HUB_DEAL.PROPERTY_MOVE_IN_CHARGES_PAID     AS MOVE_IN_CHARGES_PAID#(lf)        ,HUB_DEAL.PROPERTY_DF_REFERENCE_NUMBER      AS MOVE_IN_CHARGES_REFERENCE_ID#(lf)        ,HUB_DEAL.PROPERTY_IS_SECTION_8             AS IS_SECTION_8#(lf)        ,HUB_DEAL.PROPERTY_CONCESSION_DOLLAR_AMOUNT AS CONCESSION_DOLLAR_AMOUNT#(lf)        ,HUB_DEAL.PROPERTY_DENIAL_DISPUTE#(lf)        ,HUB_DEAL.PROPERTY_DENIAL_DISPUTE_COMMENTS#(lf)        ,HUB_DEAL.PROPERTY_DENIAL_DISPUTE_REASON#(lf)        ,HUB_DEAL.PROPERTY_APPLICATION_DENIAL_REASON#(lf)        ,HUB_DEAL.PROPERTY_RENT_QUALIFICATION_DEFICIT#(lf)        ,DEAL_LOST.DEAL_LOST_REASON#(lf)#(lf)        ,CASE#(lf)            WHEN HUB_DEAL.APP_STAGE IN ('Full Approval', 'Conditional Approval')#(lf)                THEN 'Pending HF'#(lf)            WHEN HUB_DEAL.APP_STAGE IN ('Aplication Started', 'Application Started')#(lf)                THEN COALESCE(ROUND(FINDIGS_APPLICATION_PERCENT_COMPLETE * 100, 0), 0) || '%'#(lf)            ELSE HUB_DEAL.APP_STAGE#(lf)         END AS APP_STAGE_DETAIL#(lf)#(lf)        -- All Findigs columns (star-expanded — see CTE note)#(lf)        ,FINDIGS.*#(lf)#(lf)    FROM PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL D#(lf)#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSH#(lf)            ON DSH.DEAL_KEY = D.Deal_Key#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L#(lf)            ON L.LEAD_KEY = DSH.Lead_Key#(lf)        LEFT JOIN ""PROD_REPLICA"".""HUBSPOT_2"".""CONTACT"" C#(lf)            ON C.ID = L.LEAD_ID#(lf)#(lf)        /* Receivable id from HubSpot deal-property history */#(lf)        LEFT JOIN (#(lf)            SELECT Deal_ID, Value AS RECEIEVABLE_ID#(lf)            FROM PROD_REPLICA.HUBSPOT.DEAL_PROPERTY_HISTORY#(lf)            WHERE 1 = 1#(lf)                AND NAME = 'account_receivable'#(lf)                AND _FIVETRAN_ACTIVE = 'Y'#(lf)        ) REC#(lf)            ON REC.DEAL_ID = D.DEAL_ID#(lf)#(lf)        /* Security-deposit CHARGE rows (>= $500, GL 18).#(lf)           NOTE: never selected, but PAY joins on CHG.Amount — load-bearing. */#(lf)        LEFT JOIN (#(lf)            SELECT Charge_DATE_KEY, Property_Key, Receivable_ID, Amount#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION#(lf)            WHERE TRANSACTION_TYPE = 'Charges'#(lf)                AND Amount >= 500#(lf)                AND GL_ACCOUNT_KEY IN (18)#(lf)        ) CHG#(lf)            ON CHG.Receivable_ID = TRY_CAST(REC.RECEIEVABLE_ID AS INTEGER)#(lf)#(lf)        /* Security-deposit PAYMENT rows + refund detection. */#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                 LT.PROPERTY_KEY#(lf)                ,MIN(LT.RECEIVED_ON_DATE_KEY) AS HOLDING_FEE_DATE_NEW#(lf)                ,REFUND.REFUNDED_FLAG#(lf)                ,MIN(LT.PAID_BY_USER_KEY) AS PAID_BY_USER_KEY#(lf)                ,LT.RECEIVABLE_ID#(lf)                ,LT.TENANT_KEY#(lf)                ,LT.AMOUNT#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION LT#(lf)                LEFT JOIN (#(lf)                    SELECT#(lf)                         'Refunded' AS REFUNDED_FLAG#(lf)                        ,PROPERTY_KEY#(lf)                        ,PAID_BY_USER_KEY#(lf)                        ,AMOUNT#(lf)                    FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION#(lf)                    WHERE 1 = 1#(lf)                        AND TRANSACTION_TYPE = 'Payment'#(lf)                ) REFUND#(lf)                    ON  REFUND.PROPERTY_KEY     = LT.PROPERTY_KEY#(lf)                    AND REFUND.PAID_BY_USER_KEY = LT.PAID_BY_USER_KEY#(lf)                    AND REFUND.AMOUNT           = (LT.AMOUNT * -1)#(lf)            WHERE 1 = 1#(lf)                AND LT.TRANSACTION_TYPE = 'Payment'#(lf)                AND LT.Amount >= 500#(lf)                AND LT.GL_ACCOUNT_KEY IN (18, -1)   -- SD#(lf)                AND LT.RECEIVABLE_ID = 1739849      -- FRAGILITY: hard-pinned receivable (verify intent)#(lf)            GROUP BY#(lf)                 LT.PROPERTY_KEY#(lf)                ,LT.RECEIVABLE_ID#(lf)                ,LT.TENANT_KEY#(lf)                ,LT.AMOUNT#(lf)                ,REFUND.REFUNDED_FLAG#(lf)        ) PAY#(lf)            ON  PAY.Receivable_ID = TRY_CAST(REC.RECEIEVABLE_ID AS INTEGER)#(lf)            AND PAY.Amount        = CHG.Amount#(lf)#(lf)        /* Deal user (status-accum user, falling back to the payer) */#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U#(lf)            ON U.USER_KEY = CASE WHEN DSH.User_key <> -1 THEN DSH.User_key#(lf)                                 ELSE PAY.PAID_BY_USER_KEY END#(lf)#(lf)        /* Tenant leasing accumulator (deleted/invalid tenants filtered out) */#(lf)        LEFT JOIN (#(lf)            SELECT TLA.*#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)                LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)                    ON T.Tenant_KEY = TLA.Tenant_key#(lf)                LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)                    ON TI.TENANTINFORMATIONID = T.TENANT_INFORMATION_ID#(lf)            WHERE TI._FIVETRAN_DELETED <> 'Y'#(lf)                AND RENTDUEDAY IS NOT NULL#(lf)                AND T.TENANT_KEY NOT IN (70575)#(lf)        ) TLA#(lf)            ON TLA.USER_KEY = U.User_key#(lf)#(lf)        /* Resolve the property: payment property, else deal-status property,#(lf)           else tenant-leasing property. */#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)            ON P.PROPERTY_KEY = COALESCE(#(lf)                   PAY.Property_Key,#(lf)                   CASE WHEN DSH.PROPERTY_KEY <> -1 THEN DSH.PROPERTY_KEY#(lf)                        ELSE TLA.PROPERTY_KEY END)#(lf)#(lf)        /* Property dimensions + eligibility-filter sources */#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS#(lf)            ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU#(lf)            ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY   -- used by WHERE (PU.Current_Flag)#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM#(lf)            ON HBPM.PROPERTYID = P.HBPM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_AI#(lf)            ON  PM_AI.PROPERTYID = HBPM.PROPERTYID#(lf)            AND PM_AI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO#(lf)            ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R#(lf)            ON R.REGION_KEY = PUS.REGION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O#(lf)            ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM#(lf)            ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)#(lf)        LEFT JOIN FINDIGS#(lf)            ON FINDIGS.FINDIGS_APPLICANT_ID = C.PROPERTY_FINDIGS_APPLICANT_ID#(lf)#(lf)        /* Deal lost reason from HubSpot deal-property history */#(lf)        LEFT JOIN (#(lf)            SELECT DEAL_ID, VALUE AS DEAL_LOST_REASON#(lf)            FROM ""PROD_REPLICA"".""HUBSPOT_2"".""DEAL_PROPERTY_HISTORY""#(lf)            WHERE 1 = 1#(lf)                AND name = 'deal_lost_reason'#(lf)                AND _FIVETRAN_ACTIVE = 'TRUE'#(lf)        ) DEAL_LOST#(lf)            ON DEAL_LOST.DEAL_ID = D.DEAL_ID#(lf)#(lf)        /* ------------------------------------------------------------------#(lf)           HUB_DEAL: HubSpot replica section.#(lf)           Reconciles the deal (HD) and application (APP) sides of the pipeline#(lf)           via a FULL JOIN so a deal can be matched to its application stage#(lf)           even when only one side exists, then ranks to one row per deal.#(lf)           ------------------------------------------------------------------ */#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                 APP.PROPERTY_HOLDING_FEE_TRANSACTION_DATE#(lf)                ,CAST(COALESCE(HD.DEAL_PIPELINE_STAGE_ID, APP.PROPERTY_HS_PIPELINE_STAGE) AS INT) AS DEAL_PIPELINE_STAGE_ID#(lf)                ,COALESCE(D.DEAL_KEY, APP.APP_ID) AS DEAL_KEY_JOIN#(lf)                ,DPS.Label AS DEAL_STAGE#(lf)                ,APP_ID#(lf)                ,CASE APP.PROPERTY_HS_PIPELINE_STAGE#(lf)                    WHEN 59173506 THEN 'Aplication Started'#(lf)                    WHEN 93217140 THEN 'Needs New Property'#(lf)                    WHEN 59173507 THEN 'Under Review'#(lf)                    WHEN 59187121 THEN 'Conditional Approval'#(lf)                    WHEN 59187122 THEN 'Full Approval'#(lf)                    WHEN 59187127 THEN 'Denial'#(lf)                    WHEN 59187123 THEN 'Pre-Lease Compliance'#(lf)                    WHEN 59187124 THEN 'Lease Drafting'#(lf)                    WHEN 59187125 THEN 'Lease Executed'#(lf)                    WHEN 59187126 THEN 'Move-In Scheduled'#(lf)                    WHEN 59187128 THEN 'Closed Lost'#(lf)                    ELSE NULL#(lf)                 END AS APP_STAGE#(lf)                ,RANK() OVER (#(lf)                    PARTITION BY COALESCE(D.DEAL_KEY, APP.APP_ID)#(lf)                    ORDER BY HD.PROPERTY_HS_LASTMODIFIEDDATE, APP.APP_ID DESC#(lf)                 ) AS DEAL_RANK#(lf)                ,HD.PROPERTY_LEASE_DRAFTING_STATUS#(lf)                ,HD.PROPERTY_LEASE_SIGNED_DATE#(lf)                ,HD.PROPERTY_MOVE_IN_FEE_PAYMENT_LINK#(lf)                ,HD.PROPERTY_MOVE_IN_CHARGES_PAID#(lf)                ,HD.PROPERTY_DF_REFERENCE_NUMBER#(lf)                ,HD.PROPERTY_IS_SECTION_8#(lf)                ,HD.PROPERTY_CONCESSION_DOLLAR_AMOUNT#(lf)                ,APP.PROPERTY_DENIAL_DISPUTE#(lf)                ,APP.PROPERTY_DENIAL_DISPUTE_COMMENTS#(lf)                ,APP.PROPERTY_DENIAL_DISPUTE_REASON#(lf)                ,APP.PROPERTY_APPLICATION_DENIAL_REASON#(lf)                ,APP.PROPERTY_RENT_QUALIFICATION_DEFICIT#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL D#(lf)                LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSH#(lf)                    ON DSH.DEAL_KEY = D.Deal_Key#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT_2.DEAL HD#(lf)                    ON HD.DEAL_ID = D.DEAL_ID#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT_2.APPLICATION_TO_DEAL ATD#(lf)                    ON ATD.TO_ID = D.DEAL_ID#(lf)#(lf)                /* Application side: most recent app->property mapping per app,#(lf)                   excluding known merged/bad app ids. */#(lf)                FULL JOIN (#(lf)                    SELECT DISTINCT#(lf)                         A.ID AS APP_ID#(lf)                        ,A.PROPERTY_RENT_QUALIFICATION_DEFICIT#(lf)                        ,A.PROPERTY_UNIT_ID#(lf)                        ,A.PROPERTY_HS_PIPELINE_STAGE#(lf)                        ,A.PROPERTY_HOLDING_FEE_TRANSACTION_DATE#(lf)                        ,P.PROPERTY_KEY#(lf)                        ,A.PROPERTY_DENIAL_DISPUTE#(lf)                        ,A.PROPERTY_DENIAL_DISPUTE_COMMENTS#(lf)                        ,A.PROPERTY_DENIAL_DISPUTE_REASON#(lf)                        ,A.PROPERTY_APPLICATION_DENIAL_REASON#(lf)                    FROM PROD_REPLICA.HUBSPOT_2.APPLICATION A#(lf)                        LEFT JOIN (#(lf)                            SELECT *,#(lf)                                RANK() OVER (PARTITION BY FROM_ID ORDER BY _FIVETRAN_SYNCED DESC) AS RECENT_RANK#(lf)                            FROM PROD_REPLICA.HUBSPOT_2.APPLICATION_TO_PROPERTIES#(lf)                            QUALIFY RECENT_RANK = 1#(lf)                        ) ATP#(lf)                            ON ATP.FROM_ID = A.ID#(lf)                        LEFT JOIN PROD_REPLICA.HUBSPOT_2.PROPERTIES H_P#(lf)                            ON H_P.ID = ATP.TO_ID#(lf)                        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)                            ON P.HBPM_PROPERTY_ID = H_P.PROPERTY_PROPERTY_ID#(lf)                    WHERE IS_INTEGER(A.PROPERTY_HS_PIPELINE_STAGE) = 'True'#(lf)                        AND A.PROPERTY_UNIT_ID IS NOT NULL#(lf)                        AND APP_ID NOT IN (8472470544, 8657787708, 8657665830, 6854090788)  -- merged bad data#(lf)                ) APP#(lf)                    ON  APP.APP_ID       = ATD.FROM_ID#(lf)                    AND APP.PROPERTY_KEY = DSH.PROPERTY_KEY#(lf)#(lf)                LEFT JOIN (#(lf)                    SELECT *#(lf)                    FROM PROD_REPLICA.HUBSPOT_2.DEAL_PIPELINE_STAGE#(lf)                    WHERE _FIVETRAN_DELETED = 'N'#(lf)                ) DPS#(lf)                    ON DPS.STAGE_ID = HD.DEAL_PIPELINE_STAGE_ID#(lf)            WHERE 1 = 1#(lf)            QUALIFY DEAL_RANK = 1#(lf)        ) HUB_DEAL#(lf)            ON HUB_DEAL.DEAL_KEY_JOIN = D.DEAL_KEY#(lf)#(lf)    WHERE 1 = 1#(lf)        AND P.Property_KEY IS NOT NULL#(lf)        AND D.DEAL_PIPELINE <> 'Tour Pipeline'#(lf)        AND D.DEAL_PIPELINE <> 'Renewals'#(lf)        AND D.CURRENT_flag = 'Y'#(lf)        AND (L.CURRENT_Flag = 'Y' OR DSH.LEAD_KEY = -1)#(lf)        AND (L.IS_MERGED_LEAD IS NULL OR IS_MERGED_LEAD = 'N')#(lf)        AND DSH.LEAD_KEY IS NOT NULL#(lf)        AND (TLA.TENANT_INFORMATION_ID <> 36986 OR TLA.TENANT_INFORMATION_ID IS NULL)#(lf)#(lf)        /* Property-eligibility filters (mirror master property script) */#(lf)        AND (HBAM.PROPERTYSTATUSID > 9 OR HBAM.PROPERTYSTATUSID IS NULL)          -- out of bid#(lf)        AND P.PROPERTY_STATE = 'Active'#(lf)        AND P.EntityID <> ''#(lf)        AND (HBAM.PROPERTYSTATUSID NOT IN (53, 75) OR HBAM.PROPERTYSTATUSID IS NULL)#(lf)        AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54,169)#(lf)        AND PUS.Organization_KEY NOT IN (16, 17)#(lf)        AND PO.IS_Active_AM = 'Y'#(lf)        AND PO.Current_Flag = 'Y'#(lf)        AND P.Current_Flag = 'Y'#(lf)        AND PU.Current_Flag = 'Y'#(lf)        AND PUS.Occupancy_Status NOT IN ('Not Managed')#(lf)        AND (HBPM.PROPERTYSTATEID = 26 OR HBPM.PROPERTYSTATEID IS NULL)#(lf))#(lf)#(lf)#(lf)/* =============================================================================#(lf)   FINAL SELECT#(lf)   Deal rows + matched listing + derived day/month metrics.#(lf)   ============================================================================= */#(lf)SELECT#(lf)     Deals.*#(lf)    ,RLH.RENT_LIST_HIST_ID#(lf)    ,TO_DATE(RLH.LISTING_DATE_KEY::TEXT, 'yyyymmdd') AS LISTINGDATE#(lf)    ,DATEDIFF('day', TO_DATE(RLH.LISTING_DATE_KEY::TEXT, 'yyyymmdd'), GETDATE()) AS LISTING_DOM#(lf)    ,RLH.CURRENT_LIST_PRICE AS CurrentListPrice#(lf)    ,RLH.LISTING_STATUS     AS Listing_Status#(lf)#(lf)    ,CASE WHEN TO_DATE(RLH.LISTING_DATE_KEY::TEXT, 'yyyymmdd') IS NOT NULL#(lf)               AND HOLDING_FEE_DATE_NEW IS NOT NULL#(lf)          THEN DATEDIFF(DAY, TO_DATE(RLH.LISTING_DATE_KEY::TEXT, 'yyyymmdd'), HOLDING_FEE_DATE_NEW)#(lf)          ELSE NULL#(lf)     END AS ""Days_List-HF""#(lf)#(lf)    ,CASE WHEN Deals.LEASE_START_DATE IS NOT NULL#(lf)          THEN DATEDIFF(DAY, HOLDING_FEE_DATE_NEW, Deals.LEASE_START_DATE)#(lf)          ELSE NULL#(lf)     END AS ""Days_Until_MI""#(lf)#(lf)    ,DATE_TRUNC('month', HOLDING_FEE_DATE_NEW) AS ""HF (BOM)""#(lf)    ,DATE_TRUNC('month', DEAL_CREATE_DATE)     AS ""DEAL_CREATED (BOM)""#(lf)#(lf)FROM Deals#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH#(lf)        ON RLH.LISTING_KEY = Deals.LISTING_KEY#(lf)WHERE 1 = 1", null, [EnableFolding=true]),
				    #"Renamed Columns" = Table.RenameColumns(Source,{{"HOLDING_FEE_DATE_NEW", "HF Date"}}),
				    #"Filtered Rows" = Table.SelectRows(#"Renamed Columns", each [DEAL_ID] <> 38477),
				    #"Capitalized Each Word" = Table.TransformColumns(#"Filtered Rows",{{"DEAL_OWNER", Text.Proper, type text}, {"CONTACT_OWNER", Text.Proper, type text}})
				in
				    #"Capitalized Each Word"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

