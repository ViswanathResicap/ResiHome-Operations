table 0_Days
	lineageTag: 1b9196fa-a55c-4cbb-a581-9be90a04572c

	measure 0_Collection_Day_Previous =
			
			
			MIN(CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),
			    FILTER(DW_Tenant_Receipts,
			        DW_Tenant_Receipts[CHARGE_DATE].[Day]<=MAX('0_Days'[Day])
			        &&DATE(DW_Tenant_Receipts[CHARGE_DATE_BOM].[Year],DW_Tenant_Receipts[CHARGE_DATE_BOM].[MonthNo]+1,1) = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date])
			        &&OR( DW_Tenant_Receipts[RECEIVED_DATE].[Day]<=MAX('0_Days'[Day])&&
			        DATE(DW_Tenant_Receipts[RECEIVED_DATE_BOM].[Year],DW_Tenant_Receipts[RECEIVED_DATE_BOM].[MonthNo]+1,1) = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date]),DW_Tenant_Receipts[RECEIVED_DATE]<=DW_Tenant_Receipts[CHARGE_DATE]))) /
			
			CALCULATE(SUM(DW_Tenant_Charges[Charge_Amount]),
			    FILTER(DW_Tenant_Charges,DW_Tenant_Charges[Charge_Date].[Day]<=MAX('0_Days'[Day])
			        &&DATE(DW_Tenant_Charges[Charge_Date_BOM].[Year],DW_Tenant_Charges[Charge_Date_BOM].[MonthNo]+1,1) = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date]))),1)
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 996e5a3d-e2bd-4263-a741-7f28a2d2418e

		changedProperty = FormatString

		changedProperty = IsHidden

	measure '0_Collection vs LM' = IF([0_Collection_Day_Net]<>BLANK()&&[0_Collection_Day_Previous]<>BLANK(),[0_Collection_Day_Net]-[0_Collection_Day_Previous],BLANK())
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 904b1c1d-6ba7-4acc-bfab-918198292bac

		changedProperty = FormatString

		changedProperty = IsHidden

	measure 0_Concessions_Day =
			
			IF(and(MAX('0_Days'[Day])>DAY(TODAY()),FIRSTNONBLANK('0_Days'[Month_No],'0_Days'[Month_No])=MONTH(TODAY())),
			    BLANK(),
			
			CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),
			    FILTER(DW_Tenant_Receipts,
			         DW_Tenant_Receipts[CREDITTYPEID] = 1
			         &&DW_Tenant_Receipts[CHARGE_DATE].[Day]<=MAX('0_Days'[Day])
			         &&DW_Tenant_Receipts[CHARGE_DATE_BOM]=FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date])
			        ))
			)
		lineageTag: e370e42d-9e1f-4fbe-b216-6ae6a43c0a71

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 0_Collection_Day_Net =
			
			IF(
			    AND(
			        MAX('0_Days'[Day]) > DAY(TODAY()),
			        FIRSTNONBLANK('0_Days'[Month_No], '0_Days'[Month_No]) = MONTH(TODAY())
			        && YEAR(FIRSTNONBLANK('0_Days'[Date], '0_Days'[Date])) = YEAR(TODAY())
			    ),
			    BLANK(),
			
			    MIN((CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),
			        FILTER(DW_Tenant_Receipts,
			             DW_Tenant_Receipts[CHARGE_DATE].[Day] <= MAX('0_Days'[Day])
			             && DW_Tenant_Receipts[CHARGE_DATE_BOM] = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date])
			             && OR(DW_Tenant_Receipts[RECEIVED_DATE].[Day] <= MAX('0_Days'[Day])
			                   && DW_Tenant_Receipts[RECEIVED_DATE_BOM] = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date]),
			                   DW_Tenant_Receipts[RECEIVED_DATE] <= DW_Tenant_Receipts[CHARGE_DATE]))) - [0_Concessions_Day]) /
			
			    (CALCULATE(SUM(DW_Tenant_Charges[Charge_Amount]),
			        FILTER(DW_Tenant_Charges,
			            DW_Tenant_Charges[Charge_Date].[Day] <= MAX('0_Days'[Day])
			            && DW_Tenant_Charges[Charge_Date_BOM] = FIRSTNONBLANK('0_Days'[Date],'0_Days'[Date]))) - [0_Concessions_Day]), 1))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 77ae4afc-a8ea-4f72-a1f1-949fa2b6f0af

		changedProperty = FormatString

		changedProperty = IsHidden

