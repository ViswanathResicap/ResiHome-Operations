table DW_MoveOut
	lineageTag: a7b5f76c-5f7d-4cb3-ae00-78d6bd10e7fc

	measure '0_Distinct MO' = DISTINCTCOUNT(DW_MoveOut[LEASE_ID]) + 0
		formatString: 0
		lineageTag: cd8d3d71-1e42-4f57-9a4e-46726dc00404

	measure '0_Distinct MO (Clean)' = DISTINCTCOUNT(DW_MoveOut[LEASE_ID])
		formatString: 0
		lineageTag: 7aa8620f-050c-4cca-98ee-667a38f0a1d5

	measure '0_Rent Var (MoveOut)' = ```
			CALCULATE(DIVIDE(SUM(DW_MoveOut[CURRENT_RENT]), SUM(DW_MoveOut[1_ASM_Blended]), BLANK()),FILTER(DW_MoveOut,DW_MoveOut[CURRENT_RENT]<>BLANK()&&DW_MoveOut[1_ASM_Blended]<>blank())) - 1
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: d5d24142-3c36-4ffd-82b9-2860b12897b4

