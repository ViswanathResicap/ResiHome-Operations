	column DAYS_MO_BEFORE_EXP
		dataType: double
		formatString: 0
		lineageTag: 4031cf82-201a-46ec-8e4b-6591e0283118
		summarizeBy: sum
		sourceColumn: DAYS_MO_BEFORE_EXP

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column '1_Accelerated Rent' = ```
			IF(DW_MoveOut[MOVEOUT]<>BLANK()&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3156&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3157&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3158&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3168&&DW_MoveOut[DAYS_MO_BEFORE_EXP]<>BLANK()&&DW_MoveOut[DAYS_MO_BEFORE_EXP]<60&&DW_MoveOut[DAYS_OF_NOTICE]<>BLANK()&&DW_MoveOut[DAYS_OF_NOTICE]<60&&DW_MoveOut[DAYS_OF_NOTICE]>0,
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]>=30,MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30)*DW_MoveOut[CURRENT_RENT]/30,
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]>0,(min(DW_MoveOut[DAYS_MO_BEFORE_EXP],MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30))*DW_MoveOut[CURRENT_RENT]/30) + 
			                            (MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30) - min(DW_MoveOut[DAYS_MO_BEFORE_EXP],MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30))) * DW_MoveOut[CURRENT_RENT]/30 * 1,
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]<=0,MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30) * DW_MoveOut[CURRENT_RENT]/30 * 1,                     
			                        BLANK()))),
			                        BLANK())
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: ff8971f5-94ab-4180-ab7b-4bec86dd7763
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column '1_Accelerated MTM' = ```
			IF(DW_MoveOut[MOVEOUT]<>BLANK()&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3156&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3157&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3158&&DW_MoveOut[REASONFORNOTRENEWINGID]<>3168&&DW_MoveOut[DAYS_MO_BEFORE_EXP]<>BLANK()&&DW_MoveOut[DAYS_MO_BEFORE_EXP]<60&&DW_MoveOut[DAYS_OF_NOTICE]<>BLANK()&&DW_MoveOut[DAYS_OF_NOTICE]<60&&DW_MoveOut[DAYS_OF_NOTICE]>0,
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]>=30,BLANK(),
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]>0, (MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30) - min(DW_MoveOut[DAYS_MO_BEFORE_EXP],MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30))) * DW_MoveOut[CURRENT_RENT]/30 * .15,
			                        IF(DW_MoveOut[DAYS_MO_BEFORE_EXP]<=0,MIN(60 - DW_MoveOut[DAYS_OF_NOTICE], 30) * DW_MoveOut[CURRENT_RENT]/30 * .15,                     
			                        BLANK()))),
			                        BLANK())
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 1a57e45d-e659-4daf-8f8c-18cf0abdbfaf
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

