	partition DW_MoveOut-688ddccc-0d12-42ce-9c5e-97f055bd498b = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   MOVE OUT DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per current primary tenant (anchor DIM_TENANT T), carrying#(lf)            move-out / notice / eviction milestones plus the IMPORT_* early-term#(lf)            and rent-responsible charge calculations.#(lf)   CTE chain: MoveOutNotes, RENTLY -> final SELECT off DIM_TENANT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  The single ORGANIZATION_KEY / ORGANIZATION_NAME CASE block in the#(lf)             final SELECT was updated from the prior three-group form#(lf)             (adding only 58,59 -> 'Hudson Oak') to the full six-group roll-up#(lf)             that mirrors the master PROPERTY script (source of truth).#(lf)             DELIBERATE OUTPUT CHANGE limited to the organization columns.#(lf)     [FLAG]  IMPORT_GL_ACCOUNT returns the integer literals 4550 and 4945500.#(lf)             Unlike the tenant-script '5530-0000' issue, these are written as#(lf)             plain integers (no dash), so they evaluate as intended GL codes and#(lf)             are LEFT UNCHANGED. Noting only so the value is on the record.#(lf)     No CTEs or joins dropped.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output):#(lf)        added 66                  -> 27 / 'RB DRC'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH MoveOutNotes AS (#(lf)#(tab)SELECT#(lf) #(tab)N.NOTEID AS LatestNoteID_MO#(lf) #(tab),N.NOTETEXT AS MO_Note#(lf) #(tab),N.CREATEDDATE  AS MO_NoteCreated#(lf)    ,P.PropertyId#(lf)    ,RANK() OVER( PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)#(lf)#(tab)FROM PROD_REPLICA.HBPM_DBO.NOTES N #(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.NOTETYPES NT ON NT.Id = N.NoteTypeId#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.LookUpMasterId = N.ObjectTypeId#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.UserID = N.ObjectId AND N.ObjectTypeId = 502 AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI ON PAI.UnitId = TI.UnitId AND PAI.""_FIVETRAN_DELETED"" ='N'#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P ON P.PropertyID = PAI.PropertyId AND P.""_FIVETRAN_DELETED"" ='N'#(lf) #(tab)WHERE N.NoteTypeId = 8#(lf) --#(tab)AND PAI.PROPERTYID = 36301#(lf) #(tab)QUALIFY Recent_Rank = 1)#(lf) #(tab)#(lf) --********************************************************************************************************************************************************#(lf) ,RENTLY AS (#(lf) SELECT#(lf)  MAX(STATUS_TITLE) AS Rently_Property_Status#(lf)  ,TRY_TO_NUMERIC(UNIT_)  AS PM_PropertyID#(lf)  FROM ""PROD_REPLICA"".""RENTLY"".""_3_0_DATA""#(lf)  WHERE 1=1#(lf)  AND TRY_TO_NUMERIC(UNIT_) IS NOT NULL#(lf)  GROUP BY UNIT_#(lf)  )#(lf)  --********************************************************************************************************************************************************#(lf)#(lf)  SELECT#(lf)#(lf) T.TENANT_KEY#(lf),T.TENANT_INFORMATION_ID#(lf),TS.USER_KEY#(lf),T.LEASE_ID#(lf),RANK() OVER (PARTITION BY TS.Property_KEY ORDER BY Lease_ID ASC) AS Lease_Rank #(lf)--,RANK() OVER (PARTITION BY TS.Property_KEY ORDER BY Lease_ID DESC) AS Lease_Rank_Inv#(lf),PU.PROPERTY_UNIT_KEY#(lf),TS.Property_KEY#(lf),P.HBPM_PROPERTY_ID#(lf),PO.Portfolio_Name#(lf),R.REGION_NAME#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)      #(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf),P.Address#(lf),P.EntityID#(lf),PUS.CITY_KEY#(lf),CI.CITY_NAME#(lf),PUS.STATE_KEY#(lf),S.STATE_NAME#(lf),S.STATE_CODE#(lf),P.ZIPCODE#(lf),CASE WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased' #(lf)      WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)      ELSE PUS.Occupancy_Status END AS Occupancy_Status#(lf)#(lf),U.FIRST_NAME#(lf),U.LAST_NAME#(lf) ,U.FULL_NAME#(lf),U.USER_STATUS#(lf),U.EMAIL_ADDRESS#(lf),U.PHONE_NUMBER#(lf),T.TENANT_STATUS#(lf),T.TENANT_TYPE#(lf),T.PRIMARY_TENANT#(lf),T.EVICTION_STATUS#(lf),T.MONTH_TO_MONTH#(lf),T.LEASE_TERM#(lf),to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') AS NOTICE_DATE#(lf),TLA.INITIAL_RENT_AMOUNT#(lf),T.CURRENT_RENT#(lf),to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd') AS CURRENT_LEASE_EXPIRATION_DATE#(lf),to_date(TLA.LEASE_SIGNED_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_SIGNED_DATE#(lf),to_date(TLA.LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_FROM_DATE#(lf),to_date(TLA.LEASE_TO_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_TO_DATE#(lf),RESI_TSUM.IS_NOTICE#(lf),RESI_TSUM.IS_UNDER_EVICTION#(lf)#(lf),DSA.HOLDING_FEE_PAID_DATE #(lf),CASE WHEN TI.MoveIn IS NOT NULL AND DSA.HOLDING_FEE_PAID_DATE IS NOT NULL THEN DATEDIFF(DAY, DSA.HOLDING_FEE_PAID_DATE,TI.MoveIn) #(lf)      ELSE NULL END AS Days_HoldingFee_MoveIn#(lf)#(lf),TI.MoveIn#(lf),DATE_TRUNC('month',TI.MoveIn) MOVEIN_BOM#(lf),CASE #(lf)#(tab)WHEN GREATEST(DATEDIFF(DAY, TI.MoveIn,COALESCE(TI.MoveOut,GETDATE())),0) <=5#(lf)#(tab)AND T.TENANT_STATUS = 'Past'#(lf)#(tab)THEN 1 ELSE 0#(lf)END AS EXCLUDE_FILTER#(lf)#(lf),TI.PurchaseLetterPostedDate#(lf),TI.DateNotified#(lf),TI.FiledWithCountyDate#(lf),CASE WHEN TI.FiledWithCountyDate IS NOT NULL THEN 'Filed on' ELSE 'Not Filed On' END AS Filed_With_County_Status#(lf),TI.ResidentServedDate#(lf),TI.CourtDateSetDate#(lf),TI.JudgementDate#(lf),TI.LockoutScheduledDate#(lf),TI.VacateDate#(lf),TI.AnticipatedMoveOutDate#(lf),TI.IsSection8#(lf),TI.IsMonthtoMonthLease#(lf),TI.TenantDecidedMonthtoMonth#(lf),TI.DoNotRenew#(lf),TI.ReasonForNotRenewingId#(lf),CASE WHEN T.NOTICE_DATE_KEY IS NOT NULL AND TI.MoveOut IS NOT NULL #(lf)      THEN DATEDIFF('day',to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd'),COALESCE(TI.MoveOut,TI.AnticipatedMoveOutDate)) END AS DAYS_OF_NOTICE#(lf)      #(lf) ,CASE WHEN T.NOTICE_DATE_KEY IS NOT NULL AND to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd') IS NOT NULL #(lf)      THEN DATEDIFF('day',TI.MoveOut,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) END AS DAYS_MO_BEFORE_EXP#(lf)      #(lf),TI.MoveOut#(lf),DATE_TRUNC('month',TI.MoveOut) MOVEOUT_BOM#(lf),CASE WHEN TI.MoveOut IS NOT NULL THEN 1 ELSE 0 END AS MOVE_OUT_INDICATOR#(lf)#(lf),CASE WHEN TI.MoveOut IS NULL THEN NULL WHEN TI.MoveOutComplte = 'Y' THEN 'Yes' ELSE 'No' END AS MoveOutComplete#(lf),CASE WHEN TI.MoveOut IS NULL THEN NULL WHEN TI.MoveOutComplte = 'Y' THEN 1 ELSE 0 END AS MoveOutComplete_Indicator#(lf)#(lf),DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf),AM_PM.MoveInReady#(lf),COALESCE(TI.MoveOut,TI.AnticipatedMoveOutDate,#(lf)#(tab)CASE WHEN (T.MONTH_TO_MONTH = 'Y' OR TI.TENANTDECIDEDMONTHTOMONTH = 1 OR TI.REASONFORNOTRENEWINGID = 3143 )#(lf)#(tab)#(tab)#(tab) AND TI.AnticipatedMoveOutDate IS NULL THEN NULL ELSE #(lf)#(tab)#(tab)     to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd') END) AS  Move_Out_Forecast#(lf)#(tab)#(tab)     #(lf),DATE_TRUNC('month',COALESCE(TI.MoveOut,TI.AnticipatedMoveOutDate,#(lf)#(tab)CASE WHEN (T.MONTH_TO_MONTH = 'Y' OR TI.TENANTDECIDEDMONTHTOMONTH = 1 OR TI.REASONFORNOTRENEWINGID = 3143 )#(lf)#(tab)#(tab)#(tab) AND TI.AnticipatedMoveOutDate IS NULL THEN NULL ELSE #(lf)#(tab)#(tab)     to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd') END)) AS  Move_Out_Forecast_BOM#(lf)#(tab)#(tab)     #(lf),CASE WHEN T.TENANT_STATUS = 'Notice'#(lf)      AND (DATEADD('day',30,TI.AnticipatedMoveOutDate) < to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd'))#(lf)      AND (TI.ReasonForNotRenewingId IS NULL OR TI.ReasonForNotRenewingId NOT IN (3157,3158,3156,3168,3142))#(lf)      THEN DATEDIFF('day',TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd'))#(lf)      ELSE NULL#(lf)      END AS EARLY_TERM_DAYS#(lf)#(lf),CASE #(lf)WHEN TI.MoveOut IS NOT NULL AND TI.MoveOutComplte = 'N' THEN 1#(lf)WHEN TI.MoveOut IS NOT NULL AND TI.MoveOutComplte = 'Y' AND DATEDIFF(DAY,TI.MoveOut,GETDATE()) BETWEEN 0 AND 180 THEN 1#(lf)WHEN TI.MoveOut IS NULL AND T.MONTH_TO_MONTH = 'N' AND COALESCE(TI.MoveOut,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) < GETDATE() THEN 1 #(lf)WHEN DATEDIFF(DAY,COALESCE(TI.MoveOut,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')),GETDATE()) BETWEEN -60 AND 30 THEN 1#(lf)ELSE 0#(lf)END AS Move_Out_Forecast_Filter#(lf),CASE #(lf)#(tab)WHEN TI.MoveOut IS NULL#(lf)#(tab)AND ( T.MONTH_TO_MONTH = 'N' OR (T.MONTH_TO_MONTH = 'Y' AND TI.AnticipatedMoveOutDate < GETDATE()) )#(lf)#(tab)AND DATEDIFF(DAY,COALESCE (TI.MoveOut,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')),GETDATE()) >= 0 THEN 1 #(lf)#(tab)WHEN TI.MoveOut IS NULL#(lf)#(tab)AND T.MONTH_TO_MONTH = 'Y'#(lf)#(tab)AND DATEDIFF(DAY,COALESCE (TI.MoveOut,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')),GETDATE()) >= 0 THEN NULL#(lf)#(tab)ELSE 0 END AS Past_Move_Out#(lf),'https:/honeybadgerpm.com/ReportingModule/ViewReport?reportId=1807&UnitId='||TI.UnitID||'&UserId='||TI.UserID||'#/' AS URL_SODA#(lf),'https://honeybadgerpm.com/PropertyModule#/PropertyDetails/' || HBPM.PROPERTYID || '/' || PM_AI.UnitID ||'/0' AS HBPM_URL#(lf),'https://honeybadgerpm.com/PeopleModule#/TenantDetails/' || U.USER_ID || '/' || T.TENANT_INFORMATION_ID   AS HBPM_TENANT_URL#(lf)#(lf),MO_NOTE.MO_Note#(lf),MO_NOTE.MO_NoteCreated#(lf),CASE WHEN T.TENANT_STATUS = 'Under Eviction' AND TI.AnticipatedMoveOutDate = LAST_DAY(GETDATE()) THEN 1 ELSE 0 END AS EVICITON_AMOD_FLAG#(lf),GREATEST(DATEDIFF('day',TI.MoveOut,GETDATE()),0) AS Days_Since_MO#(lf),RRQC.RRQCPassDate  AS RRQC_Result_Date#(lf),CASE WHEN RRQC.RRQCPassDate IS NOT NULL THEN 'Pass' ELSE NULL END AS RRQC_Result#(lf),AM_STRATEGY.STRATEGYNAME AS STRATEGY_NAME#(lf),Rently.Rently_Property_Status#(lf),CONVERT_TIMEZONE('EST', FTA.SODA_COMPLETION_DATE::date) AS SODA_COMPLETION_DATE#(lf),date_trunc('month',CONVERT_TIMEZONE('EST', FTA.SODA_COMPLETION_DATE::date)) AS SODA_COMPLETION_DATE_BOM#(lf),CASE WHEN TI.MoveOut IS NOT NULL AND FTA.SODA_COMPLETION_DATE IS NOT NULL #(lf)      THEN DATEDIFF('day',TI.MoveOut,CONVERT_TIMEZONE('EST', FTA.SODA_COMPLETION_DATE::date))#(lf)      ELSE NULL #(lf)      END AS DAY_TO_COMPLETE_SODA#(lf) ,'Charge' AS IMPORT_TYPE #(lf) ,GETDATE() AS IMPORT_Due_Date#(lf) #(lf) ,CASE WHEN (DNR.DESCRIPTION = 'Military Transfer' OR T.TENANT_STATUS <> 'Notice') THEN NULL#(lf) #(tab)#(lf) WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) > 60 #(lf) #(tab)  THEN TI.AnticipatedMoveOutDate#(lf)#(lf) #(tab)  WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) <= 60 #(lf)      AND to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') <= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)     #(lf)      THEN GREATEST(#(lf)              LEAST(DATEADD('day',60,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd')), DATEADD('day',30, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT,'yyyymmdd'))),#(lf)               to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd'))#(lf)    #(lf)      WHEN to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') >= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)      THEN DATEADD('day',30,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd'))#(lf) #(tab)#(lf) END AS RENT_RESPONSBLE_DATE#(lf) #(lf) #(lf) ,CASE WHEN (DNR.DESCRIPTION = 'Military Transfer' OR T.TENANT_STATUS = 'Under Eviction') THEN NULL#(lf)#(tab)  #(lf)      WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) > 60 #(lf)       AND TI.AnticipatedMoveOutDate IS NOT NULL#(lf)       THEN ROUND(T.CURRENT_RENT * 2,2)#(lf)     #(lf)       WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) <= 60 #(lf)          AND to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') <= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)          AND TI.AnticipatedMoveOutDate IS NOT NULL #(lf)          AND T.NOTICE_DATE_KEY IS NOT NULL #(lf)          THEN ROUND(#(lf)          GREATEST(#(lf)            DATEDIFF(DAY,TI.AnticipatedMoveOutDate,#(lf)            GREATEST(#(lf)              LEAST(DATEADD('day',60,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd')), DATEADD('day',30, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT,'yyyymmdd'))),#(lf)               to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')))#(lf)              ,0)#(lf)          * T.CURRENT_RENT/30,2)#(lf)#(lf)      WHEN to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') >= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)          AND TI.AnticipatedMoveOutDate IS NOT NULL #(lf)          AND T.NOTICE_DATE_KEY IS NOT NULL #(lf)          THEN ROUND(GREATEST(LEAST(30,30 - DATEDIFF('day',to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd'),TI.AnticipatedMoveOutDate)),0) * T.CURRENT_RENT/30,2)#(lf)          #(lf)       ELSE NULL END AS IMPORT_AMOUNT#(lf)       #(lf),CASE WHEN (DNR.DESCRIPTION = 'Military Transfer' OR T.TENANT_STATUS = 'Under Eviction') THEN NULL #(lf)#(tab)   WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) > 60 AND TI.AnticipatedMoveOutDate IS NOT NULL#(lf)       THEN 4550 ELSE 4945500 END AS IMPORT_GL_ACCOUNT#(lf)       #(lf) ,CASE WHEN (DNR.DESCRIPTION = 'Military Transfer' OR T.TENANT_STATUS = 'Under Eviction') THEN NULL #(lf)#(tab)   WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) > 60 AND TI.AnticipatedMoveOutDate IS NOT NULL#(lf)       THEN 'Move Out Charges - Early Termination Fee' ELSE 'Insufficient Notice / Rent Responsible' END AS IMPORT_GL_ACCOUNT_DESC#(lf) #(lf) ,CASE WHEN (DNR.DESCRIPTION = 'Military Transfer' OR T.TENANT_STATUS = 'Under Eviction') THEN NULL #(lf)#(tab)  WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate,to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) > 60 AND TI.AnticipatedMoveOutDate IS NOT NULL#(lf)       THEN  'Early Termination Fee'#(lf)     #(lf)        WHEN DATEDIFF(DAY,TI.AnticipatedMoveOutDate, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')) <= 60 #(lf)          AND to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') <= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)          AND TI.AnticipatedMoveOutDate IS NOT NULL #(lf)          AND T.NOTICE_DATE_KEY IS NOT NULL #(lf)       THEN 'Rent Responsible: ' || MONTH(TI.AnticipatedMoveOutDate) || '-' || DAY(TI.AnticipatedMoveOutDate) || ' - ' ||#(lf)       MONTH(GREATEST(#(lf)              LEAST(DATEADD('day',60,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd')), DATEADD('day',30, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT,'yyyymmdd'))),#(lf)               to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd'))) || '-' ||#(lf)       DAY(GREATEST(#(lf)              LEAST(DATEADD('day',60,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd')), DATEADD('day',30, to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT,'yyyymmdd'))),#(lf)               to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')))#(lf)       #(lf)      WHEN to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') >= to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd')#(lf)         AND TI.AnticipatedMoveOutDate IS NOT NULL #(lf)         AND T.NOTICE_DATE_KEY IS NOT NULL #(lf)       THEN 'Rent Responsible: ' || MONTH(TI.AnticipatedMoveOutDate) || '-' || DAY(TI.AnticipatedMoveOutDate) || ' - ' ||#(lf)       MONTH(DATEADD('day',30,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd'))) || '-' || DAY(DATEADD('day',30,to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd')))#(lf)       #(lf)       ELSE NULL END AS IMPORT_DESCRIPTION#(lf) #(lf) , NULL AS IMPORT_HBPM_User#(lf) , NULL AS IMPORT_Tenant_Note#(lf) , NULL AS IMPORT_Tenant_Note_Type#(lf) #(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TS ON TS.TENANT_KEY = T.TENANT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSA ON DSA.DEAL_KEY = TLA.DEAL_KEY #(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId =