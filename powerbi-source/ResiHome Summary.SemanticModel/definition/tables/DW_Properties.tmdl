	column 1_Next_GC_Due = CALCULATE(MAX(SP_PPW[Daily Due Date]),FILTER(SP_PPW,SP_PPW[1_Property_key]=DW_Properties[PROPERTY_KEY]&&SP_PPW[Daily Invoice Date]=BLANK()&&SP_PPW[Work Order Status]<>"Cancelled"&&OR(SP_PPW[Work Type Name]="Resi Grass Cut",SP_PPW[Work Type Name]="Resi Grass Cut FL")))
		lineageTag: 6dbefaab-c5d6-4e42-a7fb-f91771403364
