		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

	column 1_PPW_GC_Status = ```
			IF(AND(DW_Properties[1_Next_GC_Due]>=TODAY(),DW_Properties[1_Next_GC_Due]<(TODAY()+14)),"On Schedule",
			IF(AND(DW_Properties[1_Next_GC_Due]=BLANK(),DW_Properties[1_Last_GC_Invoiced]>=(TODAY()-3)),"On Schedule",
			If(DW_Properties[GC_RESPONSIBILITY_ID]=4474,"On Schedule",
			IF(AND(DW_Properties[1_Next_GC_Due]=BLANK(),DW_Properties[1_Last_MO]>=(TODAY()-4)),"On Schedule",
			IF(AND(DW_Properties[1_Next_GC_Due]=BLANK(),DW_Properties[1_Last_GC_Invoiced]<(TODAY()-3)),"ERR: Missing Next Cut",
			IF(AND(DW_Properties[1_Next_GC_Due]>=TODAY(),DW_Properties[1_Next_GC_Due]>=(TODAY()+31)),"ERR: Needs Next Cut Sooner",
			IF(AND(DW_Properties[1_Next_GC_Due]<>BLANK(),DW_Properties[1_Next_GC_Due]>(TODAY()-7)),"ERR: Late 1 Week",
			IF(AND(DW_Properties[1_Next_GC_Due]<>BLANK(),DW_Properties[1_Next_GC_Due]>(TODAY()-14)),"ERR: Late 2 Weeks",
			IF(DW_Properties[1_Next_GC_Due]<>BLANK(),"ERR: Late +2 Weeks","TBD")))))))))
			
			```
		lineageTag: 9274529b-cdbf-4d2b-b531-43f615085620
		summarizeBy: none

		changedProperty = IsHidden

		annotation SummarizationSetBy = Automatic

