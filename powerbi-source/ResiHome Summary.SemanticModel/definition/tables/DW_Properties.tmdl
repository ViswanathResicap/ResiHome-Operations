	partition DW_Properties-8444469c-ffe9-40ae-8cb5-b4941983a207 = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Role="UAT", Implementation="2.0"]){[Name="PROD_ANALYTICS"]}[Data], "/* =============================================================================#(lf)   MASTER PROPERTY DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:      One row per property (DISTINCT applied).#(lf)   Anchor:     PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY (P)#(lf)   Enriches:   PM / AM / MM systems, tenant + lease, listings, notes#(lf)               (collections + move-in), eviction counts, rent logs,#(lf)               lease history, and HubSpot property fields.#(lf)#(lf)   CLEANUP NOTES (behavior-preserving except where flagged):#(lf)     [FIX 1] ORGANIZATION_NAME: removed unreachable duplicate (61,70)->'Newstar'.#(lf)             First (61,70) branch returns 'ROI Property Group'; second was dead.#(lf)     [FIX 2] PROP_STATUS_FLAG: removed duplicated 'Occupied - No Tenant' block#(lf)             (identical condition appeared twice; second was unreachable).#(lf)     [FIX 3] REMOVED RB_Fence_Installed column and its RB_F join entirely#(lf)             (logic was broken — all three WHENs tested the same value — and#(lf)             the field is no longer needed).#(lf)     [FIX 4] DROPPED unused joins that were never referenced in SELECT, WHERE,#(lf)             or any downstream join (all are non-fanning single-row lookups /#(lf)             aggregated subqueries, so removal is output-identical):#(lf)               - AM_CONS  (HBAM_DBO.CONSTRUCTIONS)#(lf)               - OI, CFK, OT, VS  (four HBPM_DBO.LOOKUPMASTERS lookups)#(lf)               - MO       (most-recent move-out subquery)#(lf)             Also dropped dead NT / LM joins inside the two note CTEs.#(lf)   ============================================================================= */#(lf)#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: CollectionsNote#(lf)   Most recent collections note (NoteTypeId = 3) per property.#(lf)   Notes attach either directly to a property or via tenant -> unit -> property.#(lf)   ----------------------------------------------------------------------------- */#(lf)WITH CollectionsNote AS (#(lf)    SELECT DISTINCT#(lf)         N.NOTEID                                                          AS LatestNoteID#(lf)        ,N.NOTETEXT                                                        AS CollectionNote#(lf)        ,N.CREATEDDATE                                                     AS CollectionNoteCreated#(lf)        ,P.PropertyId#(lf)        ,RANK() OVER (PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID         = N.ObjectId#(lf)            AND N.ObjectTypeId    = 502#(lf)            AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON  PAI.UnitId        = TI.UnitId#(lf)            AND PAI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON  P.PropertyID      = COALESCE(PAI.PropertyId, N.ObjectID)#(lf)            AND P.""_FIVETRAN_DELETED"" = 'N'#(lf)    WHERE N.NoteTypeId = 3#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: MoveInNote#(lf)   Most recent move-in note (NoteTypeId = 7) per property. Same join pattern#(lf)   as CollectionsNote.#(lf)   ----------------------------------------------------------------------------- */#(lf),MoveInNote AS (#(lf)    SELECT DISTINCT#(lf)         N.NOTEID                                                          AS LatestNoteID_MI#(lf)        ,N.NOTETEXT                                                        AS MI_Note#(lf)        ,N.CREATEDDATE                                                     AS MI_NoteCreated#(lf)        ,P.PropertyId#(lf)        ,RANK() OVER (PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID         = N.ObjectId#(lf)            AND N.ObjectTypeId    = 502#(lf)            AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON  PAI.UnitId        = TI.UnitId#(lf)            AND PAI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON  P.PropertyID      = COALESCE(PAI.PropertyId, N.ObjectID)#(lf)            AND P.""_FIVETRAN_DELETED"" = 'N'#(lf)    WHERE N.NoteTypeId = 7#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: UW_RENT#(lf)   Latest underwriting rent change per unit, pulled from the most recent#(lf)   RentLogs row (max RENTLOGID) for each ENTITYID1 (= HBPM UnitId).#(lf)   ----------------------------------------------------------------------------- */#(lf),UW_RENT_MAX AS (#(lf)    SELECT#(lf)         MAX(RENTLOGID) AS RENTLOGID#(lf)        ,ENTITYID1#(lf)    FROM PROD_REPLICA.HBPM_DBO.RENTLOGS#(lf)    GROUP BY ENTITYID1#(lf))#(lf)#(lf),UW_RENT AS (#(lf)    SELECT#(lf)         RentLogs.ENTITYID1     AS HBPM_UnitID#(lf)        ,RentLogs.ORIGINALVALUE AS UW_Rent_Prior#(lf)        ,RentLogs.UPDATEVALUE   AS UW_Rent_Current#(lf)        ,RentLogs.OCCUREDON     AS UW_Update_Date#(lf)    FROM UW_RENT_MAX#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.RENTLOGS RentLogs#(lf)            ON RentLogs.RENTLOGID = UW_RENT_MAX.RENTLOGID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: LEASE_HIST#(lf)   Most recent qualifying lease per property. Limited to real leases#(lf)   (amount >= 500) that started on/after the property's RRQC pass date.#(lf)   Ranks by created date, then lease start, then lease-from date, then amount.#(lf)   ----------------------------------------------------------------------------- */#(lf),LEASE_HIST AS (#(lf)    SELECT DISTINCT#(lf)         P.PROPERTY_KEY#(lf)        ,TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT, 'yyyymmdd') AS LEASE_FROM_DATE#(lf)        ,TLH.AMOUNT#(lf)        ,RANK() OVER (#(lf)            PARTITION BY P.PROPERTY_KEY#(lf)            ORDER BY DATE_TRUNC('day', CREATED) DESC,#(lf)                     TLH.LEASESTART DESC,#(lf)                     TLA.LEASE_FROM_DATE_KEY DESC,#(lf)                     TLH.AMOUNT ASC#(lf)         ) AS RANK_1#(lf)    FROM PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES TLH#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON TI.TenantInformationId = TLH.TenantInformationId#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)            ON  T.TENANT_INFORMATION_ID = TI.TenantInformationId#(lf)            AND T.Current_FLAG = 'Y'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)            ON TLA.TENANT_KEY = T.Tenant_Key#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON  PAI.UnitId = TI.UnitId#(lf)            AND PRIMARYTENANT = 'TRUE'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM#(lf)            ON HBPM.PropertyId = PAI.PropertyId#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)            ON  P.HBPM_PROPERTY_ID = HBPM.PROPERTYID#(lf)            AND P.Current_FLAG = 'Y'#(lf)        LEFT JOIN (#(lf)            SELECT MAX(Id) AS RRQC_ID, HBID#(lf)            FROM PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS#(lf)            GROUP BY HBID#(lf)        ) RRQC_MOST_RECENT#(lf)            ON RRQC_MOST_RECENT.HBID = P.HBAM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS RRQC#(lf)            ON RRQC.ID = RRQC_MOST_RECENT.RRQC_ID#(lf)    WHERE 1 = 1#(lf)        AND TLA.LEASE_FROM_DATE_KEY IS NOT NULL#(lf)        AND T.Tenant_Status <> 'Future'#(lf)        AND TLH.AMOUNT <> 0#(lf)        AND TLH.AMOUNT >= 500#(lf)        AND RRQC.RRQCPassDate IS NOT NULL#(lf)        AND TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT, 'yyyymmdd') >= RRQC.RRQCPassDate#(lf)    QUALIFY RANK_1 = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: EVICTION_COUNT#(lf)   Count of evictions per tenant/unit in the trailing 12 months.#(lf)   ----------------------------------------------------------------------------- */#(lf),EVICTION_COUNT AS (#(lf)    SELECT#(lf)         UNITID#(lf)        ,TENANTINFORMATIONID#(lf)        ,COUNT(ID) AS EVICTION_COUNT#(lf)    FROM PROD_REPLICA.HBPM_DBO.EVICTIONS E#(lf)    WHERE TENANTINFORMATIONID IS NOT NULL#(lf)        AND CREATEDDATE >= DATEADD('YEAR', -1, GETDATE())#(lf)    GROUP BY UNITID, TENANTINFORMATIONID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: HUBSPOT#(lf)   Current HubSpot property record (one per PROPERTY_ENTITY_ID), filtered to#(lf)   live, non-merged, non-deleted rows. Source of Rently device + utility +#(lf)   enrollment fields.#(lf)   ----------------------------------------------------------------------------- */#(lf),HUBSPOT AS (#(lf)    SELECT#(lf)         ID#(lf)        ,PROPERTY_ENTITY_ID#(lf)        ,PROPERTY_RENTLY_SERIAL_SYNC_STATUS  AS RENTLY_SYNC_STATUS#(lf)        ,PROPERTY_ELECTRONIC_LOCKBOX_NUMBER  AS RENTLY_SERIAL_NUMBER#(lf)        ,PROPERTY_RENTLY_DEVICE_TYPE         AS RENTLY_DEVICE_TYPE#(lf)        ,PROPERTY_RENTLY_SH_HUB_STATUS       AS RENTLY_SH_HUB_STATUS#(lf)        ,PROPERTY_RENTLY_SH_HUB_SERIAL_ID    AS RENTLY_SH_HUB_SERIAL_ID#(lf)        ,PROPERTY_RENTLY_SH_LOCK_STATUS      AS RENTLY_SH_LOCK_STATUS#(lf)        ,PROPERTY_AIR_FILTERS_TOTAL_QUANTITY AS FILTER_QUANTITY#(lf)        ,PROPERTY_AIR_FILTERS_TYPE_1         AS FILTER_SIZE_1#(lf)        ,PROPERTY_AIR_FILTERS_TYPE_2         AS FILTER_SIZE_2#(lf)        ,PROPERTY_AIR_FILTERS_TYPE_3         AS FILTER_SIZE_3#(lf)        ,PROPERTY_ELECTRIC_PROVIDER#(lf)        ,PROPERTY_BUNDLED_UTILITIES#(lf)        ,PROPERTY_GAS_PROVIDER#(lf)        ,PROPERTY_OIL_PROPANE_PROVIDER#(lf)        ,PROPERTY_SEWER_PROVIDER#(lf)        ,PROPERTY_TRASH_PROVIDER#(lf)        ,PROPERTY_WATER_PROVIDER#(lf)        ,PROPERTY_INTERNET_ELIGIBLE#(lf)        ,PROPERTY_INTERNET_ENROLLED#(lf)        ,PROPERTY_CREDIT_REPORTING_ELIGIBLE#(lf)        ,PROPERTY_CREDIT_REPORTING_ENROLLED#(lf)        ,PROPERTY_EASY_LIVING_BUNDLE_ELIGIBLE#(lf)        ,PROPERTY_EASY_LIVING_BUNDLE_ENROLLED#(lf)        ,PROPERTY_PEST_CONTROL_ENROLLED#(lf)        ,PROPERTY_CONSERVICE_MONTHLY_FEE#(lf)        ,PROPERTY_RENTLY_SERIAL_ID_UPDATE_DATE#(lf)    FROM PROD_REPLICA.HUBSPOT_2.PROPERTIES#(lf)    WHERE 1 = 1#(lf)        AND PROPERTY_ENTITY_ID IS NOT NULL#(lf)        AND PROPERTY_HS_MERGED_OBJECT_IDS IS NULL#(lf)        AND (_fivetran_deleted = FALSE OR _fivetran_deleted IS NULL)#(lf))#(lf)#(lf)#(lf)/* =============================================================================#(lf)   FINAL SELECT#(lf)   ============================================================================= */#(lf)SELECT DISTINCT#(lf)     P.PROPERTY_KEY#(lf)#(lf)    -- ---- Cross-system property identifiers ----#(lf)    ,P.HBAM_PROPERTY_ID#(lf)    ,P.HBPM_PROPERTY_ID#(lf)    ,P.HBMM_PROPERTY_ID#(lf)    ,PU.PROPERTY_UNIT_KEY#(lf)    ,P.PROPERTY_STATE          AS ""DW_PropertyState""#(lf)    ,HBPM.PropertyStateID      AS ""PM_PropetyState""#(lf)    ,HBAM.PropertyState        AS ""AM_PropertyState""#(lf)    ,P.HBH_PROPERTY_ID#(lf)    ,HBAM.ASSETID#(lf)#(lf)    -- ---- Region / POD ----#(lf)    ,PUS.REGION_KEY#(lf)    ,CASE#(lf)        WHEN PUS.REGION_KEY IN (67,76)                  THEN 'GA'#(lf)        WHEN PUS.REGION_KEY IN (57,58,60,64,769,770)    THEN 'FL'#(lf)        WHEN PUS.REGION_KEY IN (104,161,230,246,75,7)   THEN 'SCATTERED'#(lf)        WHEN PUS.REGION_KEY IN (257,207,253,255)        THEN 'WEST'#(lf)        ELSE NULL#(lf)     END AS POD#(lf)    ,R.REGION_NAME#(lf)#(lf)    -- ---- Organization (rolled-up key + name) ----#(lf)    ,CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)               THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                        THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)            THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                        THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                           THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)#(lf)    -- [FIX 1] removed unreachable duplicate (61,70)->'Newstar' branch.#(lf)    ,CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)               THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                        THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)            THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                        THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                           THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf)#(lf)    ,NULL AS PROPERTY_MANAGER_REGIONAL_EMAIL#(lf)    ,NULL AS PROPERTY_MANAGMENT_ALL_EMAIL#(lf)#(lf)    -- ---- Venture number (parsed from portfolio name) ----#(lf)    ,CASE#(lf)        WHEN CHARINDEX(' VIII', PO.PORTFOLIO_NAME) > 0 THEN 'Venture VIII'#(lf)        WHEN CHARINDEX(' VII',  PO.PORTFOLIO_NAME) > 0 THEN 'Venture VII'#(lf)        WHEN CHARINDEX(' VI',   PO.PORTFOLIO_NAME) > 0 THEN 'Venture VI'#(lf)        WHEN CHARINDEX(' IV',   PO.PORTFOLIO_NAME) > 0 THEN 'Venture IV'#(lf)        WHEN CHARINDEX(' V',    PO.PORTFOLIO_NAME) > 0 THEN 'Venture V'#(lf)        WHEN CHARINDEX(' III',  PO.PORTFOLIO_NAME) > 0 THEN 'Venture III'#(lf)        WHEN CHARINDEX(' II',   PO.PORTFOLIO_NAME) > 0 THEN 'Venture II'#(lf)        WHEN CHARINDEX('Venture', PO.PORTFOLIO_NAME) > 0#(lf)             OR P.ORGANIZATION_KEY IN (-1,18,26,28,48,27)         THEN 'Venture I'#(lf)        ELSE 'All'#(lf)     END AS Venture_No#(lf)    ,PUS.PORTFOLIO_KEY#(lf)    ,PO.PORTFOLIO_NAME#(lf)#(lf)    -- ---- Address breakdown ----#(lf)    ,P.ADDRESS || ', ' || COALESCE(CI.CITY_NAME, PM_CI.CityName) || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS Full_Address#(lf)    ,P.ADDRESS#(lf)    ,LEFT(P.ADDRESS, CHARINDEX(' ', P.ADDRESS) - 1)                       AS ADDRESS_STREET_NO#(lf)    ,RIGHT(P.ADDRESS, LENGTH(P.Address) - CHARINDEX(' ', P.ADDRESS))      AS ADDRESS_STREET_NAME#(lf)    ,PUS.CITY_KEY#(lf)    ,CI.CITY_NAME#(lf)    ,PUS.STATE_KEY#(lf)    ,S.STATE_NAME#(lf)    ,S.STATE_CODE#(lf)    ,P.ZIPCODE#(lf)    ,COALESCE(CI.CITY_NAME, PM_CI.CityName) || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS CITY_ST_ZIP#(lf)    ,PUS.COUNTY_KEY#(lf)    ,CO.COUNTY_NAME#(lf)#(lf)    -- ---- Entity ID (with hardcoded overrides for 4 specific properties) ----#(lf)    ,CASE#(lf)        WHEN P.PROPERTY_KEY = 253325 THEN '20211012410E'#(lf)        WHEN P.PROPERTY_KEY = 209187 THEN '20211012414E'#(lf)        WHEN P.PROPERTY_KEY = 225057 THEN '20211012402E'#(lf)        WHEN P.PROPERTY_KEY = 234563 THEN '20211012406E'#(lf)        ELSE P.EntityID#(lf)     END AS ENTITYID#(lf)    ,P.PROPERTY_STATE#(lf)    ,P.PROPERTY_TYPE#(lf)#(lf)    -- ---- Subdivision (with two value remaps) ----#(lf)    ,CASE WHEN PUS.SUBDIVISION_KEY = 204 THEN 201 ELSE PUS.SUBDIVISION_KEY END AS SUBDIVISION_KEY#(lf)    ,CASE WHEN SUB.SUBDIVISION = 'Wildwood Landing Ph 2' THEN 'Wildwood Landing' ELSE SUB.SUBDIVISION END AS SUBDIVISION#(lf)    ,P.FloorPlan#(lf)    ,PUS.FLOORPLAN_KEY#(lf)    ,AM_INS.POOLSERVICEREQUIRED#(lf)#(lf)    -- ---- Purchase type ----#(lf)    ,BA.PurchaseType AS ""Purchase_Type_ID""#(lf)    ,CASE BA.PurchaseType#(lf)        WHEN 1 THEN 'Foreclosure'#(lf)        WHEN 2 THEN 'MLS'#(lf)        WHEN 3 THEN 'Off-Market'#(lf)        WHEN 4 THEN 'Bulk'#(lf)        WHEN 5 THEN 'Deed in Lieu'#(lf)        WHEN 6 THEN 'I-Buyer'#(lf)        WHEN 7 THEN 'Non-Foreclosure'#(lf)        WHEN 8 THEN 'New Construction'#(lf)        ELSE NULL#(lf)     END AS ""Purchase Type""#(lf)#(lf)    -- ---- Status / occupancy ----#(lf)    ,PUS.PROPERTY_STATUS#(lf)    ,PUS.PROPERTY_STAGE#(lf)    ,PM_OC.OccupancyStatusId#(lf)#(lf)    ,CASE#(lf)        WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased'#(lf)        WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)        ELSE PUS.Occupancy_Status#(lf)     END AS Occupancy_Status#(lf)#(lf)    ,CASE#(lf)        WHEN PUS.Occupancy_Status = 'Trustee Occupied'                                  THEN 'Trustee Occupied'#(lf)        WHEN PUS.Occupancy_Status = 'Under Inspection'                                  THEN 'Inspection'#(lf)        WHEN PUS.Occupancy_Status = 'Under Construction'                                THEN 'Constuction'#(lf)        WHEN PUS.Occupancy_Status IN ('Vacant - Off Market', 'Vacant - Onboarding')     THEN 'Vacant - Off Market'#(lf)        WHEN PUS.Occupancy_Status IN ('Vacant - On Market', 'Vacant - Pre-Leasing')     THEN 'Vacant - On Market'#(lf)        WHEN PUS.Occupancy_Status = 'Tenant Leased'                                     THEN 'Tenant Leased'#(lf)        WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)        WHEN PUS.Occupancy_Status = 'Vacant - Future Move In'                           THEN 'Vacant - FMI'#(lf)        WHEN PUS.Occupancy_Status IN ('Trustee Lease Honored', 'Trustee Leased')        THEN 'Trustee Leased'#(lf)        WHEN PUS.Occupancy_Status IN ('Pending MOI/Rekey', 'Under Turnkey')             THEN 'Turnkey'#(lf)        ELSE PUS.Occupancy_Status#(lf)     END AS Occupancy_Status_Summary#(lf)#(lf)    ,CASE#(lf)        WHEN PUS.Occupancy_Status = 'Trustee Occupied'                                  THEN 1#(lf)        WHEN PUS.Occupancy_Status = 'Under Inspection'                                  THEN 2#(lf)        WHEN PUS.Occupancy_Status = 'Under Construction'                                THEN 3#(lf)        WHEN PUS.Occupancy_Status IN ('Vacant - Off Market', 'Vacant - Onboarding')     THEN 4#(lf)        WHEN PUS.Occupancy_Status IN ('Vacant - On Market', 'Vacant - Pre-Leasing')     THEN 5#(lf)        WHEN PUS.Occupancy_Status = 'Tenant Leased'                                     THEN 8#(lf)        WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 8#(lf)        WHEN PUS.Occupancy_Status = 'Vacant - Future Move In'                           THEN 6#(lf)        WHEN PUS.Occupancy_Status IN ('Trustee Lease Honored', 'Trustee Leased')        THEN 7#(lf)        WHEN PUS.Occupancy_Status IN ('Pending MOI/Rekey', 'Under Turnkey')             THEN 9#(lf)        ELSE 10#(lf)     END AS Occupancy_Status_SummaryID#(lf)#(lf)    -- ---- Unit physical attributes (PM override, else DW) ----#(lf)    ,COALESCE(PM_AI.Bedrooms,  PU.BEDROOMS)  AS BEDROOMS#(lf)    ,COALESCE(PM_AI.BATHROOMS, PU.BATHROOMS) AS BATHROOMS#(lf)    ,PU.SQUARE_FOOTAGE#(lf)    ,P.Year_Built#(lf)    ,PUS.Under_written_rent#(lf)#(lf)    -- ---- Key dates ----#(lf)    ,COALESCE(TO_DATE(P.TRANSFER_DATE_KEY::TEXT, 'yyyymmdd'),#(lf)              TO_DATE(P.PURCHASE_DATE_KEY::TEXT, 'yyyymmdd')) AS ""Transfer_Date""#(lf)    ,TO_DATE(P.PURCHASE_DATE_KEY::TEXT, 'yyyymmdd')           AS ""Purchase_Date""#(lf)    ,TO_DATE(PROPERTY_SOLD_DATE_KEY::TEXT, 'yyyymmdd')        AS ""Sold_Date""#(lf)#(lf)    -- ---- Tenant ----#(lf)    ,TEN.CURRENT_RENT#(lf)    ,TI.UserID AS TEN_USER_ID#(lf)    ,TEN.TENANT_KEY#(lf)    ,TEN.LEASE_ID#(lf)    ,TEN.TENANT_STATUS#(lf)    ,TEN.EVICTION_STATUS#(lf)    ,TEN.MOVE_IN_DATE                AS TEN_MOVE_IN_DATE#(lf)    ,TEN.ANTICIPATED_MOVE_OUT_DATE   AS TEN_ANTICIPATED_MOVE_OUT_DATE#(lf)    ,TU.FIRST_NAME                   AS TEN_FIRST_NAME#(lf)    ,TU.LAST_NAME                    AS TEN_LAST_NAME#(lf)    ,TU.FULL_NAME                    AS TEN_FULL_NAME#(lf)    ,TU.EMAIL_ADDRESS                AS TEN_EMAIL#(lf)    ,TU.PHONE_NUMBER                 AS TEN_PHONE_NUMBER#(lf)#(lf)    -- ---- Lease ----#(lf)    ,CASE WHEN TLA.LEASE_FROM_DATE_KEY IS NULL THEN 'Never Leased' ELSE 'Post First Lease' END AS INITIAL_LEASE#(lf)    ,TO_DATE(TLA.LEASE_SIGNED_DATE_KEY::TEXT, 'yyyymmdd') AS ""LEASE_SIGNED_DATE""#(lf)    ,TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT,   'yyyymmdd') AS ""LEASE_FROM_DATE""#(lf)    ,TO_DATE(TLA.LEASE_TO_DATE_KEY::TEXT,     'yyyymmdd') AS ""LEASE_TO_DATE""#(lf)    ,TI.MoveOut AS Tenant_Move_Out_Date#(lf)    ,CASE WHEN TEN.TENANT_STATUS <> 'Past' AND TI.IsSection8 = 1 THEN 'Yes' ELSE 'No' END AS Is_Section8#(lf)    ,CASE WHEN TI.MoveOut IS NOT NULL THEN 'Y' ELSE 'N' END AS MOVE_OUT_INDICATOR#(lf)    ,CASE WHEN TI.FiledWithCountyDate IS NOT NULL THEN 'Filed on' ELSE 'Not Filed On' END AS Filed_With_County_Status#(lf)#(lf)    -- ---- Property management staff ----#(lf)    ,COALESCE(PM_U.FirstName  || ' ' || PM_U.LastName,  '(Blank)') AS Property_Manager#(lf)    ,PM_U.EmailAddress  AS Property_Manager_Email#(lf)    ,COALESCE(PM_UA.FirstName || ' ' || PM_UA.LastName, '(Blank)') AS Property_Manager_Assistant#(lf)    ,PM_UA.EmailAddress AS Property_Manager_Assistant_Email#(lf)#(lf)    -- ---- Listing ----#(lf)    ,RL.RENT_LIST_HIST_ID AS RENTAL_LISTING_ID#(lf)    ,RL.LISTING_STATUS    AS ""Listing_Status_Name""#(lf)    ,DL.IS_PUBLISHED      AS IS_PUBLISHED#(lf)    ,CASE WHEN RL.LISTING_STATUS = 'Active' AND DL.IS_PUBLISHED = 'Y' THEN DL.IS_PRELEASING ELSE NULL END AS PRE_LEASING#(lf)    ,RL.CURRENT_LIST_PRICE AS CurrentListPrice#(lf)    ,CASE WHEN RL.LISTING_STATUS = 'Withdrawn' THEN NULL#(lf)          ELSE TO_DATE(RL.LISTING_DATE_KEY::TEXT, 'yyyymmdd') END AS ListingDate#(lf)#(lf)    -- [FIX 2] removed duplicated 'Occupied - No Tenant' block (was listed twice).#(lf)    ,CASE#(lf)        WHEN RL.LISTING_STATUS <> 'Active'#(lf)             AND PUS.Occupancy_Status = 'Vacant - On Market'#(lf)            THEN 'On Market - Inactive Listings'#(lf)        WHEN RL.LISTING_STATUS = 'Active'#(lf)             AND PUS.Occupancy_Status IN ('Vacant - Future Move In', 'Vacant - Off Market')#(lf)            THEN 'Off Market - Active Listings'#(lf)        WHEN PUS.Occupancy_Status IN ('Tenant Leased', 'Trustee Lease Honored', 'Trustee Leased')#(lf)             AND (TEN.TENANT_STATUS IS NULL OR TEN.TENANT_STATUS = 'Past')#(lf)            THEN 'Occupied - No Tenant'#(lf)        WHEN PUS.Occupancy_Status NOT IN ('Tenant Leased', 'Trustee Lease Honored', 'Trustee Leased')#(lf)             AND TEN.TENANT_STATUS IN ('Current', 'Notice', 'Under Eviction')#(lf)            THEN 'Vacant - With Tenant'#(lf)        ELSE NULL#(lf)     END AS PROP_STATUS_FLAG#(lf)#(lf)    ,RRQC.RRQCPassDate#(lf)#(lf)    -- ---- Trustee / off-market status ----#(lf)    ,PM_AI.TrusteeStatus#(lf)    ,TS.Description AS TrusteeStatusName#(lf)    ,PM_AI.ReasonOffMarketId#(lf)    ,ROM.Description AS ReasonOffMarketName#(lf)    ,PM_AI.OffMarketDate#(lf)    ,AM_PM.MoveInReady#(lf)#(lf)    -- ---- Rent / GPR ----#(lf)    ,COALESCE(TEN.CURRENT_RENT, PUS.Under_written_rent) AS Gross_Potential_Rent#(lf)#(lf)    -- ---- HBPM deep link ----#(lf)    ,'https://honeybadgerpm.com/PropertyModule#/PropertyDetails/'#(lf)        || HBPM.PROPERTYID || '/' || PM_AI.UnitID || '/0' AS HBPM_URL#(lf)#(lf)    ,LEFT(P.ADDRESS, 10) AS ""Address_Trim""#(lf)    ,DATE(GETDATE())     AS TODAY#(lf)#(lf)    -- ---- Notes ----#(lf)    ,CN.CollectionNote#(lf)    ,CN.CollectionNoteCreated#(lf)    ,MI_NOTE.MI_Note#(lf)    ,MI_NOTE.MI_NoteCreated#(lf)#(lf)    -- ---- Underwriting rent change ----#(lf)    ,UW_Rent.UW_Rent_Prior#(lf)    ,UW_Rent.UW_Rent_Current#(lf)    ,UW_Rent.UW_Update_Date AS UW_Update_Date#(lf)#(lf)    -- ---- Lease history (most recent qualifying) ----#(lf)    ,LEASE_HIST.LEASE_FROM_DATE AS LAST_LEASE_START#(lf)    ,LEASE_HIST.AMOUNT          AS LAST_LEASE_AMOUNT#(lf)#(lf)    -- ---- FMI-but-leased flag ----#(lf)    ,CASE#(lf)        WHEN (PUS.Occupancy_Status = 'Vacant - Future Move In' OR RL.LISTING_STATUS = 'Deposit Taken')#(lf)             AND TEN.TENANT_STATUS IN ('Active', 'Under Eviction', 'Notice')#(lf)             AND PUS.Occupancy_Status <> 'Tenant Leased'#(lf)            THEN 'Yes'#(lf)        ELSE 'No'#(lf)     END AS FMI_Tenant_Leased#(lf)#(lf)    -- ---- Maintenance coordinator ----#(lf)    ,MM_U.FIRSTNAME || ' ' || MM_U.LASTNAME AS MC_ASSIGNED#(lf)    ,MM_U.EMAILADDRESS                       AS MC_EMAIL#(lf)    ,AM_STRATEGY.STRATEGYNAME                AS STRATEGY_NAME#(lf)#(lf)    -- ---- Lawn care / GC responsibility ----#(lf)    ,GC.LookupMasterID AS GC_Responsibility_ID#(lf)    ,GC.Description     AS GC_Responsibility#(lf)#(lf)    ,CASE WHEN RL.LISTING_STATUS = 'Withdrawn' THEN NULL ELSE PM_AI.MOVEINREADY END AS PM_MIR#(lf)#(lf)    -- ---- HubSpot record + Rently devices ----#(lf)    ,HUBSPOT.ID AS HUBSPOT_RECORD_ID#(lf)    ,HUBSPOT.RENTLY_SYNC_STATUS#(lf)    ,HUBSPOT.RENTLY_SERIAL_NUMBER#(lf)    ,HUBSPOT.RENTLY_DEVICE_TYPE#(lf)    ,HUBSPOT.RENTLY_SH_HUB_STATUS#(lf)    ,HUBSPOT.RENTLY_SH_HUB_SERIAL_ID#(lf)    ,HUBSPOT.RENTLY_SH_LOCK_STATUS#(lf)#(lf)    -- Rently smart-home next action (device type + hub/lock status driven)#(lf)    ,CASE#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE NOT IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Online'#(lf)             AND HUBSPOT.RENTLY_SH_LOCK_STATUS = 'Offline'#(lf)            THEN 'Needs SH Lock'#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE NOT IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Online'#(lf)             AND HUBSPOT.RENTLY_SH_LOCK_STATUS = 'Online'#(lf)            THEN 'Assign Hub - Remove Other Deivce'#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE NOT IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Offline'#(lf)            THEN 'Remove Hub From Account'#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Offline'#(lf)             AND PUS.Occupancy_Status NOT IN ('Tenant Leased')#(lf)             AND PUS.Occupancy_Status IN ('Vacant - On Market', 'Vacant - Pre-Leasing')#(lf)             AND HUBSPOT.RENTLY_SH_LOCK_STATUS = 'Offline'#(lf)            THEN 'Needs SH Hub & Lock'#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Offline'#(lf)             AND PUS.Occupancy_Status NOT IN ('Tenant Leased')#(lf)             AND PUS.Occupancy_Status IN ('Vacant - On Market', 'Vacant - Pre-Leasing')#(lf)             AND HUBSPOT.RENTLY_SH_LOCK_STATUS = 'Online'#(lf)            THEN 'Needs SH Hub'#(lf)        WHEN HUBSPOT.RENTLY_DEVICE_TYPE IN ('Smart Home Hub')#(lf)             AND HUBSPOT.RENTLY_SH_HUB_SERIAL_ID IS NOT NULL#(lf)             AND HUBSPOT.RENTLY_SH_HUB_STATUS = 'Online'#(lf)             AND PUS.Occupancy_Status NOT IN ('Tenant Leased')#(lf)             AND HUBSPOT.RENTLY_SH_LOCK_STATUS = 'Offline'#(lf)            THEN 'Pair Lock to Hub'#(lf)        ELSE NULL#(lf)     END AS RENTLY_SH_ACTION#(lf)#(lf)    -- ---- HubSpot air filters + utilities + enrollments ----#(lf)    ,HUBSPOT.FILTER_QUANTITY#(lf)    ,HUBSPOT.FILTER_SIZE_1#(lf)    ,HUBSPOT.FILTER_SIZE_2#(lf)    ,HUBSPOT.FILTER_SIZE_3#(lf)    ,HUBSPOT.PROPERTY_ELECTRIC_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_BUNDLED_UTILITIES#(lf)    ,HUBSPOT.PROPERTY_GAS_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_OIL_PROPANE_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_SEWER_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_TRASH_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_WATER_PROVIDER#(lf)    ,HUBSPOT.PROPERTY_INTERNET_ELIGIBLE#(lf)    ,HUBSPOT.PROPERTY_INTERNET_ENROLLED#(lf)    ,HUBSPOT.PROPERTY_CREDIT_REPORTING_ELIGIBLE#(lf)    ,HUBSPOT.PROPERTY_CREDIT_REPORTING_ENROLLED#(lf)    ,HUBSPOT.PROPERTY_EASY_LIVING_BUNDLE_ELIGIBLE#(lf)    ,HUBSPOT.PROPERTY_EASY_LIVING_BUNDLE_ENROLLED#(lf)    ,HUBSPOT.PROPERTY_PEST_CONTROL_ENROLLED#(lf)    ,HUBSPOT.PROPERTY_CONSERVICE_MONTHLY_FEE#(lf)    ,HUBSPOT.PROPERTY_RENTLY_SERIAL_ID_UPDATE_DATE#(lf)#(lf)    ,EC.EVICTION_COUNT#(lf)#(lf)    -- [FIX 3] RB_Fence_Installed column removed (broken logic, no longer needed).#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)#(lf)    /* ---- Core property / unit summary ---- */#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS#(lf)        ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)#(lf)    /* ---- Cross-system property records (replica DBs) ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM#(lf)        ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM#(lf)        ON HBPM.PROPERTYID = P.HBPM_PROPERTY_ID#(lf)    LEFT JOIN PROD_REPLICA.HBMM_DBO.PROPERTIES HBMM#(lf)        ON HBMM.PROPERTYID = P.HBMM_PROPERTY_ID#(lf)#(lf)    /* ---- Staff ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBMM_DBO.USERS MM_U#(lf)        ON MM_U.USERID = HBMM.MAINTENANCECOORDINATORID#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS PM_U#(lf)        ON PM_U.UserID = HBPM.ASSIGNEDUSERID#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS PM_UA#(lf)        ON PM_UA.UserID = HBPM.AssistantASSIGNEDUSERID#(lf)#(lf)    /* ---- PM additional info (unit-level attributes, trustee, off-market) ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_AI#(lf)        ON  PM_AI.PROPERTYID = HBPM.PROPERTYID#(lf)        AND PM_AI.""_FIVETRAN_DELETED"" = 'N'#(lf)#(lf)    /* ---- AM detail tables ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTYMANAGEMENTS AM_PM#(lf)        ON  AM_PM.PROPERTYMANAGEMENTID = HBAM.PropertyManagement_PropertyManagementId#(lf)        AND AM_PM.HBID = HBAM.HBID#(lf)        AND AM_PM.""_FIVETRAN_DELETED"" <> 'Y'#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.INSPECTIONS AM_INS#(lf)        ON  AM_INS.INSPECTIONID = HBAM.INSPECTION_INSPECTIONID#(lf)        AND AM_INS.HBID = HBAM.HBID#(lf)        AND AM_INS.""_FIVETRAN_DELETED"" <> 'Y'#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.BidAndAuctions AM_BA#(lf)        ON  AM_BA.BIDID = HBAM.BidAndAuction_BidId#(lf)        AND AM_BA.HBID = HBAM.HBID#(lf)        AND AM_BA.""_FIVETRAN_DELETED"" <> 'Y'#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.Strategies AM_STRATEGY#(lf)        ON AM_STRATEGY.STRATEGYID = AM_BA.BIDSTRATEGYSTATUS#(lf)#(lf)    /* ---- Dimension lookups ---- */#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO#(lf)        ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_CITY CI#(lf)        ON CI.CITY_KEY = PUS.CITY_KEY#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.Cities PM_CI#(lf)        ON PM_CI.CityID = HBPM.CityID#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_STATE S#(lf)        ON S.STATE_KEY = PUS.STATE_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_COUNTY CO#(lf)        ON CO.COUNTY_KEY = PUS.COUNTY_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R#(lf)        ON R.REGION_KEY = PUS.REGION_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_SUBDIVISION SUB#(lf)        ON SUB.SUBDIVISION_KEY = PUS.SUBDIVISION_KEY#(lf)#(lf)    /* ---- Lawn care responsibility (subdivision -> lookup) ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.SUBDIVISIONS SUBD#(lf)        ON SUBD.ID = SUB.HBPM_SUBDIVISION_ID#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS GC#(lf)        ON GC.LOOKUPMASTERID = SUBD.LAWNCARERESPONSIBILITYID#(lf)#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O#(lf)        ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU#(lf)        ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)#(lf)    /* ---- RRQC (most recent pass log) ---- */#(lf)    LEFT JOIN (#(lf)        SELECT MAX(Id) AS RRQC_ID, HBID#(lf)        FROM PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS#(lf)        GROUP BY HBID#(lf)    ) RRQC_MOST_RECENT#(lf)        ON RRQC_MOST_RECENT.HBID = P.HBAM_PROPERTY_ID#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS RRQC#(lf)        ON RRQC.ID = RRQC_MOST_RECENT.RRQC_ID#(lf)#(lf)    /* ---- Bid & auction (purchase type) ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBAM_DBO.BIDANDAUCTIONS BA#(lf)        ON  BA.BIDID = HBAM.BidAndAuction_BidId#(lf)        AND BA.HBID = P.HBAM_PROPERTY_ID#(lf)#(lf)    /* ---- Current primary tenant lease (max lease per property) ----#(lf)       DIM_TENANT_CLEAN picks the latest LEASE_ID for each property among#(lf)       active primary tenants; TEN then re-pulls that tenant's full row. */#(lf)    LEFT JOIN (#(lf)        SELECT#(lf)             MAX(T.Lease_ID) AS LEASE_ID#(lf)            ,TLA.Property_key#(lf)        FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)            LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)                ON TLA.TENANT_KEY = T.Tenant_Key#(lf)            LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)                ON TI.TENANTINFORMATIONID = T.Tenant_Information_id#(lf)        WHERE 1 = 1#(lf)            AND PRIMARY_TENANT = 'Y'#(lf)            AND CURRENT_FLAG = 'Y'#(lf)            AND TI._FIVETRAN_DELETED = 'N'#(lf)            AND TENANT_STATUS <> 'Past'#(lf)            AND RENT_DUE_DAY IS NOT NULL#(lf)            AND TLA.FCT_TENANT_LEASING_ACCUM_KEY NOT IN (70474)#(lf)        GROUP BY TLA.Property_key#(lf)    ) DIM_TENANT_CLEAN#(lf)        ON DIM_TENANT_CLEAN.PROPERTY_KEY = P.PROPERTY_KEY#(lf)#(lf)    LEFT JOIN (#(lf)        SELECT T.*#(lf)        FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)            LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)                ON TI.TENANTINFORMATIONID = T.Tenant_Information_id#(lf)        WHERE TI.PRIMARYTENANT = 'Y'#(lf)    ) TEN#(lf)        ON  TEN.LEASE_ID = DIM_TENANT_CLEAN.LEASE_ID#(lf)        AND TEN.PRIMARY_TENANT = 'Y'#(lf)        AND TEN.CURRENT_FLAG = 'Y'#(lf)        AND TEN.RENT_DUE_DAY IS NOT NULL#(lf)#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)        ON  TLA.TENANT_KEY = TEN.TENANT_KEY#(lf)        AND TLA.FCT_TENANT_LEASING_ACCUM_KEY NOT IN (70474)#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER TU#(lf)        ON TU.USER_KEY = TLA.USER_KEY#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)        ON  TI.TenantInformationId = TEN.TENANT_INFORMATION_ID#(lf)        AND TI._FIVETRAN_DELETED <> 'Y'#(lf)    LEFT JOIN EVICTION_COUNT EC#(lf)        ON EC.TENANTINFORMATIONID = TI.TenantInformationId#(lf)#(lf)    /* ---- Most recent rental listing per property ---- */#(lf)    LEFT JOIN (#(lf)        SELECT MAX(RENT_LIST_HIST_ID) AS ID, PROPERTY_KEY#(lf)        FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST#(lf)        GROUP BY PROPERTY_KEY#(lf)    ) RENTALLISTINGENTRIES_MOST_RECENT#(lf)        ON RENTALLISTINGENTRIES_MOST_RECENT.PROPERTY_KEY = P.PROPERTY_KEY#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RL#(lf)        ON RL.RENT_LIST_HIST_ID = RENTALLISTINGENTRIES_MOST_RECENT.ID#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LISTING DL#(lf)        ON RL.LISTING_KEY = DL.LISTING_KEY#(lf)#(lf)    /* ---- PM lookup-master descriptions (TS = trustee status, ROM = reason#(lf)       off market) — both feed output columns. ---- */#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS TS#(lf)        ON TS.LookUpMasterId = PM_AI.TrusteeStatus#(lf)    LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS ROM#(lf)        ON ROM.LookUpMasterId = PM_AI.ReasonOffMarketId#(lf)#(lf)    /* ---- Occupancy status id (lookup by description) ---- */#(lf)    LEFT JOIN (#(lf)        SELECT LookUpMasterId AS OccupancyStatusID, Description#(lf)        FROM PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS#(lf)        WHERE TypeID = 6#(lf)    ) PM_OC#(lf)        ON PM_OC.Description = PUS.Occupancy_Status#(lf)#(lf)    /* ---- Notes ---- */#(lf)    LEFT JOIN CollectionsNote CN#(lf)        ON CN.PropertyID = P.HBPM_PROPERTY_ID#(lf)    LEFT JOIN MoveInNote MI_Note#(lf)        ON MI_Note.PropertyID = P.HBPM_PROPERTY_ID#(lf)#(lf)    /* ---- Underwriting rent / HubSpot / lease history ---- */#(lf)    LEFT JOIN UW_RENT#(lf)        ON UW_Rent.HBPM_UnitID = PM_AI.UnitID#(lf)    LEFT JOIN HUBSPOT#(lf)        ON HUBSPOT.PROPERTY_ENTITY_ID = P.EntityID#(lf)    LEFT JOIN LEASE_HIST#(lf)        ON LEASE_HIST.Property_key = P.Property_key#(lf)#(lf)WHERE 1 = 1#(lf)    AND (HBAM.PROPERTYSTATUSID > 9 OR HBAM.PROPERTYSTATUSID IS NULL)          -- out of bid#(lf)    AND P.PROPERTY_STATE = 'Active'#(lf)    AND P.EntityID <> ''#(lf)    AND (HBAM.PROPERTYSTATUSID NOT IN (53, 75) OR HBAM.PROPERTYSTATUSID IS NULL)#(lf)    AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54)#(lf)    AND PUS.Organization_KEY NOT IN (16, 17)#(lf)    AND PO.IS_Active_AM = 'Y'#(lf)    AND PO.Current_Flag = 'Y'#(lf)    AND P.Current_Flag = 'Y'#(lf)    AND PU.Current_Flag = 'Y'#(lf)    AND PUS.Occupancy_Status NOT IN ('Not Managed')#(lf)    AND (HBPM.PROPERTYSTATEID = 26 OR HBPM.PROPERTYSTATEID IS NULL)#(lf)    AND P.HBMM_Property_ID IS NOT NULL#(lf)    AND P.Property_Key NOT IN (166418, 57201, 23237, 166851, 229060)#(lf)    AND (TI._FIVETRAN_DELETED = 'N' OR TI._FIVETRAN_DELETED IS NULL)", null, [EnableFolding=true]),
				    #"Capitalized Each Word" = Table.TransformColumns(Source,{{"TEN_FULL_NAME", Text.Proper, type text}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Capitalized Each Word","Holly St Unit#","Holly St Unit #",Replacer.ReplaceText,{"FULL_ADDRESS", "ADDRESS", "ADDRESS_STREET_NAME"}),
				    #"Replaced Value1" = Table.ReplaceValue(#"Replaced Value","Ln Ln","Ln",Replacer.ReplaceText,{"FULL_ADDRESS", "ADDRESS","ADDRESS_STREET_NAME"}),
				    #"Capitalized Each Word1" = Table.TransformColumns(#"Replaced Value1",{{"TEN_FULL_NAME", Text.Proper, type text}, {"FLOORPLAN", Text.Proper, type text}}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Capitalized Each Word1",{{"POOLSERVICEREQUIRED", type logical}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

