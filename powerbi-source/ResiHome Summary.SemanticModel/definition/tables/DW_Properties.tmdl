table DW_Properties
	lineageTag: 8dd02d93-93ca-471f-a41b-db7d5f058cc3

	measure 0_Count = ```
			if(ISBLANK(CALCULATE(DISTINCTCOUNT(DW_Properties[PROPERTY_KEY]))),
			                0,
			                CALCULATE(DISTINCTCOUNT(DW_Properties[PROPERTY_KEY])))
			
			```
		formatString: #,0
		lineageTag: 69b44a69-b69a-4788-a763-a3fc70fe5bdd

		changedProperty = FormatString

		changedProperty = IsHidden

	measure '0_Rent Var' = ```
			IF([0_Count_Raw]=BLANK(),BLANK(),CALCULATE(DIVIDE(SUM(DW_Properties[CURRENT_RENT]), SUM(DW_Properties[UNDER_WRITTEN_RENT]), BLANK()),FILTER(DW_Properties,DW_Properties[CURRENT_RENT]<>BLANK()&&DW_Properties[UNDER_WRITTEN_RENT]<>blank())) - 1)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: bb7753e7-e967-475d-8838-ebdd34f96644

		changedProperty = FormatString

		changedProperty = IsHidden

	measure '0_Rent / Sqft' = ```
			DIVIDE(
			  CALCULATE(SUM(DW_Properties[CURRENT_RENT]), DW_Properties[CURRENT_RENT] <> BLANK(), DW_Properties[SQUARE_FOOTAGE] <> BLANK()),
			  CALCULATE(SUM(DW_Properties[SQUARE_FOOTAGE]), DW_Properties[CURRENT_RENT] <> BLANK(), DW_Properties[SQUARE_FOOTAGE] <> BLANK())
			)
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: b48f9638-2172-4048-be26-cf3841e8a21c

		changedProperty = FormatString

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 0_Count_Raw = CALCULATE(DISTINCTCOUNT(DW_Properties[PROPERTY_KEY]))
		formatString: 0
		lineageTag: 91fbbadf-40cb-4277-b0c4-659a7f491784

		changedProperty = IsHidden

	measure 0_Current_Occupancy = ```
			VAR occupied = CALCULATE(COUNTROWS(DW_Properties), DW_Properties[OCCUPANCY_STATUS_SUMMARYID] IN {7,8})
			VAR total    = CALCULATE(COUNTROWS(DW_Properties), NOT ISBLANK(DW_Properties[OCCUPANCY_STATUS_SUMMARYID]))
			RETURN DIVIDE(occupied, total)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 1486e605-eb33-4681-a90c-afdd591e61bb

		changedProperty = IsHidden

	measure 0_PPW_On_Schedule = ```
			CALCULATE(COUNTROWS(DW_Properties),DW_Properties[1_PPW_GC_Status]="On Schedule") / CALCULATE(COUNTROWS(DW_Properties),DW_Properties[1_PPW_GC_Status]<>BLANK())
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 001906ce-bfa1-43cc-9c17-ae0fa6d96c53

		changedProperty = IsHidden

