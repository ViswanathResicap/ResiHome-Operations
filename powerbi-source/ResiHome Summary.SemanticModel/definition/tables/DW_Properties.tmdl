			&  IF(ISBLANK(CALCULATE(MAX(DW_Tenant_Secondary[FULL_NAME]),FILTER(DW_Tenant_Secondary, DW_Tenant_Secondary[LEASE_ID]=DW_Properties[LEASE_ID]&&DW_Tenant_Secondary[PRIMARY_TENANT]="N"&&DW_Tenant_Secondary[TENANT_STATUS]<>"Past"&&DW_Tenant_Secondary[TENANT_SECONDAY_RANK]=4)))
			    ,"",
			    "; "&CALCULATE(MAX(DW_Tenant_Secondary[FULL_NAME]),FILTER(DW_Tenant_Secondary, DW_Tenant_Secondary[LEASE_ID]=DW_Properties[LEASE_ID]&&DW_Tenant_Secondary[PRIMARY_TENANT]="N"&&DW_Tenant_Secondary[TENANT_STATUS]<>"Past"&&DW_Tenant_Secondary[TENANT_SECONDAY_RANK]=4)))  
			
			&  IF(ISBLANK(CALCULATE(MAX(DW_Tenant_Secondary[FULL_NAME]),FILTER(DW_Tenant_Secondary, DW_Tenant_Secondary[LEASE_ID]=DW_Properties[LEASE_ID]&&DW_Tenant_Secondary[PRIMARY_TENANT]="N"&&DW_Tenant_Secondary[TENANT_STATUS]<>"Past"&&DW_Tenant_Secondary[TENANT_SECONDAY_RANK]=5)))
			    ,"",
