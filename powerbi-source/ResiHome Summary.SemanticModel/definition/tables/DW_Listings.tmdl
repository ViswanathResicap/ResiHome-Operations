table DW_Listings
	lineageTag: b97d5fea-c1ff-4902-b9bf-54d7ec0039f6

	measure 0_MoveIns = COUNT(DW_Listings[PROPERTY_KEY]) + 0
		formatString: 0
		lineageTag: 45133d63-01d5-4704-871c-d7f914bb11c7

	measure '0_% Listings w/ Leads' = ```
			CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY]),DW_Listings[1_Leads_L7]<>BLANK()) / CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY])) + 0
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 6f25652b-476b-4ddd-a126-eba3e53b378a

		changedProperty = FormatString

	measure '0_% Listings w/ Apps' = ```
			CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY]),DW_Listings[1_Applications_Open]<>BLANK()) / CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY])) +0
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: ecd019d5-0e2b-4400-b751-02f3e7502e4d

		changedProperty = FormatString

	measure '0_Rent Var (MI)' = ```
			CALCULATE(DIVIDE(SUM(DW_Listings[CURRENT_RENT]), SUM(DW_Listings[UNDER_WRITTEN_RENT]), BLANK()),FILTER(DW_Listings,DW_Listings[CURRENT_RENT]<>BLANK()&&DW_Listings[UNDER_WRITTEN_RENT]<>blank())) - 1
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: f7fe73aa-7b01-4fc6-9d3b-d7e82e2c789c

		changedProperty = FormatString

	measure '0_Rent Var (Lease)' = ```
			IF(sum(DW_Listings[LAST_LEASE_AMOUNT])=BLANK(),BLANK(), CALCULATE(DIVIDE(SUM(DW_Listings[CURRENT_LIST_PRICE]), SUM(DW_Listings[LAST_LEASE_AMOUNT]), BLANK()),FILTER(DW_Listings,DW_Listings[CURRENT_LIST_PRICE]<>BLANK()&&DW_Listings[LAST_LEASE_AMOUNT]<>blank()))-1)
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: cd666b58-456b-48e0-8a5b-eb4df968dbff

		changedProperty = FormatString

	measure '0_Listing Count' = ```
			COUNT(DW_Listings[PROPERTY_KEY]) 
			```
		formatString: #,0
		lineageTag: 00909b8b-bcde-4b3a-9b3e-da591862258e

		changedProperty = FormatString

	measure '0_Listing Var' = ```
			CALCULATE(DIVIDE(SUM(DW_Listings[CURRENT_LIST_PRICE]), SUM(DW_Listings[ASM_BLENDED_UW_RENT]), BLANK()),FILTER(DW_Listings,DW_Listings[CURRENT_LIST_PRICE]<>BLANK()&&DW_Listings[ASM_BLENDED_UW_RENT]<>BLANK())) -1
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c3b6a7e9-95b8-4e77-a1b4-8503d90cbc21

		changedProperty = FormatString

	measure '0_Listing Count (Card)' = DISTINCTCOUNT(DW_Listings[PROPERTY_KEY]) + 0
		formatString: #,0
		lineageTag: 5d122ab6-3370-4c96-9dba-a64a24febaae

		changedProperty = FormatString

	measure '0_% Listings w/ Showings' = CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY]),FILTER(DW_Listings,DW_Listings[1_Showings_L7]<>BLANK()||DW_Listings[LISTING_DOM]<=3)) / CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY])) + 0
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 95bf4a79-b707-40d4-a1fd-ec728bb40ed1

		changedProperty = FormatString

	measure '0_% Listings w/ Modifications' = ```
			CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY]),FILTER(DW_Listings,AND(DW_Listings[Days_Since_Reduction_Active]<=7,DW_Listings[Days_Since_Reduction_Active]<>BLANK())||AND(DW_Listings[Days_On_Market_Active]<=7,DW_Listings[Days_On_Market_Active]<>BLANK()))) / CALCULATE(DISTINCTCOUNT(DW_Listings[PROPERTY_KEY])) 
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: addd75a6-0347-4a2d-9387-3165421d2aa8

		changedProperty = FormatString

	measure 0_List/Sq = ```
			DIVIDE(SUM(DW_Listings[CURRENT_LIST_PRICE]), SUM(DW_Listings[SQUARE_FOOTAGE]), BLANK())
			
			```
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		lineageTag: 996b2d26-ecb1-4cbe-823f-bb15c693536f

	measure 0_Leads_per_DOM = ```
			DIVIDE(SUM(DW_Listings[1_Leads_L7_Created]), SUM(DW_Listings[Days_On_Market_Active_Last_Week]), BLANK())
			
			```
		lineageTag: 8d91f088-0faa-4d4d-86a2-270824b7d614

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '1_Concession %' = ```
			DIVIDE(SUM(DW_Listings[CONCESSIONAMOUNT]), SUM(DW_Listings[CURRENT_LIST_PRICE]), BLANK())
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 13814bb1-aa72-407e-9fda-c2fa9798b3db

	measure '0_Rent Var (RentCast)' = IF(SUM(DW_Listings[CURRENT_LIST_PRICE])<>BLANK()&&SUM(DW_Listings[1_Rent_Cast_Estimate])<>BLANK(),CALCULATE(SUM(DW_Listings[CURRENT_LIST_PRICE]) / sum(DW_Listings[1_Rent_Cast_Estimate]),FILTER(DW_Listings,DW_Listings[CURRENT_LIST_PRICE]<>BLANK()&&DW_Listings[1_Rent_Cast_Estimate]<>BLANK())) -1,BLANK())
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 78c0cf21-f50d-40e5-95b1-8836b7a70cf9

