	partition DW_Listings-cfa09832-2273-49d7-96c8-5f8649df663d = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Role="UAT", Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   LISTINGS DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per rental-listing-history record (anchor#(lf)            FCT_PROP_RENTAL_LISTING_HIST RLH), enriched with the matched active#(lf)            Deal, Tenant, price-change history, on-market notes, ASM/UW figures.#(lf)   CTE chain: UW_RENT_MAX/UW_RENT, OnMarketNote, LIST_CHANGE, HHI, DEALS,#(lf)            TENANT, ListDeal, LEASE_HIST -> final SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  The two ORGANIZATION_KEY / ORGANIZATION_NAME CASE blocks (in DEALS#(lf)             and in the final SELECT) were updated from the prior three-group#(lf)             form (adding only 58,59 -> 'Hudson Oak') to the full six-group#(lf)             roll-up that mirrors the master PROPERTY script (source of truth).#(lf)             DELIBERATE OUTPUT CHANGE limited to the organization columns.#(lf)     The TENANT CTE selects raw P.ORGANIZATION_KEY / O.ORGANIZATION_NAME (no#(lf)     CASE); those columns are NOT surfaced in the final SELECT, so they are left#(lf)     untouched. No CTEs or joins dropped; HHI is defined-but-unused in the#(lf)     original and preserved as-is.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output):#(lf)        added 66                  -> 27 / 'RB DRC'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH UW_RENT_MAX AS (#(lf)#(tab)SELECT #(lf)#(tab)MAx(RENTLOGID) RENTLOGID #(lf)#(tab), ENTITYID1#(lf)#(tab)FROM PROD_REPLICA.HBPM_DBO.RENTLOGS#(lf)#(tab)GROUP BY ENTITYID1) #(lf)#(tab)#(lf),UW_RENT AS (#(lf)#(tab)SELECT #(lf)#(tab) RentLogs.ENTITYID1 AS HBPM_UnitID#(lf)#(tab),RentLogs.ORIGINALVALUE AS UW_Rent_Prior#(lf)#(tab),RentLogs.UPDATEVALUE AS UW_Rent_Current#(lf)#(tab),RentLogs.OCCUREDON  AS UW_Update_Date#(lf)#(tab)FROM UW_RENT_MAX#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.RENTLOGS RentLogs ON RentLogs.RENTLOGID = UW_RENT_MAX.RentLogID#(lf)#(tab))#(lf)#(lf)--******************************************************************************************************************************************#(lf),OnMarketNote AS (#(lf)#(tab)#(tab)SELECT DISTINCT #(lf)#(tab) #(tab)N.NOTEID AS LatestNoteID#(lf)#(tab) #(tab),N.NOTETEXT AS OnMarketNote#(lf)#(tab) #(tab),N.CREATEDDATE  AS OnMarketNoteCreated#(lf)#(tab) #(tab),DATEDIFF('Day',N.CREATEDDATE,GETDATE()) OnMarketNote_Days#(lf)#(tab)    ,P.PropertyId#(lf)#(tab)    ,U.FIRSTNAME || ' ' || U.LASTNAME AS OnMarketNote_Added_By#(lf)#(tab)    ,RANK() OVER( PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)#(tab)#(lf)#(tab)#(tab)FROM PROD_REPLICA.HBPM_DBO.NOTES N #(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.NOTETYPES NT ON NT.Id = N.NoteTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.LookUpMasterId = N.ObjectTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P ON P.PropertyID = N.ObjectID AND P.""_FIVETRAN_DELETED"" ='N'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS U ON U.USERID  = N.ADDEDBY #(lf)#(tab) #(tab)WHERE N.NoteTypeId = 19#(lf)#(tab) --#(tab)AND PAI.PROPERTYID = 36301#(lf)#(tab) #(tab)QUALIFY Recent_Rank = 1)#(lf)--**************************************************************************************************#(lf),LIST_CHANGE AS ( #(lf)#(lf)SELECT #(lf)LP.PROPERTY_LISTING_ID#(lf),LP.LISTING_PRICE_CHANGE#(lf),RANK() OVER(PARTITION BY LP.PROPERTY_LISTING_ID ORDER BY LP.ETL_UPDATE_DATE DESC, LISTING_PRICE_CHANGE DESC ) RECENT_RANK#(lf),LP.INITIAL_LIST_PRICE#(lf),LP.CURRENT_LIST_PRICE AS N_LIST_PRICE#(lf),LP2.CURRENT_LIST_PRICE AS O_LIST_PRICE#(lf),LP.CURRENT_LIST_PRICE - LP2.CURRENT_LIST_PRICE AS PRICE_CHANGE#(lf),TO_DATE(CONVERT_TIMEZONE('EST',LP.ETL_UPDATE_DATE::date)) AS PRICE_CHANGE_DATE#(lf),LP.ETL_UPDATE_DATE #(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_LIST_STATUS_PRICE_HIST LP#(lf)LEFT JOIN (SELECT#(lf)            CURRENT_LIST_PRICE#(lf)           ,PROPERTY_LISTING_ID#(lf)#(tab)#(tab)   ,ROW_NUMBER() OVER(PARTITION BY PROPERTY_LISTING_ID ORDER BY CHANGED_DATE_TIME DESC) RECENT_SUB_RANK#(lf)#(tab)#(tab)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_LIST_STATUS_PRICE_HIST#(lf)#(tab)#(tab)WHERE INDEX_CHANGE_TYPE IN ('List Price', 'New')#(lf)#(tab)#(tab)QUALIFY RECENT_SUB_RANK = 2#(lf)#(tab)) LP2 ON LP2.PROPERTY_LISTING_ID = LP.PROPERTY_LISTING_ID#(lf)#(lf)WHERE#(lf)1=1#(lf)AND LP.INDEX_CHANGE_TYPE = 'List Price'#(lf)AND LP.LISTING_PRICE_CHANGE <> 0#(lf)--AND LP.PROPERTY_LISTING_ID = 6831744085#(lf)#(lf)QUALIFY RECENT_RANK = 1  )#(lf)--*****************************************************************************#(lf),HHI AS (Select #(lf)#(lf)D.Deal_ID #(lf),CASE WHEN sum(C_INC.Annual_Income) <30000 THEN NULL #(lf)#(tab)  WHEN  sum(C_INC.Annual_Income) > 1000000 THEN NULL #(lf)#(tab)  ELSE  sum(C_INC.Annual_Income) END AS HHI#(lf)#(lf)FROM PROD_REPLICA.HUBSPOT.DEAL D#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.DEAL_CONTACT DC ON DC.DEAL_ID = D.DEAL_ID#(lf)LEFT JOIN (SELECT#(lf)#(tab)#(tab)#(tab)#(tab)CONTACT_ID#(lf)#(tab)#(tab)#(tab)#(tab),COALESCE (#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'total_yearly_income' THEN value ELSE null END),#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'annual_salary' THEN value ELSE null END)) AS Annual_Income#(lf)#(tab)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.COntact_PROPERTY_HISTORY#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)WHERE 1=1 #(lf)#(tab)#(tab)#(tab)#(tab)AND NAME IN ('annual_salary','total_yearly_income')#(lf)#(tab)#(tab)#(tab)#(tab)GROUP BY CONTACT_ID ) C_INC ON C_INC.Contact_ID = DC.Contact_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)WHERE 1=1 #(lf)GROUP BY D.DEAL_ID)#(lf)#(lf)---***********************************************************************************************************************#(lf),DEALS AS (SELECT #(lf)#(lf)P.PROPERTY_KEY#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)      #(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf)#(tab)      #(lf),P.HBPM_PROPERTY_ID #(lf),P.EntityID#(lf),P.Address#(lf),PUS.Under_written_rent#(lf)#(lf),REC.RECEIEVABLE_ID#(lf),PO.PORTFOLIO_NAME#(lf),R.REGION_NAME#(lf)#(lf),D.SECURITY_DEPOSIT_ID#(lf),D.DEAL_KEY#(lf),D.DEAL_ID#(lf),COALESCE(D.CURRENT_DEAL_STATUS,HUB_DEAL.DEAL_STAGE) AS CURRENT_DEAL_STATUS#(lf),HUB_DEAL.APP_ID#(lf),HUB_DEAL.APP_STAGE AS APP_STAGE#(lf)#(lf),D.COMBINED_INCOME * 12  AS COMBINED_INCOME#(lf),DSH.LEAD_KEY#(lf),D.APPLICATION_SUBMITTED_DATE::date AS Application_Submit_Date#(lf),date_trunc('month',D.APPLICATION_SUBMITTED_DATE::date) as ""App Submit (BOM)""#(lf),CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE::date) AS Application_Started_Date#(lf),date_trunc('month',CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE )::date) as App_Started_BOM#(lf)#(lf),DATEDIFF(DAY, COALESCE(D.APPLICATION_SUBMITTED_DATE ,to_date(L.Application_SUBMIT_Date_KEY::TEXT,'yyyymmdd'),CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE::date),to_date(DSH.DEAL_CREATE_DATE_KEY::TEXT,'yyyymmdd')),GETDATE())  AS DAYS_SINCE_APP_SUBMIT#(lf)#(lf),L.First_Name ||  ' '  || L.Last_Name AS Lead_Name#(lf),L.First_Name#(lf),L.Last_Name#(lf),L.PRIMARY_LEAD_ID#(lf),D.EMail#(lf),L.PHONE#(lf),to_date(L.CREATED_DATE_KEY::TEXT,'yyyymmdd') AS Lead_Created_Date#(lf),DATE_TRUNC('month', to_date(L.CREATED_DATE_KEY::TEXT,'yyyymmdd') ) AS ""1_Lead (BOM)""#(lf)#(lf),to_date(DSH.DEAL_CREATE_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_CREATE_DATE#(lf),to_date(DSH.APPLICATION_APPROVED_DATE_KEY::TEXT,'yyyymmdd') AS APPLICATION_APPROVED_DATE#(lf),to_date(DSH.DEAL_WON_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_WON_DATE#(lf),COALESCE(HUB_DEAL.PROPERTY_HOLDING_FEE_TRANSACTION_DATE,to_date(PAY.HOLDING_FEE_DATE_NEW::TEXT,'yyyymmdd'),to_date(DSH.HOLDING_FEE_PAID_DATE_KEY::TEXT,'yyyymmdd')) AS HOLDING_FEE_DATE_NEW#(lf),to_date(DSH.LEASE_SIGNED_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_SIGNED_DATE#(lf),to_date(DSH.CONVERT_TO_RESIDENT_DATE_KEY::TEXT,'yyyymmdd') AS CONVERT_TO_RESIDENT_DATE#(lf),to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') AS EXPECTED_MOVE_IN_DATE#(lf),COALESCE(to_date(DSH.LEASE_START_DATE_KEY::TEXT,'yyyymmdd'),#(lf)#(tab)#(tab)  to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') ) AS LEASE_START_DATE#(lf),to_date(DSH.LEASE_END_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_END_DATE#(lf),U.USER_KEY#(lf),TLA.Tenant_key#(lf),COALESCE(to_date(TLA.INITIAL_LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd'),#(lf)#(tab)#(tab)  to_date(TLA.LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd') ) AS TENANT_MOV