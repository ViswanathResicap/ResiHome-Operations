),TI.CourtDateSetDate#(lf),TI.JudgementDate#(lf),TI.LockoutScheduledDate#(lf),TI.VacateDate#(lf),TI.AnticipatedMoveOutDate#(lf),TI.IsSection8#(lf),TI.IsMonthtoMonthLease#(lf),TI.TenantDecidedMonthtoMonth#(lf),TI.DoNotRenew#(lf),TI.ReasonForNotRenewingId#(lf),DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf),PUS.Under_written_rent#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TS ON TS.TENANT_KEY = T.TENANT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = T.TENANT_INFORMATION_ID#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS DNR on DNR.LookUpMasterId = TI.ReasonForNotRenewingId#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.DEALS PM_D ON PM_D.LEADUSERID = TI.USERID AND PM_D.UNITID =TI.UNITID AND PM_D.SECURITYDEPOSITID IS NOT null#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = TS.USER_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TS.PROPERTY_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L ON L.lead_key = TS.LEAD_KEY #(lf)#(lf)#(lf)LEFT JOIN DEALS ON Deals.User_key = TS.USER_KEY AND (Deals.Current_Deal_Status = 'Deal Won' OR Deals.Current_Deal_Status = 'Closed Won') AND Deals.PRoperty_key = P.Property_key AND Deals.SECURITY_DEPOSIT_ID IS NOT null#(lf)#(tab)#(tab)#(tab)#(lf)LEFT JOIN (SELECT C.ID, COUNT(PET.ID) PETS#(lf)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.PET #(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.PET_TO_CONTACT PTC ON PTC.FROM_ID = PET.ID#(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.CONTACT C ON C.ID = PTC.TO_ID #(lf)#(tab)#(tab)#(tab)GROUP BY C.ID) HUB_PETS ON HUB_PETS.ID = L.LEAD_ID#(lf)#(tab)#(lf)LEFT JOIN (SELECT #(lf)#(tab)#(tab)#(tab)FCT_TENANT_SUMMARY_KEY #(lf)#(tab)#(tab)#(tab),TENANT_INFORMATION_ID #(lf)#(tab)#(tab)#(tab),AVERAGE_CREDIT_SCORE#(lf)#(tab)#(tab)#(tab),COMBINED_INCOME#(lf)#(tab)#(tab)#(tab),NUMBER_OF_CHILDREN#(lf)#(tab)#(tab)#(tab),OCCUPANTS#(lf)#(tab)#(tab)#(tab),TENANT_AGE#(lf)#(tab)#(tab)#(tab),MONTHLY_INCOME#(lf)#(tab)#(tab)#(tab),IS_RETIRED#(lf)#(tab)#(tab)#(tab),IS_NOTICE#(lf)#(tab)#(tab)#(tab),IS_UNDER_EVICTION#(lf)#(tab)#(tab)#(tab)FROM PROD_ANALYTICS.RESICAP.FCT_TENANT_SUMMARY R_TS#(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_ANALYTICS.RESICAP.DIM_TENANT R_T ON R_T.TENANT_KEY = R_TS.TENANT_KEY ) RESI_TSUM ON RESI_TSUM.TENANT_INFORMATION_ID = T.TENANT_INFORMATION_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)WHERE 1=1#(lf)AND T.CURRENT_FLAG = 'Y'#(lf)AND T.PRIMARY_TENANT = 'Y'#(lf)#(lf)AND T.Tenant_Status <> 'Future'#(lf)AND P.PROPERTY_STATE ='Active'#(lf)AND P.EntityID <> ''#(lf)AND TI._FIVETRAN_DELETED <> 'Y'#(lf)--AND (PS.PROPERTY_STATUS_ID NOT IN (53,75) OR PS.PROPERTY_STATUS_ID IS NULL)#(lf)AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952,1867, 1916,1852,1771,1919,1873)#(lf)AND P.Organization_KEY not IN (16,17)#(lf)AND PO.IS_Active_AM = 'Y'#(lf)AND PO.Current_Flag = 'Y'#(lf)AND P.Current_Flag = 'Y'#(lf)AND PU.Current_Flag = 'Y'#(lf)AND PUS.Occupancy_Status NOT IN ('Property SOLD','Not Managed') #(lf)AND TI.RENTDUEDAY IS NOT NULL#(lf)AND T.TENANT_KEY NOT IN (70575,76191)--bad DATA#(lf)AND TLA.FCT_TENANT_LEASING_ACCUM_KEY NOT IN (25236)) --bad DATA )#(lf)--AND T.TENANT_KEY NOT  (76191,76190))#(lf)--SELECT * FROM Tenant#(lf)--**************************************************************************************            #(tab)        #(tab)#(lf),ListDeal AS (#(lf)#(lf)SELECT#(lf)#(lf)RLH.FCT_PRO_RENTAL_LISTING_HIST_KEY#(lf),MIN(Deals.Deal_ID) DEAL_ID#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH#(lf)LEFT JOIN Deals ON Deals.PROPERTY_KEY = RLH.PROPERTY_KEY #(lf)#(lf)#(lf)WHERE 1=1#(lf)AND RLH.LISTING_STATUS NOT IN ('Withdrawn', 'On Hold')#(lf)AND (Deals.Current_Deal_Status IN ('Pre-Lease Compliance','Lease Drafting','Lease Executed','Move-In Scheduled','Lease Signed (Working)','Lease Start Day','Post Move-In')#(lf)   OR Deals.APP_STAGE IN ('Pre-Lease Compliance','Lease Drafting','Lease Executed','Move-In Scheduled','Lease Signed (Working)','Lease Start Day','Post Move-In'))#(lf)AND Deals.Current_Deal_Status NOT IN ('Deal Lost', 'Rejected','Closed Lost','Property Listed')#(lf)#(lf)AND APP_STAGE IS NOT NULL#(lf)AND DEALS.LISTING_KEY = RLH.LISTING_KEY#(lf)--AND DEALS.REFUNDED_FLAG IS NULL#(lf)--AND LISTING_DATE_KEY >  20220101 #(lf)--AND RLH.PRoperty_Key = 68292880#(lf)--AND RENT_LIST_HIST_ID = 6831764523#(lf)#(lf)GROUP BY FCT_PRO_RENTAL_LISTING_HIST_KEY#(lf))#(lf)#(lf)     #(lf)/*SELECT * FROM ListDeal #(lf)WHERE#(lf)-- RLH.Property_Key =15602#(lf)FCT_PRO_RENTAL_LISTING_HIST_KEY = 19164#(lf)*/#(lf)#(lf)#(lf)#(lf)--**************************************************************************************#(lf),LEASE_HIST AS #(lf)(#(lf)SELECT DISTINCT#(lf)P.PROPERTY_KEY #(lf),to_date(TLA.LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_FROM_DATE#(lf),TLH.AMOUNT#(lf),RANK () OVER (PARTITION BY P.PROPERTY_KEY ORDER BY DATE_TRUNC('day',CREATED) DESC, TLH.LEASESTART DESC, TLA.LEASE_FROM_DATE_KEY DESC, TLH.AMOUNT ASC )  RANK_1#(lf)FROM PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES TLH#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = TLH.TenantInformationId#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T ON T.TENANT_INFORMATION_ID = TI.TenantInformationId AND T.Current_FLAG = 'Y'#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI ON PAI.UnitId = TI.UnitId AND PRIMARYTENANT = 'TRUE'#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM ON HBPM.PropertyId = PAI.PropertyId#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.HBPM_PROPERTY_ID = HBPM.PROPERTYID AND P.Current_FLAG = 'Y'#(lf)LEFT JOIN (SELECT Max(Id) RRQC_ID ,HBID FROM PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS GROUP BY HBID) RRQC_MOST_RECENT ON RRQC_MOST_RECENT.HBID = P.HBAM_PROPERTY_ID#(lf)LEFT JOIN PROD_REPLICA.HBAM_DBO.RRQCCHANGELOGS RRQC ON RRQC.ID = RRQC_MOST_RECENT.RRQC_ID#(lf)#(lf)WHERE 1=1#(lf)AND TLA.LEASE_FROM_DATE_KEY IS NOT NULL#(lf)AND T.Tenant_Status <> 'Future'#(lf)AND TLH.AMOUNT <> 0#(lf)AND TLH.AMOUNT >= 500#(lf)AND RRQC.RRQCPassDate IS NOT NULL #(lf)AND to_date(TLA.LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd') >= RRQC.RRQCPassDate#(lf)--AND P.PRoperty_key = 183910#(lf)QUALIFY RANK_1 = 1)#(lf)--**************************************************************************************#(lf)#(lf)SELECT DISTINCT #(lf)#(lf)RLH.FCT_PRO_RENTAL_LISTING_HIST_KEY#(lf)#(lf),RLH.PROPERTY_KEY#(lf),PU.PROPERTY_UNIT_KEY#(lf),P.EntityID#(lf),R.Region_Name#(lf),COALESCE(PM_AI.Bedrooms, PU.BEDROOMS) AS BEDROOMS#(lf),COALESCE(PM_AI.BATHROOMS, PU.BATHROOMS) AS BATHROOMS#(lf),PU.SQUARE_FOOTAGE#(lf),P.Year_Built#(lf),P.ADDRESS || ', ' || CI.CITY_NAME || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS Full_Address#(lf),P.ADDRESS#(lf),CI.CITY_NAME#(lf),S.STATE_NAME#(lf),S.STATE_CODE#(lf),P.ZIPCODE#(lf),CO.COUNTY_NAME#(lf),SUB.SUBDIVISION#(lf),P.FloorPlan#(lf),COALESCE(to_date(P.TRANSFER_DATE_KEY::TEXT,'yyyymmdd'),to_date(P.PURCHASE_DATE_KEY::TEXT,'yyyymmdd')) AS ""Transfer_Date""#(lf),AM_PM.MoveInReady#(lf),PM_AI.MOVEINREADY AS PM_MIR#(lf),DATE_TRUNC('month',COALESCE(PM_AI.MOVEINREADY,GETDATE())) AS PM_MIR_BOM#(lf)#(lf),MO.MoveOut#(lf)#(lf),CASE  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)   WHEN PUS.Occupancy_Status = 'Tenant Leased' #(lf)#(tab)   THEN NULL#(lf)#(tab)   WHEN RRQC.RRQCPassDate IS NULL THEN 0#(lf)#(tab)   ELSE DATEDIFF(DAY,GREATEST(#(lf)#(tab)#(tab)COALESCE(RRQC.RRQCPassDate,to_date(P.TRANSFER_DATE_KEY::TEXT,'yyyymmdd'),to_date(P.PURCHASE_DATE_KEY::TEXT,'yyyymmdd'))#(lf)#(tab)#(tab),COALESCE(MO.MoveOut,'1900-01-01')),#(lf)#(tab)#(tab)GETDATE()) END AS Days_Vacant#(tab)#(lf)#(tab)#(tab)#(lf),RLH.PORTFOLIO_KEY#(lf),PO.Portfolio_Name#(lf),PUS.Occupancy_Status#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)      #(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf)#(tab)      #(lf),TO_date(RLH.LISTING_DATE_KEY::TEXT,'YYYYMMDD') AS LISTING_DATE#(lf),TO_date(RLH.LISTING_END_DATE_KEY::TEXT,'YYYYMMDD') AS LISTING_END_DATE#(lf),CASE WHEN TO_date(RLH.LISTING_END_DATE_KEY::TEXT,'YYYYMMDD') >= LC.PRICE_CHANGE_DATE THEN NULL#(lf)      ELSE LC.PRICE_CHANGE_DATE END AS RENT_MODIFIED_DATE#(lf)      #(lf),COALESCE(HL.PROPERTY_LISTING_AGENT_FULL_NAME,RLH.LEASING_AGENT) AS LEASING_AGENT#(lf),COALESCE(HL.PROPERTY_LISTING_AGENT_EMAIL,RL_U.EmailAddress) AS AGENT_EMAIL#(lf),RLH.INITIAL_LIST_PRICE#(lf),RLH.CURRENT_LIST_PRICE#(lf)#(lf),RLH.CONCESSION_TYPE_ID AS CONCESSION_TYPE_ID#(lf),RLH.CONCESSION_TYPE AS CONCESSION_TYPE#(lf),CASE WHEN RLH.CONCESSION_TYPE_ID = 4471 THEN ROUND(RLH.CONCESSION_MONTHS_OFF,1) || ' ' || RLH.CONCESSION_TYPE#(lf)#(tab)  WHEN RLH.CONCESSION_TYPE_ID = 4470 THEN ROUND(RLH.CONCESSION_AMOUNT,0) || ' ' || RLH.CONCESSION_TYPE#(lf)#(tab)  ELSE RLH.CONCESSION_TYPE #(lf)#(tab)  END AS CONCESSION_TYPE_COMBINED#(lf),to_date(RLH.CONCESSION_END_DATE_KEY::text,'yyyymmdd') AS CONCESSIONENDDATE#(lf),RLH.CONCESSION_MONTHS_OFF AS CONCESSIONMONTHSOFF#(lf),RLH.CONCESSION_AMOUNT AS CONCESSIONAMOUNT#(lf)#(lf),RLH.LISTING_STATUS#(lf),RLH.RENT_LIST_HIST_ID#(lf),D.DEAL_KEY#(lf),D.CURRENT_DEAL_STATUS#(lf),D.APP_STAGE#(lf),D.DEAL_ID#(lf),COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE) AS LEASE_START_DATE#(lf),DATE_TRUNC('month',COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE)) AS LEASE_START_DATE_BOM#(lf),COALESCE(D.LEASE_END_DATE,Tenant.LEASE_TO_DATE) AS LEASE_END_DATE#(lf),COALESCE(D.LEASE_SIGNED_DATE,Tenant.LEASE_SIGNED_DATE) AS LEASE_SIGNED_DATE#(lf),D.LEAD_KEY#(lf),D.HOLDING_FEE_DATE_NEW#(lf),U.FULL_NAME #(lf),D.EMAIL AS LEAD_EMAIL#(lf),D.LEAD_NAME #(lf),D.PHONE AS LEAD_PHONE#(lf),D.First_Name#(lf),D.Last_Name#(lf),Tenant.TENANT_KEY#(lf),D.Deal_Owner#(lf),CASE WHEN D.IS_SECTION_8 = 1 THEN 'Yes' ELSE 'No' END AS Section_8#(lf),Tenant.CURRENT_RENT#(lf),PUS.Under_written_rent#(lf),D.APP_ID#(lf),D.URL_HUBSPOT#(lf)#(lf),CASE WHEN (PUS.Occupancy_Status <> 'Vacant - Future Move In' AND RLH.LISTING_STATUS <> 'Deposit Taken') THEN NULL#(lf)#(tab)  WHEN D.CURRENT_DEAL_STATUS IS NULL OR (D.CURRENT_DEAL_STATUS = 'Closed Lost' AND (D.APP_STAGE IS NULL OR D.APP_STAGE = 'Closed Lost')) THEN -2#(lf)#(tab)  WHEN COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE) < DAte(GETDATE()) AND COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE) IS NOT NULL AND D.CURRENT_DEAL_STATUS <> 'Closed Lost' THEN -1#(lf)#(tab)  WHEN D.LEASE_START_DATE IS NULL AND D.CURRENT_DEAL_STATUS = 'Closed Lost' THEN 1#(lf)#(tab)  ELSE 2#(lf)#(tab)  END AS ""Listings Format""#(lf)#(tab)  #(lf),CASE WHEN (PUS.Occupancy_Status <> 'Vacant - Future Move In' AND RLH.LISTING_STATUS <> 'Deposit Taken') THEN NULL#(lf)#(tab)  WHEN D.CURRENT_DEAL_STATUS IS NULL OR (D.CURRENT_DEAL_STATUS = 'Closed Lost' AND (D.APP_STAGE IS NULL OR D.APP_STAGE = 'Closed Lost')) THEN 'Deal Lost'#(lf)#(tab)  WHEN COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE) < DATE(GETDATE()) AND COALESCE (D.LEASE_START_DATE,Tenant.LEASE_FROM_DATE) IS NOT NULL AND D.CURRENT_DEAL_STATUS <> 'Closed Lost'  THEN 'Past Scheduled Move-In'#(lf)#(tab)  WHEN D.LEASE_START_DATE IS NULL AND D.CURRENT_DEAL_STATUS = 'Closed Lost' THEN 'Needs Move-In Date'#(lf)#(tab)  ELSE 'On Track'#(lf)#(tab)  END AS ""Listings Format_Name""#(lf)#(lf),CASE WHEN (PUS.Occupancy_Status <> 'Vacant - Future Move In' AND RLH.LISTING_STATUS <> 'Deposit Taken') THEN NULL#(lf)      WHEN D.HOLDING_FEE_DATE_NEW IS null THEN NULL#(lf)      ELSE DATEDIFF(DAY, D.HOLDING_FEE_DATE_NEW, GETDATE() )#(lf)      END AS ""Days Since HF""#(lf)      #(lf),CASE WHEN D.LEASE_START_DATE IS NULL THEN NULL#(lf)      WHEN D.HOLDING_FEE_DATE_NEW IS Null THEN NULL#(lf)      WHEN D.LEASE_START_DATE >= D.HOLDING_FEE_DATE_NEW THEN  DATEDIFF(DAY, D.HOLDING_FEE_DATE_NEW, D.LEASE_START_DATE)#(lf)      END AS ""Days HF-MI""#(lf)      #(lf) ,CASE WHEN D.LEASE_START_DATE IS NULL THEN NULL#(lf) #(tab)   WHEN TENANT.TENANT_KEY IS NULL THEN NULL #(lf) #(tab)   ELSE DATE_TRUNC('month',D.LEASE_START_DATE)#(lf) #(tab)   END AS ""Move-In (BOM)""#(lf) #(tab)#(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL#(lf)      ELSE DATE_TRUNC('month',TO_date(RLH.LISTING_DATE_KEY::TEXT, 'YYYYMMDD'))#(lf) #(tab)  END AS ""List (BOM)""#(lf) #(tab)  #(lf),CASE WHEN RANK() OVER (PARTITION BY RLH.PROPERTY_KEY #(lf)#(tab)#(tab)#(tab)  ORDER BY RLH.RENT_LIST_HIST_ID DESC) = 1 THEN 'Yes' ELSE 'No' END AS MOST_RECENT_LISTING#(lf)#(tab)  #(lf),CASE WHEN D.LEASE_START_DATE IS NOT NULL THEN DATEDIFF(DAY,GETDATE(), D.LEASE_START_DATE ) #(lf)#(tab)  ELSE NULL END AS ""Days_Until_MI""#(lf)#(lf),CASE WHEN RLH.LISTING_STATUS ='Active' THEN DATEDIFF('day',to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())  ELSE NULL END AS Listing_DOM#(lf)#(lf)#(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL #(lf)#(tab)  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)  ELSE DATEDIFF(DAY,to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())#(lf)#(tab)  END AS ""Days_On_Market_Active""#(lf)#(tab)  #(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL #(lf)#(tab)  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)  ELSE LEAST(7,DATEDIFF(DAY,to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())-1)#(lf)#(tab)  END AS ""Days_On_Market_Active_Last_Week""#(lf)#(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL #(lf)#(tab)  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)  ELSE #(lf)#(tab)  TO_VARCHAR(TRUNCATE (DATEDIFF(DAY,to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())/10 ) * 10) || ' - ' ||#(lf)#(tab)  TO_VARCHAR(TRUNCATE (DATEDIFF(DAY,to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())/10 ) * 10 + 10)#(lf)#(tab)  END AS ""Days_On_Market_Active_Bucket""#(lf)#(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL #(lf)#(tab)  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)  ELSE #(lf)#(tab)  TRUNCATE (DATEDIFF(DAY,to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd'),GETDATE())/10 ) * 10#(lf)#(tab)  END AS ""Days_On_Market_Active_Sort""#(lf)#(tab)  #(lf),CASE WHEN RLH.LISTING_DATE_KEY IS NULL THEN NULL#(lf)#(tab)  WHEN TO_date(RLH.LISTING_END_DATE_KEY::TEXT,'YYYYMMDD') >= LC.PRICE_CHANGE_DATE THEN NULL#(lf)#(tab)  WHEN RLH.LISTING_STATUS <> 'Active' THEN NULL#(lf)#(tab)  ELSE DATEDIFF(DAY,LC.PRICE_CHANGE_DATE,GETDATE())#(lf)#(tab)  END AS ""Days_Since_Reduction_Active""#(