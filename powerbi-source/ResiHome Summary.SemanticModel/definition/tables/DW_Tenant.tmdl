table DW_Tenant
	lineageTag: 4eec517c-80c3-4eff-9f02-8f0209e90a9b

	measure '0_% Delinquent' = ```
			CALCULATE([0_Distinct_Tenant_Count],DW_Tenant[1_Balance]>0) / IF(HASONEVALUE(SEL_LeaseType[Lease Type]), CALCULATE([0_Distinct_Tenant_Count],filter(ALLEXCEPT(DW_Properties,DW_Properties[ORGANIZATION_NAME],DW_Properties[PORTFOLIO_NAME],DW_Properties[REGION_NAME],DW_Properties[OCCUPANCY_STATUS],DW_Properties[FULL_ADDRESS]),DW_Properties[OCCUPANCY_STATUS_SUMMARY]=SELECTEDVALUE(SEL_LeaseType[Lease Type])),ALLEXCEPT(DW_Tenant,DW_Tenant[TENANT_STATUS])), CALCULATE([0_Distinct_Tenant_Count],ALLEXCEPT(DW_Properties,DW_Properties[ORGANIZATION_NAME],DW_Properties[PORTFOLIO_NAME],DW_Properties[REGION_NAME],DW_Properties[OCCUPANCY_STATUS],DW_Properties[FULL_ADDRESS]),ALLEXCEPT(DW_Tenant,DW_Tenant[TENANT_STATUS])))
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 30774175-3131-4e0f-81d2-6bdb4741878a

		changedProperty = FormatString

	measure 0_Distinct_Tenant_Count = CALCULATE(DISTINCTCOUNT(DW_Tenant[PROPERTY_KEY])) + 0
		formatString: #,0
		lineageTag: 5a42d422-9e03-4e0d-83ed-eb389392d76a

		changedProperty = FormatString

	measure '0_Rent Var (Ten)' = ```
			CALCULATE(DIVIDE(SUM(DW_Tenant[CURRENT_RENT]), SUM(DW_Tenant[UNDER_WRITTEN_RENT]), BLANK()),FILTER(DW_Tenant,DW_Tenant[CURRENT_RENT]<>BLANK()&&DW_Tenant[UNDER_WRITTEN_RENT]<>blank())) - 1
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 475c5ecc-2b6b-4c06-af20-210ad64a968d

		changedProperty = FormatString

	measure 0_Days_In_Home = IF([0_Count_Raw]=BLANK(),BLANK(), ROUNDDOWN(AVERAGE(DW_Tenant[DAYS_IN_HOME])/365,0)&"y "&rounddown((AVERAGE(DW_Tenant[DAYS_IN_HOME]) - (ROUNDDOWN(AVERAGE(DW_Tenant[DAYS_IN_HOME])/365,0) *365))/30,0)&"m")
		lineageTag: 49515cf7-e4ce-4912-85d8-90459a5c5cf8

	measure '0_% Delinquent (DIH)' = ```
			CALCULATE([0_Distinct_Tenant_Count],DW_Properties[1_Tenant Balance Status (Rent)]="Delinquent") / CALCULATE([0_Distinct_Tenant_Count])
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 750b96f5-e8eb-40db-852e-cbb654f76cb7

		changedProperty = FormatString

	measure '0_Dem_% Children' = ```
			CALCULATE(DIVIDE(SUM(DW_Tenant[DEM_HAS_CHILDREN]), DISTINCTCOUNT(DW_Tenant[TENANT_KEY]), BLANK()))
			
			```
		formatString: 0%;-0%;0%
		lineageTag: 579edccf-171a-4435-a61a-c8eecdc87b98

		changedProperty = FormatString

	measure '0_Dem_% Pets' = ```
			CALCULATE(DIVIDE(SUM(DW_Tenant[DEM_WITH_PETS]), DISTINCTCOUNT(DW_Tenant[TENANT_KEY]), BLANK()))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 70ed8d06-23c1-4605-af27-693d6181027f

		changedProperty = FormatString

	measure 0_MTM = CALCULATE(DISTINCTCOUNT(DW_Tenant[PROPERTY_KEY]),FILTER(DW_Tenant,DW_Tenant[TENANT_STATUS]<>"Past"&&OR(DW_Tenant[MONTH_TO_MONTH]="Y",DW_Tenant[CURRENT_LEASE_EXPIRATION_DATE]<>BLANK()&&DW_Tenant[CURRENT_LEASE_EXPIRATION_DATE]<TODAY())))
		formatString: 0
		lineageTag: 57ccc788-4526-44dc-9408-858a388dd335

	measure '0_Tenant Count FORMAT' = IF(max(DW_Tenant[MOVEIN_BOM])=DATE(YEAR(TODAY()),MONTH(TODAY()),1),BLANK(),COUNT(DW_Tenant[TENANT_KEY]))
		formatString: 0
		lineageTag: fcbd4e32-2cfd-4740-b442-58c375f81937

	measure 1_Concession_% = ```
			DIVIDE(SUM(DW_Tenant[1_Concession_Amount]), SUM(DW_Tenant[CURRENT_RENT]), BLANK())
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 624c4e8d-2966-409c-9d7c-a35750e8d726

