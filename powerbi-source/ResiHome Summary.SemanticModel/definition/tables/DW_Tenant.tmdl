	partition DW_Tenant-190a7fdf-4a99-4727-966d-07451878d3cc = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   TENANT (PRIMARY) DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:      One row per current PRIMARY tenant, enriched with property, lease,#(lf)               eviction, notes, move-in docs, HubSpot contact/deal, monthly-charge#(lf)               (MC) breakdown, secondary tenants (TS_1..TS_4), and the matched#(lf)               lease-up rental listing. Ends with a fixed eviction-fee import#(lf)               template.#(lf)   Anchor:     PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT (T), PRIMARY_TENANT = 'Y'#(lf)   Branches off the property foundation; shares its organization roll-up logic.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  ALL THREE organization CASE blocks (in MC_Temp, TENANT_SECONDARY,#(lf)             and TENANT) updated to mirror the master PROPERTY script (source of#(lf)             truth). They were stale in three different ways; TENANT_SECONDARY#(lf)             also labeled the -1 group 'Resicap SFR' — corrected to 'RP SFR' per#(lf)             confirmation. DELIBERATE OUTPUT CHANGE — see ""ORG SYNC IMPACT"".#(lf)     [FIX 1] DROPPED the HHI CTE — defined but never referenced downstream.#(lf)     [FIX 2] DROPPED dead NT / LM joins inside the three note CTEs.#(lf)     [FIX 3] REMOVED the dead commented-out AUTOPAYS join in TENANT (autopay now#(lf)             comes from FCT_TENANT_ACTIVITY).#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original tenant output):#(lf)     Surfaced org columns come from the TENANT CTE (via Tenant.*) and the#(lf)     MC_Temp->MC_Final chain (Organization_Key drives smart-lock logic).#(lf)     Rows for these orgs previously fell through to ELSE; after sync they roll up:#(lf)        54,45,55,53,56,57,66 -> 27 / 'RB DRC'#(lf)        58,59                -> 58 / 'Hudson Oak'#(lf)        62,63,64,65,68,69    -> 62 / 'Rocklyn Homes'#(lf)        61,70                -> 61 / 'ROI Property Group'#(lf)        67                   -> 67 / 'Newstar'#(lf)     (TENANT_SECONDARY's org columns are computed but NOT surfaced downstream, so#(lf)      its sync — including 'Resicap SFR'->'RP SFR' — does not change final output.)#(lf)#(lf)   KNOWN ISSUES (flagged, NOT changed — would alter output):#(lf)     - IMPORT_GL_ACCOUNT is written as 5530-0000, which SQL evaluates as#(lf)       arithmetic (5530 - 0000 = 5530). It was almost certainly meant to be the#(lf)       GL code string '5530-0000'. Preserved exactly to keep output identical;#(lf)       recommend fixing to '5530-0000' when ready (changes int 5530 -> string).#(lf)     - Venture_No in TENANT is shorter than the property script's (missing#(lf)       VIII/VII/VI/IV/V). The sync instruction covered ORG only, so Venture_No is#(lf)       left as-is. Flag if you want it synced too.#(lf)     - TENANT_SECONDARY computes many columns that are never consumed downstream#(lf)       (only name/email feed TS_1..TS_4). Left intact to avoid an output-shape#(lf)       change; candidate for a future projection trim.#(lf)   ============================================================================= */#(lf)#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   Note CTEs: latest note of each type per property, plus author.#(lf)   CollectionsNote = type 3, EvictionNote = type 2, MoveInNote = type 7.#(lf)   ----------------------------------------------------------------------------- */#(lf)WITH CollectionsNote AS (#(lf)    SELECT DISTINCT#(lf)         N.NOTEID                                   AS LatestNoteID#(lf)        ,N.NOTETEXT                                 AS CollectionNote#(lf)        ,N.CREATEDDATE                              AS CollectionNoteCreated#(lf)        ,DATEDIFF('Day', N.CREATEDDATE, GETDATE())  AS CollectionNote_Days#(lf)        ,P.PropertyId#(lf)        ,U.FIRSTNAME || ' ' || U.LASTNAME           AS CollectionNote_Added_By#(lf)        ,RANK() OVER (PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID = N.ObjectId AND N.ObjectTypeId = 502#(lf)            AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON PAI.UnitId = TI.UnitId AND PAI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON P.PropertyID = COALESCE(PAI.PropertyId, N.ObjectID) AND P.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS U#(lf)            ON U.USERID = N.ADDEDBY#(lf)    WHERE N.NoteTypeId = 3#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf),EvictionNote AS (#(lf)    SELECT DISTINCT#(lf)         N.NOTEID                                   AS LatestNoteID_EV#(lf)        ,N.NOTETEXT                                 AS EvictionNote#(lf)        ,N.CREATEDDATE                              AS EvictionNoteCreated#(lf)        ,DATEDIFF('Day', N.CREATEDDATE, GETDATE())  AS EvictionNote_Days#(lf)        ,P.PropertyId#(lf)        ,RANK() OVER (PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID = N.ObjectId AND N.ObjectTypeId = 502#(lf)            AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON PAI.UnitId = TI.UnitId AND PAI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON P.PropertyID = COALESCE(PAI.PropertyId, N.ObjectID) AND P.""_FIVETRAN_DELETED"" = 'N'#(lf)    WHERE N.NoteTypeId = 2#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf),MoveInNote AS (#(lf)    SELECT DISTINCT#(lf)         N.NOTEID        AS LatestNoteID_MI#(lf)        ,N.NOTETEXT      AS MI_Note#(lf)        ,N.CREATEDDATE   AS MI_NoteCreated#(lf)        ,P.PropertyId#(lf)        ,U.FIRSTNAME || ' ' || U.LASTNAME AS MINote_Added_By#(lf)        ,RANK() OVER (PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID = N.ObjectId AND N.ObjectTypeId = 502#(lf)            AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON PAI.UnitId = TI.UnitId AND PAI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON P.PropertyID = COALESCE(PAI.PropertyId, N.ObjectID) AND P.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS U#(lf)            ON U.USERID = N.ADDEDBY#(lf)    WHERE N.NoteTypeId = 7#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: EVICTIONS#(lf)   Most recent eviction per unit/tenant with lookup-master descriptions + DIQ.#(lf)   ----------------------------------------------------------------------------- */#(lf),EVICTIONS AS (#(lf)    SELECT#(lf)         UNITID#(lf)        ,ET.Description AS EVICTION_EVICTIONTYPE#(lf)        ,TENANTINFORMATIONID#(lf)        ,ID AS EVICTION_ID#(lf)        ,RANK() OVER (PARTITION BY UNITID, TENANTINFORMATIONID ORDER BY ID DESC) AS RECENT_RANK#(lf)        ,EVICTIONCOMPANY AS EVICTION_EVICTIONCOMPANY#(lf)        ,EVICTIONSOURCE  AS EVICTION_EVICTIONSOURCE#(lf)        ,DATESENTTOATTORNEY                      AS EVICTION_DATESENTTOATTORNEY#(lf)        ,COALESCE(DATEFILED, DATESENTTOATTORNEY) AS EVICTION_DATEFILED#(lf)        ,VENDORSCHEDULED                         AS EVICTION_VENDORSCHEDULED#(lf)        ,CASHFORKEYSAMOUNT                       AS EVICTION_CASHFORKEYSAMOUNT#(lf)        ,ESTIMATEDVACATEDATE                     AS EVICTION_ESTIMATEDVACATEDATE#(lf)        ,DATESCHEDULEDWITHVENDOR                 AS EVICTION_DATESCHEDULEDWITHVENDOR#(lf)        ,COURTDATESETDATE                        AS EVICTION_COURTDATESETDATE#(lf)        ,JUDGMENTDATE                            AS EVICTION_JUDGMENTDATE#(lf)        ,CASHFORKEYSCHEDULEDDATE                 AS EVICTION_CASHFORKEYSCHEDULEDDATE#(lf)        ,PENDINGLOCKOUTDATE                      AS EVICTION_PENDINGLOCKOUTDATE#(lf)        ,LOCKOUTSCHEDULEDDATE                    AS EVICTION_LOCKOUTSCHEDULEDDATE#(lf)        ,WRITREQUESTEDDATE                       AS EVICTION_WRITREQUESTEDDATE#(lf)        ,LASTEDITEDDATE                          AS EVICTION_LASTEDITEDDATE#(lf)        ,EVICTIONTERMINATEDDATE                  AS EVICTION_EVICTIONTERMINATEDDATE#(lf)        ,DEFENDANTAPPEALDATE                     AS EVICTION_DEFENDANTAPPEALDATE#(lf)        ,ANSWERFILEDDATE                         AS EVICTION_ANSWERFILEDDATE#(lf)        ,VACATEDATE                              AS EVICTION_VACATEDATE#(lf)        ,CASE#(lf)            WHEN ES.Description IN ('Filed with County', 'Sent to Attorney')#(lf)                THEN DATEDIFF('day', COALESCE(DATEFILED, DATESENTTOATTORNEY), GETDATE())#(lf)            WHEN ES.Description IN ('Court Date Set')   THEN DATEDIFF('day', COURTDATESETDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Judgement')        THEN DATEDIFF('day', JUDGMENTDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Writ of Possesion') THEN DATEDIFF('day', WRITREQUESTEDDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Pending Lockout')#(lf)                THEN DATEDIFF('day', COALESCE(LOCKOUTSCHEDULEDDATE, PENDINGLOCKOUTDATE), GETDATE())#(lf)            WHEN ES.Description IN ('Lockout Scheduled') THEN DATEDIFF('day', LOCKOUTSCHEDULEDDATE, GETDATE())#(lf)            WHEN ES.Description NOT IN ('Eviction Terminated', 'Vacated - Skipped', 'Vacated - Completed')#(lf)                THEN DATEDIFF('day', LASTEDITEDDATE, GETDATE())#(lf)            ELSE NULL#(lf)         END AS EVICTION_DIQ#(lf)        ,CFK.Description AS EVICTION_CASHFORKEYSTATUS#(lf)        ,OI.Description  AS EVICTION_OCCUPANTS_INTENSION#(lf)        ,VS.Description  AS EVICTION_VACATESOURCE#(lf)        ,ES.Description  AS EVICTION_EVICTIONSTATUS#(lf)        ,OT.Description  AS EVICTION_OCCUPANTTYPE#(lf)        ,EVICTIONNOTES   AS EVICTION_EVICTIONNOTES#(lf)        ,E.EVICTIONSTATUSID AS EVICTION_EVICTIONSTATUSID#(lf)    FROM PROD_REPLICA.HBPM_DBO.EVICTIONS E#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS CFK ON E.CASHFORKEYSTATUSID = CFK.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS ES  ON E.EVICTIONSTATUSID   = ES.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS OI  ON E.OCCUINTENSIONID    = OI.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS VS  ON E.VACATESOURCEID     = VS.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS OT  ON E.OCCUPANTTYPEID     = OT.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS ET  ON E.EVICTIONTYPEID     = ET.LOOKUPMASTERID#(lf)    WHERE TENANTINFORMATIONID IS NOT NULL#(lf)    QUALIFY RECENT_RANK = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: EVICTION_COUNT — evictions per tenant/unit in the trailing 12 months.#(lf)   ----------------------------------------------------------------------------- */#(lf),EVICTION_COUNT AS (#(lf)    SELECT#(lf)         UNITID#(lf)        ,TENANTINFORMATIONID#(lf)        ,COUNT(ID) AS EVICTION_COUNT#(lf)    FROM PROD_REPLICA.HBPM_DBO.EVICTIONS E#(lf)    WHERE TENANTINFORMATIONID IS NOT NULL#(lf)        AND CREATEDDATE >= DATEADD('YEAR', -1, GETDATE())#(lf)    GROUP BY UNITID, TENANTINFORMATIONID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: MoveInDocs — most recent move-in inspection document per tenant object.#(lf)   ----------------------------------------------------------------------------- */#(lf),MoveInDocs AS (#(lf)    SELECT#(lf)         DocumentID#(lf)        ,CreatedOn#(lf)        ,ObjectID#(lf)        ,DocumentName#(lf)        ,US.FirstName || ' ' || US.LastName AS UploadedBy#(lf)        ,RANK() OVER (PARTITION BY ObjectID ORDER BY CreatedOn DESC) AS Recent_Rank#(lf)    FROM PROD_REPLICA.HBPM_DBO.DOCUMENTMANAGERS DM#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.""USERS"" US ON US.USERID = DM.UPLOADEDBY#(lf)    WHERE 1 = 1#(lf)        AND DocumentTypeID = 8021       -- Inspection#(lf)        AND DocumentSubTypeID = 8038#(lf)        AND ObjectTypeID = 502#(lf)    QUALIFY Recent_Rank = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: HUB_CONTACT — latest HubSpot contact per HBPM tenant (owner + last call).#(lf)   ----------------------------------------------------------------------------- */#(lf),HUB_CONTACT AS (#(lf)    SELECT DISTINCT#(lf)         C.ID                AS CONTACT_ID#(lf)        ,C.PROPERTY_EMAIL    AS CONTACT_EMAIL#(lf)        ,CO.FIRST_NAME || ' ' || CO.LAST_NAME AS DEAL_OWNER#(lf)        ,C.PROPERTY_HBPM_TENANT_ID#(lf)        ,TO_VARCHAR(CONVERT_TIMEZONE('America/New_York', C.PROPERTY_LAST_CALL_DATE_TIMESTAMP),#(lf)                    'YYYY-MM-DD HH24:MI:SS') AS PROPERTY_LAST_CALL_DATE#(lf)        ,RANK() OVER (PARTITION BY C.PROPERTY_HBPM_TENANT_ID#(lf)                      ORDER BY C.PROPERTY_CREATEDATE DESC, PROPERTY_LAST_CALL_DATE DESC) AS RANK_1#(lf)    FROM PROD_REPLICA.HUBSPOT_2.CONTACT C#(lf)        LEFT JOIN PROD_REPLICA.HUBSPOT_2.CONTACT_PROPERTY_HISTORY CPH#(lf)            ON CPH.CONTACT_ID = C.ID AND CPH.NAME = 'hubspot_owner_id' AND CPH._FIVETRAN_ACTIVE = 'Y'#(lf)        LEFT JOIN PROD_REPLICA.HUBSPOT_2.OWNER CO#(lf)            ON CO.OWNER_ID = CPH.VALUE#(lf)    WHERE 1 = 1#(lf)        AND C._FIVETRAN_DELETED = 'FALSE'#(lf)        AND C.ID <> 15088601#(lf)        AND CPH.VALUE <> ''#(lf)    QUALIFY RANK_1 = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: HUB_NAME — latest deal-owner per contact full name (name-based fallback).#(lf)   ----------------------------------------------------------------------------- */#(lf),HUB_NAME AS (#(lf)    SELECT DISTINCT#(lf)         C.PROPERTY_FIRSTNAME || ' ' || C.PROPERTY_LASTNAME AS CONTACT_NAME#(lf)        ,CO.FIRST_NAME || ' ' || CO.LAST_NAME AS DEAL_OWNER#(lf)        ,RANK() OVER (PARTITION BY C.PROPERTY_FIRSTNAME || ' ' || C.PROPERTY_LASTNAME#(lf)                      ORDER BY C.PROPERTY_CREATEDATE DESC) AS RANK_1#(lf)    FROM PROD_REPLICA.HUBSPOT_2.CONTACT C#(lf)        LEFT JOIN PROD_REPLICA.HUBSPOT_2.CONTACT_PROPERTY_HISTORY CPH#(lf)            ON CPH.CONTACT_ID = C.ID AND CPH.NAME = 'hubspot_owner_id' AND CPH._FIVETRAN_ACTIVE = 'Y'#(lf)        LEFT JOIN PROD_REPLICA.HUBSPOT_2.OWNER CO#(lf)            ON CO.OWNER_ID = CPH.VALUE#(lf)    WHERE 1 = 1#(lf)        AND C._FIVETRAN_DELETED = 'FALSE'#(lf)        AND CPH.VALUE <> ''#(lf)    QUALIFY RANK_1 = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   Monthly-charge (MC) chain.#(lf)   MC_Temp pulls recurring debit charges per tenant/unit, remaps GL accounts,#(lf)   then MC_Revised filters to active leased tenants, MC_Community computes a#(lf)   per-subdivision max, MC_Final assigns a charge group, MC_GROUP pivots to#(lf)   per-tenant totals (rent / MTM / smart-lock / pet).#(lf)   ----------------------------------------------------------------------------- */#(lf),MC_Temp AS (#(lf)    SELECT#(lf)         TCH.TENANTCHARGEID#(lf)        ,P.Property_key#(lf)        ,P.EntityID#(lf)        ,P.Address#(lf)        ,T.Tenant_key#(lf)        ,T.Tenant_Status#(lf)        ,T.CURRENT_RENT#(lf)        ,CASE WHEN TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') < GETDATE()#(lf)              THEN 'Y' ELSE COALESCE(T.MONTH_TO_MONTH, 'N')#(lf)         END AS MONTH_TO_MONTH#(lf)        ,TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') AS LEASE_EXP#(lf)        ,T.Lease_ID#(lf)        ,R.REGION_NAME#(lf)#(lf)        -- [SYNC] organization roll-up — mirrors master PROPERTY script.#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)            ELSE P.ORGANIZATION_KEY#(lf)         END AS ORGANIZATION_KEY#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)            ELSE O.ORGANIZATION_NAME#(lf)         END AS ORGANIZATION_NAME#(lf)#(lf)        ,PUS.PORTFOLIO_KEY#(lf)        ,PO.PORTFOLIO_NAME#(lf)        ,P.Subdivision#(lf)        ,CASE#(lf)            WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased'#(lf)            WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)            ELSE PUS.Occupancy_Status#(lf)         END AS Occupancy_Status#(lf)        ,TCH.UNITID#(lf)        ,TCH.TENANTINFORMATIONID#(lf)        ,TCH.GLACCOUNTID AS GLAccountID#(lf)        ,GL.Accountnumber AS GLAccountNO#(lf)        ,GL.Description AS GLDescription#(lf)        ,CASE#(lf)            WHEN TCH.GLAccountID IN (12, 82)  THEN 12#(lf)            WHEN TCH.GLAccountID IN (395, 403) THEN 395#(lf)            WHEN TCH.GLAccountID IN (83, 378)  THEN 378#(lf)            WHEN TCH.GLAccountID IN (408, 379) THEN 379#(lf)            WHEN TCH.GLAccountID IN (316) AND Amount = 4 THEN 410#(lf)            ELSE TCH.GLAccountID#(lf)         END AS Revised_GLAccountID#(lf)        ,TCH.ISDEBIT#(lf)        ,TCH.CHARGEDESCRIPTION#(lf)        ,TCH.ISMOVEOUTSPECIFIC#(lf)        ,TCH.ONETIMECHARGES#(lf)        ,TCH.AMOUNT#(lf)        ,TCH.LASTBILLEDON#(lf)        ,TCH.STARTDATE#(lf)        ,TCH.ENDDATE#(lf)    FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES PM_P#(lf)            ON PM_P.PROPERTYID = P.HBPM_PROPERTY_ID AND PM_P.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_PA#(lf)            ON PM_PA.PROPERTYID = PM_P.PROPERTYID AND PM_PA.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS#(lf)            ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU#(lf)            ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO#(lf)            ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R#(lf)            ON R.REGION_KEY = PUS.REGION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O#(lf)            ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTCHARGEHISTORIES TCH#(lf)            ON TCH.UNITID = PM_PA.UnitID AND TCH._FIVETRAN_DELETED = 'N'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.GLACCOUNTS GL#(lf)            ON GL.GLACCOUNTID = TCH.GLACCOUNTID#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)            ON T.Tenant_Information_ID = TCH.TENANTINFORMATIONID AND T.CURRENT_FLAG = 'Y'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)            ON TLA.TENANT_KEY = T.Tenant_Key#(lf)    WHERE 1 = 1#(lf)        AND ONETIMECHARGES = 0#(lf)        AND ISDEBIT = 'Y'#(lf)        AND (ISMOVEOUTSPECIFIC = 'N' OR ISMOVEOUTSPECIFIC IS NULL)#(lf)        AND TCH.CHARGEDESCRIPTION NOT LIKE '%Prorate%'#(lf)        AND TCH._FIVETRAN_DELETED = 'N'#(lf)        AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54)#(lf)        AND PUS.Organization_KEY NOT IN (16, 17)#(lf)        AND PO.IS_Active_AM = 'Y'#(lf)        AND PO.Current_Flag = 'Y'#(lf)        AND P.Current_Flag = 'Y'#(lf)        AND PU.Current_Flag = 'Y'#(lf)        AND PUS.Occupancy_Status NOT IN ('Not Managed', 'Property SOLD')#(lf))#(lf)#(lf),MC_Revised AS (#(lf)    SELECT#(lf)         MC_Temp.*#(lf)        ,GL.Accountnumber AS Revised_GLAccountNO#(lf)        ,GL.Description   AS Revised_GLDescripton#(lf)    FROM MC_Temp#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.GLACCOUNTS GL#(lf)            ON GL.GLACCOUNTID = MC_Temp.Revised_GLAccountID#(lf)    WHERE 1 = 1#(lf)        AND Occupancy_Status IN ('Tenant Leased', 'Trustee Leased')#(lf)        AND (Tenant_Status <> 'Past' OR Tenant_Status IS NULL)#(lf))#(lf)#(lf),MC_Community AS (#(lf)    SELECT#(lf)         MC_Revised.Subdivision#(lf)        ,MC_Revised.Revised_GLAccountID#(lf)        ,MAX(AMOUNT) AS Max_Communtiy_GL_Charge#(lf)    FROM MC_Revised#(lf)    WHERE MC_Revised.Subdivision IS NOT NULL#(lf)        AND Revised_GLAccountID IN (395, 379, 410, 420)#(lf)    GROUP BY#(lf)         MC_Revised.Subdivision#(lf)        ,MC_Revised.Revised_GLAccountID#(lf))#(lf)#(lf),MC_Final AS (#(lf)    SELECT#(lf)         MCR.*#(lf)        ,CASE WHEN Organization_Key = 1 AND MCR.Revised_GLAccountID = 410 THEN 4#(lf)              ELSE Max_Communtiy_GL_Charge#(lf)         END AS Max_Communtiy_GL_Charge#(lf)        ,CASE#(lf)            WHEN GLACCOUNTID IN (12, 82) THEN 'Rent'#(lf)            WHEN GLACCOUNTID IN (83, 378) THEN 'Pet'#(lf)            WHEN GLACCOUNTID IN (68) THEN 'MTM'#(lf)            WHEN GLACCOUNTID IN (410, 316) AND AMOUNT = 4 THEN 'Smart Lock'#(lf)            ELSE NULL#(lf)         END AS CHARGE_GROUP#(lf)    FROM MC_Revised MCR#(lf)        LEFT JOIN MC_Community MCC#(lf)            ON MCC.Subdivision = MCR.Subdivision AND MCC.Revised_GLAccountID = MCR.Revised_GLAccountID#(lf))#(lf)#(lf),MC_GROUP AS (#(lf)    SELECT#(lf)         TENANT_KEY#(lf)        ,SUM(CASE WHEN CHARGE_GROUP = 'Rent'       THEN AMOUNT ELSE NULL END) AS MC_Rent#(lf)        ,SUM(CASE WHEN CHARGE_GROUP = 'MTM'        THEN AMOUNT ELSE NULL END) AS MC_MTM#(lf)        ,SUM(CASE WHEN CHARGE_GROUP = 'Smart Lock' THEN AMOUNT ELSE NULL END) AS MC_Smart_Lock#(lf)        ,SUM(CASE WHEN CHARGE_GROUP = 'Pet'        THEN AMOUNT ELSE NULL END) AS MC_Pet#(lf)    FROM MC_FINAL#(lf)    GROUP BY TENANT_KEY#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: TENANT_SECONDARY#(lf)   Non-primary tenants (PRIMARY_TENANT = 'N'), ranked within each lease so the#(lf)   final query can pull up to four secondary tenants (TS_1..TS_4).#(lf)   NOTE: only name/email columns are consumed downstream; the rest are computed#(lf)   but unused (see header ""KNOWN ISSUES"").#(lf)   ----------------------------------------------------------------------------- */#(lf),TENANT_SECONDARY AS (#(lf)    SELECT#(lf)         T.TENANT_KEY#(lf)        ,RANK() OVER (PARTITION BY T.LEASE_ID ORDER BY T.TENANT_KEY) AS TENANT_SECONDAY_RANK#(lf)        ,T.TENANT_INFORMATION_ID#(lf)        ,TS.USER_KEY#(lf)        ,T.LEASE_ID#(lf)        ,RANK() OVER (PARTITION BY TS.Property_KEY ORDER BY Lease_ID ASC) AS Lease_Rank#(lf)        ,PU.PROPERTY_UNIT_KEY#(lf)        ,TS.Property_KEY#(lf)        ,P.HBPM_PROPERTY_ID#(lf)        ,PO.Portfolio_Name#(lf)        ,R.REGION_NAME#(lf)#(lf)        -- [SYNC] organization roll-up — mirrors master PROPERTY script#(lf)        -- (was -1-only with label 'Resicap SFR'; corrected to 'RP SFR').#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)            ELSE P.ORGANIZATION_KEY#(lf)         END AS ORGANIZATION_KEY#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)            ELSE O.ORGANIZATION_NAME#(lf)         END AS ORGANIZATION_NAME#(lf)#(lf)        ,P.Address#(lf)        ,P.EntityID#(lf)        ,CI.CITY_NAME#(lf)        ,CASE#(lf)            WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased'#(lf)            WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)            ELSE PUS.Occupancy_Status#(lf)         END AS Occupancy_Status#(lf)        ,U.FIRST_NAME#(lf)        ,U.LAST_NAME#(lf)        ,U.FULL_NAME#(lf)        ,U.USER_STATUS#(lf)        ,U.EMAIL_ADDRESS#(lf)        ,U.PHONE_NUMBER#(lf)        ,T.TENANT_STATUS#(lf)        ,T.TENANT_TYPE#(lf)        ,T.PRIMARY_TENANT#(lf)        ,T.EVICTION_STATUS#(lf)        ,T.VEHICLES#(lf)        ,T.PETS#(lf)        ,CASE WHEN T.PETS = 'Y' THEN COALESCE(HUB_PETS.PETS, 1) ELSE COALESCE(HUB_PETS.PETS, 0) END AS ""PETS_AMOUNT""#(lf)        ,CASE WHEN TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') < GETDATE()#(lf)              THEN 'Y' ELSE COALESCE(T.MONTH_TO_MONTH, 'N')#(lf)         END AS MONTH_TO_MONTH#(lf)        ,T.LEASE_TERM#(lf)        ,TO_DATE(T.NOTICE_DATE_KEY::TEXT, 'yyyymmdd') AS NOTICE_DATE#(lf)        ,TLA.INITIAL_RENT_AMOUNT#(lf)        ,T.CURRENT_RENT#(lf)        ,TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') AS CURRENT_LEASE_EXPIRATION_DATE#(lf)        ,TO_DATE(TLA.LEASE_SIGNED_DATE_KEY::TEXT, 'yyyymmdd') AS LEASE_SIGNED_DATE#(lf)        ,TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT,   'yyyymmdd') AS LEASE_FROM_DATE#(lf)        ,TO_DATE(TLA.LEASE_TO_DATE_KEY::TEXT,     'yyyymmdd') AS LEASE_TO_DATE#(lf)        ,TO_DATE(T.DOB_DATE_KEY::TEXT, 'yyyymmdd') AS DOB#(lf)        ,CASE WHEN RESI_TSUM.NUMBER_OF_CHILDREN > 0 THEN 1 ELSE 0 END AS Dem_Has_Children#(lf)        ,CASE WHEN HUB_PETS.PETS > 0 OR T.PEts = 'Y' THEN 1 ELSE 0 END AS Dem_With_Pets#(lf)        ,COALESCE(RESI_TSUM.NUMBER_OF_CHILDREN, 0) AS NUMBER_OF_CHILDREN#(lf)        ,COALESCE(RESI_TSUM.OCCUPANTS, 1) AS OCCUPANTS#(lf)        ,RESI_TSUM.TENANT_AGE#(lf)        ,RESI_TSUM.MONTHLY_INCOME#(lf)        ,RESI_TSUM.IS_RETIRED#(lf)        ,RESI_TSUM.IS_NOTICE#(lf)        ,RESI_TSUM.IS_UNDER_EVICTION#(lf)        ,TI.EVICTIONCOMPANY#(lf)        ,TI.MoveIn#(lf)        ,DATE_TRUNC('month', TI.MoveIn) AS MOVEIN_BOM#(lf)        ,TI.MoveOut#(lf)        ,CASE WHEN TI.MoveOut IS NOT NULL THEN 1 ELSE 0 END AS MOVE_OUT_INDICATOR#(lf)        ,GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0) AS Days_In_Home#(lf)        ,CASE WHEN GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0) <= 5#(lf)                   AND T.TENANT_STATUS = 'Past'#(lf)              THEN 1 ELSE 0#(lf)         END AS EXCLUDE_FILTER#(lf)        ,TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) || 'y '#(lf)            || LEAST(TRUNC((GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)#(lf)                - (TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) * 365))/30), 11) || 'm' AS DAY_IN_HOME_LABEL#(lf)        ,TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) || '.'#(lf)            || LEAST(TRUNC((GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)#(lf)                - (TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) * 365))/30), 11)/12 AS DAY_IN_HOME_LABEL_SORT#(lf)        ,TI.EVICTIONSTATUSID AS Eviction_Status_ID#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.PurchaseLetterPostedDate END AS PurchaseLetterPostedDate#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.DateNotified END AS DateNotified#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.FiledWithCountyDate END AS FiledWithCountyDate#(lf)        ,CASE WHEN TI.FiledWithCountyDate IS NOT NULL AND TI.EVICTIONSTATUSID <> 409 THEN 'Filed on' ELSE 'Not Filed On' END AS Filed_With_County_Status#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.ResidentServedDate END AS ResidentServedDate#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.CourtDateSetDate END AS CourtDateSetDate#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.JudgementDate END AS JudgementDate#(lf)        ,CASE WHEN TI.EVICTIONSTATUSID = 409 THEN NULL ELSE TI.LockoutScheduledDate END AS LockoutScheduledDate#(lf)        ,TI.VacateDate#(lf)        ,TI.AnticipatedMoveOutDate#(lf)        ,TI.IsSection8#(lf)        ,TI.IsMonthtoMonthLease#(lf)        ,TI.TenantDecidedMonthtoMonth#(lf)        ,TI.DoNotRenew#(lf)        ,TI.ReasonForNotRenewingId#(lf)        ,CASE WHEN TI.MoveOut IS NULL THEN NULL WHEN TI.MoveOutComplte = 'Y' THEN 'Yes' ELSE 'No' END AS MoveOutComplete#(lf)        ,DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf)        ,PUS.Under_written_rent#(lf)        ,AM_PM.MoveInReady#(lf)        ,COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')) AS Move_Out_Forecast#(lf)        ,CASE#(lf)            WHEN TI.MoveOut IS NOT NULL AND TI.MoveOutComplte = 'N' THEN 1#(lf)            WHEN TI.MoveOut IS NULL AND T.MONTH_TO_MONTH = 'N'#(lf)                 AND COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')) < GETDATE() THEN 1#(lf)            WHEN DATEDIFF(DAY, COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')), GETDATE()) BETWEEN -30 AND 0 THEN 1#(lf)            ELSE 0#(lf)         END AS Move_Out_Forecast_Filter#(lf)        ,CASE#(lf)            WHEN TI.MoveOut IS NULL AND T.MONTH_TO_MONTH = 'N'#(lf)                 AND DATEDIFF(DAY, COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')), GETDATE()) > 1 THEN 1#(lf)            ELSE 0#(lf)         END AS Past_Move_Out#(lf)        ,AUTO.DAYOFWITHDRAW   AS AUTOPAY_DAYOFWITHDRAW#(lf)        ,AUTO.NEXTWITHDRAWDATE AS AUTOPAY_NEXTWITHDRAWDATE#(lf)        ,AUTO.PAYMENTTYPE     AS AUTOPAY_PAYMENTTYPE#(lf)        ,'https://honeybadgerpm.com/ReportingModule/ViewReport?reportId=1807&UnitId=' || TI.UnitID || '&UserId=' || TI.UserID || '#/' AS URL_SODA#(lf)    FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TS ON TS.TENANT_KEY = T.TENANT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = T.TENANT_INFORMATION_ID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS DNR ON DNR.LookUpMasterId = TI.ReasonForNotRenewingId#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.DEALS PM_D#(lf)            ON PM_D.LEADUSERID = TI.USERID AND PM_D.UNITID = TI.UNITID AND PM_D.SECURITYDEPOSITID IS NOT NULL#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = TS.USER_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TS.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_CITY CI ON CI.CITY_KEY = PUS.CITY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L ON L.lead_key = TS.LEAD_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTYMANAGEMENTS AM_PM#(lf)            ON AM_PM.PROPERTYMANAGEMENTID = HBAM.PropertyManagement_PropertyManagementId AND AM_PM.HBID = HBAM.HBID#(lf)        LEFT JOIN (#(lf)            SELECT C.ID, COUNT(PET.ID) AS PETS#(lf)            FROM PROD_REPLICA.HUBSPOT.PET#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT.PET_TO_CONTACT PTC ON PTC.FROM_ID = PET.ID#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT.CONTACT C ON C.ID = PTC.TO_ID#(lf)            GROUP BY C.ID#(lf)        ) HUB_PETS ON HUB_PETS.ID = L.LEAD_ID#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                 FCT_TENANT_SUMMARY_KEY#(lf)                ,TENANT_INFORMATION_ID#(lf)                ,AVERAGE_CREDIT_SCORE#(lf)                ,R_TS.COMBINED_INCOME#(lf)                ,NUMBER_OF_CHILDREN#(lf)                ,OCCUPANTS#(lf)                ,TENANT_AGE#(lf)                ,MONTHLY_INCOME#(lf)                ,IS_RETIRED#(lf)                ,IS_NOTICE#(lf)                ,IS_UNDER_EVICTION#(lf)            FROM PROD_ANALYTICS.RESICAP.FCT_TENANT_SUMMARY R_TS#(lf)                LEFT JOIN PROD_ANALYTICS.RESICAP.DIM_TENANT R_T ON R_T.TENANT_KEY = R_TS.TENANT_KEY#(lf)        ) RESI_TSUM ON RESI_TSUM.TENANT_INFORMATION_ID = T.TENANT_INFORMATION_ID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.AUTOPAYS AUTO#(lf)            ON AUTO.TENANTINFORMATIONID = T.TENANT_INFORMATION_ID AND AUTO.ISACTIVE = 'Y'#(lf)    WHERE 1 = 1#(lf)        AND T.CURRENT_FLAG = 'Y'#(lf)        AND T.PRIMARY_TENANT = 'N'#(lf)        AND P.PROPERTY_STATE = 'Active'#(lf)        AND P.EntityID <> ''#(lf)        AND TI._FIVETRAN_DELETED <> 'Y'#(lf)        AND TI.RENTDUEDAY IS NOT NULL#(lf)        AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952, 1867, 1916, 1852, 1771, 1919, 1873, 169)#(lf)        AND P.Organization_KEY NOT IN (16, 17)#(lf)        AND PO.IS_Active_AM = 'Y'#(lf)        AND PO.Current_Flag = 'Y'#(lf)        AND P.Current_Flag = 'Y'#(lf)        AND PU.Current_Flag = 'Y'#(lf)        AND PUS.Occupancy_Status NOT IN ('Property SOLD', 'Not Managed')#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: TENANT#(lf)   The core PRIMARY-tenant row, with HubSpot deal/application context via the#(lf)   embedded HUB_DEAL replica block (deal + application FULL JOIN, ranked to one#(lf)   row per deal), notes, move-in docs, evictions, and a fixed eviction-fee import#(lf)   template.#(lf)   ----------------------------------------------------------------------------- */#(lf),TENANT AS (#(lf)    SELECT#(lf)         T.TENANT_KEY#(lf)        ,T.TENANT_INFORMATION_ID#(lf)        ,TS.USER_KEY#(lf)        ,T.LEASE_ID#(lf)        ,RANK() OVER (PARTITION BY TS.Property_KEY ORDER BY Lease_ID ASC) AS Lease_Rank#(lf)        ,PU.PROPERTY_UNIT_KEY#(lf)        ,TS.Property_KEY#(lf)        ,P.HBPM_PROPERTY_ID#(lf)        ,PO.Portfolio_Name#(lf)        ,R.REGION_NAME#(lf)#(lf)        -- [SYNC] organization roll-up — mirrors master PROPERTY script.#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)            ELSE P.ORGANIZATION_KEY#(lf)         END AS ORGANIZATION_KEY#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)            ELSE O.ORGANIZATION_NAME#(lf)         END AS ORGANIZATION_NAME#(lf)#(lf)        ,P.Address#(lf)        ,P.EntityID#(lf)        ,CI.CITY_NAME#(lf)        ,CASE#(lf)            WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased'#(lf)            WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)            ELSE PUS.Occupancy_Status#(lf)         END AS Occupancy_Status#(lf)        ,U.FIRST_NAME#(lf)        ,U.LAST_NAME#(lf)        ,U.FULL_NAME#(lf)        ,U.USER_STATUS#(lf)        ,U.EMAIL_ADDRESS#(lf)        ,U.PHONE_NUMBER#(lf)        ,T.TENANT_STATUS#(lf)        ,T.TENANT_TYPE#(lf)        ,T.PRIMARY_TENANT#(lf)#(lf)        -- ---- Eviction detail (from EVICTIONS via alias E) ----#(lf)        ,E.EVICTION_EVICTIONCOMPANY#(lf)        ,E.EVICTION_EVICTIONSOURCE#(lf)        ,E.EVICTION_DATESENTTOATTORNEY#(lf)        ,E.EVICTION_DATEFILED#(lf)        ,E.EVICTION_VENDORSCHEDULED#(lf)        ,E.EVICTION_CASHFORKEYSAMOUNT#(lf)        ,E.EVICTION_ESTIMATEDVACATEDATE#(lf)        ,E.EVICTION_DATESCHEDULEDWITHVENDOR#(lf)        ,E.EVICTION_COURTDATESETDATE#(lf)        ,E.EVICTION_JUDGMENTDATE#(lf)        ,E.EVICTION_CASHFORKEYSCHEDULEDDATE#(lf)        ,E.EVICTION_PENDINGLOCKOUTDATE#(lf)        ,E.EVICTION_LOCKOUTSCHEDULEDDATE#(lf)        ,E.EVICTION_WRITREQUESTEDDATE#(lf)        ,E.EVICTION_LASTEDITEDDATE#(lf)        ,E.EVICTION_EVICTIONTERMINATEDDATE#(lf)        ,E.EVICTION_DEFENDANTAPPEALDATE#(lf)        ,E.EVICTION_ANSWERFILEDDATE#(lf)        ,E.EVICTION_VACATEDATE#(lf)        ,E.EVICTION_CASHFORKEYSTATUS#(lf)        ,E.EVICTION_OCCUPANTS_INTENSION#(lf)        ,E.EVICTION_VACATESOURCE#(lf)        ,E.EVICTION_EVICTIONSTATUS#(lf)        ,E.EVICTION_OCCUPANTTYPE#(lf)        ,E.EVICTION_EVICTIONNOTES#(lf)        ,E.EVICTION_DIQ#(lf)        ,CASE WHEN E.EVICTION_DATEFILED IS NOT NULL AND EVICTION_EVICTIONSTATUSID <> 409 THEN 'Filed on' ELSE 'Not Filed On' END AS Filed_With_County_Status#(lf)#(lf)        ,T.VEHICLES#(lf)        ,T.PETS#(lf)        ,CASE WHEN T.PETS = 'Y' THEN COALESCE(HUB_PETS.PETS, 1) ELSE COALESCE(HUB_PETS.PETS, 0) END AS ""PETS_AMOUNT""#(lf)        ,CASE WHEN TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') < GETDATE()#(lf)              THEN 'Y' ELSE COALESCE(T.MONTH_TO_MONTH, 'N')#(lf)         END AS MONTH_TO_MONTH#(lf)        ,T.LEASE_TERM#(lf)        ,TO_DATE(T.NOTICE_DATE_KEY::TEXT, 'yyyymmdd') AS NOTICE_DATE#(lf)        ,TLA.INITIAL_RENT_AMOUNT#(lf)        ,T.CURRENT_RENT#(lf)        ,COALESCE(PM_D.DEAL_OWNER, HUB_CONTACT.DEAL_OWNER, HUB_NAME.DEAL_OWNER) AS DEAL_OWNER#(lf)        ,DATE_TRUNC('month', PM_D.APPLICATION_SUBMITTED_DATE::date) AS ""App Submit (BOM)""#(lf)        ,CONVERT_TIMEZONE('EST', PM_D.APPLICATION_STARTED_DATE::date) AS Application_Started_Date#(lf)        ,DATE_TRUNC('month', CONVERT_TIMEZONE('EST', PM_D.APPLICATION_STARTED_DATE)::date) AS App_Started_BOM#(lf)        ,HUB_DEAL.PROPERTY_HOLDING_FEE_TRANSACTION_DATE AS ""HOLDING_FEE_DATE_NEW""#(lf)        ,TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd') AS CURRENT_LEASE_EXPIRATION_DATE#(lf)        ,TO_DATE(TLA.LEASE_SIGNED_DATE_KEY::TEXT, 'yyyymmdd') AS LEASE_SIGNED_DATE#(lf)        ,TO_DATE(TLA.LEASE_FROM_DATE_KEY::TEXT,   'yyyymmdd') AS LEASE_FROM_DATE#(lf)        ,TO_DATE(TLA.LEASE_TO_DATE_KEY::TEXT,     'yyyymmdd') AS LEASE_TO_DATE#(lf)        ,TO_DATE(T.DOB_DATE_KEY::TEXT, 'yyyymmdd') AS DOB#(lf)        ,CASE WHEN RESI_TSUM.NUMBER_OF_CHILDREN > 0 THEN 1 ELSE 0 END AS Dem_Has_Children#(lf)        ,CASE WHEN HUB_PETS.PETS > 0 OR T.PEts = 'Y' THEN 1 ELSE 0 END AS Dem_With_Pets#(lf)        ,CASE WHEN COALESCE(PM_D.AVERAGE_CREDIT_SCORE, RESI_TSUM.AVERAGE_CREDIT_SCORE) > 850 THEN NULL#(lf)              ELSE COALESCE(PM_D.AVERAGE_CREDIT_SCORE, RESI_TSUM.AVERAGE_CREDIT_SCORE)#(lf)         END AS AVERAGE_CREDIT_SCORE#(lf)        ,CASE WHEN PM_D.COMBINED_INCOME IS NOT NULL AND PM_D.COMBINED_INCOME > 10000 AND PM_D.COMBINED_INCOME < 1000000#(lf)              THEN PM_D.COMBINED_INCOME ELSE NULL#(lf)         END AS COMBINED_INCOME#(lf)        ,PM_D.DEAL_ID#(lf)        ,HUB_DEAL.FINDIGS_URL#(lf)        ,COALESCE(RESI_TSUM.NUMBER_OF_CHILDREN, 0) AS NUMBER_OF_CHILDREN#(lf)        ,COALESCE(RESI_TSUM.OCCUPANTS, 1) AS OCCUPANTS#(lf)        ,COALESCE(RESI_TSUM.TENANT_AGE, DATEDIFF('year', TO_DATE(T.DOB_DATE_KEY::TEXT, 'yyyymmdd'), GETDATE())) AS TENANT_AGE#(lf)        ,RESI_TSUM.MONTHLY_INCOME#(lf)        ,RESI_TSUM.IS_NOTICE#(lf)        ,RESI_TSUM.IS_UNDER_EVICTION#(lf)        ,TI.MoveIn#(lf)        ,DATE_TRUNC('month', TI.MoveIn) AS MOVEIN_BOM#(lf)        ,CASE WHEN TI.MoveIn IS NOT NULL AND DSA.HOLDING_FEE_PAID_DATE IS NOT NULL#(lf)              THEN DATEDIFF(DAY, COALESCE(TO_DATE(HOLDING_FEE_PAID_DATE::TEXT, 'AUTO'), HUB_DEAL.PROPERTY_HOLDING_FEE_TRANSACTION_DATE), TI.MoveIn)#(lf)              ELSE NULL#(lf)         END AS Days_HoldingFee_MoveIn#(lf)        ,TI.MoveOut#(lf)        ,DATE_TRUNC('month', TI.MoveOut) AS MOVEOUT_BOM#(lf)        ,CASE WHEN TI.MoveOut IS NOT NULL THEN 1 ELSE 0 END AS MOVE_OUT_INDICATOR#(lf)        ,GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0) AS Days_In_Home#(lf)        ,CASE WHEN GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0) <= 5#(lf)                   AND T.TENANT_STATUS = 'Past'#(lf)              THEN 1 ELSE 0#(lf)         END AS EXCLUDE_FILTER#(lf)        ,TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) || 'y '#(lf)            || LEAST(TRUNC((GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)#(lf)                - (TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) * 365))/30), 11) || 'm' AS DAY_IN_HOME_LABEL#(lf)        ,TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) || '.'#(lf)            || LEAST(TRUNC((GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)#(lf)                - (TRUNC(GREATEST(DATEDIFF(DAY, TI.MoveIn, COALESCE(TI.MoveOut, GETDATE())), 0)/365) * 365))/30), 11)/12 AS DAY_IN_HOME_LABEL_SORT#(lf)        ,TI.UserID AS TEN_USER_ID#(lf)        ,TI.AnticipatedMoveOutDate#(lf)        ,COALESCE(TI.IsSection8, 'N') AS IsSection8#(lf)        ,TI.IsMonthtoMonthLease#(lf)        ,TI.TenantDecidedMonthtoMonth#(lf)        ,TI.DoNotRenew#(lf)        ,TI.ReasonForNotRenewingId#(lf)        ,TI.ALLOWONLINEPAYMENTS#(lf)        ,TI.CERTIFIEDFUNDSONLY#(lf)        ,CASE WHEN TI.MoveOut IS NULL THEN NULL WHEN TI.MoveOutComplte = 'Y' THEN 'Yes' ELSE 'No' END AS MoveOutComplete#(lf)        ,DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf)        ,PUS.Under_written_rent#(lf)        ,AM_PM.MoveInReady#(lf)        ,COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')) AS Move_Out_Forecast#(lf)        ,CASE#(lf)            WHEN TI.MoveOut IS NOT NULL AND TI.MoveOutComplte = 'N' THEN 1#(lf)            WHEN TI.MoveOut IS NULL AND T.MONTH_TO_MONTH = 'N'#(lf)                 AND COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')) < GETDATE() THEN 1#(lf)            WHEN DATEDIFF(DAY, COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')), GETDATE()) BETWEEN -30 AND 0 THEN 1#(lf)            ELSE 0#(lf)         END AS Move_Out_Forecast_Filter#(lf)        ,CASE#(lf)            WHEN TI.MoveOut IS NULL AND T.MONTH_TO_MONTH = 'N'#(lf)                 AND DATEDIFF(DAY, COALESCE(TI.MoveOut, TI.AnticipatedMoveOutDate, TO_DATE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY::TEXT, 'yyyymmdd')), GETDATE()) > 1 THEN 1#(lf)            ELSE 0#(lf)         END AS Past_Move_Out#(lf)        ,TS.AUTOPAY_DAY_OF_WITHDRAW AS AUTOPAY_DAYOFWITHDRAW#(lf)        ,CONVERT_TIMEZONE('UTC', 'EST', TS.AUTOPAY_NEXT_WITHDRAW_DATE::TIMESTAMP_NTZ) AS AUTOPAY_NEXTWITHDRAWDATE#(lf)        ,TS.AUTOPAY_PAYMENT_TYPE_ID AS AUTOPAY_PAYMENTTYPE#(lf)        ,CASE#(lf)            WHEN CHARINDEX('III', PO.PORTFOLIO_NAME) > 0 THEN 'Venture III'#(lf)            WHEN CHARINDEX('II',  PO.PORTFOLIO_NAME) > 0 THEN 'Venture II'#(lf)            WHEN CHARINDEX('Venture', PO.PORTFOLIO_NAME) > 0 OR P.ORGANIZATION_KEY IN (-1,18,26,28,48,27) THEN 'Venture I'#(lf)            ELSE 'All'#(lf)         END AS Venture_No   -- NOTE: shorter than property script's Venture_No (see header)#(lf)        ,'https://honeybadgerpm.com/ReportingModule/ViewReport?reportId=1807&UnitId=' || TI.UnitID || '&UserId=' || TI.UserID || '#/' AS URL_SODA#(lf)        ,'https://honeybadgerpm.com/PeopleModule#/TenantDetails/' || U.USER_ID || '/' || T.TENANT_INFORMATION_ID AS HBPM_TENANT_URL#(lf)#(lf)        -- ---- Notes / docs ----#(lf)        ,CN.CollectionNote#(lf)        ,CN.CollectionNoteCreated#(lf)        ,CN.CollectionNote_Days#(lf)        ,CN.CollectionNote_Added_By#(lf)        ,EN.EvictionNote#(lf)        ,EN.EvictionNoteCreated#(lf)        ,CASE WHEN T.TENANT_STATUS = 'Under Eviction' THEN COALESCE(EN.EvictionNote_Days, 99) ELSE NULL END AS EvictionNote_Days#(lf)        ,MI.MI_Note#(lf)        ,MI.MI_NoteCreated#(lf)        ,MINote_Added_By#(lf)        ,MID.CreatedOn    AS MID_Added_Date#(lf)        ,MID.DocumentName AS MID_Document_Name#(lf)        ,MID.UploadedBy   AS MID_UploadedBy#(lf)        ,DATEDIFF(DAY, TI.MoveIn, GETDATE()) AS Days_Since_MI#(lf)#(lf)        -- ---- Flags ----#(lf)        ,CASE WHEN TI.isESA = 1 THEN 'Yes' ELSE 'No' END AS IsESA#(lf)        ,CASE WHEN TI.IsFiledHAP = 1 THEN 'Yes' ELSE 'No' END AS IsFiledHAP#(lf)        ,CASE WHEN TI.IsFiledRA = 1 THEN 'Yes' ELSE 'No' END AS IsFiledRA#(lf)        ,CASE WHEN TI.IsPromiseToPay = 1 THEN 'Yes' ELSE 'No' END AS IsPromiseToPay#(lf)        ,CASE WHEN TI.IsPromiseToPay = 1 THEN TI.PromiseToPayDate ELSE NULL END AS PromiseToPayDate#(lf)        ,CASE WHEN TI.IsPromiseToPay = 1 AND TI.PromiseToPayDate <= GETDATE() AND TI.PromiseToPayDate IS NOT NULL THEN 1 ELSE 0 END AS PromiseToPayDate_Flag#(lf)        ,CASE WHEN TI.IsPromiseToPay = 1 AND TI.PromiseToPayDate <= GETDATE() AND TI.PromiseToPayDate IS NOT NULL THEN 'Yes' ELSE 'No' END AS PromiseToPayDate_Flag_Text#(lf)        ,CASE#(lf)            WHEN T.TENANT_STATUS = 'Notice' OR T.TENANT_STATUS = 'Under Eviction'#(lf)                THEN DATE_TRUNC('month', TI.AnticipatedMoveOutDate)#(lf)            WHEN T.TENANT_STATUS = 'Current'#(lf)                THEN DATE_TRUNC('month', TO_DATE(COALESCE(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY, TLA.LEASE_TO_DATE_KEY)::TEXT, 'yyyymmdd'))#(lf)            ELSE NULL#(lf)         END AS EXPIRATION_FORECAST#(lf)#(lf)        -- ---- Fixed eviction-fee import template ----#(lf)        ,'Charge' AS IMPORT_TYPE#(lf)        ,GETDATE() AS IMPORT_Due_Date#(lf)        ,CASE WHEN S.STATE_CODE IN ('IN', 'SC') THEN 400 ELSE 450 END AS IMPORT_AMOUNT#(lf)        ,5530-0000 AS IMPORT_GL_ACCOUNT   -- NOTE: evaluates to 5530 (arithmetic). Intended GL code is likely '5530-0000' (see header).#(lf)        ,'Eviction Fees' AS IMPORT_GL_ACCOUNT_DESC#(lf)        ,'Eviction Settlement' AS IMPORT_DESCRIPTION#(lf)        ,NULL AS IMPORT_HBPM_User#(lf)        ,NULL AS IMPORT_Tenant_Note#(lf)        ,NULL AS IMPORT_Tenant_Note_Type#(lf)        ,4940511 AS IMPORT_GL_CC_ACCOUNT#(lf)        ,'One Time Concession-Move in Recovery' AS IMPORT_GL_CC_ACCOUNT_DESC#(lf)        ,'Move-In Concession Recovery' AS IMPORT_CC_DESCRIPTION#(lf)        ,EC.EVICTION_COUNT#(lf)        ,HUB_CONTACT.PROPERTY_LAST_CALL_DATE AS LAST_CALL_DATE#(lf)#(lf)    FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TS ON TS.TENANT_KEY = T.TENANT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = T.TENANT_INFORMATION_ID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS DNR ON DNR.LookUpMasterId = TI.ReasonForNotRenewingId#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSA ON DSA.DEAL_KEY = TLA.DEAL_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL PM_D ON PM_D.DEAL_KEY = DSA.DEAL_KEY#(lf)#(lf)        /* ------------------------------------------------------------------#(lf)           HUB_DEAL: HubSpot replica section.#(lf)           Deal (HD) + application (APP) reconciled via FULL JOIN, ranked to one#(lf)           row per deal. Supplies holding-fee date, lease/move-in fields, and the#(lf)           Findigs URL.#(lf)           ------------------------------------------------------------------ */#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                 APP.PROPERTY_HOLDING_FEE_TRANSACTION_DATE#(lf)                ,CAST(COALESCE(HD.DEAL_PIPELINE_STAGE_ID, APP.PROPERTY_HS_PIPELINE_STAGE) AS INT) AS DEAL_PIPELINE_STAGE_ID#(lf)                ,COALESCE(D.DEAL_KEY, APP.APP_ID) AS DEAL_KEY_JOIN#(lf)                ,DPS.Label AS DEAL_STAGE#(lf)                ,APP_ID#(lf)                ,CASE APP.PROPERTY_HS_PIPELINE_STAGE#(lf)                    WHEN 59173506 THEN 'Aplication Started'#(lf)                    WHEN 93217140 THEN 'Needs New Property'#(lf)                    WHEN 59173507 THEN 'Under Review'#(lf)                    WHEN 59187121 THEN 'Conditional Approval'#(lf)                    WHEN 59187122 THEN 'Full Approval'#(lf)                    WHEN 59187127 THEN 'Denial'#(lf)                    WHEN 59187123 THEN 'Pre-Lease Compliance'#(lf)                    WHEN 59187124 THEN 'Lease Drafting'#(lf)                    WHEN 59187125 THEN 'Lease Executed'#(lf)                    WHEN 59187126 THEN 'Move-In Scheduled'#(lf)                    WHEN 59187128 THEN 'Closed Lost'#(lf)                    ELSE NULL#(lf)                 END AS APP_STAGE#(lf)                ,RANK() OVER (PARTITION BY COALESCE(D.DEAL_KEY, APP.APP_ID)#(lf)                              ORDER BY HD.PROPERTY_HS_LASTMODIFIEDDATE, APP.APP_ID DESC) AS DEAL_RANK#(lf)                ,HD.PROPERTY_LEASE_DRAFTING_STATUS#(lf)                ,HD.PROPERTY_LEASE_SIGNED_DATE#(lf)                ,HD.PROPERTY_MOVE_IN_FEE_PAYMENT_LINK#(lf)                ,HD.PROPERTY_MOVE_IN_CHARGES_PAID#(lf)                ,HD.PROPERTY_DF_REFERENCE_NUMBER#(lf)                ,HD.PROPERTY_IS_SECTION_8#(lf)                ,'https://resihome.findigs.com/group-applications/v2/groupid=' || HD.Property_group_application_id AS FINDIGS_URL#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL D#(lf)                LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSH ON DSH.DEAL_KEY = D.Deal_Key#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT_2.DEAL HD ON HD.DEAL_ID = D.DEAL_ID#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT_2.APPLICATION_TO_DEAL ATD ON ATD.TO_ID = D.DEAL_ID#(lf)                FULL JOIN (#(lf)                    SELECT DISTINCT#(lf)                         A.ID AS APP_ID#(lf)                        ,A.PROPERTY_UNIT_ID#(lf)                        ,A.PROPERTY_HS_PIPELINE_STAGE#(lf)                        ,A.PROPERTY_HOLDING_FEE_TRANSACTION_DATE#(lf)                        ,P.PROPERTY_KEY#(lf)                    FROM PROD_REPLICA.HUBSPOT_2.APPLICATION A#(lf)                        LEFT JOIN (#(lf)                            SELECT *,#(lf)                                RANK() OVER (PARTITION BY FROM_ID ORDER BY _FIVETRAN_SYNCED DESC) AS RECENT_RANK#(lf)                            FROM PROD_REPLICA.HUBSPOT_2.APPLICATION_TO_PROPERTIES#(lf)                            QUALIFY RECENT_RANK = 1#(lf)                        ) ATP ON ATP.FROM_ID = A.ID#(lf)                        LEFT JOIN PROD_REPLICA.HUBSPOT_2.PROPERTIES H_P ON H_P.ID = ATP.TO_ID#(lf)                        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.HBPM_PROPERTY_ID = H_P.PROPERTY_PROPERTY_ID#(lf)                    WHERE IS_INTEGER(A.PROPERTY_HS_PIPELINE_STAGE) = 'True'#(lf)                        AND A.PROPERTY_UNIT_ID IS NOT NULL#(lf)                        AND APP_ID NOT IN (8472470544, 8657787708, 8657665830, 6854090788)  -- merged bad data#(lf)                ) APP#(lf)                    ON APP.APP_ID = ATD.FROM_ID AND APP.PROPERTY_KEY = DSH.PROPERTY_KEY#(lf)                LEFT JOIN (#(lf)                    SELECT * FROM PROD_REPLICA.HUBSPOT_2.DEAL_PIPELINE_STAGE WHERE _FIVETRAN_DELETED = 'N'#(lf)                ) DPS ON DPS.STAGE_ID = HD.DEAL_PIPELINE_STAGE_ID#(lf)            WHERE 1 = 1#(lf)            QUALIFY DEAL_RANK = 1#(lf)        ) HUB_DEAL#(lf)            ON HUB_DEAL.DEAL_KEY_JOIN = PM_D.DEAL_KEY#(lf)#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = TS.USER_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TS.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_STATE S ON S.STATE_KEY = PUS.STATE_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_CITY CI ON CI.CITY_KEY = PUS.CITY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L ON L.lead_key = TS.LEAD_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTYMANAGEMENTS AM_PM#(lf)            ON AM_PM.PROPERTYMANAGEMENTID = HBAM.PropertyManagement_PropertyManagementId AND AM_PM.HBID = HBAM.HBID#(lf)        LEFT JOIN (#(lf)            SELECT C.ID, COUNT(PET.ID) AS PETS#(lf)            FROM PROD_REPLICA.HUBSPOT.PET#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT.PET_TO_CONTACT PTC ON PTC.FROM_ID = PET.ID#(lf)                LEFT JOIN PROD_REPLICA.HUBSPOT.CONTACT C ON C.ID = PTC.TO_ID#(lf)            GROUP BY C.ID#(lf)        ) HUB_PETS ON HUB_PETS.ID = L.LEAD_ID#(lf)        LEFT JOIN (#(lf)            SELECT#(lf)                 FCT_TENANT_SUMMARY_KEY#(lf)                ,TENANT_INFORMATION_ID#(lf)                ,AVERAGE_CREDIT_SCORE#(lf)                ,R_TS.COMBINED_INCOME#(lf)                ,NUMBER_OF_CHILDREN#(lf)                ,OCCUPANTS#(lf)                ,TENANT_AGE#(lf)                ,MONTHLY_INCOME#(lf)                ,IS_RETIRED#(lf)                ,IS_NOTICE#(lf)                ,IS_UNDER_EVICTION#(lf)            FROM PROD_ANALYTICS.RESICAP.FCT_TENANT_SUMMARY R_TS#(lf)                LEFT JOIN PROD_ANALYTICS.RESICAP.DIM_TENANT R_T ON R_T.TENANT_KEY = R_TS.TENANT_KEY#(lf)        ) RESI_TSUM ON RESI_TSUM.TENANT_INFORMATION_ID = T.TENANT_INFORMATION_ID#(lf)        /* (Dead commented-out AUTOPAYS join removed — autopay now sourced from FCT_TENANT_ACTIVITY/TS.) */#(lf)        LEFT JOIN HUB_CONTACT ON HUB_CONTACT.PROPERTY_HBPM_TENANT_ID = T.TENANT_INFORMATION_ID#(lf)        LEFT JOIN HUB_NAME    ON HUB_NAME.CONTACT_NAME = U.FULL_NAME#(lf)        LEFT JOIN CollectionsNote CN ON CN.PropertyID = P.HBPM_PROPERTY_ID#(lf)        LEFT JOIN EvictionNote EN ON EN.PropertyID = P.HBPM_PROPERTY_ID#(lf)        LEFT JOIN MoveInNote MI ON MI.PropertyID = P.HBPM_PROPERTY_ID#(lf)        LEFT JOIN MoveInDocs MID ON MID.ObjectID = T.TENANT_INFORMATION_ID#(lf)        LEFT JOIN EVICTIONS E ON E.TENANTINFORMATIONID = TI.TenantInformationId#(lf)        LEFT JOIN EVICTION_COUNT EC ON EC.TENANTINFORMATIONID = T.Tenant_Information_ID#(lf)#(lf)    WHERE 1 = 1#(lf)        AND T.CURRENT_FLAG = 'Y'#(lf)        AND T.PRIMARY_TENANT = 'Y'#(lf)        AND P.PROPERTY_STATE = 'Active'#(lf)        AND P.EntityID <> ''#(lf)        AND TI._FIVETRAN_DELETED <> 'Y'#(lf)        AND TI.RENTDUEDAY IS NOT NULL#(lf)        AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952, 1867, 1916, 1852, 1771, 1919, 1873, 169)#(lf)        AND P.Organization_KEY NOT IN (16, 17)#(lf)        AND PO.IS_Active_AM = 'Y'#(lf)        AND PO.Current_Flag = 'Y'#(lf)        AND P.Current_Flag = 'Y'#(lf)        AND PU.Current_Flag = 'Y'#(lf)        AND PUS.Occupancy_Status NOT IN ('Property SOLD', 'Not Managed')#(lf)        AND T.TENANT_KEY NOT IN (76191)#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: Tenant_Listings#(lf)   Earliest qualifying lease-up listing per (lease, property): a listing live#(lf)   within 10 days of the initial lease-from date, excluding withdrawn/on-hold.#(lf)   ----------------------------------------------------------------------------- */#(lf),Tenant_Listings AS (#(lf)    SELECT#(lf)         MIN(RENT_LIST_HIST_ID) AS RENT_LIST_HIST_KEY#(lf)        ,TEN.Lease_ID#(lf)        ,TLA.Property_key#(lf)    FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT TEN#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = TEN.Tenant_Key#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TENANTINFORMATIONID = TEN.Tenant_Information_id#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH ON RLH.PROPERTY_KEY = TLA.Property_Key#(lf)    WHERE 1 = 1#(lf)        AND PRIMARY_TENANT = 'Y'#(lf)        AND CURRENT_FLAG = 'Y'#(lf)        AND RENT_DUE_DAY IS NOT NULL#(lf)        AND TI._FIVETRAN_DELETED = 'N'#(lf)        AND TI.CURRENTRENT > 500#(lf)        AND TO_DATE(RLH.LISTING_DATE_KEY::TEXT, 'yyyymmdd') <= DATEADD(DAY, 10, TO_DATE(COALESCE(TLA.INITIAL_LEASE_FROM_DATE_KEY, TLA.LEASE_FROM_DATE_KEY)::TEXT, 'yyyymmdd'))#(lf)        AND RLH.LISTING_STATUS <> 'Withdrawn'#(lf)        AND RLH.LISTING_STATUS <> 'On Hold'#(lf)    GROUP BY#(lf)         TEN.Lease_ID#(lf)        ,TLA.Property_key#(lf))#(lf)#(lf)#(lf)/* =============================================================================#(lf)   FINAL SELECT#(lf)   Primary tenant + matched listing + MC charge totals + secondary tenants#(lf)   (TS_1..TS_4) + import template scaffolding.#(lf)   ============================================================================= */#(lf)SELECT DISTINCT#(lf)     Tenant.*#(lf)    ,COALESCE(Tenant.DEAL_OWNER, RLH.LEASING_AGENT) AS DEAL_OWNER_1#(lf)    ,RLH.RENT_LIST_HIST_ID AS RENT_LIST_ID#(lf)    ,MC_GROUP.MC_Rent#(lf)    ,MC_GROUP.MC_MTM#(lf)    ,MC_GROUP.MC_Smart_Lock#(lf)    ,MC_GROUP.MC_Pet#(lf)    ,DIV0NULL(MC_GROUP.MC_MTM, Tenant.CURRENT_RENT) AS MTM_Charge_Percent#(lf)    ,CASE WHEN Tenant.Occupancy_Status = 'Tenant Leased'#(lf)               AND (DIV0NULL(MC_GROUP.MC_MTM, Tenant.CURRENT_RENT) < .149 OR DIV0NULL(MC_GROUP.MC_MTM, Tenant.CURRENT_RENT) > .151)#(lf)          THEN 1 ELSE NULL#(lf)     END AS MC_FLAG_MTM#(lf)    ,CASE WHEN Tenant.Occupancy_Status = 'Tenant Leased' AND MC_GROUP.MC_Smart_Lock IS NULL THEN 1 ELSE NULL END AS MC_FLAG_Smart_Lock#(lf)    ,CASE WHEN Tenant.Occupancy_Status = 'Tenant Leased' AND COALESCE(Tenant.""PETS_AMOUNT"", 0) * 30 > COALESCE(MC_GROUP.MC_Pet, 0) THEN 1 ELSE NULL END AS MC_FLAG_Pet#(lf)    ,COALESCE(RLH.LEASING_AGENT, Tenant.DEAL_OWNER) AS LISTING_AGENT#(lf)    ,RLH.LISTING_AGENT_EMAIL AS LISTING_AGENT_EMAIL#(lf)    ,NULL AS TS_P_DOB#(lf)    ,NULL AS TS_P_SSN#(lf)#(lf)    ,TS_1.FIRST_NAME    AS TS_1_FIRST_NAME#(lf)    ,TS_1.LAST_NAME     AS TS_1_LAST_NAME#(lf)    ,TS_1.FULL_NAME     AS TS_1_FULL_NAME#(lf)    ,TS_1.EMAIL_ADDRESS AS TS_1_EMAIL_ADDRESS#(lf)    ,NULL AS TS_1_DOB#(lf)    ,NULL AS TS_1_SSN#(lf)#(lf)    ,TS_2.FIRST_NAME    AS TS_2_FIRST_NAME#(lf)    ,TS_2.LAST_NAME     AS TS_2_LAST_NAME#(lf)    ,TS_2.FULL_NAME     AS TS_2_FULL_NAME#(lf)    ,TS_2.EMAIL_ADDRESS AS TS_2_EMAIL_ADDRESS#(lf)    ,NULL AS TS_2_DOB#(lf)    ,NULL AS TS_2_SSN#(lf)#(lf)    ,TS_3.FIRST_NAME    AS TS_3_FIRST_NAME#(lf)    ,TS_3.LAST_NAME     AS TS_3_LAST_NAME#(lf)    ,TS_3.FULL_NAME     AS TS_3_FULL_NAME#(lf)    ,TS_3.EMAIL_ADDRESS AS TS_3_EMAIL_ADDRESS#(lf)    ,NULL AS TS_3_DOB#(lf)    ,NULL AS TS_3_SSN#(lf)#(lf)    ,TS_4.FIRST_NAME    AS TS_4_FIRST_NAME#(lf)    ,TS_4.LAST_NAME     AS TS_4_LAST_NAME#(lf)    ,TS_4.FULL_NAME     AS TS_4_FULL_NAME#(lf)    ,TS_4.EMAIL_ADDRESS AS TS_4_EMAIL_ADDRESS#(lf)    ,NULL AS TS_4_DOB#(lf)    ,NULL AS TS_4_SSN#(lf)#(lf)    ,NULL AS IMP_Unit_Type#(lf)    ,NULL AS IMP_Address_2#(lf)    ,NULL AS IMP_Subsidized#(lf)    ,NULL AS IMP_Future_Rent#(lf)    ,NULL AS IMP_Military#(lf)    ,'& All Other Occupants' AS IMP_ALL_OTHERS#(lf)    ,DATE_TRUNC('month', TO_DATE(GETDATE())) AS IMP_Deliquency_Date#(lf)    ,DATEADD(DAY, 5, DATE_TRUNC('month', TO_DATE(GETDATE()))) AS IMP_Notice_Date#(lf)#(lf)FROM Tenant#(lf)    LEFT JOIN Tenant_Listings TL#(lf)        ON TL.Lease_ID = Tenant.Lease_ID AND TL.Property_key = Tenant.Property_key#(lf)    LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH#(lf)        ON RLH.RENT_LIST_HIST_ID = TL.RENT_LIST_HIST_KEY#(lf)    LEFT JOIN MC_GROUP#(lf)        ON MC_GROUP.Tenant_Key = Tenant.Tenant_Key#(lf)    LEFT JOIN TENANT_SECONDARY AS TS_1 ON TS_1.Lease_ID = Tenant.Lease_ID AND TS_1.TENANT_SECONDAY_RANK = 1 AND TS_1.Tenant_Status <> 'Past'#(lf)    LEFT JOIN TENANT_SECONDARY AS TS_2 ON TS_2.Lease_ID = Tenant.Lease_ID AND TS_2.TENANT_SECONDAY_RANK = 2 AND TS_2.Tenant_Status <> 'Past'#(lf)    LEFT JOIN TENANT_SECONDARY AS TS_3 ON TS_3.Lease_ID = Tenant.Lease_ID AND TS_3.TENANT_SECONDAY_RANK = 3 AND TS_3.Tenant_Status <> 'Past'#(lf)    LEFT JOIN TENANT_SECONDARY AS TS_4 ON TS_4.Lease_ID = Tenant.Lease_ID AND TS_4.TENANT_SECONDAY_RANK = 4 AND TS_4.Tenant_Status <> 'Past'#(lf)WHERE 1 = 1", null, [EnableFolding=true]),
				    #"Capitalized Each Word" = Table.TransformColumns(Source,{{"FIRST_NAME", Text.Proper, type text}, {"LAST_NAME", Text.Proper, type text},{"DEAL_OWNER", Text.Proper, type text}, {"FULL_NAME", Text.Proper, type text}, {"TS_1_FIRST_NAME", Text.Proper, type text}, {"TS_1_LAST_NAME", Text.Proper, type text}, {"TS_1_FULL_NAME", Text.Proper, type text}, {"TS_2_FIRST_NAME", Text.Proper, type text}, {"TS_2_LAST_NAME", Text.Proper, type text}, {"TS_2_FULL_NAME", Text.Proper, type text}, {"TS_3_FIRST_NAME", Text.Proper, type text}, {"TS_3_LAST_NAME", Text.Proper, type text}, {"TS_3_FULL_NAME", Text.Proper, type text}, {"TS_4_FIRST_NAME", Text.Proper, type text}, {"TS_4_LAST_NAME", Text.Proper, type text}, {"TS_4_FULL_NAME", Text.Proper, type text}}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Capitalized Each Word",{{"IMPORT_GL_ACCOUNT", type text}}),
				    #"Replaced Value" = Table.ReplaceValue(#"Changed Type","5530","5530-0000",Replacer.ReplaceText,{"IMPORT_GL_ACCOUNT"})
				in
				    #"Replaced Value"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

