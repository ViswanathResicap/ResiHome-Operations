		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   RENEWALS DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:      One row per tenant leasing-history record (the ""current"" lease),#(lf)               paired with the next lease (N_*) where one exists, enriched with#(lf)               tenant/property/eviction/inspection/renewal-deal context and a#(lf)               set of derived renewal-outcome buckets.#(lf)   Anchor:     PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES (TLH)#(lf)   Branches off the property foundation; shares its organization roll-up logic.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  ORGANIZATION_KEY / ORGANIZATION_NAME CASE updated to mirror the#(lf)             master PROPERTY script (source of truth). This script's version was#(lf)             the most truncated of all (27-group was only 27,50,51,52).#(lf)             DELIBERATE OUTPUT CHANGE — see ""ORG SYNC IMPACT"".#(lf)     [FIX 1] COLLAPSED the duplicate EVICTIONS CTE. It was defined TWICE; only#(lf)             three of its columns are consumed downstream#(lf)             (EVICTION_EVICTIONSTATUSID, EVICTION_EVICTIONSTATUS,#(lf)             EVICTION_EVICTIONTERMINATEDDATE) and those are byte-identical across#(lf)             both definitions with the same FROM/filter/ranking — so a single#(lf)             definition is output-identical and removes the duplicate-name#(lf)             hazard. Kept the richer (COALESCE + EVICTION_DIQ) body.#(lf)     [FIX 2] DROPPED dead NT / LM joins inside RenewalNote (never referenced).#(lf)     [FIX 3] REMOVED the commented-out LR_O / TLH_O prior-lease scaffolding.#(lf)     [FIX 4] REMOVED the ORDER BY inside the RENEWALS CTE (ordering inside a CTE#(lf)             that is re-joined downstream has no effect on final output).#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original renewals output):#(lf)     Renewals tied to these orgs previously fell through to ELSE (raw key +#(lf)     unmapped O.ORGANIZATION_NAME); after the sync they roll up:#(lf)        54,45,55,53,56,57,66 -> 27 / 'RB DRC'   (added to the 27-group)#(lf)        58,59                -> 58 / 'Hudson Oak'#(lf)        62,63,64,65,68,69    -> 62 / 'Rocklyn Homes'#(lf)        61,70                -> 61 / 'ROI Property Group'#(lf)        67                   -> 67 / 'Newstar'#(lf)     An EXCEPT diff vs. the old output will show rows ONLY for these orgs.#(lf)   ============================================================================= */#(lf)#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: LeaseRanking#(lf)   Forward + inverse rank of each lease per tenant, used to walk from the#(lf)   current lease (C_*) to the next lease (N_*).#(lf)   ----------------------------------------------------------------------------- */#(lf)WITH LeaseRanking AS (#(lf)    SELECT#(lf)         TenantLeasingHistoryId#(lf)        ,TenantInformationId#(lf)        ,RANK() OVER (PARTITION BY TenantInformationId ORDER BY TenantLeasingHistoryId ASC)  AS Lease_Rank#(lf)        ,RANK() OVER (PARTITION BY TenantInformationId ORDER BY TenantLeasingHistoryId DESC) AS Lease_Rank_INV#(lf)    FROM PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES#(lf)    WHERE 1 = 1#(lf)        AND _FIVETRAN_DELETED <> 'Y'#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: RenewalNote#(lf)   Latest renewal note (NoteTypeId = 1, tenant object) per property.#(lf)   ----------------------------------------------------------------------------- */#(lf),RenewalNote AS (#(lf)    SELECT#(lf)         MAX(NoteID) AS LatestNoteID#(lf)        ,P.PropertyId#(lf)    FROM PROD_REPLICA.HBPM_DBO.NOTES N#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON  TI.UserID = N.ObjectId#(lf)            AND N.ObjectTypeId = 502#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON PAI.UnitId = TI.UnitId#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P#(lf)            ON P.PropertyID = PAI.PropertyId#(lf)    WHERE N.NoteTypeId = 1#(lf)        AND N.ObjectTypeId = 502#(lf)    GROUP BY P.PropertyId#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: EVICTION_COUNT#(lf)   Count of evictions per tenant/unit in the trailing 12 months.#(lf)   ----------------------------------------------------------------------------- */#(lf),EVICTION_COUNT AS (#(lf)    SELECT#(lf)         UNITID#(lf)        ,TENANTINFORMATIONID#(lf)        ,COUNT(ID) AS EVICTION_COUNT#(lf)    FROM PROD_REPLICA.HBPM_DBO.EVICTIONS E#(lf)    WHERE TENANTINFORMATIONID IS NOT NULL#(lf)        AND CREATEDDATE >= DATEADD('YEAR', -1, GETDATE())#(lf)    GROUP BY UNITID, TENANTINFORMATIONID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: EVICTIONS  (single, collapsed definition — see FIX 1)#(lf)   Most recent eviction per unit/tenant, with lookup-master descriptions and a#(lf)   days-in-queue (EVICTION_DIQ) measure. Consumed downstream via two aliases:#(lf)   EV (joined on tenant) and E (for the terminated date).#(lf)   ----------------------------------------------------------------------------- */#(lf),EVICTIONS AS (#(lf)    SELECT#(lf)         UNITID#(lf)        ,ET.Description AS EVICTION_EVICTIONTYPE#(lf)        ,TENANTINFORMATIONID#(lf)        ,ID AS EVICTION_ID#(lf)        ,RANK() OVER (PARTITION BY UNITID, TENANTINFORMATIONID ORDER BY ID DESC) AS RECENT_RANK#(lf)        ,EVICTIONCOMPANY AS EVICTION_EVICTIONCOMPANY#(lf)        ,EVICTIONSOURCE  AS EVICTION_EVICTIONSOURCE#(lf)        ,DATESENTTOATTORNEY                     AS EVICTION_DATESENTTOATTORNEY#(lf)        ,COALESCE(DATEFILED, DATESENTTOATTORNEY) AS EVICTION_DATEFILED#(lf)        ,VENDORSCHEDULED                        AS EVICTION_VENDORSCHEDULED#(lf)        ,CASHFORKEYSAMOUNT                      AS EVICTION_CASHFORKEYSAMOUNT#(lf)        ,ESTIMATEDVACATEDATE                    AS EVICTION_ESTIMATEDVACATEDATE#(lf)        ,DATESCHEDULEDWITHVENDOR                AS EVICTION_DATESCHEDULEDWITHVENDOR#(lf)        ,COURTDATESETDATE                       AS EVICTION_COURTDATESETDATE#(lf)        ,JUDGMENTDATE                           AS EVICTION_JUDGMENTDATE#(lf)        ,CASHFORKEYSCHEDULEDDATE                AS EVICTION_CASHFORKEYSCHEDULEDDATE#(lf)        ,PENDINGLOCKOUTDATE                     AS EVICTION_PENDINGLOCKOUTDATE#(lf)        ,LOCKOUTSCHEDULEDDATE                   AS EVICTION_LOCKOUTSCHEDULEDDATE#(lf)        ,WRITREQUESTEDDATE                      AS EVICTION_WRITREQUESTEDDATE#(lf)        ,LASTEDITEDDATE                         AS EVICTION_LASTEDITEDDATE#(lf)        ,EVICTIONTERMINATEDDATE                 AS EVICTION_EVICTIONTERMINATEDDATE#(lf)        ,DEFENDANTAPPEALDATE                    AS EVICTION_DEFENDANTAPPEALDATE#(lf)        ,ANSWERFILEDDATE                        AS EVICTION_ANSWERFILEDDATE#(lf)        ,VACATEDATE                             AS EVICTION_VACATEDATE#(lf)        ,CASE#(lf)            WHEN ES.Description IN ('Filed with County', 'Sent to Attorney')#(lf)                THEN DATEDIFF('day', COALESCE(DATEFILED, DATESENTTOATTORNEY), GETDATE())#(lf)            WHEN ES.Description IN ('Court Date Set')#(lf)                THEN DATEDIFF('day', COURTDATESETDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Judgement')#(lf)                THEN DATEDIFF('day', JUDGMENTDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Writ of Possesion')#(lf)                THEN DATEDIFF('day', WRITREQUESTEDDATE, GETDATE())#(lf)            WHEN ES.Description IN ('Pending Lockout')#(lf)                THEN DATEDIFF('day', COALESCE(LOCKOUTSCHEDULEDDATE, PENDINGLOCKOUTDATE), GETDATE())#(lf)            WHEN ES.Description IN ('Lockout Scheduled')#(lf)                THEN DATEDIFF('day', LOCKOUTSCHEDULEDDATE, GETDATE())#(lf)            WHEN ES.Description NOT IN ('Eviction Terminated', 'Vacated - Skipped', 'Vacated - Completed')#(lf)                THEN DATEDIFF('day', LASTEDITEDDATE, GETDATE())#(lf)            ELSE NULL#(lf)         END AS EVICTION_DIQ#(lf)        ,CFK.Description AS EVICTION_CASHFORKEYSTATUS#(lf)        ,OI.Description  AS EVICTION_OCCUPANTS_INTENSION#(lf)        ,VS.Description  AS EVICTION_VACATESOURCE#(lf)        ,ES.Description  AS EVICTION_EVICTIONSTATUS#(lf)        ,OT.Description  AS EVICTION_OCCUPANTTYPE#(lf)        ,EVICTIONNOTES   AS EVICTION_EVICTIONNOTES#(lf)        ,E.EVICTIONSTATUSID AS EVICTION_EVICTIONSTATUSID#(lf)    FROM PROD_REPLICA.HBPM_DBO.EVICTIONS E#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS CFK ON E.CASHFORKEYSTATUSID = CFK.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS ES  ON E.EVICTIONSTATUSID   = ES.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS OI  ON E.OCCUINTENSIONID    = OI.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS VS  ON E.VACATESOURCEID     = VS.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS OT  ON E.OCCUPANTTYPEID     = OT.LOOKUPMASTERID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS ET  ON E.EVICTIONTYPEID     = ET.LOOKUPMASTERID#(lf)    WHERE TENANTINFORMATIONID IS NOT NULL#(lf)    QUALIFY RECENT_RANK = 1#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: HUBSPOT#(lf)   Live HubSpot property records (entity id -> hubspot record id).#(lf)   ----------------------------------------------------------------------------- */#(lf),HUBSPOT AS (#(lf)    SELECT#(lf)         ID#(lf)        ,PROPERTY_ENTITY_ID#(lf)    FROM PROD_REPLICA.HUBSPOT_2.PROPERTIES#(lf)    WHERE 1 = 1#(lf)        AND PROPERTY_ENTITY_ID IS NOT NULL#(lf)        AND (_fivetran_deleted = FALSE OR _fivetran_deleted IS NULL)#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: LAST_CALL#(lf)   Most recent outbound-call timestamp per HBPM tenant, from HubSpot contacts.#(lf)   ----------------------------------------------------------------------------- */#(lf),LAST_CALL AS (#(lf)    SELECT#(lf)         PROPERTY_HBPM_TENANT_ID#(lf)        ,MAX(TO_VARCHAR(CONVERT_TIMEZONE('America/New_York', PROPERTY_LAST_CALL_DATE_TIMESTAMP),#(lf)                        'YYYY-MM-DD HH24:MI:SS')) AS PROPERTY_LAST_CALL_DATE#(lf)    FROM PROD_REPLICA.HUBSPOT_2.CONTACT#(lf)    WHERE 1 = 1#(lf)        AND PROPERTY_HBPM_TENANT_ID IS NOT NULL#(lf)    GROUP BY PROPERTY_HBPM_TENANT_ID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: RENEWAL_DEAL#(lf)   Renewal-pipeline deals with their offered rates, joined to the HubSpot deal#(lf)   record. Excludes two bad entity ids and a long list of bad deal ids.#(lf)   ----------------------------------------------------------------------------- */#(lf),RENEWAL_DEAL AS (#(lf)    SELECT#(lf)         R.DEAL_KEY#(lf)        ,R.DEAL_ID#(lf)        ,R.CURRENT_DEAL_STATUS#(lf)        ,TO_DATE(R.LEASE_START_DATE_KEY::TEXT,  'yyyymmdd') AS RENEWAL_START_DATE#(lf)        ,TO_DATE(R.LEASE_END_DATE_KEY::TEXT,    'yyyymmdd') AS RENEWAL_END_DATE#(lf)        ,TO_DATE(R.LEASE_SIGNED_DATE_KEY::TEXT, 'yyyymmdd') AS RENEWAL_SIGNED_DATE#(lf)        ,R.FIRST_NAME#(lf)        ,R.LAST_NAME#(lf)        ,R.EMAIL#(lf)        ,R.PHONE#(lf)        ,R.DEAL_OWNER#(lf)        ,R.DEAL_NAME#(lf)        ,D.PROPERTY_HS_OBJECT_ID#(lf)        ,TO_DATE(D.PROPERTY_CREATEDATE::TEXT, 'AUTO') AS CREATED_DATE#(lf)        ,D.PROPERTY_LEASE_DRAFTING_STATUS#(lf)        ,D.PROPERTY_PRIMARY_APPLICANT_NAME#(lf)        ,D.PROPERTY_PROPERTY_ID#(lf)        ,D.PROPERTY_ENTITY_ID#(lf)        ,D.PROPERTY_ADDRESS#(lf)        ,D.PROPERTY_MINIMUM_ACCEPTABLE_RENEWAL_RATE_MARR_ AS MARR#(lf)        ,D.PROPERTY_N_12_MONTH_RENEWAL_RATE AS RATE_12_MONTH#(lf)        ,D.PROPERTY_N_15_MONTH_RENEWAL_RATE AS RATE_15_MONTH#(lf)        ,D.PROPERTY_N_18_MONTH_RENEWAL_RATE AS RATE_18_MONTH#(lf)        ,COALESCE(D.PROPERTY_N_24_MONTH_RENEWAL_RATE, D.PROPERTY_N_25_MONTH_RENEWAL_RATE) AS RATE_24_MONTH#(lf)        ,D.PROPERTY_MARKET_RENT AS MARKET_RENT#(lf)    FROM ""PROD_ANALYTICS"".""DBT_RESICAP"".""DIM_DEAL"" R#(lf)        LEFT JOIN ""PROD_REPLICA"".""HUBSPOT_2"".""DEAL"" D#(lf)            ON D.DEAL_ID = R.DEAL_ID#(lf)    WHERE 1 = 1#(lf)        AND R.DEAL_PIPELINE = 'Renewals'#(lf)        AND D.PROPERTY_ENTITY_ID NOT IN ('13545864', '63653634')#(lf)        AND R.DEAL_ID NOT IN (#(lf)            16852651365,16852662951,16852818188,16852625001,16852830527,16852588187,16852902240,#(lf)            16852535222,16852602181,16852613985,16852551050,16851979618,16852902250,16852685735,#(lf)            16852606516,16852609954,16852591747,16852838701,16852805227,16852670267,16852769112,#(lf)            16852640109,16852769109,16852024887,16852571050,16852651357,16852582701,16852840328,#(lf)            16852647079,16852038791,16852575895)#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: UW_RENT#(lf)   Latest underwriting rent change per unit (max RENTLOGID per ENTITYID1).#(lf)   ----------------------------------------------------------------------------- */#(lf),UW_RENT_MAX AS (#(lf)    SELECT#(lf)         MAX(RENTLOGID) AS RENTLOGID#(lf)        ,ENTITYID1#(lf)    FROM PROD_REPLICA.HBPM_DBO.RENTLOGS#(lf)    GROUP BY ENTITYID1#(lf))#(lf)#(lf),UW_RENT AS (#(lf)    SELECT#(lf)         RentLogs.ENTITYID1     AS HBPM_UnitID#(lf)        ,RentLogs.ORIGINALVALUE AS UW_Rent_Prior#(lf)        ,RentLogs.UPDATEVALUE   AS UW_Rent_Current#(lf)        ,RentLogs.OCCUREDON     AS UW_Update_Date#(lf)    FROM UW_RENT_MAX#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.RENTLOGS RentLogs#(lf)            ON RentLogs.RENTLOGID = UW_RENT_MAX.RENTLOGID#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   HappyCo inspection chain (Trustee-Leased renewal inspections)#(lf)   CLEAN_ITEM -> CLEAN_UNIT -> CLEAN_INPSECTION -> HAPPY_CO_DETAIL -> HAPPY_CO_RENEWAL#(lf)   ----------------------------------------------------------------------------- */#(lf),CLEAN_ITEM AS (#(lf)    SELECT#(lf)         ITEM._MODIFIED#(lf)        ,ITEM._ID      AS ITEM_ID#(lf)        ,ITEM.SECTION  AS ITEM_Section#(lf)        ,ITEM.ITEM     AS ITEM_Item#(lf)        ,ITEM.RATINGS  AS ITEM_Ratings#(lf)        ,ITEM.NOTES    AS ITEM_Notes#(lf)        ,ITEM.INSPECTION_ID#(lf)        ,RANK() OVER (PARTITION BY ITEM.INSPECTION_ID#(lf)                      ORDER BY DATE_TRUNC('min', _FIVETRAN_SYNCED) DESC) AS UPDATE_RANK#(lf)        ,RANK() OVER (PARTITION BY ITEM_SECTION, ITEM_ITEM, ITEM.INSPECTION_ID#(lf)                      ORDER BY DATE_TRUNC('min', _MODIFIED) DESC,#(lf)                               DATE_TRUNC('min', _DATE_UPDATED) DESC) AS RECENT_RANK#(lf)    FROM PROD_REPLICA.HAPPYCO_NEW.ITEM#(lf))#(lf)#(lf),CLEAN_UNIT_PRE AS (#(lf)    SELECT#(lf)         UNIT._MODIFIED#(lf)        ,UNIT.ID          AS UNIT_ID#(lf)        ,UNIT.EXTERNAL_ID AS UNIT_EXTERNAL_ID#(lf)        ,UNIT.ADDRESS     AS UNIT_ADDRESS#(lf)        ,UNIT.LINE_1      AS UNIT_LINE_1#(lf)        ,RANK() OVER (PARTITION BY ID ORDER BY DATE_TRUNC('min', _MODIFIED) DESC) AS RECENT_RANK#(lf)    FROM PROD_REPLICA.HAPPY_CO.UNIT#(lf))#(lf)#(lf),CLEAN_UNIT AS (#(lf)    SELECT DISTINCT#(lf)         CLEAN_UNIT_PRE.*#(lf)        ,COALESCE(P1.PROPERTY_KEY, P2.PROPERTY_KEY, P3.PROPERTY_KEY, P4.PROPERTY_KEY) AS PROPERTY_KEY#(lf)    FROM CLEAN_UNIT_PRE#(lf)        /* Four fallback property matches: HBAM id, entity id, full address, then a#(lf)           10-char address prefix. */#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P1#(lf)            ON  TO_CHAR(P1.HBAM_PROPERTY_ID) = CLEAN_UNIT_PRE.UNIT_EXTERNAL_ID#(lf)            AND P1.CURRENT_FLAG = 'Y' AND P1.PROPERTY_STATE = 'Active'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P2#(lf)            ON  P2.ENTITYID = CLEAN_UNIT_PRE.UNIT_EXTERNAL_ID#(lf)            AND P2.CURRENT_FLAG = 'Y' AND P2.PROPERTY_STATE = 'Active'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P3#(lf)            ON  INITCAP(TRIM(P3.ADDRESS)) = INITCAP(TRIM(CLEAN_UNIT_PRE.UNIT_LINE_1))#(lf)            AND P3.CURRENT_FLAG = 'Y' AND P3.PROPERTY_STATE = 'Active'#(lf)        LEFT JOIN (#(lf)            SELECT LEFT(INITCAP(TRIM(ADDRESS)), 10) AS ADD_TRIM, MAX(PROPERTY_KEY) AS PROPERTY_KEY#(lf)            FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY#(lf)            WHERE CURRENT_FLAG = 'Y' AND PROPERTY_STATE = 'Active'#(lf)            GROUP BY LEFT(INITCAP(TRIM(ADDRESS)), 10)#(lf)        ) P4#(lf)            ON ADD_TRIM = LEFT(INITCAP(TRIM(CLEAN_UNIT_PRE.UNIT_LINE_1)), 10)#(lf)    WHERE CLEAN_UNIT_PRE.RECENT_RANK = 1#(lf))#(lf)#(lf),CLEAN_INPSECTION AS (#(lf)    SELECT#(lf)         INS._MODIFIED#(lf)        ,INS._LINE#(lf)        ,INS.INSPECTION_ID#(lf)        ,INS.INSPECTION_INSPECTOR_NAME#(lf)        ,INS.INSPECTION_COMPLETED_DATE#(lf)        ,INS.INSPECTION_STATUS#(lf)        ,INS.INSPECTION_TEMPLATE#(lf)        ,INS.INSPECTION_LINK#(lf)        ,INS.UNIT_ID#(lf)        ,RANK() OVER (PARTITION BY INS.INSPECTION_ID ORDER BY DATE_TRUNC('min', _MODIFIED) DESC) AS RECENT_RANK#(lf)    FROM PROD_REPLICA.HAPPY_CO.INSPECTION INS#(lf))#(lf)#(lf),HAPPY_CO_DETAIL AS (#(lf)    SELECT DISTINCT#(lf)         CLEAN_UNIT.PROPERTY_KEY#(lf)        ,CLEAN_UNIT.UNIT_ID#(lf)        ,CLEAN_UNIT.UNIT_EXTERNAL_ID#(lf)        ,CLEAN_UNIT.UNIT_Address#(lf)        ,CLEAN_UNIT.UNIT_LINE_1#(lf)        ,RANK() OVER (PARTITION BY CLEAN_UNIT.PROPERTY_KEY#(lf)                      ORDER BY CLEAN_INPSECTION.INSPECTION_COMPLETED_DATE DESC,#(lf)                               CLEAN_INPSECTION.INSPECTION_ID DESC) AS RECENT_INS_RANK#(lf)        ,CLEAN_INPSECTION.INSPECTION_ID#(lf)        ,CLEAN_INPSECTION.INSPECTION_INSPECTOR_NAME#(lf)        ,CLEAN_INPSECTION._LINE#(lf)        ,CLEAN_INPSECTION.INSPECTION_COMPLETED_DATE#(lf)        ,CLEAN_INPSECTION.INSPECTION_STATUS#(lf)        ,CLEAN_INPSECTION.INSPECTION_TEMPLATE#(lf)        ,CLEAN_INPSECTION.INSPECTION_LINK#(lf)        ,CLEAN_ITEM.ITEM_Section#(lf)        ,CLEAN_ITEM.ITEM_Item#(lf)        ,CLEAN_ITEM.ITEM_Ratings#(lf)        ,CLEAN_ITEM.ITEM_Notes#(lf)        ,CASE WHEN CLEAN_ITEM.ITEM_Section = 'Report Status' THEN 1 ELSE 0 END AS Report_Status#(lf)        ,CASE WHEN CLEAN_ITEM.ITEM_Section = 'Pre Leasing Status' THEN 1 ELSE 0 END AS PreLease_Status#(lf)        ,CASE WHEN CLEAN_ITEM.ITEM_ITEM = 'Resident Maintaining the Home / Condition OK to Renew?' THEN 1 ELSE 0 END AS Renewal_Trustee_Status#(lf)    FROM CLEAN_INPSECTION#(lf)        LEFT JOIN CLEAN_ITEM#(lf)            ON  CLEAN_ITEM.INSPECTION_ID = CLEAN_INPSECTION.INSPECTION_ID#(lf)            AND CLEAN_ITEM.RECENT_RANK = 1#(lf)            AND CLEAN_ITEM.UPDATE_RANK = 1#(lf)        LEFT JOIN CLEAN_UNIT#(lf)            ON  CLEAN_UNIT.UNIT_ID = CLEAN_INPSECTION.UNIT_ID#(lf)            AND CLEAN_UNIT.RECENT_RANK = 1#(lf)    WHERE 1 = 1#(lf)        AND CLEAN_INPSECTION.RECENT_RANK = 1#(lf)        AND CLEAN_INPSECTION.INSPECTION_STATUS = 'Complete'#(lf)        AND CLEAN_INPSECTION.INSPECTION_TEMPLATE LIKE '%Trustee Leased Inspection%'#(lf)        AND CLEAN_ITEM.ITEM_SECTION IS NOT NULL#(lf))#(lf)#(lf),HAPPY_CO_RENEWAL AS (#(lf)    SELECT#(lf)         HCD.PROPERTY_KEY#(lf)        ,HCD.INSPECTION_LINK#(lf)        ,HCD.INSPECTION_COMPLETED_DATE#(lf)        ,MAX(CASE WHEN Renewal_Trustee_Status = 1 THEN ITEM_Ratings ELSE NULL END) AS Renewal_Trustee_Status#(lf)    FROM HAPPY_CO_DETAIL HCD#(lf)    WHERE 1 = 1#(lf)        AND HCD.RECENT_INS_RANK = 1#(lf)    GROUP BY#(lf)         HCD.PROPERTY_KEY#(lf)        ,HCD.INSPECTION_LINK#(lf)        ,HCD.INSPECTION_COMPLETED_DATE#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: RENEWALS#(lf)   The core renewal row. Pairs the current lease (C_*) with the next lease (N_*)#(lf)   via LeaseRanking, derives renewal-result buckets, renewal-note flags, and#(lf)   pulls UW rent + HappyCo inspection + eviction context.#(lf)   ----------------------------------------------------------------------------- */#(lf),RENEWALS AS (#(lf)    SELECT#(lf)         TLH.TENANTLEASINGHISTORYID#(lf)        ,TLH.TENANTINFORMATIONID#(lf)        ,T.TENANT_KEY#(lf)        ,T.CURRENT_FLAG#(lf)        ,P.PROPERTY_KEY#(lf)        ,P.HBPM_PROPERTY_ID#(lf)        ,PO.PORTFOLIO_NAME#(lf)#(lf)        -- [SYNC] organization roll-up — mirrors master PROPERTY script.#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)            ELSE P.ORGANIZATION_KEY#(lf)         END AS ORGANIZATION_KEY#(lf)#(lf)        ,CASE#(lf)            WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)            WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)            WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)            WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)            WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)            WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)            ELSE O.ORGANIZATION_NAME#(lf)         END AS ORGANIZATION_NAME#(lf)#(lf)        ,P.ADDRESS#(lf)        ,P.ADDRESS || ', ' || COALESCE(CI.CITY_NAME, PM_CI.CityName) || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS Full_Address#(lf)        ,P.ENTITYID#(lf)        ,TI.TENANTSTATUSID#(lf)        ,TS.DESCRIPTION AS ""TENANTSTATUS""#(lf)        ,EV.EVICTION_EVICTIONSTATUSID#(lf)        ,EV.EVICTION_EVICTIONSTATUS AS ""EVICTIONSTATUS""#(lf)        ,U.FULL_NAME#(lf)        ,U.EMAIL_ADDRESS#(lf)        ,U.PHONE_NUMBER#(lf)        ,TI.MOVEIN#(lf)        ,TI.MOVEOUT#(lf)        ,DATE_TRUNC('month', TI.MoveOut) AS MOVEOUT_BOM#(lf)        ,TI.AnticipatedMoveOutDate#(lf)        ,TI.MONTHTOMONTH#(lf)        ,TI.NOTICEDATE#(lf)        ,TI.ISMONTHTOMONTHLEASE#(lf)        ,TI.TENANTDECIDEDMONTHTOMONTH#(lf)        ,CASE WHEN TI.DONOTRENEW = FALSE THEN NULL ELSE TI.DONOTRENEW END AS DONOTRENEW#(lf)        ,TI.REASONFORNOTRENEWINGID#(lf)        ,TI.PrimaryTenant#(lf)        ,COALESCE(TI.IsSection8, 'N') AS IsSection8#(lf)        ,DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf)#(lf)        -- ---- Current lease (C_*) ----#(lf)        ,TLH.CREATED        AS ""C_CREATED""#(lf)        ,LR.Lease_Rank      AS ""C_LEASENUMBER""#(lf)        ,LR.Lease_Rank_INV  AS ""C_LEASENUMBER_INV""#(lf)        ,TLH.LEASESIGNED    AS ""C_LEASESIGNED""#(lf)        ,TLH.LEASESTART     AS ""C_LEASESTART""#(lf)        ,TLH.LEASEEND       AS ""C_LEASEEND""#(lf)        ,TLH.ISRENEWAL      AS ""C_ISRENEWAL""#(lf)        ,TLH.AMOUNT         AS ""C_AMOUNT""#(lf)        ,F_TLH.LEASING_CONCESSION_AMOUNT AS ""C_LEASING_CONCESSION""#(lf)        ,F_TLH.OWNER_CONCESSION_AMOUNT   AS ""C_OWNER_CONCESSION""#(lf)#(lf)        -- ---- Next lease (N_*) ----#(lf)        ,TLH_N.CREATED       AS ""N_CREATED""#(lf)        ,LR_N.Lease_Rank     AS ""N_LEASENUMBER""#(lf)        ,LR_N.Lease_Rank_INV AS ""N_LEASENUMBER_INV""#(lf)        ,TLH_N.LEASESIGNED   AS ""N_LEASESIGNED""#(lf)        ,TLH_N.LEASESTART    AS ""N_LEASESTART""#(lf)        ,TLH_N.LEASEEND      AS ""N_LEASEEND""#(lf)        ,TLH_N.ISRENEWAL     AS ""N_ISRENEWAL""#(lf)        ,TLH_N.AMOUNT        AS ""N_AMOUNT""#(lf)        ,F_TLH_N.LEASING_CONCESSION_AMOUNT AS ""N_LEASING_CONCESSION""#(lf)        ,F_TLH_N.OWNER_CONCESSION_AMOUNT   AS ""N_OWNER_CONCESSION""#(lf)#(lf)        ,CASE WHEN TLH_N.AMOUNT IS NOT NULL AND TLH.AMOUNT IS NOT NULL#(lf)              THEN DIV0NULL(TLH_N.AMOUNT, TLH.AMOUNT) - 1#(lf)              ELSE NULL#(lf)         END AS RENT_GROWTH#(lf)#(lf)        -- ---- Renewal eligibility / result buckets ----#(lf)        ,CASE WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)              THEN 'Not Eligible' ELSE 'Eligible'#(lf)         END AS ""Lease Eligibility""#(lf)#(lf)        ,CASE WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)              THEN 'Vacated Early' ELSE 'Vacated w/ Lease Exp'#(lf)         END AS ""Lease Eligibility_FILTER""#(lf)#(lf)        ,CASE#(lf)            WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)                 AND (TI.REASONFORNOTRENEWINGID = 3156 OR TI.REASONFORNOTRENEWINGID = 3157)#(lf)                THEN ' Early Vacate - Evictions'#(lf)            WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)                 AND TI.REASONFORNOTRENEWINGID <> 3156 AND TI.REASONFORNOTRENEWINGID <> 3164 AND TI.REASONFORNOTRENEWINGID <> 3157#(lf)                THEN ' Early Vacate - Other'#(lf)            WHEN TLH_N.LEASESIGNED IS NOT NULL OR TI.REASONFORNOTRENEWINGID = 3164#(lf)                THEN 'Renewed'#(lf)            WHEN TS.DESCRIPTION = 'Notice' OR TS.DESCRIPTION = 'Past'#(lf)                THEN 'Notice'#(lf)            WHEN TI.TENANTDECIDEDMONTHTOMONTH = 1 OR TI.REASONFORNOTRENEWINGID = 3143 OR TI.MONTHTOMONTH = 'Yes'#(lf)                THEN 'MTM'#(lf)            WHEN (TS.DESCRIPTION = 'Under Eviction') OR TI.REASONFORNOTRENEWINGID = 3156#(lf)                THEN 'Current Eviction'#(lf)            ELSE 'Pending'#(lf)         END AS ""Renewal Result""#(lf)#(lf)        ,CASE#(lf)            WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)                 AND (TI.REASONFORNOTRENEWINGID = 3156 OR TI.REASONFORNOTRENEWINGID = 3157)#(lf)                THEN '6'#(lf)            WHEN TI.MOVEOUT IS NOT NULL AND TI.MOVEOUT < DATEADD(DAY, -30, TLH.LEASEEND)#(lf)                 AND TI.REASONFORNOTRENEWINGID <> 3156 AND TI.REASONFORNOTRENEWINGID <> 3164 AND TI.REASONFORNOTRENEWINGID <> 3157#(lf)                THEN '7'#(lf)            WHEN TLH_N.LEASESIGNED IS NOT NULL OR TI.REASONFORNOTRENEWINGID = 3164#(lf)                THEN '5'#(lf)            WHEN TS.DESCRIPTION = 'Notice' OR TS.DESCRIPTION = 'Past'#(lf)                THEN '2'#(lf)            WHEN TI.TENANTDECIDEDMONTHTOMONTH = 1 OR TI.REASONFORNOTRENEWINGID = 3143 OR TI.MONTHTOMONTH = 'Yes'#(lf)                THEN '3'#(lf)            WHEN (TS.DESCRIPTION = 'Under Eviction') OR TI.REASONFORNOTRENEWINGID = 3156#(lf)                THEN '4'#(lf)            ELSE '1'#(lf)         END AS ""Renewal Result ID""#(lf)#(lf)        ,CASE#(lf)            WHEN (TI.MONTHTOMONTH = 'Y' OR (C_LEASEEND IS NOT NULL AND C_LEASEEND < GETDATE())) AND TS.DESCRIPTION <> 'Past'#(lf)                THEN 1#(lf)            WHEN DATE_TRUNC('month', TLH.LEASEEND) <= DATEADD(MONTH, 3, DATE_TRUNC('month', GETDATE()))#(lf)                 AND DATE_TRUNC('month', TLH.LEASEEND) >= DATEADD(MONTH, -3, DATE_TRUNC('month', GETDATE()))#(lf)                THEN 1#(lf)            ELSE NULL#(lf)         END AS ""YTD Filter""#(lf)#(lf)        ,CASE#(lf)            WHEN DATE_TRUNC('month', TLH.LEASEEND) <= DATEADD(MONTH, 5, DATE_TRUNC('month', GETDATE()))#(lf)                 AND DATE_TRUNC('month', TLH.LEASEEND) >= DATEADD(MONTH, -3, DATE_TRUNC('month', GETDATE()))#(lf)                THEN 1#(lf)            ELSE NULL#(lf)         END AS ""3M Filter""#(lf)#(lf)        ,.67 AS ""0_Renewal Goal""#(lf)        ,.1  AS ""0_Rent_Growth_Goal""#(lf)        ,DATE_TRUNC('month', TLH.LEASEEND) AS ""1_C_LeaseEnd(BOM)""#(lf)#(lf)        ,CASE WHEN TLH_N.LEASESIGNED IS NOT NULL OR TI.MOVEOUT IS NULL THEN NULL#(lf)              ELSE DATE_TRUNC('month', COALESCE(TI.MOVEOUT, TLH.LEASEEND))#(lf)         END AS ""Vacate Date (BOM)""#(lf)#(lf)        ,RNOTE.NoteText    AS RenewalNote#(lf)        ,RNOTE.CreatedDate AS RenewalNoteCreated#(lf)        ,CASE#(lf)            WHEN TI.AnticipatedMoveOutDate IS NOT NULL#(lf)                 AND (RNOTE.CreatedDate IS NULL OR LAST_CALL.PROPERTY_LAST_CALL_DATE IS NULL)#(lf)                 AND TS.DESCRIPTION = 'Notice'#(lf)                THEN 'Needs Updated Renewal Note'#(lf)            WHEN TI.AnticipatedMoveOutDate IS NOT NULL#(lf)                 AND TI.NOTICEDATE > RNOTE.CreatedDate#(lf)                 AND TS.DESCRIPTION = 'Notice'#(lf)                 AND RU.FIRSTNAME || ' ' || RU.LASTNAME NOT IN#(lf)                     ('Abby Nolasco','Cedric Cagurol','Kelvin Espada','Lorelie Bate','Reste delarama','Roman Quesada')#(lf)                THEN 'Needs Updated Renewal Note'#(lf)            WHEN TI.AnticipatedMoveOutDate IS NOT NULL#(lf)                 AND TI.NOTICEDATE > LAST_CALL.PROPERTY_LAST_CALL_DATE#(lf)                 AND TS.DESCRIPTION = 'Notice'#(lf)                THEN 'Needs Updated Renewal Note'#(lf)            ELSE NULL#(lf)         END AS Renewal_Note_Flag#(lf)#(lf)        ,RU.FIRSTNAME || ' ' || RU.LASTNAME AS RenewalNote_Added_By#(lf)        ,CASE#(lf)            WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased'#(lf)            WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)            ELSE PUS.Occupancy_Status#(lf)         END AS Occupancy_Status#(lf)#(lf)        ,UW_Rent.UW_Rent_Prior#(lf)        ,UW_Rent.UW_Rent_Current#(lf)        ,UW_Rent.UW_Update_Date AS UW_Update_Date#(lf)        ,DATEDIFF('day', UW_Rent.UW_Update_Date, GETDATE()) AS UW_Days_Since_Update#(lf)#(lf)        ,HCR.INSPECTION_LINK#(lf)        ,HCR.INSPECTION_COMPLETED_DATE#(lf)        ,HCR.Renewal_Trustee_Status#(lf)        ,'https://honeybadgerpm.com/PropertyModule#/PropertyDetails/' || HBPM.PROPERTYID || '/' || PM_AI.UnitID || '/0' AS HBPM_URL#(lf)        ,'https://honeybadgerpm.com/PeopleModule#/TenantDetails/'     || U.User_ID || '/' || TI.TenantInformationId AS TENANT_URL#(lf)#(lf)        ,CASE WHEN TS.DESCRIPTION = 'Past' AND TI.MOVEOUT IS NULL THEN 'Missing MO Date' ELSE NULL END AS MO_DATE_FLAG#(lf)#(lf)        ,CASE#(lf)            WHEN TS.DESCRIPTION = 'Past' THEN 'No'#(lf)            WHEN TLH_N.LEASESIGNED IS NOT NULL AND TLH_N.LEASEEND > TLH.LEASEEND THEN 'No'#(lf)            WHEN TI.MONTHTOMONTH = 'Y' OR (C_LEASEEND IS NOT NULL AND C_LEASEEND < GETDATE()) THEN 'Yes'#(lf)            ELSE 'No'#(lf)         END AS MTM_FLAG#(lf)#(lf)        ,EC.EVICTION_COUNT#(lf)        ,E.EVICTION_EVICTIONTERMINATEDDATE#(lf)        ,AM_STRATEGY.STRATEGYNAME AS STRATEGY_NAME#(lf)        ,PU.SQUARE_FOOTAGE#(lf)        ,P.FloorPlan#(lf)        ,'Renewal' AS TYPE#(lf)        ,LAST_CALL.PROPERTY_LAST_CALL_DATE#(lf)#(lf)    FROM PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES TLH#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_HIST F_TLH#(lf)            ON F_TLH.TENANT_LEASING_HISTORY_ID = TLH.TenantLeasingHistoryId#(lf)#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI#(lf)            ON TI.TenantInformationId = TLH.TenantInformationId#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)            ON  T.TENANT_INFORMATION_ID = TI.TenantInformationId#(lf)            AND T.Current_FLAG = 'Y'#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS TS#(lf)            ON TS.LookUpMasterId = TI.TenantStatusId#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TSUM#(lf)            ON TSUM.TENANT_KEY = T.TENANT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U#(lf)            ON U.USER_KEY = TSUM.USER_KEY#(lf)#(lf)        LEFT JOIN EVICTIONS EV#(lf)            ON EV.TENANTINFORMATIONID = T.TENANT_INFORMATION_ID#(lf)#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS DNR#(lf)            ON DNR.LookUpMasterId = TI.ReasonForNotRenewingId#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI#(lf)            ON PAI.UnitId = TI.UnitId#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM#(lf)            ON HBPM.PropertyId = PAI.PropertyId#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_AI#(lf)            ON  PM_AI.PROPERTYID = HBPM.PROPERTYID#(lf)            AND PM_AI.""_FIVETRAN_DELETED"" = 'N'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)            ON  P.HBPM_PROPERTY_ID = HBPM.PROPERTYID#(lf)            AND P.Current_FLAG = 'Y'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS#(lf)            ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU#(lf)            ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO#(lf)            ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O#(lf)            ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_CITY CI#(lf)            ON CI.CITY_KEY = PUS.CITY_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.Cities PM_CI#(lf)            ON PM_CI.CityID = HBPM.CityID#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_STATE S#(lf)            ON S.STATE_KEY = PUS.STATE_KEY#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM#(lf)            ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.BidAndAuctions AM_BA#(lf)            ON  AM_BA.BIDID = HBAM.BidAndAuction_BidId#(lf)            AND AM_BA.HBID = HBAM.HBID#(lf)            AND AM_BA.""_FIVETRAN_DELETED"" <> 'Y'#(lf)        LEFT JOIN PROD_REPLICA.HBAM_DBO.Strategies AM_STRATEGY#(lf)            ON AM_STRATEGY.STRATEGYID = AM_BA.BIDSTRATEGYSTATUS#(lf)#(lf)        /* Current lease rank, then walk to the next lease (rank + 1) */#(lf)        LEFT JOIN LeaseRanking LR#(lf)            ON LR.TenantLeasingHistoryId = TLH.TenantLeasingHistoryId#(lf)        LEFT JOIN LeaseRanking LR_N#(lf)            ON  LR_N.TenantInformationId = TLH.TenantInformationId#(lf)            AND LR_N.Lease_Rank = (LR.Lease_Rank + 1)#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTLEASINGHISTORIES TLH_N#(lf)            ON  TLH_N.TenantLeasingHistoryId = LR_N.TenantLeasingHistoryId#(lf)            AND TLH._FIVETRAN_DELETED <> 'Y'#(lf)        LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_HIST F_TLH_N#(lf)            ON F_TLH_N.TENANT_LEASING_HISTORY_ID = TLH_N.TenantLeasingHistoryId#(lf)#(lf)        /* Renewal note + author */#(lf)        LEFT JOIN RenewalNote RN#(lf)            ON RN.PropertyID = P.HBPM_PROPERTY_ID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.NOTES RNOTE#(lf)            ON RNOTE.NOTEID = RN.LatestNoteID#(lf)        LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS RU#(lf)            ON RU.USERID = RNOTE.ADDEDBY#(lf)#(lf)        LEFT JOIN UW_RENT#(lf)            ON UW_Rent.HBPM_UnitID = PAI.UnitID#(lf)        LEFT JOIN HAPPY_CO_RENEWAL HCR#(lf)            ON HCR.PROPERTY_KEY = P.PROPERTY_KEY#(lf)        LEFT JOIN EVICTION_COUNT EC#(lf)            ON EC.TENANTINFORMATIONID = TLH.TENANTINFORMATIONID#(lf)        LEFT JOIN EVICTIONS E#(lf)            ON E.TENANTINFORMATIONID = TI.TenantInformationId#(lf)        LEFT JOIN LAST_CALL#(lf)            ON LAST_CALL.PROPERTY_HBPM_TENANT_ID = TI.TenantInformationId#(lf)#(lf)    WHERE 1 = 1#(lf)        AND TI.PrimaryTenant = 1#(lf)        AND TLH._FIVETRAN_DELETED <> 'Y'#(lf)        AND P.PROPERTY_STATE = 'Active'#(lf)        AND P.EntityID <> ''#(lf)        AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952, 1867, 1916, 1852, 1771, 1919, 1873)#(lf)        AND P.Organization_KEY NOT IN (16, 17)#(lf)        AND PO.IS_Active_AM = 'Y'#(lf)        AND PO.Current_Flag = 'Y'#(lf)        AND P.Current_Flag = 'Y'#(lf)        AND PU.Current_Flag = 'Y'#(lf)        AND PUS.Occupancy_Status NOT IN ('Property SOLD', 'Not Managed')#(lf)        AND T.TENANT_KEY NOT IN (70575)#(lf))#(lf)#(lf)/* -----------------------------------------------------------------------------#(lf)   CTE: DEAL_RANK#(lf)   Most recent renewal deal matched to each renewal row (by entity id and the#(lf)   renewal start landing within the current lease's renewal window).#(lf)   ----------------------------------------------------------------------------- */#(lf),DEAL_RANK AS (#(lf)    SELECT#(lf)         R.TENANT_KEY#(lf)        ,R.PROPERTY_KEY#(lf)        ,R.""C_LEASENUMBER""#(lf)        ,RD.DEAL_ID#(lf)        ,RANK() OVER (#(lf)            PARTITION BY R.TENANT_KEY, R.PROPERTY_KEY, R.""C_LEASENUMBER""#(lf)            ORDER BY CREATED_DATE DESC, DEAL_KEY DESC#(lf)         ) AS DEAL_RANK#(lf)    FROM RENEWALS R#(lf)        LEFT JOIN RENEWAL_DEAL RD#(lf)            ON  RD.PROPERTY_ENTITY_ID = R.EntityID#(lf)            AND RD.RENEWAL_START_DATE >  DATEADD('day', -30, R.""C_LEASEEND"")#(lf)            AND RD.RENEWAL_START_DATE <= COALESCE(R.""N_LEASESTART"", DATE('12-31-9999', 'MM-DD-YYYY'))#(lf)            AND RD.CURRENT_DEAL_STATUS <> 'Renewal Canceled'#(lf)    QUALIFY DEAL_RANK = 1#(lf))#(lf)#(lf)#(lf)/* =============================================================================#(lf)   FINAL SELECT#(lf)   Renewal rows + their matched renewal deal + a fixed late-fee import template.#(lf)   ============================================================================= */#(lf)SELECT#(lf)     R.*#(lf)    ,RD.CURRENT_DEAL_STATUS AS RENEWAL_DEAL_STATUS#(lf)    ,RD.DEAL_OWNER          AS RENEWAL_OWNER#(lf)    ,RD.DEAL_NAME           AS RENEWAL_DEAL_NAME#(lf)    ,RD.DEAL_ID#(lf)    ,RD.MARR#(lf)    ,RD.RATE_12_MONTH#(lf)    ,RD.RATE_15_MONTH#(lf)    ,RD.RATE_18_MONTH#(lf)    ,RD.RATE_24_MONTH#(lf)    ,RD.MARKET_RENT#(lf)    ,RD.PROPERTY_LEASE_DRAFTING_STATUS AS RENEWAL_LEASE_STATUS#(lf)    ,'https://app.hubspot.com/contacts/22536354/record/0-3/' || RD.DEAL_ID || '/' AS RENEWAL_LINK#(lf)    ,HUBSPOT.ID AS HUBSPOT_RECORD_ID#(lf)#(lf)    -- Fixed late-fee charge import template#(lf)    ,'Charge'              AS IMPORT_TYPE#(lf)    ,GETDATE()             AS IMPORT_Due_Date#(lf)    ,100                   AS IMPORT_AMOUNT#(lf)    ,4004063               AS IMPORT_GL_ACCOUNT#(lf)    ,'PM Renewal Late Fee' AS IMPORT_GL_ACCOUNT_DESC#(lf)    ,'Renewal Late Fee'    AS IMPORT_DESCRIPTION#(lf)    ,NULL AS IMPORT_HBPM_User#(lf)    ,NULL AS IMPORT_Tenant_Note#(lf)    ,NULL AS IMPORT_Tenant_Note_Type#(lf)#(lf)    ,CASE#(lf)        WHEN EVICTION_COUNT >= 3#(lf)             AND ""TENANTSTATUS"" = 'Current'#(lf)             AND EVICTION_EVICTIONTERMINATEDDATE > DATEADD('d', -90, GETDATE())#(lf)             AND RD.CURRENT_DEAL_STATUS IS NOT NULL#(lf)             AND RD.CURRENT_DEAL_STATUS <> 'Renewal Won'#(lf)            THEN 'Send Non-Renewal'#(lf)        ELSE NULL#(lf)     END AS DNR_FLAG#(lf)#(lf)FROM RENEWALS R#(lf)    LEFT JOIN DEAL_RANK DR#(lf)        ON  DR.TENANT_KEY    = R.TENANT_KEY#(lf)        AND DR.PROPERTY_KEY  = R.PROPERTY_KEY#(lf)        AND DR.""C_LEASENUMBER"" = R.""C_LEASENUMBER""#(lf)    LEFT JOIN RENEWAL_DEAL RD#(lf)        ON RD.DEAL_ID = DR.DEAL_ID#(lf)    LEFT JOIN HUBSPOT#(lf)        ON HUBSPOT.PROPERTY_ENTITY_ID = R.EntityID", null, [EnableFolding=true]),
				    #"Capitalized Each Word" = Table.TransformColumns(Source,{{"REASONFORNOTRENEWINGNAME", Text.Proper, type text}, {"FULL_NAME", Text.Proper, type text}, {"FLOORPLAN", Text.Proper, type text}}),
				    #"Changed Type" = Table.TransformColumnTypes(#"Capitalized Each Word",{{"ISSECTION8", type logical}})
				in
				    #"Changed Type"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

