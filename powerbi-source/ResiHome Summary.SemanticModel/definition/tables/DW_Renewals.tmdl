	column 1_12_Month_Suggested = ```
			IF(COUNT(DW_Rent_Comps[FLOORPLAN])=BLANK(),BLANK(),MROUND(
			    MAX(
			        MIN(( 
			            IF(RELATED(DW_Rent_Comps[LISTED_RENT_COUNT])<>BLANK(),RELATED(DW_Rent_Comps[LISTED_RENT_AVG]),RELATED(DW_Rent_Comps[TENANT_RENT_AVG]))*.5+
			            RELATED(DW_Rent_Comps[TENANT_RENT_MAX])*.25+
			            RELATED(DW_Rent_Comps[TENANT_RENT_MOST_RECENT])*.25) * (1+
			            IF(RELATED(DW_Rent_Comps[LISTED_DOM_AVG])=BLANK(),.015,
			            IF(RELATED(DW_Rent_Comps[LISTED_DOM_AVG])<=35&&RELATED(DW_Rent_Comps[TENANT_DOM_AVG])<=60,.01,
			            IF(RELATED(DW_Rent_Comps[LISTED_DOM_AVG])<=60&&RELATED(DW_Rent_Comps[TENANT_DOM_AVG])<=75,.005,
			            .000)))),
			            DW_Renewals[C_AMOUNT] * 1.04),
			            DW_Renewals[C_AMOUNT] * 1.0175),5))
			```
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 397d04bd-e06a-4366-96be-2af62770906a
		summarizeBy: sum

