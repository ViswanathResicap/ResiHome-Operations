table DW_Renewals
	lineageTag: dc00b77d-69ec-4c60-826e-030069192ab7

	measure '0_Rent Growth' = ```
			if(average(DW_Renewals[N_AMOUNT])=BLANK(),BLANK(),CALCULATE( DIVIDE(AVERAGE(DW_Renewals[N_AMOUNT]), AVERAGE(DW_Renewals[C_AMOUNT]), BLANK()) -1,DW_Renewals[N_AMOUNT]<>BLANK()))
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: cfce74a2-11c2-4239-b1be-bb8853c37e79

		changedProperty = FormatString

	measure '0_R_Renewal %' = ```
			calculate(COUNTROWS(DW_Renewals),DW_Renewals[Renewal Result]="Renewed")/CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[STRATEGY_NAME]<>"Repair/Sell")
			
			```
		formatString: 0%;-0%;0%
		lineageTag: 5c463085-0ea6-49de-9cab-915f22831887

		changedProperty = FormatString

	measure '0_Renewal Count' = COUNT(DW_Renewals[PROPERTY_KEY]) +0
		formatString: #,0
		lineageTag: 8b4d3934-8896-46ff-8b5f-eef2c2a531f3

		changedProperty = FormatString

	measure '0_Current Rent' = ```
			calculate(AVERAGE(DW_Renewals[C_AMOUNT]),DW_Renewals[N_AMOUNT]<>BLANK())
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 1729e25b-edb9-474e-97c4-b9ff8b08cd5e

		changedProperty = FormatString

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure '0_Renewal Chart %' = ```
			IF(MAX(DW_Renewals[YTD Filter])=1&&COUNT(DW_Renewals[PROPERTY_KEY])>0,COALESCE(calculate(COUNTROWS(DW_Renewals),DW_Renewals[N_LEASESIGNED]<>BLANK()),0)/COUNT(DW_Renewals[PROPERTY_KEY]), calculate(COUNTROWS(DW_Renewals),DW_Renewals[N_LEASESIGNED]<>BLANK())/COUNT(DW_Renewals[PROPERTY_KEY]))
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: c58a5e9b-bb5c-4854-8db3-937792ca322e

		changedProperty = FormatString

	measure '0_Gross_Renewal (L3) %' = ```
			calculate(COUNTROWS(DW_Renewals),FILTER(DW_Renewals,DW_Renewals[N_LEASESIGNED]<>BLANK()&&DW_Renewals[Lease Eligibility]="Eligible")) / CALCULATE(COUNT(DW_Renewals[PROPERTY_KEY]),DW_Renewals[Lease Eligibility]="Eligible")
			
			```
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 107a72d2-87de-43f1-adec-267970bf2093

	measure 0_Eligible = ```
			CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[Lease Eligibility]="Eligible")
			
			```
		formatString: 0
		lineageTag: f36eed43-1787-4ada-b951-035a768e9986

	measure '0_Eviction Exposure' = CALCULATE(COUNTROWS(DW_Renewals),FILTER(DW_Renewals,DW_Renewals[Renewal Result]="Current Eviction"||DW_Renewals[Renewal Result]=" Early Vacate - Evictions")) / CALCULATE(COUNTROWS(DW_Renewals))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: a9b28f3e-ea3a-4545-b982-02f62b4dcd9a

	measure '0_Max Renewal' = CALCULATE(COUNTROWS(DW_Renewals),FILTER(DW_Renewals,DW_Renewals[Renewal Result]="Renewed"||DW_Renewals[Renewal Result]="Pending")) / CALCULATE(COUNTROWS(DW_Renewals),FILTER(DW_Renewals,AND(DW_Renewals[STRATEGY_NAME]<>"Repair/Sell",DW_Renewals[Renewal Result]="Renewed"||DW_Renewals[Renewal Result]="Notice"||DW_Renewals[Renewal Result]="MTM"||DW_Renewals[Renewal Result]="Pending")))
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: 00ccd38c-2ebd-4771-8b1f-df9bfe716605

	measure 0_ET_Other = ```
			CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[Renewal Result]=" Early Vacate - Other") / CALCULATE(COUNTROWS(DW_Renewals))
			
			```
		formatString: 0%;-0%;0%
		lineageTag: 7afad579-0b0f-443b-bccb-2f59438614ab

	measure '0_Active Renew %' = ```
			CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[Renewal Result]="Renewed") / CALCULATE(COUNTROWS(DW_Renewals),FILTER(DW_Renewals,AND(DW_Renewals[STRATEGY_NAME]<>"Repair/Sell",DW_Renewals[Renewal Result]="Renewed"||DW_Renewals[Renewal Result]="Notice"||DW_Renewals[Renewal Result]="MTM")))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: e23fa608-36fb-4645-9235-9789710ea987

	measure '0_Implied Retention' = ```
			(([0_Active Renew %] * CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[Renewal Result]="Pending") ) + (CALCULATE(COUNTROWS(DW_Renewals),DW_Renewals[Renewal Result]="Renewed"))) / CALCULATE(COUNTROWS(DW_Renewals))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 3df98cbd-7168-4766-87df-deba2692e429

	measure 0_1_YR_Offer_Mrkt_Prem = ```
			if(AVERAGE(DW_Renewals[MARKET_RENT])=blank(),blank(),CALCULATE(DIVIDE(AVERAGE(DW_Renewals[RATE_12_MONTH]), AVERAGE(DW_Renewals[MARKET_RENT]), BLANK())-1,FILTER(DW_Renewals,DW_Renewals[RATE_12_MONTH]>0&&DW_Renewals[MARKET_RENT]>0)))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: c2babdd2-f9f3-420d-b146-390a19fbbb81

	measure 0_1_YR_Offer_Rent_Growth = ```
			if(AVERAGE(DW_Renewals[RATE_12_MONTH])=blank(),blank(),CALCULATE(DIVIDE(AVERAGE(DW_Renewals[RATE_12_MONTH]), AVERAGE(DW_Renewals[C_AMOUNT]), BLANK())-1,FILTER(DW_Renewals,DW_Renewals[RATE_12_MONTH]>0&&DW_Renewals[C_AMOUNT]>0)))
			
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 21fb5fc6-3c5e-4fce-abc1-ec06f6aa9cfa

