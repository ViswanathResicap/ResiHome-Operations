),TI.TICKET_ID#(lf),WO.WORKORDER_KEY#(lf),TI.TICKET_TYPE#(lf),COALESCE(TI.TICKET_TYPE, 'Maintenance') AS TICKET_TYPE_CLOSED#(lf),TI.TICKET_STATUS#(lf),WO.WORKORDER_ID#(lf),COALESCE(WO.MAINT_ID,TI.ID_KEY) AS MAINT_ID#(lf),WO.HBH_ID_KEY#(lf) #(lf),CASE WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Accepted' AND to_date(INSP_START_DATE_KEY ::TEXT,'yyyymmdd') IS NULL THEN 'WO Accepted (TBD)'#(lf)      WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Accepted' AND to_date(INSP_START_DATE_KEY ::TEXT,'yyyymmdd') < DATEADD(D, -1, GETDATE()) THEN 'WO Accepted (Past Due)'#(lf)      WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Accepted' THEN 'WO Accepted (Scheduled)'#(lf)#(lf)      WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Pending Completion' AND to_date(WO_END_DATE_KEY ::TEXT,'yyyymmdd') IS NULL THEN 'WO Pending Completion (TBD)'#(lf)      WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Pending Completion' AND to_date(WO_END_DATE_KEY::TEXT,'yyyymmdd') < DATEADD(D, -1, GETDATE()) THEN 'WO Pending Completion (Past Due)'#(lf)      WHEN COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) = 'WO Pending Completion' THEN 'WO Pending Completion (Scheduled)'#(lf)      ELSE COALESCE(WO.WORKORDER_STATUS,TI.TICKET_STATUS) #(lf)      END AS WORKORDER_STATUS#(lf)#(lf),COALESCE(WO.PRIORITY,TI.PRIORITY) AS PRIORITY#(lf),WO.BILL_TO#(lf)#(lf),P.Property_Key#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf),CASE#(lf)        