	column '1_Warranty Check' =
			IF(DW_WO[WORKORDER_STATUS]="Cancelled"||DW_WO[BILL_TO]<>"Owner",BLANK(),
			IF(DW_WO[Purchase Type]="New Construction"&&DW_WO[Purchase_Date]>(TODAY()-365)&&DW_WO[Purchase_Date]<>BLANK(),"New Construction Warranty",
			IF(DW_WO[Purchase Type]<>"New Construction"&&DW_WO[RRQC_PASS_DATE_MM]<>BLANK()&&DW_WO[RRQC_PASS_DATE_MM]>(TODAY()-365)&&DW_WO[CATEGORYNAME]<>"Dewinterization"&&DW_WO[CATEGORYNAME]<>"Hotel Accommodation"&&DW_WO[CATEGORYNAME]<>"Inspections"&&DW_WO[CATEGORYNAME]<>"Move Out Inspection"&&DW_WO[CATEGORYNAME]<>"Unit Turns (Paint/Clean/Minor Repairs)"&&DW_WO[CATEGORYNAME]<>"Utility Activation"&&DW_WO[CATEGORYNAME]<>"Winterization",
			    "Rehab Warranty",
			IF(AND(DW_WO[WO_PREV]<>BLANK()||DW_WO[WO_NEXT]<>BLANK(),DW_WO[CATEGORYNAME]<>"Dewinterization"&&DW_WO[CATEGORYNAME]<>"Hotel Accommodation"&&DW_WO[CATEGORYNAME]<>"Inspections"&&DW_WO[CATEGORYNAME]<>"Move Out Inspection"&&DW_WO[CATEGORYNAME]<>"Unit Turns (Paint/Clean/Minor Repairs)"&&DW_WO[CATEGORYNAME]<>"Utility Activation"&&DW_WO[CATEGORYNAME]<>"Winterization"),
			    "Vendor Warranty",
			BLANK()))))
		lineageTag: 5f70ee5a-0931-437c-af82-d1bba4003647
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

