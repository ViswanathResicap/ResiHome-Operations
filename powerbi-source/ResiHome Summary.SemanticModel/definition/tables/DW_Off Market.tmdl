	column '2_TOTAL_Most Recent QC Result' = 'DW_Off Market'[2_AM_QC_Result]
		lineageTag: 518fecac-4a52-4b8d-8179-f68981c1ff09
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '2_TOTAL_Most Recent QC Result Date' = 'DW_Off Market'[2_AM_QC_Result_Date]
		formatString: Short Date
		lineageTag: 29348fd0-77a9-4659-b44f-35c5bcba9de2
		summarizeBy: none

		variation Variation
			isDefault
			relationship: c7cc599e-fe40-4828-8d8d-872762be8f04
			defaultHierarchy: LocalDateTable_dfc80222-d32e-48fe-9e09-0a21f58011a1.'Date Hierarchy'

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

	column '2_PC Status' = CALCULATE(MIN(QC_ResiAims[Move-In(Y/N)]),FILTER(QC_ResiAims,QC_ResiAims[Entity ID/Client ID]='DW_Off Market'[ENTITYID]))
		lineageTag: 22a02bfd-1dff-45a5-b855-860dd4159544
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '2_Off Market Page Flag' =
			IF(
			'DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Off Market"
			||('DW_Off Market'[OCCUPANCY_STATUS]="Under Construction"&&('DW_Off Market'[PROJECTEDCOMPLETIONDATE]+7)<=(TODAY()+25)&&'DW_Off Market'[2_PC Status]="Cleared to Move-In"&&'DW_Off Market'[2_MM_WO_Open_Count]=BLANK()&&'DW_Off Market'[Listing_Status_Name]<>"Active"&&'DW_Off Market'[Listing_Status_Name]<>"Deposit Taken")
			||'DW_Off Market'[1_Turn_Ready_to_List]="Ready to List"
			||'DW_Off Market'[ORGANIZATION_KEY]=27&&'DW_Off Market'[2_TOTAL_Most Recent QC Result]<>"Pass",1,0)
		formatString: 0
		lineageTag: 1380025e-2a18-488a-82f3-ea62aa0bb545
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

	column '2_STATUS_Off Market' = ```
			IF('DW_Off Market'[2_Off Market Page Flag]<>1&&'DW_Off Market'[1_CON_QC_Needed]<>1,BLANK(),
			            IF('DW_Off Market'[1_CON_QC_Needed] = 1 ,"Final Walk - Schedule QC",
			            IF('DW_Off Market'[REASONOFFMARKETNAME]<>BLANK()&&'DW_Off Market'[REASONOFFMARKETNAME]<>"Maintenance In Progress","Squatter / Other",
			
			            IF('DW_Off Market'[OCCUPANCY_STATUS]="Under Construction"&&('DW_Off Market'[PROJECTEDCOMPLETIONDATE]+7)<=(TODAY()+25)&&'DW_Off Market'[2_PC Status]="Cleared to Move-In"&&'DW_Off Market'[2_MM_WO_Open_Count]=BLANK()&&'DW_Off Market'[Listing_Status_Name]<>"Active"&&'DW_Off Market'[Listing_Status_Name]<>"Deposit Taken","Ready to List - Prelease",
			
			            IF('DW_Off Market'[Purchase Type]<>"New Construction"&&'DW_Off Market'[ORGANIZATION_KEY]=-1&&'DW_Off Market'[REASONOFFMARKETNAME]=BLANK()&&COALESCE('DW_Off Market'[MOVEINREADY],'DW_Off Market'[CON_DATE_FW_OR_COMPLETE])=BLANK(),"Send / Under Construction",
			
			            IF('DW_Off Market'[ORGANIZATION_KEY]=27&&OR('DW_Off Market'[QC_TRIGGER_DATE]=BLANK(),'DW_Off Market'[DRC_CO_DATE]=BLANK()),"Send / Under Construction",
			
			            IF('DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass"&&'DW_Off Market'[2_PC Status]="Cleared to Move-In"&&OR('DW_Off Market'[2_MM_WO_Open_Count]=BLANK(),'DW_Off Market'[2_TOTAL_Most Recent QC Result Date]>'DW_Off Market'[2_MM_TKT_Created_Date]&&'DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass")&&OR('DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Off Market",'DW_Off Market'[OCCUPANCY_STATUS]="Under Construction")&&'DW_Off Market'[REASONOFFMARKETNAME]=BLANK()
			            --&&'DW_Off Market'[RENTLY_LOCKBOX]<>BLANK()
			                ,IF('DW_Off Market'[PICTURE_COUNT]>5,"Ready to List - On Market","Ready to List - Awaiting Photos"),
			            
			            IF('DW_Off Market'[1_Turn_Ready_to_List]="Ready to List"&&'DW_Off Market'[2_PC Status]="Cleared to Move-In"&&'DW_Off Market'[REASONOFFMARKETNAME]=BLANK()
			            --&&'DW_Off Market'[RENTLY_LOCKBOX]<>BLANK()
			                ,IF('DW_Off Market'[PICTURE_COUNT]>5,"Ready to List - On Market","Ready to List - Awaiting Photos"),
			
			            IF(OR('DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass",'DW_Off Market'[1_Turn_Ready_to_List]="Ready to List")&&'DW_Off Market'[2_PC Status]="Cleared to Move-In"&&'DW_Off Market'[Purchase Type]="New Construction"&&'DW_Off Market'[ORGANIZATION_KEY]=-1&&OR('DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Off Market",'DW_Off Market'[OCCUPANCY_STATUS]="Under Construction")&&'DW_Off Market'[REASONOFFMARKETNAME]=BLANK()&&OR('DW_Off Market'[2_MM_WO_Open_Count]=BLANK(),'DW_Off Market'[2_MM_TKT_Created_Date]<='DW_Off Market'[OFFMARKETDATE])
			            --&&'DW_Off Market'[RENTLY_LOCKBOX]<>BLANK()
			                ,IF('DW_Off Market'[PICTURE_COUNT]>5,"Ready to List - On Market","Ready to List - Awaiting Photos"),
			
			            IF('DW_Off Market'[2_MM_WO_Open_Count]=BLANK()&&'DW_Off Market'[2_TOTAL_Most Recent QC Result]="Fail"&&'DW_Off Market'[2_MM_TKT_Created_Date]<='DW_Off Market'[2_TOTAL_Most Recent QC Result Date],"RRQC Fail",
			                
			            IF('DW_Off Market'[2_TOTAL_Most Recent QC Result]<>"Pass"&&OR('DW_Off Market'[2_MM_WO_Open_Count]=BLANK(),'DW_Off Market'[ORGANIZATION_NAME]="RB DRC")&&'DW_Off Market'[REASONOFFMARKETNAME]<>"Maintenance In Progress"&&'DW_Off Market'[1_Turn_Ready_to_List]=BLANK()&&OR('DW_Off Market'[2_TOTAL_Most Recent QC Result]<>"Pass",
			                AND([2_MM_TKT_Created_Date]>='DW_Off Market'[2_TOTAL_Most Recent QC Result Date],'DW_Off Market'[2_MM_WO_Closed_Date]>='DW_Off Market'[2_TOTAL_Most Recent QC Result Date])),"Pending RRQC",
			
			           -- IF('DW_Off Market'[RENTLY_LOCKBOX]=BLANK()&&'DW_Off Market'[2_MM_WO_Open_Count]=BLANK()&&'DW_Off Market'[OCCUPANCY_STATUS]<>"Under Construction","Missing Rently",
			            IF('DW_Off Market'[2_MM_WO_Open_Count]<>BLANK() ||'DW_Off Market'[REASONOFFMARKETNAME] ="Maintenance In Progress","Pending Maintenance",
			            IF('DW_Off Market'[2_PC Status]="Not Cleared to Move-In"||'DW_Off Market'[2_PC Status]=BLANK(), "Not PC Passed",
			            IF('DW_Off Market'[ORGANIZATION_KEY]=27&&'DW_Off Market'[TODAY]>='DW_Off Market'[CABINETS_PRELEASE_DATE]&&'DW_Off Market'[CABINETS_PRELEASE_DATE]<>BLANK()&&'DW_Off Market'[LISTINGDATE]=BLANK(),"Ready to List - Prelease",
			            "NO BUCKET"))))))))))))))
			            --)
			```
		lineageTag: 6aeb5ba7-c661-49e5-a6e7-07a88c4804bd
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '2_STATUS_Minor Fail' = ```
			IF(AND(
			'DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Off Market"||'DW_Off Market'[OCCUPANCY_STATUS]="Vacant - On Market"||'DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Pre-Leasing"||'DW_Off Market'[OCCUPANCY_STATUS]="Vacant - Future Move In"||'DW_Off Market'[OCCUPANCY_STATUS]="Tenant Leased",
			'DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass"),
			    IF('DW_Off Market'[2_MM_WO_Open_Count]<>BLANK(),"Open WO",
			    IF('DW_Off Market'[2_MM_WO_Closed_Date]>='DW_Off Market'[2_TOTAL_Most Recent QC Result Date],"Review Issues"
			    ,"Create Maint TKT")),       
			    BLANK())
			                
			```
		lineageTag: 55fab739-d1b1-4071-921b-6149609b7f02
		summarizeBy: none

		annotation SummarizationSetBy = Automatic

	column '2_Days in Status' =
			IF('DW_Off Market'[2_Off Market Page Flag]<>1||'DW_Off Market'[2_Days_Off_Market_Active]=BLANK(),BLANK(),
			max(
			MIN('DW_Off Market'[2_Days_Off_Market_Active],
			    SWITCH('DW_Off Market'[2_STATUS_Off Market],
			    "Not PC Passed",TODAY() - MAX(MAX('DW_Off Market'[2_TOTAL_Most Recent QC Result Date],'DW_Off Market'[MOVEINREADY]),'DW_Off Market'     [Purchase_Date]),
			    "Missing Rently",TODAY() - max('DW_Off Market'[2_TOTAL_Most Recent QC Result Date],'DW_Off Market'[OFFMARKETDATE]),
			    "Pending Maintenance",TODAY() - 'DW_Off Market'[2_MM_TKT_Created_Date],
			    "Pending RRQC",TODAY()- COALESCE(max('DW_Off Market'[2_MM_WO_Closed_Date],'DW_Off Market'[2_TOTAL_Most Recent QC Result Date]),'DW_Off Market'[Transfer_Date]),
			    "Ready to List - On Market",TODAY() - 'DW_Off Market'[2_TOTAL_Most Recent QC Result Date],
			    "Ready to List - Awaiting Photos",TODAY() - 'DW_Off Market'[2_TOTAL_Most Recent QC Result Date],
			    "Ready to List - Preleasing",TODAY() - 'DW_Off Market'[2_TOTAL_Most Recent QC Result Date],
			    "RRQC Fail", today() - 'DW_Off Market'[2_TOTAL_Most Recent QC Result Date],
			    "Squatter / Other" ,TODAY() - COALESCE('DW_Off Market'[OFFMARKETDATE],'DW_Off Market'[Transfer_Date])))
			,0))
		dataType: int64
		lineageTag: 568e41b1-7a82-49b3-8470-c372a7342fb3
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column '2_Days Off Market' =
			IF(OR('DW_Off Market'[Transfer_Date]<='DW_Off Market'[INITIAL_LEASE_DATE],'DW_Off Market'[INITIAL_LEASE_DATE]=BLANK())&&'DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass"&&'DW_Off Market'[INITIAL_LISTING_DATE]<>BLANK()&&OR('DW_Off Market'[INITIAL_LISTING_DATE]<='DW_Off Market'[INITIAL_LEASE_DATE],'DW_Off Market'[INITIAL_LEASE_DATE]=BLANK()),
			MAX('DW_Off Market'[INITIAL_LISTING_DATE] - max('DW_Off Market'[MOVEINREADY],'DW_Off Market'[Transfer_Date]),0),
			BLANK())
		dataType: int64
		formatString: 0
		lineageTag: a6db9a43-87e9-47b5-8f5b-9cb9a748a5a0
		summarizeBy: sum

		changedProperty = FormatString

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column 2_Days_Off_Market_Active =
			
			IF('DW_Off Market'[OCCUPANCY_STATUS]<>"Vacant - Off Market",
			    BLANK(),
			    ROUNDUP(TODAY()-COALESCE('DW_Off Market'[OFFMARKETDATE],'DW_Off Market'[MOVEINREADY],'DW_Off Market'[Transfer_Date]),0))
		dataType: int64
		formatString: 0
		lineageTag: 701ef8ec-42fb-42ba-b2b8-bed684788671
		summarizeBy: sum

		changedProperty = DataType

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isDecimal":true}

	column '2_Days Since QC Pass' = IF('DW_Off Market'[2_TOTAL_Most Recent QC Result]="Pass",TODAY()-'DW_Off Market'[2_TOTAL_Most Recent QC Result Date],BLANK())
		dataType: int64
		formatString: 0
		lineageTag: a3cba39b-96be-491f-a075-57b26b5a0068
