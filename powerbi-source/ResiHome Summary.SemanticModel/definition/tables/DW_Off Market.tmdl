	partition 'DW_Off Market-20eba13f-d92d-4ec5-a3bf-858185831aac' = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   OFF MARKET DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per active property (anchor DIM_PROPERTY P), enriched with#(lf)            most-recent + initial rental listing, AM/MM/QC status, Rently device#(lf)            data, construction/BuilderMetrix milestones, off-market notes, UW rent.#(lf)   CTE chain: PICS, OffMarketNote, RENTLY_CLEAN, UW_RENT_MAX/UW_RENT, VANDALISM,#(lf)            WO, WO_Summary, MAX_LEASE, Tenant_Listings, BUILDER_MATRIX_DETAIL,#(lf)            BUILDER_MATRIX_SUMMARY, HUBSPOT -> final SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  The single ORGANIZATION_KEY / ORGANIZATION_NAME CASE block in the#(lf)             final SELECT was updated to the full six-group roll-up that mirrors#(lf)             the master PROPERTY script (source of truth). The prior form used an#(lf)             extended member list for group 27 but was missing org 66 and the#(lf)             58/59, 62.., 61/70, 67 groups. DELIBERATE OUTPUT CHANGE limited to#(lf)             the organization columns.#(lf)     No CTEs or joins dropped. MAX_LEASE and Tenant_Listings are defined-but-#(lf)             unused in the original and preserved as-is; the PM_OC and AM_INS#(lf)             joins (also unreferenced in SELECT) are likewise preserved.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output):#(lf)        added 66                  -> 27 / 'RB DRC'#(lf)        58,59                     -> 58 / 'Hudson Oak'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH PICS AS (#(lf)#(lf) SELECT#(lf)  MAX(PHOTO_COUNT) AS Picture_Count#(lf)  ,TRY_TO_NUMERIC(UNIT_) AS PM_PropertyID#(lf)  FROM ""PROD_REPLICA"".""RENTLY"".""_3_0_DATA""#(lf)  WHERE 1=1#(lf)  AND TRY_TO_NUMERIC(UNIT_) IS NOT NULL#(lf)  GROUP BY UNIT_#(lf))#(lf)#(lf),OffMarketNote AS (#(lf)#(tab)#(tab)SELECT DISTINCT #(lf)#(tab) #(tab)N.NOTEID AS LatestNoteID#(lf)#(tab) #(tab),N.NOTETEXT AS OffMarketNote#(lf)#(tab) #(tab),N.CREATEDDATE  AS OffMarketNoteCreated#(lf)#(tab) #(tab),DATEDIFF('Day',N.CREATEDDATE,GETDATE()) OffMarketNote_Days#(lf)#(tab)    ,P.PropertyId#(lf)#(tab)    ,U.FIRSTNAME || ' ' || U.LASTNAME AS OffMarketNote_Added_By#(lf)#(tab)    ,RANK() OVER( PARTITION BY P.PropertyId ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)#(tab)#(lf)#(tab)#(tab)FROM PROD_REPLICA.HBPM_DBO.NOTES N #(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.NOTETYPES NT ON NT.Id = N.NoteTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.LookUpMasterId = N.ObjectTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P ON P.PropertyID = N.ObjectID AND P.""_FIVETRAN_DELETED"" ='N'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS U ON U.USERID  = N.ADDEDBY #(lf)#(tab) #(tab)WHERE N.NoteTypeId = 20#(lf)#(tab) --#(tab)AND PAI.PROPERTYID = 36301#(lf)#(tab) #(tab)QUALIFY Recent_Rank = 1)#(lf)#(lf)--*******************************************#(lf)#(lf),RENTLY_CLEAN AS (#(lf)SELECT #(lf) Rently.ID AS Rently_Prop_ID#(lf),TRY_TO_NUMERIC(Rently.UNIT_) AS UNIT_#(lf),Rently.STARDARD_ADDRESS#(lf),Rently.LOCKBOX#(lf),Rently.STATUS_TITLE#(lf),Rently.ACTIVE#(lf),to_date(Rently.LB_ASSIGNED_DATE::TEXT,'AUTO') LB_ASSIGNED_DATE#(lf),to_date(Rently.AUTOSHOWING_DATE::TEXT,'AUTO') AUTOSHOWING_DATE#(lf),RANK() OVER( PARTITION BY Rently.UNIT_ ORDER BY Rently.LB_ASSIGNED_DATE DESC, DATE_TRUNC('min', _FIVETRAN_SYNCED) DESC, Rently.ID DESC) Rank_1#(lf)#(lf)FROM PROD_REPLICA.RENTLY.PROPERTIES RENTLY#(lf)WHERE 1=1#(lf)AND UNIT_ IS NOT NULL#(lf)AND MANAGER_APP_ACCESS_ALLOWED = 1 #(lf)AND TRY_TO_NUMERIC(Rently.UNIT_) IS NOT NULL#(lf)QUALIFY RANK_1 = 1#(lf))#(lf)#(lf)--******************************************************************************************************************************************************#(lf),UW_RENT_MAX AS (#(lf)#(tab)SELECT #(lf)#(tab)MAx(RENTLOGID) RENTLOGID #(lf)#(tab), ENTITYID1#(lf)#(tab)FROM PROD_REPLICA.HBPM_DBO.RENTLOGS#(lf)#(tab)GROUP BY ENTITYID1) #(lf)#(tab)#(lf),UW_RENT AS (#(lf)#(tab)SELECT #(lf)#(tab) RentLogs.ENTITYID1 AS HBPM_UnitID#(lf)#(tab),RentLogs.ORIGINALVALUE AS UW_Rent_Prior#(lf)#(tab),RentLogs.UPDATEVALUE AS UW_Rent_Current#(lf)#(tab),RentLogs.OCCUREDON  AS UW_Update_Date#(lf)#(tab)FROM UW_RENT_MAX#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.RENTLOGS RentLogs ON RentLogs.RENTLOGID = UW_RENT_MAX.RentLogID#(lf)#(tab))#(lf)#(lf)--******************************************************************************************************************************************#(lf),VANDALISM AS (#(lf)SELECT #(lf)PROPERTY_KEY#(lf),MAX(CHANGE_TIME) AS VANDALISM_DATE#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_VACANT_OFF_MARKET_HIST#(lf)WHERE REASON_FOR_OFF_MARKET = 'Vandalism'#(lf)GROUP BY PROPERTY_KEY)#(lf)--******************************************************************************************************************************************#(lf),WO AS (#(lf)#(lf)SELECT #(lf) #(lf)TI.TICKET_KEY#(lf),WO.WORKORDER_KEY#(lf),TI.TICKET_TYPE#(lf),TI.TICKET_STATUS#(lf),WO.WORKORDER_ID#(lf),WO.MAINT_ID#(lf),WO.WORKORDER_STATUS#(lf),WO.PRIORITY#(lf),WO.BILL_TO#(lf)#(lf),P.Property_Key#(lf)#(lf),to_date(TI.CREATED_DATE_KEY::TEXT,'YYYYMMDD') AS TICKET_CREATED_DATE#(lf),to_date(WO.CREATED_DATE_KEY::TEXT,'YYYYMMDD') AS WO_CREATED_DATE#(lf),to_date(WOST.WO_ESTIMATED_DATE_KEY::TEXT,'YYYYMMDD') AS WO_ESTIMATED_DATE#(lf),to_date(WOST.WO_PENDING_COMPLETION_DATE_KEY::TEXT,'YYYYMMDD') AS WO_PENDING_COMPLETION_DATE#(lf),to_date(WOST.WO_COMPLETED_AWAITING_APPROVAL_DATE_KEY::TEXT,'YYYYMMDD') AS WO_COMPLETED_AWAITING_APPROVAL_DATE#(lf),to_date(WOST.WO_UNBILLED_DATE_KEY::TEXT,'YYYYMMDD') AS WO_UNBILLED_DATE#(lf),to_date(WOST.WO_CLOSED_DATE_KEY::TEXT,'YYYYMMDD') AS WO_CLOSED_DATE#(lf)#(lf),C.CategoryID#(lf),C.CATEGORYNAME#(lf),MCD.WO_PROBLEM#(lf),MCD.WO_Solution#(lf)#(lf) ,CASE WHEN V.VENDOR_ID IN (17689,17783,17959,18747,19140) THEN 'Warranty Vendor' ELSE 'External Vendor' END AS Warranty#(lf) ,'https://honeybadgermm.com/Maintenance#/CreateWorkOrder/' || WO.Maint_ID AS HBMM_URL       #(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TICKET TI#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TICKET_STATUS_ACCUM TSA ON TSA.TICKET_KEY  = TI.TICKET_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_WO_STATUS_ACCUM WOST ON WOST.TICKET_KEY  = TI.TICKET_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_WORKORDER WO ON WO.WORKORDER_KEY = WOST.WORKORDER_KEY AND WO.CURRENT_FLAG = 'Y'#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_VENDOR V ON V.VENDOR_KEY = WOST.VENDOR_KEY#(tab)#(tab)#(tab)#(lf)LEFT JOIN (SELECT #(lf)#(tab)#(tab)#(tab)#(tab)Min(MaintenanceCategoryDetailId) AS MaintenanceCategoryDetailID#(lf)#(tab)#(tab)#(tab)#(tab),MIN(CategoryDescription) AS WO_Problem#(lf)#(tab)#(tab)#(tab)#(tab),MIN(VENDORNOTES) AS WO_Solution#(lf)#(tab)#(tab)#(tab)#(tab),MaintenanceIDKey#(lf)                FROM PROD_REPLICA.HBMM_DBO.MAINTENANCECATEGORYDETAILS #(lf)                --WHERE MaintenanceIDKey = 668614#(lf)#(tab)#(tab)#(tab)#(tab)GROUP BY MaintenanceIDKey) MCD on MCD.MaintenanceIdkey = WO.MAINT_ID #(lf)LEFT JOIN PROD_REPLICA.HBMM_DBO.MaintenanceCategoryDetails on MaintenanceCategoryDetails.MaintenanceCategoryDetailId = MCD.MaintenanceCategoryDetailID#(lf)LEFT JOIN PROD_REPLICA.HBMM_DBO.MaintenanceCategories C on C.CategoryId = MaintenanceCategoryDetails.CategoryId#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TSA.PROPERTY_KEY AND P.CURRENT_FLAG ='Y'#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)WHERE 1=1 #(lf)AND (WO.WORKORDER_STATUS <> 'Cancelled' OR WO.WORKORDER_STATUS IS NULL)#(lf)AND TI.TICKET_STATUS <> 'Cancelled'#(lf)AND TI.TICKET_TYPE <> 'PPI'#(lf)AND ((TI.TICKET_STATUS = 'Closed' AND WO.WORKORDER_KEY IS NOT NULL)#(lf)#(tab)OR (TI.TICKET_STATUS = 'Open' AND WO.WORKORDER_KEY IS NOT NULL )#(lf)#(tab)OR (TI.TICKET_STATUS <> 'Closed' AND TI.TICKET_STATUS <> 'Open') )#(tab)#(lf)AND TI.CREATED_DATE_KEY > '20210101'#(lf)AND P.PROPERTY_STATE ='Active'#(lf)AND P.EntityID <> ''#(lf)--AND (PS.PROPERTY_STATUS_ID NOT IN (53,75) OR PS.PROPERTY_STATUS_ID IS NULL)#(lf)AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952,1867, 1916,1852,1771,1919,1873)#(lf)AND P.Organization_KEY not IN (16,17)#(lf)AND PO.IS_Active_AM = 'Y'#(lf)AND PO.Current_Flag = 'Y'#(lf)AND P.Current_Flag = 'Y'#(lf)AND PU.Current_Flag = 'Y'#(lf)AND PUS.Occupancy_Status NOT IN ('Property SOLD','Not Managed') #(lf))#(lf)#(lf),WO_Summary AS (#(lf)SELECT #(lf)WO.Property_Key#(lf),MAX( TICKET_CREATED_DATE) AS ""2_MM_TKT_Created_Date""#(lf),SUM( CASE WHEN WORKORDER_STATUS = 'Closed'OR WORKORDER_STATUS = 'Unbilled' THEN 0 ELSE 1 END) AS ""2_MM_WO_Open_Count""#(lf),COALESCE(MAX(WO_CLOSED_DATE),MAX(WO_UNBILLED_DATE) )  AS ""2_MM_WO_Closed_Date""#(lf),SUM( CASE WHEN WORKORDER_STATUS = 'Closed' OR WORKORDER_STATUS = 'Unbilled' THEN 1 ELSE 0 END) AS ""2_MM_WO_Closed Count""#(lf)FROM #(lf)WO#(lf)GROUP BY Property_Key#(lf))#(lf)--******************************************************************************************************************************************************#(lf),MAX_LEASE AS (#(lf)#(lf)SELECT#(lf) MAX(T.Lease_ID) LEASE_ID#(lf) ,TLA.Property_key#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf) LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf) LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TENANTINFORMATIONID = T.Tenant_Information_id#(lf)#(lf)WHERE 1=1#(lf) AND PRIMARY_TENANT ='Y' #(lf) AND CURRENT_FLAG ='Y'#(lf) AND RENT_DUE_DAY IS NOT NULL#(lf) AND TI._FIVETRAN_DELETED = 'N'#(lf) AND TI.CURRENTRENT >500#(lf)GROUP BY TLA.Property_key )#(lf)#(lf)--************************************************************************************************************#(lf),Tenant_Listings AS (#(lf)#(lf)SELECT #(lf) MIN(RENT_LIST_HIST_ID) RENT_LIST_HIST_KEY#(lf) ,TEN.Lease_ID  #(lf) ,TLA.Property_key#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT TEN#(lf) LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = TEN.Tenant_Key#(lf) LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TENANTINFORMATIONID = TEN.Tenant_Information_id#(lf)#(lf) LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH ON RLH.PROPERTY_KEY  = TLA.Property_Key#(lf)#(lf) WHERE 1=1#(lf) AND PRIMARY_TENANT ='Y' #(lf) AND CURRENT_FLAG ='Y'#(lf) AND RENT_DUE_DAY IS NOT NULL#(lf) AND TI._FIVETRAN_DELETED = 'N'#(lf) AND TI.CURRENTRENT >500 #(lf) #(lf) AND to_date(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd') <= DATEADD(DAY,10,to_date(COALESCE(TLA.INITIAL_LEASE_FROM_DATE_KEY,TLA.LEASE_FROM_DATE_KEY)::TEXT,'yyyymmdd'))#(lf) AND RLH.LISTING_STATUS <> 'Withdrawn'#(lf) AND RLH.LISTING_STATUS <> 'On Hold'#(lf) #(lf) GROUP BY#(lf)  TEN.Lease_ID  #(lf) ,TLA.Property_key ) #(lf)#(lf)--************************************************************************************************************#(lf) ,BUILDER_MATRIX_DETAIL AS (#(lf)#(lf)SELECT#(lf)   JM.JOBAID#(lf)  ,T0.ProjectId#(lf)  ,T0.JobNo#(lf)#(lf)  ,CASE WHEN  T1.StageDescription ='CABINETS' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_CABINETS#(lf)  ,CASE WHEN  T1.StageDescription ='FINAL MECHANICAL' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_FINAL_MECHANICAL#(lf)  ,CASE WHEN  T1.StageDescription ='FLOORING' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_FLOORING#(lf)  ,CASE WHEN  T1.StageDescription ='INTERIOR FINISHES' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_INTERIOR_FINISHES#(lf)  ,CASE WHEN  T1.StageDescription ='DRYWALL' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_DRYWALL#(lf)  ,CASE WHEN  T1.StageDescription ='ROUGH MECHANICALS' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_ROUGH_MECHANICALS#(lf)  ,CASE WHEN  T1.StageDescription ='FRAME' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_FRAME#(lf)  ,CASE WHEN  T1.StageDescription ='FOUNDATION' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_FOUNDATION#(lf)  ,CASE WHEN  T1.StageDescription ='LANDSCAPING' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_LANDSCAPING#(lf)  ,CASE WHEN  T1.StageDescription ='QC 2' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_QC_2#(lf)  ,CASE WHEN  T1.StageDescription ='CO' THEN MAX(T0.ActualEndDate) ELSE NULL END AS BUILDERMATRIX_CO_DATE#(lf)  #(lf)FROM PROD_REPLICA.BUILDERMETRIX_RESIBUILT.BUILDER_SCHEDULEMASTERDETAIL T0#(lf)  LEFT JOIN PROD_REPLICA.BUILDERMETRIX_RESIBUILT.BUILDER_SCHEDULETASKMASTER T1#(lf)    ON T0.BuilderId = T1.BuilderId#(lf)    AND T0.TaskCode = T1.TaskCode#(lf)    AND T0.StageCode = T1.StageCode#(lf)LEFT JOIN PROD_REPLICA.BUILDERMETRIX_RESIBUILT.BUILDER_JOBMASTER JM ON JM.JobNo = T0.JOBNO#(lf)#(lf)WHERE 1=1#(lf)AND T0.BuilderId = 'BT-311420' #(lf)--AND T0.ProjectID <> '60297' #(lf)--AND JOBAID = 'RBGA0065-2046'#(lf)#(lf)GROUP BY#(lf)  T0.ProjectId,#(lf)  T0.JobNo,#(lf)  JM.JOBAID,#(lf)  T1.StageDescription)#(lf)  #(lf)--************************************************************************************************************#(lf),BUILDER_MATRIX_SUMMARY AS (#(lf) #(lf) SELECT#(lf)   JOBAID#(lf)  ,PROJECTID#(lf)  ,JOBNO#(lf)  #(lf),to_Date(MAX(BUILDERMATRIX_CABINETS)) AS BUILDERMATRIX_CABINETS#(lf),to_Date(MAX(BUILDERMATRIX_FINAL_MECHANICAL)) AS BUILDERMATRIX_FINAL_MECHANICAL#(lf),to_Date(MAX(BUILDERMATRIX_FLOORING)) AS BUILDERMATRIX_FLOORING#(lf),to_Date(MAX(BUILDERMATRIX_INTERIOR_FINISHES)) AS BUILDERMATRIX_INTERIOR_FINISHES#(lf),to_Date(MAX(BUILDERMATRIX_DRYWALL)) AS BUILDERMATRIX_DRYWALL#(lf),to_Date(MAX(BUILDERMATRIX_ROUGH_MECHANICALS)) AS BUILDERMATRIX_ROUGH_MECHANICALS#(lf),to_Date(MAX(BUILDERMATRIX_FRAME)) AS BUILDERMATRIX_FRAME#(lf),to_Date(MAX(BUILDERMATRIX_FOUNDATION)) AS BUILDERMATRIX_FOUNDATION#(lf),to_Date(MAX(BUILDERMATRIX_LANDSCAPING)) AS BUILDERMATRIX_LANDSCAPING#(lf),to_Date(MAX(BUILDERMATRIX_QC_2)) AS BUILDERMATRIX_QC_2#(lf),to_Date(MAX(BUILDERMATRIX_CO_DATE)) AS BUILDERMATRIX_CO_DATE#(lf)#(lf)#(lf)FROM BUILDER_MATRIX_DETAIL#(lf)GROUP BY#(lf)  JOBAID#(lf) ,PROJECTID#(lf) ,JOBNO)#(lf) --******************************************************************************************************************************************#(tab)#(lf)#(tab)#(lf)#(tab),HUBSPOT AS (#(lf)      SELECT#(lf)#(lf)       ID#(lf)       ,PROPERTY_ENTITY_ID#(lf)       ,PROPERTY_RENTLY_SERIAL_SYNC_STATUS  AS RENTLY_SYNC_STATUS#(lf)       ,PROPERTY_ELECTRONIC_LOCKBOX_NUMBER AS RENTLY_SERIAL_NUMBER#(lf)       ,PROPERTY_RENTLY_DEVICE_TYPE AS RENTLY_DEVICE_TYPE#(lf)       ,PROPERTY_RENTLY_SH_HUB_STATUS AS RENTLY_SH_HUB_STATUS#(lf)       ,PROPERTY_RENTLY_SH_HUB_SERIAL_ID  AS RENTLY_SH_HUB_SERIAL_ID#(lf)       ,PROPERTY_RENTLY_SH_LOCK_STATUS  AS RENTLY_SH_LOCK_STATUS#(lf)       ,PROPERTY_CO_DATE#(lf)       ,property_rently_serial_id_update_date#(lf)#(lf)      FROM PROD_REPLICA.HUBSPOT_2.PROPERTIES#(lf)      WHERE 1=1#(lf)      AND PROPERTY_ENTITY_ID is not null#(lf)     -- AND ARCHIVED = FALSE#(lf)      AND PROPERTY_HS_MERGED_OBJECT_IDS IS null#(lf)      AND (_fivetran_deleted = FALSE OR _fivetran_deleted  is null)) #(lf) --************************************************************************************************************#(lf)SELECT DISTINCT#(lf)#(lf)P.PROPERTY_KEY#(lf)#(lf)#(lf),P.HBAM_PROPERTY_ID#(lf),P.HBPM_PROPERTY_ID#(lf),P.HBMM_PROPERTY_ID#(lf),R.REGION_NAME#(lf),P.FloorPlan#(lf),SUB.SUBDIVISION#(lf),PUS.FLOORPLAN_KEY#(lf),PUS.SUBDIVISION_KEY#(lf),P.ZIPCODE#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)      #(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf)#(lf),PO.PORTFOLIO_NAME#(lf),P.ADDRESS || ', ' || COALESCE (CI.CITY_NAME, PM_CI.CityName) || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS Full_Address#(lf),P.ADDRESS#(lf),P.ENTITYID#(lf),BA.PurchaseType AS ""Purchase_Type_ID""#(lf),CASE #(lf)#(tab)WHEN BA.PurchaseType = 1 THEN 'Foreclosure'#(lf)#(tab)WHEN BA.PurchaseType = 2 THEN 'MLS'#(lf)#(tab)WHEN BA.PurchaseType = 3 THEN 'Off-Market'#(lf)#(tab)WHEN BA.PurchaseType = 4 THEN 'Bulk'#(lf)#(tab)WHEN BA.PurchaseType = 5 THEN 'Deed in Lieu'#(lf)#(tab)WHEN BA.PurchaseType = 6 THEN 'I-Buyer'#(lf)#(tab)WHEN BA.PurchaseType = 7 THEN 'Non-Foreclosure'#(lf)#(tab)WHEN BA.PurchaseType = 8 THEN 'New Construction'#(lf)#(tab)ELSE Null#(tab)#(lf)END AS ""Purchase Type""#(lf)#(lf),CASE WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' THEN 'Trustee Leased' #(lf)      WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)      ELSE PUS.Occupancy_Status END AS Occupancy_Status#(lf)#(lf),CASE WHEN PUS.Occupancy_Status = 'Trustee Occupied' THEN 'Trustee Occupied'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Under Inspection' THEN 'Inspection'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Under Construction' THEN 'Constuction'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - Off Market' OR PUS.Occupancy_Status = 'Vacant - Onboarding' THEN 'Vacant - Off Market'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - On Market' OR PUS.Occupancy_Status = 'Vacant - Pre-Leasing' THEN 'Vacant - On Market'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Tenant Leased' THEN 'Tenant Leased'#(lf)#(tab)  WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Tenant Leased'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 'Vacant - FMI'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' OR PUS.Occupancy_Status = 'Trustee Leased' THEN 'Trustee Leased'#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Pending MOI/Rekey' OR  PUS.Occupancy_Status = 'Under Turnkey' THEN 'Turnkey'#(lf)#(tab)  ELSE PUS.Occupancy_Status END AS Occupancy_Status_Summary#(lf)#(lf),CASE WHEN PUS.Occupancy_Status = 'Trustee Occupied' THEN 1#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Under Inspection' THEN 2#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Under Construction' THEN 3#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - Off Market' OR PUS.Occupancy_Status = 'Vacant - Onboarding'  THEN 4#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - On Market' OR PUS.Occupancy_Status = 'Vacant - Pre-Leasing' THEN 5#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Tenant Leased' THEN 8#(lf)#(tab)  WHEN PUS.Property_Status = 'Tenant Lease' AND PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 8#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Vacant - Future Move In' THEN 6#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Trustee Lease Honored' OR PUS.Occupancy_Status = 'Trustee Leased' THEN 7#(lf)#(tab)  WHEN PUS.Occupancy_Status = 'Pending MOI/Rekey' OR  PUS.Occupancy_Status = 'Under Turnkey' THEN 9#(lf)#(tab)  ELSE 10 END AS Occupancy_Status_SummaryID#(lf)#(lf),PUS.PROPERTY_STATUS AS AM_Property_Status#(lf),COALESCE(PM_AI.Bedrooms, PU.BEDROOMS) AS BEDROOMS#(lf),COALESCE(PM_AI.BATHROOMS, PU.BATHROOMS) AS BATHROOMS#(lf),PU.SQUARE_FOOTAGE#(lf),P.Year_Built#(lf),COALESCE(to_date(P.TRANSFER_DATE_KEY::TEXT,'yyyymmdd'),to_date(P.PURCHASE_DATE_KEY::TEXT,'yyyymmdd'),P.CREATED_DATE) AS ""Transfer_Date""#(lf),to_date(P.PURCHASE_DATE_KEY::TEXT,'yyyymmdd') AS ""Purchase_Date""#(lf)#(lf),RL.RENT_LIST_HIST_ID AS RENTAL_LISTING_ID#(lf),RL.LISTING_STATUS AS ""Listing_Status_Name""#(lf),to_date(RL.LISTING_DATE_KEY::TEXT,'yyyymmdd') AS ListingDate#(lf)#(lf),RL_I.RENT_LIST_HIST_ID AS INITIAL_RENTAL_LISTING_ID#(lf),RL_I.LISTING_STATUS AS ""INITIAL_Listing_Status_Name""#(lf),to_date(RL_I.LISTING_DATE_KEY::TEXT,'yyyymmdd') AS INITIAL_Listing_Date#(lf),Date_trunc('month',to_date(RL_I.LISTING_DATE_KEY::TEXT,'yyyymmdd') )AS INITIAL_Listing_Date_BOM#(lf)#(lf),PM_AI.ReasonOffMarketId --*#(lf),PM_AI.MOVEINREADY AS PM_MIR#(lf),ROM.Description AS ReasonOffMarketName#(lf),OffMarket.OffMarketDate#(lf),AM_PM.MoveInReady#(lf),AM_CON.PROJECTEDCOMPLETIONDATE#(lf)#(lf),to_date(P.INITIAL_LEASE_DATE_KEY::TEXT,'yyyymmdd') AS INITIAL_LEASE_DATE#(lf),'https://honeybadgerpm.com/PropertyModule#/PropertyDetails/' || HBPM.PROPERTYID || '/' || PM_AI.UnitID ||'/0' AS HBPM_URL#(lf),'https://honeybadgermm.com/Property#/PropertyDetails/' || P.HBMM_PROPERTY_ID AS HBMM_URL#(lf),'https://honeyba