table 'DW_Off Market'
	lineageTag: 0c505f40-c2ba-4fdf-abf3-6b72656415ed

	measure 0_Off_Market_Count = DISTINCTCOUNT('DW_Off Market'[PROPERTY_KEY]) + 0
		formatString: #,0
		lineageTag: ae171370-232c-409b-b4fb-e2d3b1592afd

		changedProperty = FormatString

	measure '0_Squatter / Other' = CALCULATE(DISTINCTCOUNT('DW_Off Market'[PROPERTY_KEY]),FILTER('DW_Off Market','DW_Off Market'[REASONOFFMARKETNAME]="Squatter")) + 0 & " / " & CALCULATE(DISTINCTCOUNT('DW_Off Market'[PROPERTY_KEY]),FILTER('DW_Off Market','DW_Off Market'[REASONOFFMARKETNAME]<>"Squatter"&&'DW_Off Market'[REASONOFFMARKETNAME]<>BLANK()&&'DW_Off Market'[REASONOFFMARKETNAME]<>"Maintenance In Progress")) + 0
		lineageTag: 58a791ef-dcbf-4f3a-8162-9572914f67d8

	measure '0_DRC Var' = IF(MIN(DW_Properties[1_DRC_Status])="Off-Market",BLANK(),CALCULATE(sum(DW_Properties[1_DRC_Price]) / SUM(DW_Properties[UNDER_WRITTEN_RENT]) ,FILTER(DW_Properties,DW_Properties[1_DRC_Price]<>BLANK()&&DW_Properties[UNDER_WRITTEN_RENT]<>BLANK()))-1)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 37196265-6b7c-49b4-8bd4-cec66ce81551

	column PROPERTY_KEY
		dataType: double
