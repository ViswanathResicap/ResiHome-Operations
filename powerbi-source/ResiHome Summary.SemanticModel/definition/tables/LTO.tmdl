	partition LTO = calculated
		mode: import
		source = ```
				UNION(
				    SUMMARIZE(FILTER(DW_Renewals,DW_Renewals[Renewal Result]="Renewed"),
				    DW_Renewals[PROPERTY_KEY],
				    DW_Renewals[ENTITYID],
				    DW_Renewals[PORTFOLIO_NAME],
				    DW_Renewals[ADDRESS],
				    DW_Renewals[FLOORPLAN],
				    DW_Renewals[SQUARE_FOOTAGE],
				    DW_Renewals[C_AMOUNT],
				    DW_Renewals[N_AMOUNT],
				    DW_Renewals[RENT_GROWTH],
				    DW_Renewals[N_LEASESTART],
				    DW_Renewals[TYPE]),
				
				SUMMARIZE(FILTER(DW_Turns,DW_Turns[N_MOVEIN]<>BLANK()),
				    DW_Turns[PROPERTY_KEY],
				    DW_Turns[ENTITYID],
				    DW_Turns[PORTFOLIO_NAME],
				    DW_Turns[ADDRESS],
				    DW_Turns[FLOORPLAN],
				    DW_Turns[SQUARE_FOOTAGE],
				    DW_Turns[O_CURRENT_RENT],
				    DW_Turns[N_CURRENT_RENT],
				    DW_Turns[RENT_GROWTH],
				    DW_Turns[N_MOVEIN],
				    DW_Turns[TYPE]))
				
				
				```

	annotation PBI_Id = 87421351131d4d1c9a94374c766426da

