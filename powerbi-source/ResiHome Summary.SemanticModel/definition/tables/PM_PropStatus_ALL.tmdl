	partition PM_PropStatus_ALL-775d1235-c813-4be0-a2b2-30620fe9bd8f = m
		mode: import
		queryGroup: 'PM Other'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH"){[Name="PROD_REPLICA"]}[Data], "SELECT DISTINCT#(lf)#(tab)  P.HBPM_PROPERTY_ID AS PropertyId#(lf)          ,P.Address#(lf) #(tab)  , FCT_PROP_UNIT_STATUS_HIST_KEY AS AuditLogId#(lf)#(tab) ,LM.LOOKUPMASTERID AS AfterValue#(lf)#(tab) ,NEW_OCCUPANCY_STATUS AS Occupancy_Status#(lf)#(tab) ,to_date(CHANGED_DATE_KEY::TEXT,'yyyymmdd') AS LogDateTime#(lf)#(tab)  FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_UNIT_STATUS_HIST PSH#(lf)#(tab)  LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.DESCRIPTION = PSH.NEW_OCCUPANCY_STATUS   AND LM.TYPEID = 6#(lf)#(tab)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = PSH.PROPERTY_KEY #(lf)#(tab)  WHERE 1=1#(lf)#(tab)#(lf)#(tab)   AND P.PROPERTY_STATE ='Active'#(lf)#(tab)   AND P.EntityID <> ''#(lf)#(tab)   --AND P.Current_Flag = 'Y'#(lf)#(tab)   AND P.HBMM_Property_ID IS NOT NULL#(lf)#(tab)  #(lf)#(tab)  ORDER BY LogDateTime DESC", null, [EnableFolding=true])
				in
				    Source

	annotation PBI_ResultType = Table

