ES) AS WO_Solution#(lf)#(tab)#(tab)#(tab)#(tab),MaintenanceIDKey#(lf)                FROM PROD_REPLICA.HBMM_DBO.MAINTENANCECATEGORYDETAILS #(lf)                --WHERE MaintenanceIDKey = 668614#(lf)#(tab)#(tab)#(tab)#(tab)GROUP BY MaintenanceIDKey) MCD on MCD.MaintenanceIdkey = WO.MAINT_ID #(lf)#(lf)LEFT JOIN PROD_REPLICA.HBMM_DBO.MaintenanceCategoryDetails on MaintenanceCategoryDetails.MaintenanceCategoryDetailId = MCD.MaintenanceCategoryDetailID#(lf)LEFT JOIN PROD_REPLICA.HBMM_DBO.MaintenanceCategories C on C.CategoryId = MaintenanceCategoryDetails.CategoryId#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TSA.PROPERTY_KEY AND P.CURRENT_FLAG ='Y'#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY = P.PROPERTY_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)LEFT JOIN PROD_ANALYTICS.BI_MASTER_DATASETS.MASTER_MM_WORKORDER MM_MASTER ON MM_MASTER.""IDKey"" = COALESCE(WO.MAINT_ID,TI.ID_KEY)#(lf)#(lf)WHERE 1=1 #(lf)AND (WO.WORKORDER_STATUS <> 'Cancelled' OR WO.WORKORDER_STATUS IS NULL)#(lf)AND TI.TICKET_STATUS <> 'Cancelled'#(lf)AND ((TI.TICKET_STATUS = 'Closed' AND WO.WORKORDER_KEY IS NOT NULL)#(lf)#(tab)OR (TI.TICKET_STATUS = 'Open' AND WO.WORKORDER_KEY IS NOT NULL )#(lf)#(tab)OR (TI.TICKET_STATUS <> 'Closed' AND TI.TICKET_STATUS <> 'Open') )#(lf)#(tab)#(tab)#(lf)AND TI.CREATED_DATE_KEY > '20210101'#(lf)#(lf)AND P.PROPERTY_STATE ='Active'#(lf)AND P.EntityID <> ''#(lf)--AND (PS.PROPERTY_STATUS_ID NOT IN (53,75) OR PS.PROPERTY_STATUS_ID IS NULL)#(lf)AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952,1867, 1916,1852,1771,1919,1873)#(lf)AND P.Organization_KEY not IN (16,17)#(lf)AND PO.IS_Active_AM = 'Y'#(lf)AND PO.Current_Flag = 'Y'#(lf)AND P.Current_Flag = 'Y'#(lf)AND PU.Current_Flag = 'Y'#(lf)AND PUS.Occupancy_Status NOT IN ('Property SOLD','Not Managed')#(lf)--AND P.Property_key= 223502#(lf))#(lf)#(lf)#(lf)--**************************************************************************************#(lf),WO_TURN AS (#(lf)SELECT #(lf)WO_DETAIL.TICKET_KEY#(lf),WO_DETAIL.WORKORDER_KEY#(lf),MIN(Turnkey.O_TURN_ID) O_Turn_ID#(lf)#(lf)FROM WO_DETAIL#(lf)LEFT JOIN Turnkey ON Turnkey.Property_key = WO_DETAIL.Property_key#(lf)#(lf)WHERE 1=1#(lf)AND (TICKET_TYPE = 'Turnkey' OR CategoryName = 'Unit Turns (Paint/Clean/Minor Repairs)')#(lf)AND TICKET_TYPE <> 'Trespassers/Vandalism'#(lf)AND TICKET_CREATED_DATE >=  to_date(LEAST(Turnkey.O_MOVE_OUT,O_Notice_Date)::TEXT,'AUTO')#(lf)AND (TICKET_CREATED_DATE <= Turnkey.N_LEASE_FROM_DATE OR N_LEASE_FROM_DATE IS NULL)#(lf)--AND Turnkey.Property_key= 223502#(lf)#(lf)GROUP BY #(lf)WO_DETAIL.TICKET_KEY#(lf),WO_DETAIL.WORKORDER_KEY)#(lf)#(lf)--SELECT * FROM WO_TURN #(lf)#(lf)--**************************************************************************************#(lf),TURN_WO_SUMMARY AS (#(lf)SELECT #(lf)#(lf)WO_TURN.O_TURN_ID#(lf),MIN(TICKET_CREATED_DATE) AS TKT_Created_Min#(lf),MAX(TICKET_CREATED_DATE) AS TKT_Created_Max#(lf),MAX(WO_NOTE_TEXT) AS WO_NOTE_TEXT#(lf),MAX(WO_END_DATE) AS WO_END_DATE#(lf),MAX(WO_REQUESTED_DATE) AS WO_REQUESTED_DATE#(lf),MIN(WORKORDER_STATUS) AS WO_STATUS#(lf),MAX(WO_NOTE_CREATED_DATE) AS WO_NOTE_CREATED_DATE#(lf),MAX(WO_NOTE_ADDED_BY) AS WO_NOTE_ADDED_BY#(lf)#(lf),MAX(COALESCE(CLIENT_INVOICE_DATE,WO_CLOSED_DATE,VENDOR_INVOICE_DATE)) AS TKT_Closed_Max#(lf)#(lf),SUM(CASE WHEN (TICKET_STATUS = 'Open' AND WORKORDER_STATUS NOT IN ('Closed','Unbilled','Completed Awaiting Approval'))#(lf)#(tab)#(tab)#(tab)OR (TICKET_STATUS = 'New' AND WO_DETAIL.WORKORDER_KEY IS NULL) THEN 1 ELSE NULL END) AS TKT_WOS_OPEN#(lf)#(tab)#(tab)#(tab)#(lf),SUM(CASE WHEN WORKORDER_STATUS IN ('Closed','Unbilled','Completed Awaiting Approval') THEN 1 ELSE NULL END) AS TKT_WOS_CLOSED#(lf)#(lf),MIN(CASE WHEN HC_TURN_REPORT_STATUS = 'Fail' AND TICKET_CREATED_DATE >= HC_TURN_COMPLETED_DATE#(lf)#(tab)#(tab)THEN TICKET_CREATED_DATE ELSE NULL END ) AS TKT_Created_HARD_Fail#(lf)#(tab)#(tab)#(lf),MAX(CASE WHEN HC_TURN_REPORT_STATUS ='Fail' AND TICKET_CREATED_DATE >= HC_TURN_COMPLETED_DATE#(lf)#(tab)#(tab)THEN COALESCE(CLIENT_INVOICE_DATE,WO_CLOSED_DATE,VENDOR_INVOICE_DATE) ELSE NULL END ) AS TKT_Closed_HARD_Fail#(lf)#(tab)#(tab)#(lf),MIN(CASE WHEN Turnkey.PASS_MINOR = 'Pass (Minor Fail)' AND TICKET_CREATED_DATE >= HC_TURN_COMPLETED_DATE#(lf)#(tab)#(tab)THEN TICKET_CREATED_DATE ELSE NULL END ) AS TKT_Created_MINOR_Fail#(lf)#(tab)#(tab)#(lf),MAX(CASE WHEN Turnkey.PASS_MINOR = 'Pass (Minor Fail)' AND TICKET_CREATED_DATE >= HC_TURN_COMPLETED_DATE#(lf)#(tab)#(tab)THEN COALESCE(CLIENT_INVOICE_DATE,WO_CLOSED_DATE,VENDOR_INVOICE_DATE) ELSE NULL END ) AS TKT_Closed_MINOR_Fail#(lf)#(tab)#(tab)#(lf),SUM(GREATEST(COALESCE(CLIENT_INVOICE_AMOUNT,CLIENT_ESTIMATE),COALESCE(CLIENT_ESTIMATE,CLIENT_INVOICE_AMOUNT))) AS TKT_COST#(lf)#(lf)FROM WO_DETAIL#(lf)JOIN WO_TURN #(lf)#(tab)#(tab)#(tab)#(tab)ON WO_TURN.TICKET_KEY = WO_DETAIL.TICKET_KEY#(lf)#(tab)#(tab)#(tab)#(tab)AND (CASE WHEN WO_DETAIL.WORKORDER_KEY IS NULL THEN 1=1#(lf)#(tab)#(tab)#(tab)#(tab)ELSE WO_TURN.WORKORDER_KEY = WO_DETAIL.WORKORDER_KEY END)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)LEFT JOIN Turnkey ON Turnkey.O_Turn_ID  =  WO_TURN.O_Turn_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)GROUP BY#(lf)WO_TURN.O_TURN_ID#(lf))#(lf)--SELECT * FROM TURN_WO_SUMMARY #(lf)--WHERE O_TURN_ID =  23369#(lf)--**************************************************************************************#(lf)#(lf) #(lf) SELECT#(lf)Turnkey.*#(lf),f_listing.RENT_LIST_HIST_ID AS RENT_LIST_HIST_KEY#(lf),d_listing.LISTING_DATE AS N_Listing_Date#(lf),f_listing.CURRENT_LIST_PRICE AS N_Listing_Price#(lf),d_listing.listing_status AS N_Listing_Status#(lf),TKT_CREATED_MIN#(lf),TKT_CREATED_MAX#(lf),TKT_Closed_Max#(lf),TKT_WOS_OPEN#(lf),TKT_WOS_CLOSED#(lf),TKT_CREATED_HARD_FAIL#(lf),TKT_CLOSED_HARD_FAIL#(lf),TKT_CREATED_MINOR_FAIL#(lf),TKT_CLOSED_MINOR_FAIL#(lf),WO_STATUS#(lf),WO_END_DATE#(lf),WO_REQUESTED_DATE#(lf),WO_NOTE_TEXT#(lf),WO_NOTE_CREATED_DATE#(lf),WO_NOTE_ADDED_BY#(lf)#(lf),CASE WHEN (TKT_WOS_OPEN IS NULL OR HC_TURN_REPORT_STATUS ='Pass') AND PASS_MINOR IS NULL#(lf)#(tab)THEN COALESCE(TKT_COST,0)#(lf)#(tab)ELSE TKT_COST #(lf)#(tab)END AS TKT_COST#(lf)#(lf),CASE WHEN (TKT_WOS_OPEN IS NULL OR HC_TURN_REPORT_STATUS ='Pass') AND (HC_TURN_COMPLETED_DATE IS NOT NULL OR N_LEASE_FROM_DATE IS NOT NULL OR TKT_Closed_Max IS NOT NULL)#(lf)      THEN LEAST(#(lf)                 COALESCE(HC_TURN_COMPLETED_DATE, '12/31/9999'::date),#(lf)                 COALESCE(N_LEASE_FROM_DATE, '12/31/9999'::date),#(lf)                 COALESCE(TKT_Closed_Max, '12/31/9999'::date))#(lf)      ELSE NULL#(lf)      END AS TURN_COMPLETED#(lf)      #(lf),CASE WHEN (TKT_WOS_OPEN IS NULL OR HC_TURN_REPORT_STATUS ='Pass') AND (HC_TURN_COMPLETED_DATE IS NOT NULL OR N_LEASE_FROM_DATE IS NOT NULL OR TKT_Closed_Max IS NOT NULL)#(lf)      THEN DATE_TRUNC('month',#(lf)      #(tab)#(tab)#(tab) LEAST(  #(lf)      #(tab)#(tab)#(tab) COALESCE(HC_TURN_COMPLETED_DATE, '12/31/9999'::date),#(lf)                 COALESCE(N_LEASE_FROM_DATE, '12/31/9999'::date),#(lf)                 COALESCE(TKT_Closed_Max, '12/31/9999'::date)))::date#(lf)      ELSE NULL#(lf)      END AS TURN_COMPLETED_BOM#(lf)      #(lf),CASE WHEN Turnkey.O_CURRENT_RENT > 0 AND COALESCE(Turnkey.N_INITIAL_RENT,Turnkey.N_CURRENT_RENT) >0  #(lf)      THEN DIV0NULL(COALESCE(Turnkey.N_INITIAL_RENT,Turnkey.N_CURRENT_RENT), Turnkey.O_CURRENT_RENT) - 1#(lf)#(tab)  ELSE NULL END AS RENT_GROWTH#(lf)#(tab)  #(lf),CASE WHEN Turnkey.O_CURRENT_RENT > 0 AND f_listing.CURRENT_LIST_PRICE >0  #(lf)      THEN  DIV0NULL(COALESCE( f_listing.CURRENT_LIST_PRICE,Turnkey.N_CURRENT_RENT), Turnkey.O_CURRENT_RENT) - 1#(lf)#(tab)  ELSE NULL END AS RENT_GROWTH_LIST#(lf)#(lf)#(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND HC_SCOPE_COMPLETED_DATE IS NOT NULL THEN DATEDIFF(DAY, Turnkey.O_Move_Out, HC_SCOPE_COMPLETED_DATE) #(lf)#(tab)  ELSE NULL END AS ""Days_MoveOut_Scope""#(lf)#(tab)  #(lf),CASE WHEN HC_SCOPE_COMPLETED_DATE IS NOT NULL AND TKT_CREATED_MIN IS NOT NULL THEN DATEDIFF(DAY,  HC_SCOPE_COMPLETED_DATE, TKT_CREATED_MIN) #(lf)#(tab)  ELSE NULL END AS ""Days_Scope_TKT_Created""#(lf)#(tab)  #(tab)  #(lf),CASE WHEN TKT_CREATED_MIN IS NOT NULL AND TKT_Closed_Max IS NOT NULL THEN DATEDIFF(DAY, TKT_CREATED_MIN, TKT_Closed_Max) #(lf)#(tab)  ELSE NULL END AS ""Days_TKT_Created_TKT_Closed""#(lf)#(tab)  #(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND COALESCE(TKT_Closed_Max, HC_TURN_COMPLETED_DATE) IS NOT NULL THEN DATEDIFF(DAY, Turnkey.O_Move_Out, COALESCE(TKT_Closed_Max, HC_TURN_COMPLETED_DATE))#(lf)#(tab)  ELSE NULL END AS ""Days_MO_TKT_Closed""#(lf)#(tab)  #(lf),CASE WHEN TKT_Closed_Max IS NOT NULL AND HC_TURN_COMPLETED_DATE IS NOT NULL THEN DATEDIFF(DAY, TKT_Closed_Max, HC_TURN_COMPLETED_DATE) #(lf)#(tab)  ELSE NULL END AS ""Days_TKT_Closed_QC""#(lf)#(tab)  #(lf),CASE WHEN d_listing.LISTING_DATE IS NOT NULL AND HC_TURN_COMPLETED_DATE IS NOT NULL THEN DATEDIFF(DAY, HC_TURN_COMPLETED_DATE, d_listing.LISTING_DATE) #(lf)#(tab)  ELSE NULL END AS ""Days_QC_List""#(lf)#(tab)  #(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND HC_TURN_COMPLETED_DATE IS NOT NULL THEN DATEDIFF(DAY, Turnkey.O_Move_Out, HC_TURN_COMPLETED_DATE)#(lf)#(tab)  ELSE NULL END AS ""Days_MoveOut_Closed_QC""#(lf)#(tab)  #(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND d_listing.LISTING_DATE IS NOT NULL THEN DATEDIFF(DAY, COALESCE(Turnkey.O_Move_Out,O_AnticipatedMoveOutDate), d_listing.LISTING_DATE) #(lf)#(tab)  ELSE NULL END AS ""Days_MoveOut_List""#(lf)#(tab)  #(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND N_HOLDING_FEE_DATE IS NOT NULL THEN DATEDIFF(DAY, Turnkey.O_Move_Out, N_HOLDING_FEE_DATE) #(lf)#(tab)  ELSE NULL END AS ""Days_MoveOut_HoldingFee""#(lf)#(lf),CASE WHEN Turnkey.O_Move_Out IS NOT NULL AND N_MoveIn IS NOT NULL THEN DATEDIFF(DAY, Turnkey.O_Move_Out, N_MoveIn) #(lf)#(tab)  ELSE NULL END AS ""Days_MoveOut_MoveIn""#(lf)#(tab)  #(lf),CASE WHEN N_MoveIn IS NULL THEN COALESCE (DATEDIFF(DAY, COALESCE(Turnkey.O_Move_Out,O_AnticipatedMoveOutDate), GETDATE()) , 0)#(lf)#(tab)  ELSE NULL END  AS ""Days_ActiveInTurn""#(lf)#(tab)  #(lf),CASE WHEN d_listing.LISTING_DATE IS NOT NULL THEN  DATEDIFF(DAY, d_listing.LISTING_DATE, COALESCE (N_MoveIn,GETDATE()) )#(lf)#(tab)  ELSE NULL END  AS ""Days_On_Market""#(lf)#(tab)  #(lf),CASE WHEN DATEDIFF(DAY, Turnkey.O_Move_Out, GETDATE()) <=30 THEN 'Under 30 Days' ELSE 'Over 30 Days' END AS MOVE_OUT_TIMING#(tab)  #(lf)#(tab)  #(lf),CASE WHEN d_listing.listing_status IN ('Active') AND WO_END_DATE IS NOT NULL AND WO_END_DATE >= Listing_MI_READY_DATE AND  WO_END_DATE >= GETDATE()  THEN 'Push MIRD' ELSE NULL END AS MIRD_FLAG#(lf)#(tab)  #(lf),DATE_TRUNC('month', d_listing.LISTING_DATE) AS ""1_N_List (BOM)""#(lf),DATE_TRUNC('month', N_MoveIn) AS ""1_N_Lease_FROM (BOM)""#(lf),d_listing.IS_PUBLISHED AS N_IS_PUBLISHED#(lf),CASE WHEN Turnkey.MOVEOUTCOMPLETE = 'Yes' THEN COALESCE(MOC.MoveOutCharges,0.001) ELSE NULL END AS MoveOutCharges#(lf),RANK () OVER( PARTITION BY Turnkey.Property_key ORDER BY f_listing.RENT_LIST_HIST_ID DESC) AS RECENT_TURN_RANK#(lf),CASE WHEN N_LISTING_DATE IS NOT NULL AND N_MoveIn IS NULL THEN 1 ELSE NULL END AS ON_MARKET_FLAG #(lf)#(lf),CASE WHEN Turnkey.MOVEOUTCOMPLETE = 'Yes' THEN COALESCE(MoveOutReceipts_PAID,0.001) + COALESCE(MoveOutReceipts_CONCESSION,0.001) ELSE NULL END AS MoveOutReceipts_Final#(lf),CASE WHEN Turnkey.MOVEOUTCOMPLETE = 'Yes' THEN COALESCE(MOC.MoveOutCharges,0.001) - COALESCE(MoveOutReceipts_PAID,0.001) - COALESCE(MoveOutReceipts_CONCESSION,0.001) ELSE NULL END AS MoveOutReceipts_OUTSTANDING#(lf)#(lf),MoveOutReceipts_PAID#(lf),MoveOutReceipts_CONCESSION#(lf),MoveOutReceipts_BAD_DEBT#(lf),MoveOutReceipts_TOTAL#(lf)#(lf),CASE WHEN HSP.PROPERTY_SEPTIC_FEE = '35' THEN 'Yes' ELSE NULL END AS SEPTIC_FLAG#(lf),CONVERT_TIMEZONE('EST', SODA_COMPLETION_DATE::date) AS SODA_COMPLETION_DATE#(lf)#(lf)FROM Turnkey#(lf)LEFT JOIN Turn_Listings TL ON TL.O_Turn_ID = Turnkey.O_Turn_ID AND TL.Property_Key = Turnkey.Property_key#(lf)left join PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST f_listing on TL.rent_list_hist_key = f_listing.RENT_LIST_HIST_ID#(lf)left join PROD_ANALYTICS.DBT_RESICAP.DIM_LISTING d_listing on f_listing.LISTING_KEY = d_listing.LISTING_KEY and d_listing.CURRENT_FLAG = 'Y'#(lf)LEFT JOIN TURN_WO_SUMMARY TWS ON TWS.O_Turn_ID = Turnkey.O_Turn_ID #(lf)LEFT JOIN MoveOutCharges MOC ON MOC.LeaseID = Turnkey.O_Turn_ID #(lf)LEFT JOIN MoveOutReceipts MOR ON MOR.LeaseID = Turnkey.O_Turn_ID #(lf)LEFT JOIN (#(lf)            SELECT#(lf)                UPPER(P.PROPERTY_ENTITY_ID) AS PROPERTY_ENTITY_ID#(lf)                ,P.PROPERTY_SEPTIC_FEE#(lf)                ,RANK () OVER(PARTITION BY UPPER(P.PROPERTY_ENTITY_ID) ORDER BY _FIVETRAN_SYNCED DESC) RANK #(lf)                FROM PROD_REPLICA.HUBSPOT_2.PROPERTIES P#(lf)                QUALIFY Rank = 1 ) HSP ON HSP.PROPERTY_ENTITY_ID = Turnkey.EntityId#(lf)#(lf)LEFT JOIN ""PROD_ANALYTICS"".""DBT_RESICAP"".""FCT_TENANT_ACTIVITY"" FTA ON FTA.Tenant_KEY = Turnkey.O_Tenant_KEY#(lf)#(lf)#(lf)WHERE 1=1#(lf)--AND Turnkey.EntityID = 'RPTX00219'#(lf)--AND Turnkey.O_Turn_ID = 23369", null, [EnableFolding=true]),
