	column 1_Turn_Tkt_Substatus = IF(DW_Turns[1_Turn Status]="Pending TKT",COALESCE(CALCULATE(MAX(GS_RateCards[Status]),FILTER(GS_RateCards,GS_RateCards[EntityID]=DW_Turns[ENTITYID]&&GS_RateCards[Timestamp]>=DW_Turns[O_MOVE_OUT])),"Unsubmitted"),BLANK())
		lineageTag: 176aac7d-5085-4e0f-be71-ddea5b71e6df
