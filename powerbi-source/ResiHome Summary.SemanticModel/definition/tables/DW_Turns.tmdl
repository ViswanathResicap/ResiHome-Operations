	column MOVEOUTRECEIPTS_BAD_DEBT
		dataType: double
		lineageTag: 6532878f-2c16-4439-bc4c-9a45d89a01aa
		summarizeBy: sum
		sourceColumn: MOVEOUTRECEIPTS_BAD_DEBT

