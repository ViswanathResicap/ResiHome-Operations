			relationship: b3390965-32ea-41db-bd67-63930d3d61bd
			defaultHierarchy: LocalDateTable_05685991-1155-4d76-a859-733e18455e0d.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

	column '1_Pet Fee' = CALCULATE(SUM(DW_Tenant_Receipts[PAID_AMOUNT]),FILTER(DW_Tenant_Receipts,DW_Tenant_Receipts[LEASE_ID]=DW_Turns[O_TURN_ID]&&DW_Tenant_Receipts[IS_CREDIT]="N"&&DW_Tenant_Receipts[GL]="4012"&&OR(DW_Tenant_Receipts[CREDITTYPEID]=0,DW_Tenant_Receipts[CREDITTYPEID]=BLANK())))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 7de8055e-9e99-4282-8ccd-369cb669944f
		summarizeBy: sum

