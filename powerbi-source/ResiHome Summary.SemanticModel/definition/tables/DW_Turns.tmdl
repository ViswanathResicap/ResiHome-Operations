	partition DW_Turns-372614dd-00e5-46ce-9ad2-7e51d8d7fd6b = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Role="UAT", Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   TURNS DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per turn (anchored on Turnkey.O_Turn_ID), combining tenant#(lf)            move-out/move-in pairing, HappyCo scope & QC inspections, turn work#(lf)            orders, listings, and move-out charge/receipt reconciliation.#(lf)   Anchor:  Turnkey CTE (built from TENANT self-join old->new lease).#(lf)   Large CTE chain: CollectionsNote, PICS, CLEAN_ITEM/UNIT/INSPECTION,#(lf)            HAPPY_CO_DETAIL/SCOPE/QC, RESIWALK_INS/ANSWER_AGG/SCOPE/QC, UW_RENT,#(lf)            HHI, DEALS, TENANT, HAPPY_CO_TURN, Turnkey, Turn_Listings, MoveOut*,#(lf)            BadDebt, WO_DETAIL, WO_TURN, TURN_WO_SUMMARY -> final SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  ORGANIZATION_KEY / ORGANIZATION_NAME CASE blocks in DEALS, TENANT,#(lf)             Turnkey, and WO_DETAIL updated from the prior two-group form#(lf)             (-1.. -> 'RP SFR', 27.. -> 'RB DRC') to the full six-group roll-up#(lf)             that mirrors the master PROPERTY script (source of truth).#(lf)             DELIBERATE OUTPUT CHANGE limited to the organization columns.#(lf)     No CTEs or joins dropped: every CTE feeds the final result (directly or via#(lf)     Turnkey / WO_TURN / TURN_WO_SUMMARY). The commented-out legacy HHI HubSpot#(lf)     block and the commented-out RESI_TSUM join are preserved exactly as found.#(lf)#(lf)   [RESIWALK ADD] HAPPY_CO_SCOPE and HAPPY_CO_QC now UNION ALL in ResiWalk#(lf)     (HubSpot-native) inspections so Turn data uses BOTH sources:#(lf)        - RESIWALK_SCOPE: template pm_scope_rate_card -> '(PM) Scope Inspection'#(lf)        - RESIWALK_QC:    template pm_turn_reinspect_qc -> '(PM) Turn Inspection'#(lf)     Property link: INSPECTION.PROPERTY_ENTITY_ID -> DIM_PROPERTY.ENTITYID (1:1).#(lf)     Status filter: ResiWalk native lowercase 'completed'.#(lf)     ISSUE_COUNT mapped from rate_card_line answer count (each scoped line = an#(lf)     identified deficiency), mirroring HappyCo's HC_*_ISSUE_COUNT.#(lf)     HC_SCOPE_REPORT_STATUS has no ResiWalk analog -> NULL.#(lf)     HC_TURN_REPORT_STATUS read from the inspection-object result field#(lf)     (inspection_result) and standardized to the HappyCo vocabulary:#(lf)        'pass' -> 'Pass', 'fail' -> 'Fail', anything else/blank -> NULL.#(lf)     The result column is referenced dynamically via GET(OBJECT_CONSTRUCT(HI.*),..)#(lf)     so the query COMPILES before Fivetran adds the column to the replica (no#(lf)     completed Turn/QC inspections have populated it yet); it resolves to NULL#(lf)     today and maps live Pass/Fail values automatically once the field syncs.#(lf)     As of build: 12 completed Scope inspections (live), 0 completed Turn/QC#(lf)     inspections (QC leg is forward-compatible plumbing, 0 rows today).#(lf)   ============================================================================= */#(lf)#(lf)WITH CollectionsNote AS (#(lf)#(tab)#(tab)SELECT DISTINCT #(lf)#(tab) #(tab)N.NOTEID AS LatestNoteID#(lf)#(tab) #(tab),N.NOTETEXT AS CollectionNote#(lf)#(tab) #(tab),N.CREATEDDATE  AS CollectionNoteCreated#(lf)#(tab) #(tab),DATEDIFF('Day',N.CREATEDDATE,GETDATE()) CollectionNote_Days#(lf)#(tab)    ,P.PropertyId#(lf)#(tab)    ,TI.UserID#(lf)#(tab)    ,U.FIRSTNAME || ' ' || U.LASTNAME AS CollectionNote_Added_By#(lf)#(tab)    ,RANK() OVER( PARTITION BY TI.UserID ORDER BY N.CREATEDDATE DESC) AS Recent_Rank#(lf)#(tab)#(lf)#(tab)#(tab)FROM PROD_REPLICA.HBPM_DBO.NOTES N #(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.NOTETYPES NT ON NT.Id = N.NoteTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.LookUpMasterId = N.ObjectTypeId#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.UserID = N.ObjectId AND N.ObjectTypeId = 502 AND TI.""_FIVETRAN_DELETED"" = 'N'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PAI ON PAI.UnitId = TI.UnitId AND PAI.""_FIVETRAN_DELETED"" ='N'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES P ON P.PropertyID = COALESCE(PAI.PropertyId, N.ObjectID) AND P.""_FIVETRAN_DELETED"" ='N'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.USERS U ON U.USERID  = N.ADDEDBY #(lf)#(tab) #(tab)WHERE N.NoteTypeId = 3#(lf)#(tab) --#(tab)AND PAI.PROPERTYID = 36301#(lf)#(tab) #(tab)QUALIFY Recent_Rank = 1)#(lf)#(lf)--****************************************************************************#(lf),PICS AS (#(lf) SELECT#(lf)  MAX(PHOTO_COUNT) AS Picture_Count#(lf)  ,TRY_TO_NUMERIC(UNIT_) AS PM_PropertyID#(lf)  FROM ""PROD_REPLICA"".""RENTLY"".""_3_0_DATA""#(lf)  WHERE 1=1#(lf)  AND TRY_TO_NUMERIC(UNIT_) IS NOT NULL#(lf)  GROUP BY UNIT_#(lf))#(lf)#(lf)--****************************************************************************#(lf)#(lf),CLEAN_ITEM AS (#(lf)#(lf)SELECT #(lf)  ITEM._MODIFIED#(lf) ,ITEM.ID AS ITEM_ID#(lf) ,ITEM.SECTION AS  ITEM_Section#(lf) ,ITEM.ITEM  AS ITEM_Item#(lf) ,ITEM.RATINGS AS  ITEM_Ratings#(lf) ,ITEM.NOTES  AS  ITEM_Notes#(lf) ,ITEM.INSPECTION_ID#(lf) ,RANK() OVER( PARTITION BY ITEM.INSPECTION_ID ORDER BY DATE_TRUNC('min',_FIVETRAN_SYNCED)  DESC) UPDATE_RANK#(lf) ,RANK() OVER( PARTITION BY ITEM_SECTION, ITEM_ITEM, ITEM.INSPECTION_ID ORDER BY DATE_TRUNC('min',_MODIFIED)  DESC) RECENT_RANK#(lf)FROM PROD_REPLICA.HAPPYCO_NEW.ITEM_2025 ITEM#(lf))#(lf)--AND ITEM_SECTION = 'Report Status' )#(lf)#(lf)#(lf),CLEAN_UNIT_PRE AS (#(lf) SELECT #(lf)   UNIT._MODIFIED#(lf)  ,UNIT.ID AS UNIT_ID#(lf)  ,UNIT.EXTERNAL_ID AS UNIT_EXTERNAL_ID #(lf)  ,UNIT.ADDRESS AS UNIT_ADDRESS#(lf)  ,UNIT.LINE_1 AS UNIT_LINE_1#(lf)  ,RANK() OVER( PARTITION BY ID ORDER BY DATE_TRUNC('min',_MODIFIED) DESC) RECENT_RANK#(lf)FROM PROD_REPLICA.HAPPY_CO.UNIT)#(lf)#(lf),CLEAN_UNIT AS (#(lf) SELECT DISTINCT#(lf)  CLEAN_UNIT_PRE.*#(lf)  ,COALESCE (P1.PROPERTY_KEY,P2.PROPERTY_KEY,P3.PROPERTY_KEY,P4.PROPERTY_KEY ) AS PROPERTY_KEY#(lf)  ,P1.PROPERTY_KEY P1#(lf)  ,P2.PROPERTY_KEY P2#(lf)  ,P3.PROPERTY_KEY P3#(lf)  ,P4.PROPERTY_KEY  P4#(lf) FROM CLEAN_UNIT_PRE#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P1 ON TO_CHAR(P1.HBAM_PROPERTY_ID) = CLEAN_UNIT_PRE.UNIT_EXTERNAL_ID AND P1.CURRENT_FLAG = 'Y' AND P1.PROPERTY_STATE = 'Active' AND P1.PROPERTY_STATUS <> 'Property Sold'#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P2 ON  P2.ENTITYID = CLEAN_UNIT_PRE.UNIT_EXTERNAL_ID  AND P2.CURRENT_FLAG = 'Y' AND P2.PROPERTY_STATE = 'Active' AND P2.PROPERTY_STATUS <> 'Property Sold'#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P3 ON  INITCAP(TRIM(P3.ADDRESS))  = INITCAP(TRIM(CLEAN_UNIT_PRE.UNIT_LINE_1))  AND P3.CURRENT_FLAG = 'Y' AND P3.PROPERTY_STATE = 'Active' AND P3.PROPERTY_STATUS <> 'Property Sold'#(lf)  LEFT JOIN (SELECT LEFT(INITCAP(TRIM(ADDRESS)),9) ADD_TRIM, MAX(PROPERTY_KEY) PROPERTY_KEY#(lf)             FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY#(lf)             WHERE CURRENT_FLAG = 'Y' AND PROPERTY_STATE = 'Active' AND PROPERTY_STATUS <> 'Property Sold'#(lf)             GROUP BY LEFT(INITCAP(TRIM(ADDRESS)),9) ) P4#(lf)  #(tab)         ON  ADD_TRIM  = LEFT(INITCAP(TRIM(COALESCE(CLEAN_UNIT_PRE.UNIT_LINE_1,UNIT_ADDRESS))),9) #(lf)#(lf)  WHERE CLEAN_UNIT_PRE.RECENT_RANK = 1)#(lf) #(lf) #(lf),CLEAN_INPSECTION AS (#(lf) SELECT#(lf)  INS._MODIFIED#(lf)  ,INS._LINE#(lf) ,INS.INSPECTION_ID#(lf) ,INS.INSPECTION_INSPECTOR_NAME#(lf) ,INS.INSPECTION_COMPLETED_DATE#(lf) ,INS.INSPECTION_STATUS#(lf) ,CASE WHEN INS.INSPECTION_TEMPLATE = '(QC) Turn RRQC Inspection' THEN '(QC) Turn Inspection'#(lf)      ELSE  INS.INSPECTION_TEMPLATE END AS INSPECTION_TEMPLATE#(lf) ,INS.INSPECTION_LINK#(lf) ,INS.UNIT_ID#(lf) ,RANK() OVER( PARTITION BY INS.INSPECTION_ID ORDER BY DATE_TRUNC('min',_MODIFIED) DESC) RECENT_RANK#(lf)FROM PROD_REPLICA.HAPPY_CO.INSPECTION INS#(lf)WHERE INSPECTION_ID NOT IN ('wAS8twd-A-rGt','Qqzpo2d-A-3c2')#(lf))#(lf)------------------------------------------------#(lf)#(lf),HAPPY_CO_DETAIL AS (#(lf)SELECT DISTINCT #(lf)#(lf) CLEAN_UNIT.PROPERTY_KEY#(lf),CLEAN_UNIT.UNIT_ID#(lf),CLEAN_UNIT.UNIT_EXTERNAL_ID#(lf),CLEAN_UNIT.UNIT_Address#(lf),CLEAN_UNIT.UNIT_LINE_1#(lf),RANK() OVER(PARTITION BY CLEAN_UNIT.PROPERTY_KEY, CLEAN_INPSECTION.INSPECTION_TEMPLATE ORDER BY CLEAN_INPSECTION.INSPECTION_COMPLETED_DATE DESC, CLEAN_INPSECTION.INSPECTION_ID DESC) RECENT_INS_RANK#(lf),CLEAN_INPSECTION.INSPECTION_ID#(lf),CLEAN_INPSECTION.INSPECTION_INSPECTOR_NAME#(lf),CLEAN_INPSECTION._LINE#(lf),CLEAN_INPSECTION.INSPECTION_COMPLETED_DATE#(lf),CLEAN_INPSECTION.INSPECTION_STATUS#(lf),CLEAN_INPSECTION.INSPECTION_TEMPLATE#(lf),CLEAN_INPSECTION.INSPECTION_LINK#(lf),CLEAN_ITEM.ITEM_Section#(lf),CLEAN_ITEM.ITEM_Item#(lf),CLEAN_ITEM.ITEM_Ratings#(lf),CLEAN_ITEM.ITEM_Notes#(lf),CASE WHEN CLEAN_ITEM.ITEM_Section = 'Report Status' AND CLEAN_ITEM.ITEM_ITEM = 'Pass/Fail' THEN 1 ELSE 0 END AS Report_Status#(lf),CASE WHEN CLEAN_ITEM.ITEM_ITEM = 'Deficiencies corrected from Scope' THEN 1 ELSE 0 END AS TURN_LINE#(lf),CASE WHEN CLEAN_ITEM.ITEM_Section = 'Pre Leasing Status' THEN 1 ELSE 0 END AS PreLease_Status#(lf)#(lf)FROM CLEAN_INPSECTION #(lf)LEFT JOIN CLEAN_ITEM ON CLEAN_ITEM.INSPECTION_ID = CLEAN_INPSECTION.INSPECTION_ID AND CLEAN_ITEM.RECENT_RANK = 1 AND CLEAN_ITEM.UPDATE_RANK = 1 #(lf)LEFT JOIN CLEAN_UNIT ON CLEAN_UNIT.UNIT_ID = CLEAN_INPSECTION.UNIT_ID AND CLEAN_UNIT.RECENT_RANK = 1#(lf)#(lf)WHERE 1=1#(lf)AND CLEAN_INPSECTION.RECENT_RANK = 1 #(lf)AND CLEAN_INPSECTION.INSPECTION_STATUS = 'Complete'#(lf)--AND CLEAN_INPSECTION.INSPECTION_TEMPLATE LIKE '%(QC)%'#(lf)--AND CLEAN_INPSECTION.INSPECTION_TEMPLATE NOT LIKE '%(PM)%') OR CLEAN_INPSECTION.INSPECTION_TEMPLATE = '(PM) Pre Move-Out')#(lf)--AND CLEAN_INPSECTION.INSPECTION_TEMPLATE LIKE '%(PM) (QC) - Vacancy & Security Check%'#(lf)AND CLEAN_ITEM.ITEM_SECTION IS NOT NULL#(lf))#(lf)#(lf)--SELECT * FROM HAPPY_CO_DETAIL#(lf)--WHERE Property_key = 46390#(lf)#(lf)-----------------------------------------------------------------------------------------------#(lf)-- [RESIWALK ADD] ResiWalk (HubSpot-native) inspection rows, header-level.#(lf)-- PROPERTY_ENTITY_ID -> DIM_PROPERTY.ENTITYID (clean 1:1). inspection_result#(lf)-- read dynamically (column not yet in replica) and standardized to HappyCo#(lf)-- Pass/Fail vocabulary.#(lf),RESIWALK_INS AS (#(lf) SELECT#(lf)  HI.ID AS INSPECTION_ID#(lf) ,P.PROPERTY_KEY#(lf) ,COALESCE(HI.PROPERTY_LINK_MASTER, HI.PROPERTY_PDF_MASTER_URL) AS INSPECTION_LINK#(lf) ,HI.PROPERTY_COMPLETED_AT::DATE AS INSPECTION_COMPLETED_DATE#(lf) ,HI.PROPERTY_TEMPLATE_TYPE#(lf) -- Standardize ResiWalk inspection_result ('pass'/'fail') to the HappyCo#(lf) -- HC_TURN_REPORT_STATUS vocabulary ('Pass'/'Fail'), which drives the downstream#(lf) -- PASS_MINOR + TKT_*_Fail logic. Dynamic GET() reference so the query compiles#(lf) -- before Fivetran adds the column to the replica (no completed Turn/QC inspections#(lf) -- have populated it yet); resolves to NULL today, maps live values once it syncs.#(lf) ,CASE LOWER(TRIM(GET(OBJECT_CONSTRUCT(HI.*), 'PROPERTY_INSPECTION_RESULT')::TEXT))#(lf)    WHEN 'pass' THEN 'Pass'#(lf)    WHEN 'fail' THEN 'Fail'#(lf)    ELSE NULL#(lf)  END AS INSPECTION_RESULT_STD#(lf) FROM PROD_REPLICA.HUBSPOT_2.INSPECTION HI#(lf) LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.ENTITYID = HI.PROPERTY_ENTITY_ID AND P.CURRENT_FLAG = 'Y'#(lf) WHERE (HI._FIVETRAN_DELETED = FALSE OR HI._FIVETRAN_DELETED IS NULL)#(lf) AND HI.PROPERTY_TEMPLATE_TYPE IN ('pm_scope_rate_card','pm_turn_reinspect_qc')#(lf) AND LOWER(HI.PROPERTY_STATUS) = 'completed'#(lf) AND P.PROPERTY_KEY IS NOT NULL#(lf))#(lf)#(lf),RESIWALK_ANSWER_AGG AS (#(lf) SELECT#(lf)  ATI.TO_ID AS INSPECTION_ID#(lf) ,COUNT(CASE WHEN A.PROPERTY_ANSWER_TYPE = 'rate_card_line' THEN 1 END) AS RATE_CARD_LINE_COUNT#(lf) FROM PROD_REPLICA.HUBSPOT_2.INSPECTION_ANSWER_TO_INSPECTION ATI#(lf) JOIN PROD_REPLICA.HUBSPOT_2.INSPECTION_ANSWER A ON A.ID = ATI.FROM_ID#(lf)   AND (A._FIVETRAN_DELETED = FALSE OR A._FIVETRAN_DELETED IS NULL)#(lf) GROUP BY ATI.TO_ID#(lf))#(lf)#(lf)-- Mirrors HAPPY_CO_SCOPE output columns exactly (for UNION ALL below).#(lf),RESIWALK_SCOPE AS (#(lf) SELECT#(lf)  R.PROPERTY_KEY#(lf) ,R.INSPECTION_LINK AS HC_SCOPE_INSPECTION_LINK#(lf) ,R.INSPECTION_COMPLETED_DATE AS HC_SCOPE_COMPLETED_DATE#(lf) ,CAST(NULL AS TEXT) AS HC_SCOPE_REPORT_STATUS#(lf) ,AGG.RATE_CARD_LINE_COUNT AS HC_SCOPE_ISSUE_COUNT#(lf) ,RANK() OVER( PARTITION BY R.PROPERTY_KEY, R.INSPECTION_COMPLETED_DATE ORDER BY R.INSPECTION_LINK DESC) AS Recent_Rank#(lf) FROM RESIWALK_INS R#(lf) LEFT JOIN RESIWALK_ANSWER_AGG AGG ON AGG.INSPECTION_ID = R.INSPECTION_ID#(lf) WHERE R.PROPERTY_TEMPLATE_TYPE = 'pm_scope_rate_card'#(lf))#(lf)#(lf)-- Mirrors HAPPY_CO_QC output columns exactly (for UNION ALL below).#(lf),RESIWALK_QC AS (#(lf) SELECT#(lf)  R.PROPERTY_KEY#(lf) ,R.INSPECTION_LINK AS HC_TURN_INSPECTION_LINK#(lf) ,R.INSPECTION_COMPLETED_DATE AS HC_TURN_COMPLETED_DATE#(lf) ,R.INSPECTION_RESULT_STD AS HC_TURN_REPORT_STATUS#(lf) ,AGG.RATE_CARD_LINE_COUNT AS HC_TURN_ISSUE_COUNT#(lf) ,RANK() OVER( PARTITION BY R.PROPERTY_KEY, R.INSPECTION_COMPLETED_DATE ORDER BY R.INSPECTION_LINK DESC) AS Recent_Rank#(lf) FROM RESIWALK_INS R#(lf) LEFT JOIN RESIWALK_ANSWER_AGG AGG ON AGG.INSPECTION_ID = R.INSPECTION_ID#(lf) WHERE R.PROPERTY_TEMPLATE_TYPE = 'pm_turn_reinspect_qc'#(lf))#(lf)#(lf)-----------------------------------------------------------------------------------------------#(lf),HAPPY_CO_SCOPE AS (#(lf)#(lf)SELECT #(lf) HCD.PROPERTY_KEY#(lf),HCD.INSPECTION_LINK AS HC_SCOPE_INSPECTION_LINK#(lf),HCD.INSPECTION_COMPLETED_DATE AS  HC_SCOPE_COMPLETED_DATE#(lf),MAX(CASE WHEN Report_Status = 1 THEN ITEM_Ratings ELSE NULL END) AS HC_SCOPE_REPORT_STATUS#(lf),SUM(CASE WHEN ITEM_Ratings = 'Issue' THEN 1 ELSE NULL END) AS HC_SCOPE_ISSUE_COUNT#(lf),RANK() OVER( PARTITION BY HCD.PROPERTY_KEY, HCD.INSPECTION_COMPLETED_DATE ORDER BY HC_SCOPE_INSPECTION_LINK DESC) AS Recent_Rank#(lf)#(lf)FROM HAPPY_CO_DETAIL HCD#(lf)WHERE 1=1#(lf)--AND HCD.RECENT_INS_RANK = 1#(lf)AND ITEM_SECTION <> 'Locks'#(lf)--AND HCD.INSPECTION_TEMPLATE IN ('(QC) Scope Inspection','(PM) Scope Inspection','(PM) Squatter Scope')#(lf)AND HCD.INSPECTION_TEMPLATE IN ('(QC) Scope Inspection','(PM) Scope Inspection','(PM) Scope Inspection (BI FIX ONLY)','(PM) Squatter Scope')#(lf)--AND HCD.Property_key =234243#(lf)#(lf)GROUP BY#(lf) HCD.PROPERTY_KEY#(lf),HCD.INSPECTION_LINK#(lf),HCD.INSPECTION_COMPLETED_DATE#(lf)--QUALIFY Recent_Rank = 1#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT#(lf) PROPERTY_KEY#(lf),HC_SCOPE_INSPECTION_LINK#(lf),HC_SCOPE_COMPLETED_DATE#(lf),HC_SCOPE_REPORT_STATUS#(lf),HC_SCOPE_ISSUE_COUNT#(lf),Recent_Rank#(lf)FROM RESIWALK_SCOPE#(lf)#(lf))#(lf)-----------------------------------------------------------------------------------------------#(lf),HAPPY_CO_QC AS (#(lf)#(lf)SELECT #(lf) HCD.PROPERTY_KEY#(lf),HCD.INSPECTION_LINK AS HC_TURN_INSPECTION_LINK#(lf),HCD.INSPECTION_COMPLETED_DATE  AS  HC_TURN_COMPLETED_DATE#(lf),MAX(CASE WHEN Report_Status = 1  THEN ITEM_Ratings ELSE NULL END) AS HC_TURN_REPORT_STATUS#(lf),SUM(CASE WHEN CONTAINS(ITEM_Ratings,'No') AND TURN_LINE = 1 THEN 1 ELSE NULL END) AS HC_TURN_ISSUE_COUNT#(lf),RANK() OVER( PARTITION BY HCD.PROPERTY_KEY, HCD.INSPECTION_COMPLETED_DATE ORDER BY HCD.INSPECTION_LINK DESC) AS Recent_Rank#(lf)#(lf)FROM HAPPY_CO_DETAIL HCD#(lf)WHERE 1=1#(lf)--AND HCD.RECENT_INS_RANK = 1#(lf)AND ITEM_SECTION <> 'Locks'#(lf)AND (HCD.INSPECTION_TEMPLATE LIKE '(QC) Turn Inspection%'#(lf)    OR HCD.INSPECTION_TEMPLATE LIKE '(PM) Turn Inspection%')#(lf)--AND HCD.Property_key =251448#(lf)    #(lf)GROUP BY#(lf) HCD.PROPERTY_KEY#(lf),HCD.INSPECTION_LINK#(lf),HCD.INSPECTION_COMPLETED_DATE#(lf)--QUALIFY Recent_Rank = 1#(lf)#(lf)UNION ALL#(lf)#(lf)SELECT#(lf) PROPERTY_KEY#(lf),HC_TURN_INSPECTION_LINK#(lf),HC_TURN_COMPLETED_DATE#(lf),HC_TURN_REPORT_STATUS#(lf),HC_TURN_ISSUE_COUNT#(lf),Recent_Rank#(lf)FROM RESIWALK_QC#(lf)#(lf))#(lf)#(lf)#(lf)-----------------------------------------------------------------------------------------------#(lf)-----------------------------------------------------------------------------------------------#(lf),UW_RENT_MAX AS (#(lf)#(tab)SELECT #(lf)#(tab)MAX(RENTLOGID) RENTLOGID #(lf)#(tab), ENTITYID1#(lf)#(tab)FROM PROD_REPLICA.HBPM_DBO.RENTLOGS#(lf)#(tab)GROUP BY ENTITYID1) #(lf)#(tab)#(lf),UW_RENT AS (#(lf)#(tab)SELECT #(lf)#(tab) RentLogs.ENTITYID1 AS HBPM_UnitID#(lf)#(tab),RentLogs.ORIGINALVALUE AS UW_Rent_Prior#(lf)#(tab),RentLogs.UPDATEVALUE AS UW_Rent_Current#(lf)#(tab),RentLogs.OCCUREDON  AS UW_Update_Date#(lf)#(tab)FROM UW_RENT_MAX#(lf)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.RENTLOGS RentLogs ON RentLogs.RENTLOGID = UW_RENT_MAX.RentLogID)#(lf)#(lf)-----------------------------------------------------------------------------------------------#(lf),HHI AS (#(lf)/*Select #(lf)#(lf)D.Deal_ID #(lf),CASE WHEN sum(C_INC.Annual_Income) <30000 THEN NULL #(lf)#(tab)  WHEN  sum(C_INC.Annual_Income) > 1000000 THEN NULL #(lf)#(tab)  ELSE  sum(C_INC.Annual_Income) END AS HHI#(lf)#(lf)FROM PROD_REPLICA.HUBSPOT.DEAL D#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.DEAL_CONTACT DC ON DC.DEAL_ID = D.DEAL_ID#(lf)LEFT JOIN (SELECT#(lf)#(tab)#(tab)#(tab)#(tab)CONTACT_ID#(lf)#(tab)#(tab)#(tab)#(tab),COALESCE (#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'total_yearly_income' THEN value ELSE null END),#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'annual_salary' THEN value ELSE null END)) AS Annual_Income#(lf)#(tab)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.COntact_PROPERTY_HISTORY#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)WHERE 1=1 #(lf)#(tab)#(tab)#(tab)#(tab)AND NAME IN ('annual_salary','total_yearly_income')#(lf)#(tab)#(tab)#(tab)#(tab)GROUP BY CONTACT_ID ) C_INC ON C_INC.Contact_ID = DC.Contact_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)WHERE 1=1 #(lf)GROUP BY D.DEAL_ID*/#(lf)#(lf)SELECT dd.DEAL_KEY #(lf),CASE #(lf)#(tab)WHEN dl.TOTAL_YEARLY_INCOME <30000 THEN NULL  #(lf)#(tab)WHEN dl.TOTAL_YEARLY_INCOME > 1000000 THEN NULL #(lf)#(tab)ELSE dl.TOTAL_YEARLY_INCOME#(lf)END AS HHI#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM f_deal#(lf)JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL dd #(lf)#(tab)ON f_deal.DEAL_KEY = dd.DEAL_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD dl #(lf)#(tab)ON f_deal.LEAD_KEY = dl.LEAD_KEY #(lf))#(lf)#(lf)---***********************************************************************************************************************#(lf),DEALS AS (SELECT #(lf)#(lf)P.PROPERTY_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf),P.HBPM_PROPERTY_ID #(lf),P.EntityID#(lf),P.Address#(lf),PUS.Under_written_rent#(lf)#(lf),REC.RECEIEVABLE_ID#(lf),PO.PORTFOLIO_NAME#(lf),R.REGION_NAME#(lf)#(lf),D.SECURITY_DEPOSIT_ID#(lf),D.DEAL_KEY#(lf),D.DEAL_ID#(lf),COALESCE(D.CURRENT_DEAL_STATUS,HUB_DEAL.DEAL_STAGE) AS CURRENT_DEAL_STATUS#(lf),HUB_DEAL.APP_ID#(lf),HUB_DEAL.APP_STAGE AS APP_STAGE#(lf)#(lf),D.COMBINED_INCOME * 12  AS COMBINED_INCOME#(lf),DSH.LEAD_KEY#(lf),D.APPLICATION_SUBMITTED_DATE::date AS Application_Submit_Date#(lf),date_trunc('month',D.APPLICATION_SUBMITTED_DATE::date) as ""App Submit (BOM)""#(lf),CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE::date) AS Application_Started_Date#(lf),date_trunc('month',CONVERT_TIMEZONE('EST', APPLICATION_STARTED_DATE )::date) as App_Started_BOM#(lf)#(lf),DATEDIFF(DAY, COALESCE(D.APPLICATION_SUBMITTED_DATE ,to_date(L.Application_SUBMIT_Date_KEY::TEXT,'yyyymmdd'),to_date(DSH.DEAL_CREATE_DATE_KEY::TEXT,'yyyymmdd')),GETDATE())  AS DAYS_SINCE_APP_SUBMIT#(lf)#(lf),L.First_Name ||  ' '  || L.Last_Name AS Lead_Name#(lf),L.PRIMARY_LEAD_ID#(lf),D.EMail#(lf),L.PHONE#(lf),to_date(L.CREATED_DATE_KEY::TEXT,'yyyymmdd') AS Lead_Created_Date#(lf),DATE_TRUNC('month', to_date(L.CREATED_DATE_KEY::TEXT,'yyyymmdd') ) AS ""1_Lead (BOM)""#(lf)#(lf),to_date(DSH.DEAL_CREATE_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_CREATE_DATE#(lf),to_date(DSH.APPLICATION_APPROVED_DATE_KEY::TEXT,'yyyymmdd') AS APPLICATION_APPROVED_DATE#(lf),to_date(DSH.DEAL_WON_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_WON_DATE#(lf),COALESCE(HUB_DEAL.PROPERTY_HOLDING_FEE_TRANSACTION_DATE,to_date(PAY.HOLDING_FEE_DATE_NEW::TEXT,'yyyymmdd'),to_date(DSH.HOLDING_FEE_PAID_DATE_KEY::TEXT,'yyyymmdd')) AS HOLDING_FEE_DATE_NEW#(lf),to_date(DSH.LEASE_SIGNED_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_SIGNED_DATE#(lf),to_date(DSH.CONVERT_TO_RESIDENT_DATE_KEY::TEXT,'yyyymmdd') AS CONVERT_TO_RESIDENT_DATE#(lf),to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') AS EXPECTED_MOVE_IN_DATE#(lf),COALESCE(to_date(DSH.LEASE_START_DATE_KEY::TEXT,'yyyymmdd'),#(lf)#(tab)#(tab)  to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') ) AS LEASE_START_DATE#(lf),to_date(DSH.LEASE_END_DATE_KEY::TEXT,'yyyymmdd') AS LEA