f) ,LT.CHARGE_GL_ACCOUNT_NAME as GlAccountDesc #(lf) ,ARV.Description as Description#(lf) ,LT.IS_CREDIT#(lf) ,BD.CreditTypeId#(lf) ,CASE WHEN BD.CreditTypeId = 1 THEN 'Concession'#(lf)     WHEN BD.CreditTypeId = 2 THEN 'Bad Debt' END AS Credit_Type_Name#(lf) ,TI.USERID #(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION LT#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.ACCOUNTSRECEIPTDETAILS ARD ON  ARD.RECEIPTDETAILID = LT.RECEIPT_DETAIL_ID AND ARD.""_FIVETRAN_DELETED""='N'#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.ACCOUNTSRECEIPTS AR ON AR.RECEIPTID = ARD.RECEIPTID AND AR.""_FIVETRAN_DELETED""='N'#(lf)LEFT join PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS RS ON RS.LOOKUPMASTERID = AR.RECEIPTSTATUSID #(lf)LEFT join PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS PT ON PT.LOOKUPMASTERID = AR.PAIDBYTYPEID #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_GL_ACCOUNT GL ON GL.GL_ACCOUNT_KEY = LT.GL_ACCOUNT_KEY #(lf)LEFT JOIN BadDebt BD ON BD.ReceiptID = ARD.ReceiptID#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.AccountsReceivables ARV ON  ARV.ReceivableID = LT.RECEIVABLE_ID #(lf)#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT TEN ON TEN.LEASE_ID = AR.LeaseID AND TEN.PRIMARY_TENANT = 'Y'  AND TEN.CURRENT_FLAG = 'Y'#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = TEN.TENANT_INFORMATION_ID#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TS ON TS.TENANT_KEY = TEN.TENANT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = TS.USER_KEY#(lf)#(lf)WHERE 1=1#(lf)AND LT.TRANSACTION_TYPE = 'Payment'#(lf)AND LT.Tenant_Key IS NOT NULL#(tab)#(lf)AND (AR.RECEIPTSTATUSID IN (901,904) OR AR.RECEIPTSTATUSID Is null) --Active/Pending#(lf)AND ARD.""_FIVETRAN_DELETED""='N'#(lf)AND AR.""_FIVETRAN_DELETED""='N'#(lf)AND LT.STATUS = 'Active'#(lf)AND LT.IS_CREDIT = 'N'#(lf)AND  LT.CHARGE_GL_ACCOUNT_NUMBER = '4016'#(lf)  #(lf)--ORDER BY LEASEID DESC#(lf))#(lf)--*****************************************************************************************#(lf),MoveOutReceipts AS (#(lf)SELECT #(lf)#(tab)LeaseID#(lf)#(tab),SUM(CASE WHEN CreditTypeId IS NULL THEN Payments ELSE 0 END) MoveOutReceipts_PAID#(lf)  #(tab),SUM(CASE WHEN CreditTypeId = 1 THEN Payments ELSE 0 END ) MoveOutReceipts_CONCESSION#(lf)  #(tab),SUM(CASE WHEN CreditTypeId = 2 THEN Payments ELSE 0 END) MoveOutReceipts_BAD_DEBT#(lf)  #(tab),SUM(Payments) MoveOutReceipts_TOTAL#(lf)  #(lf)  #(lf)FROM MoveOutLineItemsReceipts#(lf)WHERE LeaseID IS NOT NULL#(lf)AND Description NOT LIKE '%Early Term%'#(lf)AND Description NOT LIKE '%Insufficient Notice%'#(lf)AND Description NOT LIKE '%Prorated%'#(lf)GROUP BY LEASEID#(lf))#(lf)#(lf)--*****************************************************************************************#(lf)#(lf),WO_DETAIL AS (#(lf)SELECT #(lf) #(lf)TI.TICKET_KEY#(lf),WO.WORKORDER_KEY#(lf),TI.TICKET_TYPE#(lf),COALESCE(TI.TICKET_TYPE, 'Maintenance') AS TICKET_TYPE_CLOSED#(lf),TI.TICKET_STATUS#(lf),WO.WORKORDER_ID#(lf),WO.MAINT_ID#(lf),WO.HBH_ID_KEY#(lf),WO.WORKORDER_STATUS#(lf),WO.PRIORITY#(lf),WO.BILL_TO#(lf)#(lf),P.Property_Key#(lf)#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'R