	partition DW_Occupancy-5290055d-6a55-4b2c-acc5-6b41f2287487 = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   OCCUPANCY DATASET#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per current primary tenant (final output is#(lf)            SELECT ... FROM Tenant).#(lf)   CTE chain: HHI, DEALS, TENANT -> final SELECT off TENANT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  Both ORGANIZATION_KEY / ORGANIZATION_NAME CASE blocks updated to the#(lf)             full six-group roll-up that mirrors the master PROPERTY script#(lf)             (source of truth):#(lf)               - DEALS  was a stale SINGLE-group form (-1.. -> 'Resicap SFR').#(lf)               - TENANT was a three-group form (+58,59 -> 'Hudson Oak').#(lf)             Only TENANT's org columns surface in the final SELECT (which reads#(lf)             FROM Tenant); DEALS' org columns are internal. DELIBERATE OUTPUT#(lf)             CHANGE limited to the organization columns.#(lf)     [DROP]  The Turnkey CTE was DEAD CODE: defined but never referenced#(lf)             downstream (the final SELECT reads FROM Tenant, and the only other#(lf)             mention was a commented-out '--SELECT * FROM Turnkey'). Removed.#(lf)             Confirmed output-identical via row count + non-org fingerprint.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output, TENANT surfaced cols):#(lf)        added 66                  -> 27 / 'RB DRC'#(lf)        58,59                     -> 58 / 'Hudson Oak'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH HHI AS (Select #(lf)#(lf)D.Deal_ID #(lf),CASE WHEN sum(C_INC.Annual_Income) <30000 THEN NULL #(lf)#(tab)  WHEN  sum(C_INC.Annual_Income) > 1000000 THEN NULL #(lf)#(tab)  ELSE  sum(C_INC.Annual_Income) END AS HHI#(lf)#(lf)FROM PROD_REPLICA.HUBSPOT.DEAL D#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.DEAL_CONTACT DC ON DC.DEAL_ID = D.DEAL_ID#(lf)LEFT JOIN (SELECT#(lf)#(tab)#(tab)#(tab)#(tab)CONTACT_ID#(lf)#(tab)#(tab)#(tab)#(tab),COALESCE (#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'total_yearly_income' THEN value ELSE null END),#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)SUM(CASE WHEN NAME = 'annual_salary' THEN value ELSE null END)) AS Annual_Income#(lf)#(tab)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.COntact_PROPERTY_HISTORY#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)WHERE 1=1 #(lf)#(tab)#(tab)#(tab)#(tab)AND NAME IN ('annual_salary','total_yearly_income')#(lf)#(tab)#(tab)#(tab)#(tab)GROUP BY CONTACT_ID ) C_INC ON C_INC.Contact_ID = DC.Contact_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)WHERE 1=1 #(lf)GROUP BY D.DEAL_ID)#(lf)#(lf)---***********************************************************************************************************************#(lf),DEALS AS (SELECT #(lf)#(lf) P.PROPERTY_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf),P.HBPM_PROPERTY_ID #(lf),P.EntityID#(lf),P.Address#(lf),PUS.Under_written_rent#(lf)#(lf),REC.RECEIEVABLE_ID#(lf),PO.PORTFOLIO_NAME#(lf),R.REGION_NAME#(lf)#(lf),D.SECURITY_DEPOSIT_ID#(lf),D.DEAL_KEY#(lf),D.DEAL_ID#(lf),D.CURRENT_DEAL_STATUS#(lf),COALESCE(HHI.HHI  ,D.COMBINED_INCOME) AS COMBINED_INCOME#(lf),DSH.LEAD_KEY#(lf),to_date(L.Application_SUBMIT_Date_KEY::TEXT,'yyyymmdd') AS Application_Submit_Date#(lf), DATEDIFF(DAY, to_date(L.Application_SUBMIT_Date_KEY::TEXT,'yyyymmdd'), COALESCE(to_date(PAY.HOLDING_FEE_DATE_NEW::TEXT,'yyyymmdd'),to_date(DSH.HOLDING_FEE_PAID_DATE_KEY::TEXT,'yyyymmdd'),GETDATE()) ) AS DAYS_SINCE_APP_SUBMIT#(lf)#(lf),L.First_Name ||  ' '  || L.Last_Name AS Lead_Name#(lf),L.PRIMARY_LEAD_ID#(lf)#(lf),to_date(DSH.DEAL_CREATE_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_CREATE_DATE#(lf),to_date(DSH.APPLICATION_APPROVED_DATE_KEY::TEXT,'yyyymmdd') AS APPLICATION_APPROVED_DATE#(lf),to_date(DSH.DEAL_WON_DATE_KEY::TEXT,'yyyymmdd') AS DEAL_WON_DATE#(lf),COALESCE(to_date(PAY.HOLDING_FEE_DATE_NEW::TEXT,'yyyymmdd'),to_date(DSH.HOLDING_FEE_PAID_DATE_KEY::TEXT,'yyyymmdd')) AS HOLDING_FEE_DATE_NEW#(lf),to_date(DSH.LEASE_SIGNED_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_SIGNED_DATE#(lf),to_date(DSH.CONVERT_TO_RESIDENT_DATE_KEY::TEXT,'yyyymmdd') AS CONVERT_TO_RESIDENT_DATE#(lf),to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') AS EXPECTED_MOVE_IN_DATE#(lf),COALESCE(to_date(DSH.LEASE_START_DATE_KEY::TEXT,'yyyymmdd'),#(lf)#(tab)#(tab)  to_date(DSH.EXPECTED_MOVE_IN_DATE_KEY::TEXT,'yyyymmdd') ) AS LEASE_START_DATE#(lf),to_date(DSH.LEASE_END_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_END_DATE#(lf),U.USER_KEY#(lf),TLA.Tenant_key#(lf),COALESCE (HO.FIRST_NAME || ' ' || HO.LAST_NAME ,CO.FIRST_NAME || ' ' || CO.LAST_NAME, 'Billy Mixon') AS DEAL_OWNER#(lf),D.AVERAGE_CREDIT_SCORE#(lf),CO.CONTACT_ID#(lf),'https://app.hubspot.com/contacts/5444448/contact/' || CO.CONTACT_ID AS URL_HUBSPOT#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_DEAL D#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_DEAL_STATUS_ACCUM DSH ON DSH.DEAL_KEY  = D.Deal_Key#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.DEAL HD ON HD.DEAL_ID = D.DEAL_ID#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L ON L.LEAD_KEY = DSH.Lead_Key#(lf)#(lf)LEFT JOIN (SELECT#(lf)#(tab)#(tab)#(tab)#(tab)Deal_ID #(lf)#(tab)#(tab)#(tab)#(tab),Value AS RECEIEVABLE_ID#(lf)#(tab)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.DEAL_PROPERTY_HISTORY#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)WHERE 1=1#(lf)#(tab)#(tab)#(tab)#(tab)--AND DEAL_ID =8496423848#(lf)#(tab)#(tab)#(tab)#(tab)AND NAME = 'account_receivable'#(lf)#(tab)#(tab)#(tab)#(tab)AND _FIVETRAN_ACTIVE = 'Y') REC ON REC.DEAL_ID = D.DEAL_ID#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)#(lf)LEFT JOIN (SELECT Charge_DATE_KEY, Property_Key, Receivable_ID, Amount #(lf)#(tab)#(tab)#(tab)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION#(lf)#(tab)#(tab)#(tab)WHERE #(lf)#(tab)#(tab)#(tab)TRANSACTION_TYPE = 'Charges' #(lf)#(tab)#(tab)#(tab)--AND IS_REVERSED = 'N' #(lf)#(tab)#(tab)#(tab)AND Amount >= 500 #(lf)#(tab)#(tab)#(tab)AND GL_ACCOUNT_KEY IN (18) ) CHG ON CHG.Receivable_ID = TRY_CAST(REC.RECEIEVABLE_ID AS INTEGER)#(lf)#(lf)LEFT JOIN (SELECT#(lf)#(tab)#(tab)#(tab)MIN(RECEIVED_ON_DATE_KEY) AS HOLDING_FEE_DATE_NEW#(lf)#(tab)#(tab)#(tab),PROPERTY_KEY#(lf)#(tab)#(tab)#(tab),PAID_BY_USER_KEY#(lf)#(tab)#(tab)    ,RECEIVABLE_ID#(lf)#(tab)#(tab)    ,TENANT_KEY#(lf)#(tab)#(tab)#(tab),AMOUNT#(lf)#(tab)#(tab)#(tab)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_LEASING_TRANSACTION#(lf)#(tab)#(tab)#(tab)WHERE #(lf)#(tab)#(tab)#(tab)TRANSACTION_TYPE = 'Payment' #(lf)#(tab)#(tab)#(tab)--AND IS_REVERSED = 'N' #(lf)#(tab)#(tab)#(tab)AND Amount >= 500 -- Weed OUT noise#(lf)#(tab)#(tab)#(tab)AND GL_ACCOUNT_KEY IN (18,-1) -- SD#(lf)#(tab)#(tab)#(tab)GROUP BY#(lf)#(tab)#(tab)#(tab) PROPERTY_KEY#(lf)#(tab)#(tab)#(tab) ,PAID_BY_USER_KEY#(lf)#(tab)#(tab)#(tab),RECEIVABLE_ID#(lf)#(tab)#(tab)#(tab),TENANT_KEY#(lf)#(tab)#(tab)#(tab),AMOUNT) PAY ON PAY.Receivable_ID = TRY_CAST(REC.RECEIEVABLE_ID AS INTEGER) AND PAY.Amount = CHG.Amount#(lf)#(lf)#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = CASE WHEN DSH.User_key <> -1 THEN DSH.User_key#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) ELSE Pay.PAID_BY_USER_KEY END#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab) #(lf)LEFT JOIN (SELECT TLA.* #(lf)#(tab)#(tab)FROM PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA#(lf)#(tab)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T ON T.Tenant_KEY = TLA.Tenant_key#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TENANTINFORMATIONID  = T.TENANT_INFORMATION_ID#(lf)#(tab)#(tab)WHERE TI._FIVETRAN_DELETED <> 'Y'#(lf)#(tab)#(tab)AND RENTDUEDAY IS NOT NULL#(lf)#(tab)#(tab)AND T.TENANT_KEY NOT IN (70575)) TLA ON TLA.USER_KEY = U.User_key#(lf)#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON #(lf)#(lf)(CASE WHEN #(lf)#(tab)#(tab)PAY.Property_Key IS NOT NULL #(lf)#(tab)#(tab)OR DSH.PROPERTY_KEY <> -1#(lf)#(tab)#(tab)OR TLA.PROPERTY_KEY IS NOT NULL  #(lf)#(tab)THEN P.PROPERTY_KEY = COALESCE ( PAY.Property_Key,#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)CASE WHEN DSH.PROPERTY_KEY <> -1 THEN DSH.PROPERTY_KEY#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)ELSE TLA.PROPERTY_KEY END)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)ELSE P.Address = LEFT(HD.PROPERTY_ADDRESS,CHARINDEX(',',HD.PROPERTY_ADDRESS)-1) END )#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM ON HBPM.PROPERTYID = P.HBPM_PROPERTY_ID --*REPLCA DB*#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)#(lf)#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.DEAL_PROPERTY_HISTORY DPH ON DPH.DEAL_ID = D.DEAL_ID AND DPH._FIVETRAN_ACTIVE = 'Y' AND DPH.NAME = 'owner_id'  --HUBSPOT ACTUAL#(lf)LEFT JOIN PROD_REPLICA.HUBSPOT.OWNER HO ON HO.OWNER_ID =  TRY_CAST(DPH.VALUE AS INTEGER)  #(lf)LEFT JOIN HHI ON HHI.Deal_ID = D.Deal_ID#(lf)#(lf)LEFT JOIN (select DISTINCT #(lf)#(tab)#(tab)DC.DEAL_ID, C.ID AS CONTACT_ID, CO.FIRST_NAME, CO.LAST_NAME#(lf)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.DEAL_CONTACT DC #(lf)#(tab)#(tab)JOIN PROD_REPLICA.HUBSPOT.DEAL D ON D.Deal_ID = DC.DEAL_ID#(lf)#(tab)#(tab)JOIN PROD_REPLICA.HUBSPOT.CONTACT C ON C.ID = DC.CONTACT_ID AND C._FIVETRAN_DELETED ='FALSE'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.CONTACT_PROPERTY_HISTORY CPH ON CPH.CONTACT_ID = C.ID AND CPH.NAME='hubspot_owner_id' AND CPH._FIVETRAN_ACTIVE = 'Y'#(lf)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.OWNER CO ON CO.OWNER_ID = CPH.VALUE     #(lf)#(lf)#(tab)#(tab)WHERE 1=1#(lf)#(tab)#(tab)AND D.PROPERTY_APPLICANT_EMAIL =  C.PROPERTY_EMAIL#(lf)#(tab)#(tab)) CO ON CO.DEAL_ID = D.DEAL_ID#(lf)#(lf)#(lf)#(tab)#(tab)#(lf)WHERE 1=1#(lf)#(lf)AND HD.IS_DELETED <>'Y'#(lf)AND P.Property_KEY IS NOT NULL#(lf)AND D.Current_Deal_Status IS NOT NULL#(lf)AND D.CURRENT_flag = 'Y'#(lf)AND L.CURRENT_Flag = 'Y'#(lf)AND DSH.LEAD_KEY  IS NOT NULL#(lf)--AND L.Application_SUBMIT_Date_KEY IS NOT null#(lf)AND (TLA.TENANT_INFORMATION_ID <> 36986 OR TLA.TENANT_INFORMATION_ID IS NULL)#(lf)#(lf)#(lf)AND (HBAM.PROPERTYSTATUSID >9 OR HBAM.PROPERTYSTATUSID IS NULL) --out of bid#(lf)AND P.PROPERTY_STATE ='Active'#(lf)AND P.EntityID <> ''#(lf)AND (HBAM.PROPERTYSTATUSID NOT IN (53,75) OR HBAM.PROPERTYSTATUSID IS NULL)#(lf)AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54,169)#(lf)AND PUS.Organization_KEY not IN (16,17)#(lf)AND PO.IS_Active_AM = 'Y'#(lf)AND PO.Current_Flag = 'Y'#(lf)AND P.Current_Flag = 'Y'#(lf)AND PU.Current_Flag = 'Y'#(lf)AND PUS.Occupancy_Status NOT IN ('Not Managed')#(lf)AND (HBPM.PROPERTYSTATEID = 26 OR HBPM.PROPERTYSTATEID IS NULL) #(lf)#(lf)--AND DSH.HOLDING_FEE_PAID_DATE_KEY >= 20220201#(lf)--AND TLA.Tenant_Key = 4099#(lf)--AND D.DEAL_ID = 9265777025#(lf))#(lf)--SELECT * FROM Deals#(lf)--****************************************************************************************************************#(lf)            #(tab)#(lf),TENANT AS (#(lf) #(lf)SELECT#(lf)#(lf) T.TENANT_KEY#(lf),T.TENANT_INFORMATION_ID#(lf),TS.USER_KEY#(lf),T.LEASE_ID#(lf),RANK() OVER (PARTITION BY TS.Property_KEY ORDER BY Lease_ID ASC) AS Lease_Rank #(lf),PU.PROPERTY_UNIT_KEY#(lf),TS.Property_KEY#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf)#(tab),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME,P.HBPM_PROPERTY_ID#(lf),PO.Portfolio_Name#(lf),P.Address#(lf),P.EntityID#(lf),PUS.Occupancy_Status#(lf)#(lf),U.FULL_NAME#(lf),U.USER_STATUS#(lf),U.EMAIL_ADDRESS#(lf),U.PHONE_NUMBER#(lf),T.TENANT_STATUS#(lf),T.TENANT_TYPE#(lf),T.PRIMARY_TENANT#(lf),T.EVICTION_STATUS#(lf),T.VEHICLES#(lf),T.PETS#(lf),T.MONTH_TO_MONTH#(lf),T.LEASE_TERM#(lf),to_date(T.NOTICE_DATE_KEY::TEXT,'yyyymmdd') AS NOTICE_DATE#(lf),TLA.INITIAL_RENT_AMOUNT#(lf),T.CURRENT_RENT#(lf),Deals.HOLDING_FEE_DATE_NEW AS ""HOLDING_FEE_DATE_NEW""#(lf),to_date(TLA.CURRENT_LEASE_EXPIRATION_DATE_KEY ::TEXT,'yyyymmdd') AS CURRENT_LEASE_EXPIRATION_DATE#(lf),to_date(TLA.LEASE_SIGNED_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_SIGNED_DATE#(lf),to_date(TLA.LEASE_FROM_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_FROM_DATE#(lf),to_date(TLA.LEASE_TO_DATE_KEY::TEXT,'yyyymmdd') AS LEASE_TO_DATE#(lf)#(lf),to_date(T.DOB_DATE_KEY::TEXT,'yyyymmdd') AS DOB#(lf),CASE WHEN COALESCE(RESI_TSUM.AVERAGE_CREDIT_SCORE, PM_D.AVERAGECREDITSCORE, DEALS.AVERAGE_CREDIT_SCORE) > 850 THEN NULL #(lf) ELSE COALESCE(RESI_TSUM.AVERAGE_CREDIT_SCORE, PM_D.AVERAGECREDITSCORE, DEALS.AVERAGE_CREDIT_SCORE)  END AS AVERAGE_CREDIT_SCORE#(lf),COALESCE(RESI_TSUM.COMBINED_INCOME,PM_D.COMBINEDINCOME,DEALS.COMBINED_INCOME) COMBINEDINCOME#(lf),RESI_TSUM.NUMBER_OF_CHILDREN#(lf),RESI_TSUM.OCCUPANTS#(lf),RESI_TSUM.TENANT_AGE#(lf),RESI_TSUM.MONTHLY_INCOME#(lf),RESI_TSUM.IS_RETIRED#(lf),RESI_TSUM.IS_NOTICE#(lf),RESI_TSUM.IS_UNDER_EVICTION#(lf),HUB_PETS.PETS AS ""PETS_AMOUNT""#(lf)#(lf),TI.MoveIn#(lf),TI.MoveOut#(lf),TI.PurchaseLetterPostedDate#(lf),TI.DateNotified#(lf),TI.FiledWithCountyDate#(lf),TI.ResidentServedDate#(lf),TI.CourtDateSetDate#(lf),TI.JudgementDate#(lf),TI.LockoutScheduledDate#(lf),TI.VacateDate#(lf),TI.AnticipatedMoveOutDate#(lf),TI.IsSection8#(lf),TI.IsMonthtoMonthLease#(lf),TI.TenantDecidedMonthtoMonth#(lf),TI.DoNotRenew#(lf),TI.ReasonForNotRenewingId#(lf),DNR.DESCRIPTION AS REASONFORNOTRENEWINGNAME#(lf),PUS.Under_written_rent#(lf),AM_PM.MoveInReady#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_TENANT T#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_ACTIVITY TS ON TS.TENANT_KEY = T.TENANT_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_TENANT_LEASING_ACCUM TLA ON TLA.TENANT_KEY = T.Tenant_Key#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.TENANTINFORMATIONS TI ON TI.TenantInformationId = T.TENANT_INFORMATION_ID#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS DNR on DNR.LookUpMasterId = TI.ReasonForNotRenewingId#(lf)LEFT JOIN PROD_REPLICA.HBPM_DBO.DEALS PM_D ON PM_D.LEADUSERID = TI.USERID AND PM_D.UNITID =TI.UNITID AND PM_D.SECURITYDEPOSITID IS NOT null#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_USER U ON U.USER_KEY = TS.USER_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = TS.PROPERTY_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD L ON L.lead_key = TS.LEAD_KEY #(lf)LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID --*REPLCA DB*#(lf)LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTYMANAGEMENTS AM_PM ON AM_PM.PROPERTYMANAGEMENTID = HBAM.PropertyManagement_PropertyManagementId AND AM_PM.HBID = HBAM.HBID#(lf)#(lf)LEFT JOIN DEALS ON Deals.User_key = TS.USER_KEY AND Deals.Current_Deal_Status = 'Deal Won' AND Deals.PRoperty_key = P.Property_key AND Deals.SECURITY_DEPOSIT_ID IS NOT null#(lf)#(tab)#(tab)#(tab)#(lf)LEFT JOIN (SELECT C.ID, COUNT(PET.ID) PETS#(lf)#(tab)#(tab)#(tab)FROM PROD_REPLICA.HUBSPOT.PET #(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.PET_TO_CONTACT PTC ON PTC.FROM_ID = PET.ID#(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_REPLICA.HUBSPOT.CONTACT C ON C.ID = PTC.TO_ID #(lf)#(tab)#(tab)#(tab)GROUP BY C.ID) HUB_PETS ON HUB_PETS.ID = L.LEAD_ID#(lf)#(tab)#(lf)LEFT JOIN (SELECT #(lf)#(tab)#(tab)#(tab)FCT_TENANT_SUMMARY_KEY #(lf)#(tab)#(tab)#(tab),TENANT_INFORMATION_ID #(lf)#(tab)#(tab)#(tab),AVERAGE_CREDIT_SCORE#(lf)#(tab)#(tab)#(tab),R_TS.COMBINED_INCOME#(lf)#(tab)#(tab)#(tab),NUMBER_OF_CHILDREN#(lf)#(tab)#(tab)#(tab),OCCUPANTS#(lf)#(tab)#(tab)#(tab),TENANT_AGE#(lf)#(tab)#(tab)#(tab),MONTHLY_INCOME#(lf)#(tab)#(tab)#(tab),IS_RETIRED#(lf)#(tab)#(tab)#(tab),IS_NOTICE#(lf)#(tab)#(tab)#(tab),IS_UNDER_EVICTION#(lf)#(tab)#(tab)#(tab)FROM PROD_ANALYTICS.RESICAP.FCT_TENANT_SUMMARY R_TS#(lf)#(tab)#(tab)#(tab)LEFT JOIN PROD_ANALYTICS.RESICAP.DIM_TENANT R_T ON R_T.TENANT_KEY = R_TS.TENANT_KEY ) RESI_TSUM ON RESI_TSUM.TENANT_INFORMATION_ID = T.TENANT_INFORMATION_ID#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(lf)WHERE 1=1#(lf)AND T.CURRENT_FLAG = 'Y'#(lf)AND T.PRIMARY_TENANT = 'Y'#(lf)#(lf)AND P.PROPERTY_STATE ='Active'#(lf)AND P.EntityID <> ''#(lf)AND TI._FIVETRAN_DELETED <> 'Y'#(lf)AND TI.RENTDUEDAY IS NOT NULL#(lf)--AND (PS.PROPERTY_STATUS_ID NOT IN (53,75) OR PS.PROPERTY_STATUS_ID IS NULL)#(lf)AND PO.Portfolio_KEY NOT IN (1845, 2210, 2207, 2218, 1952,1867, 1916,1852,1771,1919,1873)#(lf)AND P.Organization_KEY not IN (16,17)#(lf)AND PO.IS_Active_AM = 'Y'#(lf)AND PO.Current_Flag = 'Y'#(lf)AND P.Current_Flag = 'Y'#(lf)AND PU.Current_Flag = 'Y'#(lf)AND PUS.Occupancy_Status NOT IN ('Property SOLD','Not Managed') #(lf)AND T.TENANT_KEY NOT IN (70575))#(lf)#(lf)--SELECT * FROM Tenant#(lf)--**************************************************************************************        #(lf)#(lf)#(lf)#(lf)#(lf)--**************************************************************************************#(lf)#(lf)SELECT#(lf)Property_KEY#(lf),ORGANIZATION_KEY             #(lf),ORGANIZATION_NAME#(lf),EntityID#(lf),HBPM_PROPERTY_ID#(lf),TENANT_STATUS#(lf),MoveIn#(lf),MoveOut#(lf)FROM Tenant#(lf)WHERE 1=1#(lf)--AND Tenant_key =192066#(lf)#(lf)--**************************************************************************************", null, [EnableFolding=true])
