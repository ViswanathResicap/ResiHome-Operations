table PM_BOM
	lineageTag: 5af503f2-8317-44c2-a0bd-e7b42bd332e1

	measure '0_Run Rate (90+ Spend)' = ```
			(DIVIDE(SUM(PM_BOM[MM Ongoing Spend Post Lease+90]), SUM(PM_BOM[DAYS_POST_90_MTD]), BLANK())) * 365
			
			```
		formatString: \$#,0;(\$#,0);\$#,0
		lineageTag: 39ea6cbf-3722-4269-aef6-e28e8e01d7ce

		changedProperty = FormatString

	measure '0_Run Rate Monthly' = FORMAT(SUM(PM_BOM[MM Ongoing Spend Post Lease+90]), "$#,###") &" / " & FORMAT(SUM(PM_BOM[DAYS_POST_90_FULL]) * 1700/365, "$#,###")
		lineageTag: 6fafbc22-ba7b-4113-82e5-a49030932c94

	column BEG_OF_MONTH
		dataType: dateTime
		formatString: Short Date
		lineageTag: f6bcf10a-8d5a-4484-b652-71d1e9dc65e4
		summarizeBy: none
		sourceColumn: BEG_OF_MONTH

		variation Variation
			isDefault
			relationship: e2add70f-4dc9-4689-af9f-1881adc6639a
			defaultHierarchy: LocalDateTable_9fd09431-f8c4-4490-ace0-6e5881f85f14.'Date Hierarchy'

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column Property_Key = RELATED(DW_Properties[PROPERTY_KEY])
		lineageTag: 0510f3a1-3554-452d-b86e-3a9f46874bd3
		summarizeBy: count

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column '1_Occ_Status (DW)' = if(PM_BOM[BEG_OF_MONTH]>date(year(TODAY()),MONTH(TODAY()),1),CALCULATE(MIN(DW_Properties[OCCUPANCYSTATUSID]),FILTER(DW_Properties,DW_Properties[HBPM_PROPERTY_ID]=PM_BOM[HBPM_PropertyID])),PM_BOM[BEG_MONTH_VALUE])
		lineageTag: 1ca920db-e228-4da7-b7ca-9422570de251
		summarizeBy: sum

		annotation SummarizationSetBy = Automatic

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	column 1_Move-In = CALCULATE(MAX(DW_Occupancy[MOVEIN]),FILTER(DW_Occupancy,DW_Occupancy[HBPM_PROPERTY_ID]=PM_BOM[HBPM_PropertyID]&&DW_Occupancy[MOVEIN]<=eomonth(PM_BOM[BEG_OF_MONTH],0)&&OR(DW_Occupancy[MOVEOUT]=BLANK(),DW_Occupancy[MOVEOUT]>=PM_BOM[BEG_OF_MONTH])))
		formatString: Short Date
		lineageTag: c10a59dc-b089-42cf-a08f-585f0476ff9a
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 99996c9c-145b-46ad-8724-79b9f2ac8e35
			defaultHierarchy: LocalDateTable_a5bca677-3493-41de-8da6-28e4df322a39.'Date Hierarchy'

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

	column 1_Move-Out = CALCULATE(Min(DW_Occupancy[MOVEOUT]),FILTER(DW_Occupancy,DW_Occupancy[PROPERTY_KEY]=PM_BOM[Property_Key]&&DW_Occupancy[MOVEOUT]<>BLANK()&&DW_Occupancy[MOVEOUT]>(PM_BOM[BEG_OF_MONTH]-14)&&DW_Occupancy[MOVEIN]<=eomonth(PM_BOM[BEG_OF_MONTH],0)))
		formatString: Short Date
		lineageTag: 6b8abe30-55ce-4e8c-877b-dfd200208251
		summarizeBy: none

		variation Variation
			isDefault
			relationship: bfba0b94-b611-4592-a65b-a657ebbc9922
			defaultHierarchy: LocalDateTable_1abe006b-209c-4242-aff7-de398a372011.'Date Hierarchy'

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

	column 'Days Occ' =
			IF(PM_BOM[1_Move-In]=BLANK()||PM_BOM[BEG_OF_MONTH]>TODAY()||PM_BOM[1_Move-In]>TODAY()||PM_BOM[AfterValue]=BLANK(),BLANK(),
			           IF(PM_BOM[1_Move-Out]<PM_BOM[1_Move-In]&&PM_BOM[1_Move-In]>=PM_BOM[BEG_OF_MONTH]&&PM_BOM[1_Move-In]<>BLANK()&&PM_BOM[1_Move-Out]<>BLANK(),(PM_BOM[1_Move-Out]-PM_BOM[BEG_OF_MONTH])+(EOMONTH(PM_BOM[BEG_OF_MONTH],0) - PM_BOM[1_Move-In])+1,
			           IF(PM_BOM[1_Move-Out]<>BLANK(),MIN(EOMONTH(PM_BOM[BEG_OF_MONTH],0),PM_BOM[1_Move-Out]) - MAX(MAX(PM_BOM[1_Move-In],PM_BOM[BEG_OF_MONTH]),PM_BOM[Transfer Date]) +1,
			           max(MIN(TODAY(),EOMONTH(PM_BOM[BEG_OF_MONTH],0)) - MAX(max(PM_BOM[1_Move-In],PM_BOM[BEG_OF_MONTH]),PM_BOM[Transfer Date]) +1,0))))
		dataType: int64
		formatString: 0
		lineageTag: b7d86bd1-c098-4fae-82a0-778d45504899
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column 'Owned Days' =
			IF(PM_BOM[BEG_OF_MONTH]>TODAY()||PM_BOM[Transfer Date]>eomonth(PM_BOM[BEG_OF_MONTH],0),BLANK(),
			             MIN(TODAY(),EOMONTH(PM_BOM[BEG_OF_MONTH],0)) - max(PM_BOM[BEG_OF_MONTH],PM_BOM[Transfer Date]) + 1)
		dataType: int64
		formatString: 0
		lineageTag: 6e09916a-2b83-4259-9914-5ac959f68420
		summarizeBy: sum

		changedProperty = DataType

		annotation SummarizationSetBy = Automatic

	column 'Transfer Date' = COALESCE(RELATED(DW_Properties[Transfer_Date]),RELATED(DW_Properties[Purchase_Date]))
		formatString: Short Date
		lineageTag: d3cc1c57-a25b-4a71-b918-8a1d7d662ccd
		summarizeBy: none

		variation Variation
			isDefault
			relationship: 2febd0d1-1b84-4372-8c61-832c5505e1da
			defaultHierarchy: LocalDateTable_f551f1bb-c957-47ff-a41c-1c957d730fb8.'Date Hierarchy'

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

