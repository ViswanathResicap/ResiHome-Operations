	column BEG_MONTH_OCC_STATUS
		dataType: string
		lineageTag: bcf9e264-7121-4e4a-a3c9-88a0eadb688f
		summarizeBy: none
		sourceColumn: BEG_MONTH_OCC_STATUS

		annotation SummarizationSetBy = Automatic

	partition PM_BOM-95094b65-bcfd-4b17-8994-70252fdb84a4 = m
		mode: import
		queryGroup: 'PM Other'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   PM BOM DATASET (Beginning-of-Month property occupancy + post-90 days)#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per property x beginning-of-month (anchor: Prop_Calendar =#(lf)            DIM_PROPERTY cross-joined to a generated month spine from 2024-01).#(lf)   CTE chain: Calendar, Prop_Calendar, Prop_Hist (status-history UNION current#(lf)            status), BOM_Status (latest status as-of EOM and as-of BOM),#(lf)            RENT_HIST, RENT_TEMP -> final SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     No organization roll-up exists in this query (no ORGANIZATION_KEY /#(lf)     ORGANIZATION_NAME columns are produced), so NO org sync was applied. This#(lf)     pass is COSMETIC ONLY: header added, trailing semicolon removed; query#(lf)     logic is unchanged byte-for-byte.#(lf)     [FLAG]  The DIM_OWNER_ORGANIZATION O join (in Prop_Calendar and in the#(lf)             second leg of Prop_Hist) is referenced only in its own ON clause#(lf)             (O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY) and surfaces no column;#(lf)             the active org filter uses PUS.Organization_KEY. It is a one-row-#(lf)             per-key dimension LEFT JOIN, so it neither fans out nor filters and#(lf)             could be dropped, but is PRESERVED here to keep this a no-logic-#(lf)             change pass.#(lf)#(lf)   ORG SYNC IMPACT: none (no organization columns in this dataset).#(lf)   ============================================================================= */#(lf)#(lf)WITH Calendar AS (#(lf)    SELECT DATEADD('month', SEQ4(), DATE_FROM_PARTS(2024, 1, 1)) AS BEG_OF_MONTH#(lf)    FROM TABLE(GENERATOR(ROWCOUNT => 10000))#(lf)    WHERE BEG_OF_MONTH <= DATE_TRUNC('month', CURRENT_DATE())#(lf))#(lf)  --Select * from Calendar#(lf)--***************************************************************************#(lf)#(lf),Prop_Calendar AS (#(lf)  Select#(lf)   P.HBPM_PROPERTY_ID AS PropertyId#(lf)   ,P.PROPERTY_KEY AS PROP_KEY#(lf)   ,P.ENTITYID#(lf)   ,BEG_OF_MONTH#(lf)  FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)  LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID --*REPLCA DB*#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM ON HBPM.PROPERTYID = P.HBPM_PROPERTY_ID --*REPLCA DB*#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_AI ON PM_AI.PROPERTYID  = HBPM.PROPERTYID AND PM_AI.""_FIVETRAN_DELETED"" = 'N' #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)  CROSS JOIN Calendar#(lf)#(lf)  WHERE 1=1#(lf)#(tab)AND (HBAM.PROPERTYSTATUSID >9 OR HBAM.PROPERTYSTATUSID IS NULL) --out of bid#(lf)#(tab)AND P.PROPERTY_STATE ='Active'#(lf)#(tab)AND P.EntityID <> ''#(lf)#(tab)AND (HBAM.PROPERTYSTATUSID NOT IN (53,75) OR HBAM.PROPERTYSTATUSID IS NULL)#(lf)#(tab)AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54)#(lf)#(tab)AND PUS.Organization_KEY not IN (16,17)#(lf)#(tab)AND PO.IS_Active_AM = 'Y'#(lf)#(tab)AND PO.Current_Flag = 'Y'#(lf)#(tab)AND P.Current_Flag = 'Y'#(lf)#(tab)AND PU.Current_Flag = 'Y'#(lf)#(tab)AND PUS.Occupancy_Status NOT IN ('Not Managed')#(lf)#(tab)AND (HBPM.PROPERTYSTATEID = 26 OR HBPM.PROPERTYSTATEID IS NULL) #(lf)#(tab)AND P.HBMM_Property_ID IS NOT NULL )#(lf)  --Select * from Prop_Calendar#(lf)--***************************************************************************#(lf)#(lf),Prop_Hist AS (#(lf)  SELECT#(lf)   P.HBPM_PROPERTY_ID AS PropertyId#(lf)   ,P.PROPERTY_KEY  AS PROP_KEY#(lf)  ,FCT_PROP_UNIT_STATUS_HIST_KEY AS AuditLogId#(lf)  ,LM.LOOKUPMASTERID AS AfterValue#(lf)  ,NEW_OCCUPANCY_STATUS AS Occupancy_Status#(lf)  ,to_date(CHANGED_DATE_KEY::TEXT,'yyyymmdd') AS LogDateTime#(lf)  #(lf)  FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_UNIT_STATUS_HIST PSH#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.DESCRIPTION = PSH.NEW_OCCUPANCY_STATUS #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY = PSH.PROPERTY_KEY #(lf)  WHERE 1=1#(lf)#(lf)    AND P.PROPERTY_STATE ='Active'#(lf)    AND P.EntityID <> ''#(lf)    AND P.Current_Flag = 'Y'#(lf)    AND P.HBMM_Property_ID IS NOT NULL#(lf)#(lf)UNION ALL#(lf)#(lf)Select #(lf)   P.HBPM_PROPERTY_ID AS PropertyId#(lf)   ,P.Property_key AS PROP_KEY#(lf)  ,1 As AuditLogId#(lf)  ,LM.LOOKUPMASTERID AS OccupancyStatusId#(lf)  ,PUS.OCCUPANCY_STATUS#(lf)  ,P.Created_Date AS LogDateTime#(lf)  #(lf)  FROM PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)  LEFT JOIN PROD_REPLICA.HBAM_DBO.PROPERTIES HBAM ON HBAM.HBID = P.HBAM_PROPERTY_ID --*REPLCA DB*#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTIES HBPM ON HBPM.PROPERTYID = P.HBPM_PROPERTY_ID --*REPLCA DB*#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.PROPERTYADDLINFOES PM_AI ON PM_AI.PROPERTYID  = HBPM.PROPERTYID AND PM_AI.""_FIVETRAN_DELETED"" = 'N' #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY_UNIT PU ON PU.PROPERTY_UNIT_KEY = PUS.PROPERTY_UNIT_KEY#(lf)  LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY#(lf)  LEFT JOIN PROD_REPLICA.HBPM_DBO.LOOKUPMASTERS LM ON LM.DESCRIPTION = PUS.OCCUPANCY_STATUS #(lf)  #(lf)  LEFT JOIN (Select DISTINCT Property_Key FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_UNIT_STATUS_HIST PSH) AL  ON AL.Property_key = P.Property_Key#(lf) #(lf)  WHERE 1=1#(lf)#(tab)AND (HBAM.PROPERTYSTATUSID >9 OR HBAM.PROPERTYSTATUSID IS NULL) --out of bid#(lf)#(tab)AND P.PROPERTY_STATE ='Active'#(lf)#(tab)AND P.EntityID <> ''#(lf)#(tab)AND (HBAM.PROPERTYSTATUSID NOT IN (53,75) OR HBAM.PROPERTYSTATUSID IS NULL)#(lf)#(tab)AND PO.Portfolio_KEY NOT IN (223,598,147,102,109,28,603,169,602,170,58,54)#(lf)#(tab)AND PUS.Organization_KEY not IN (16,17)#(lf)#(tab)AND PO.IS_Active_AM = 'Y'#(lf)#(tab)AND PO.Current_Flag = 'Y'#(lf)#(tab)AND P.Current_Flag = 'Y'#(lf)#(tab)AND PU.Current_Flag = 'Y'#(lf)#(tab)AND PUS.Occupancy_Status NOT IN ('Not Managed')#(lf)#(tab)AND (HBPM.PROPERTYSTATEID = 26 OR HBPM.PROPERTYSTATEID IS NULL) #(lf)#(tab)AND P.HBMM_Property_ID IS NOT NULL#(lf)    AND AL.Property_Key is not null )#(lf)#(lf)--Select * from Prop_Hist#(lf)--WHERE PropertyId = 47719#(lf)--338866#(lf)--***************************************************************************#(lf)#(lf) ,BOM_Status AS (#(lf)   Select #(lf)   MAX(Prop_Hist.AuditLogID) AuditLogID#(lf)   ,MAX(Prop_Hist_2.AuditLogID) AuditLogID_2#(lf)   ,Prop_Calendar.PropertyId#(lf)   ,Prop_Calendar.PROP_KEY#(lf)   ,Prop_Calendar.EntityId#(lf)   ,Prop_Calendar.BEG_OF_MONTH#(lf)   From Prop_Calendar#(lf)   LEFT JOIN Prop_Hist ON Prop_Hist.PropertyId = Prop_Calendar.PropertyId#(lf)   #(tab)#(tab)#(tab)#(tab)     AND Prop_Hist.LogDateTime < DATEADD(day,1,Last_day(BEG_OF_MONTH))#(lf)   LEFT JOIN Prop_Hist AS Prop_Hist_2 ON Prop_Hist_2.PropertyId = Prop_Calendar.PropertyId#(lf)   #(tab)#(tab)#(tab)#(tab)     AND Prop_Hist_2.LogDateTime < BEG_OF_MONTH#(lf)   #(lf)   GROUP BY#(lf)   Prop_Calendar.PropertyId#(lf)  ,Prop_Calendar.PROP_KEY#(lf)  ,Prop_Calendar.EntityId#(lf)   ,Prop_Calendar.BEG_OF_MONTH)#(lf)   #(lf)  -- Select * from BOM_Status#(lf)   -- WHERE #(lf)--***************************************************************************#(lf) ,RENT_HIST AS (#(lf) #(lf) SELECT #(lf) PROPERTY_KEY#(lf) ,FCT_PROP_UNIT_RENT_HIST_KEY#(lf) ,RENT_CHANGED_DATE#(lf) ,RANK() OVER( PARTITION BY PROPERTY_KEY ORDER BY RENT_CHANGED_DATE DESC) CHANGED_RANK#(lf) ,CURRENT_RENT#(lf) #(lf) FROM PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_UNIT_RENT_HIST#(lf) WHERE CURRENT_RENT IS NOT NULL )#(lf)--***************************************************************************#(tab)#(lf) ,RENT_TEMP AS (#(lf) Select #(lf)   BOM_Status.PropertyId AS HBPM_PropertyID#(lf)   ,BOM_Status.PROP_KEY#(lf)   ,BOM_Status.EntityId#(lf)   ,BOM_Status.BEG_OF_MONTH#(lf)   ,MAX(FCT_PROP_UNIT_RENT_HIST_KEY) FCT_PROP_UNIT_RENT_HIST_KEY#(lf)    FROM BOM_Status#(lf)    LEFT JOIN RENT_HIST ON RENT_HIST.PROPERTY_KEY = BOM_Status.PROP_KEY AND RENT_HIST.RENT_CHANGED_DATE <= DATEADD('day',1,LAST_DAY(BOM_Status.BEG_OF_MONTH,'month'))#(lf)    GROUP BY#(lf)    BOM_Status.PropertyId #(lf)   ,BOM_Status.PROP_KEY#(lf)   ,BOM_Status.EntityId#(lf)   ,BOM_Status.BEG_OF_MONTH#(lf) )#(lf)--***************************************************************************#(tab) #(lf) Select #(lf)   BOM_Status.PropertyId AS HBPM_PropertyID#(lf)   ,BOM_Status.PROP_KEY#(lf)   ,BOM_Status.EntityId#(lf)   ,BOM_Status.BEG_OF_MONTH#(lf)   ,Prop_Hist.AfterValue#(lf)   ,Prop_Hist.Occupancy_Status#(lf)   ,Prop_Hist_2.AfterValue AS BEG_MONTH_VALUE#(lf)   ,Prop_Hist_2.Occupancy_Status AS BEG_MONTH_OCC_STATUS#(lf)   #(lf)   ,to_Date( DATEADD('day',90,P.FIRST_LEASE_START_DATE_POST_RRQC)) FIRST_LEASE_PLUS_90#(lf)   #(lf)   ,CASE#(lf)   WHEN P.FIRST_LEASE_START_DATE_POST_RRQC IS NULL#(lf)   #(tab)#(tab)#(tab)OR to_Date( DATEADD('day',90,P.FIRST_LEASE_START_DATE_POST_RRQC)) >= LAST_DAY(BOM_Status.BEG_OF_MONTH)#(lf)   #(tab)#(tab)#(tab)THEN NULL#(lf)   WHEN GREATEST(BOM_Status.BEG_OF_MONTH, to_Date( DATEADD('day',90,P.FIRST_LEASE_START_DATE_POST_RRQC))) > DATEFROMPARTS(year(GETDATE()),MONTH(GETDATE()),DAY(GETDATE())) THEN NULL#(lf)   ELSE DATEDIFF('day',#(lf)   #(tab)#(tab)#(tab)#(tab)GREATEST(DATEADD('day',91,P.FIRST_LEASE_START_DATE_POST_RRQC),BOM_Status.BEG_OF_MONTH),#(lf)   #(tab)#(tab)#(tab)#(tab)LEAST(DATEFROMPARTS(year(GETDATE()),MONTH(GETDATE()),DAY(GETDATE())),LAST_DAY(BOM_Status.BEG_OF_MONTH))) + #(lf)   #(tab)#(tab)(CASE WHEN BOM_Status.BEG_OF_MONTH = date_trunc('month',GETDATE()) THEN 1 ELSE 1 END)#(lf)   END AS DAYS_POST_90_MTD#(lf)  #(lf)  ,CASE#(lf)   WHEN P.FIRST_LEASE_START_DATE_POST_RRQC IS NULL#(lf)   #(tab)#(tab)#(tab)OR to_Date( DATEADD('day',90,P.FIRST_LEASE_START_DATE_POST_RRQC)) >= LAST_DAY(BOM_Status.BEG_OF_MONTH)#(lf)   #(tab)#(tab)#(tab)THEN NULL#(lf)   WHEN GREATEST(BOM_Status.BEG_OF_MONTH, to_Date( DATEADD('day',90,P.FIRST_LEASE_START_DATE_POST_RRQC))) > DATEFROMPARTS(year(GETDATE()),MONTH(GETDATE()),DAY(GETDATE())) THEN NULL#(lf)   ELSE DATEDIFF('day',#(lf)   #(tab)#(tab)#(tab)#(tab)GREATEST(DATEADD('day',91,P.FIRST_LEASE_START_DATE_POST_RRQC),BOM_Status.BEG_OF_MONTH),#(lf)   #(tab)#(tab)#(tab)#(tab)LAST_DAY(BOM_Status.BEG_OF_MONTH)) + 1#(lf)   END AS DAYS_POST_90_FULL#(lf)   #(lf)   ,to_date(PROPERTY_SOLD_DATE_KEY::TEXT,'yyyymmdd') AS SOLD_DATE#(lf)      ,CURRENT_RENT#(lf)   #(lf)   from BOM_Status#(lf)   LEFT JOIN Prop_Hist ON Prop_Hist.PropertyId = BOM_Status.PropertyId AND Prop_Hist.AuditLogId = BOM_Status.AuditLogID#(lf)   LEFT JOIN Prop_Hist Prop_Hist_2 ON Prop_Hist_2.PropertyId = BOM_Status.PropertyId AND Prop_Hist_2.AuditLogId = BOM_Status.AuditLogID_2#(lf)   #(lf)   LEFT JOIN RENT_TEMP ON RENT_TEMP.PROP_KEY = BOM_Status.PROP_KEY AND RENT_TEMP.BEG_OF_MONTH = BOM_Status.BEG_OF_MONTH#(lf)   LEFT JOIN RENT_HIST ON RENT_HIST.FCT_PROP_UNIT_RENT_HIST_KEY = RENT_TEMP.FCT_PROP_UNIT_RENT_HIST_KEY#(lf)   LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.PROPERTY_KEY  = BOM_Status.PROP_KEY#(lf) #(lf)   WHERE 1=1#(lf)  -- AND BOM_Status.BEG_OF_MONTH = '2023-01-01'#(lf)  -- AND BOM_Status.EntityId = 'RP3OK00146'#(lf)  -- ORDER BY  DAYS_POST_90_MTD ASC#(lf)#(lf) --***************************************************************************#(lf)   #(lf