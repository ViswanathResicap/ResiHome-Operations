	column 1_Rent_Charges = CALCULATE(COUNTROWS(DW_Tenant_Charges),FILTER(DW_Tenant_Charges,DW_Tenant_Charges[PROPERTY_KEY]=PM_BOM[Property_Key]&&DW_Tenant_Charges[CHARGE_DATE_BOM]=PM_BOM[BEG_OF_MONTH]&&OR(DW_Tenant_Charges[ACCOUNT_NUMBER]="4010",DW_Tenant_Charges[ACCOUNT_NUMBER]="4011")&&DW_Tenant_Charges[Charge_Amount]>0))
		formatString: 0
