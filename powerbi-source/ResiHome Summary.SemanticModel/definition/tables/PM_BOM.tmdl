	column SOLD_DATE
		dataType: dateTime
		formatString: Long Date
		lineageTag: 5ed2859a-560b-4201-b812-1df4d30c6ab2
		summarizeBy: none
		sourceColumn: SOLD_DATE

		variation Variation
			isDefault
			relationship: d004a4c6-1199-4657-ab6a-fd9149320e38
			defaultHierarchy: LocalDateTable_1f78dac9-6ff4-4541-99dd-f6fdef065d71.'Date Hierarchy'

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column 'MM Ongoing Spend Post Lease+90' =
			CALCULATE(SUM(DW_WO[CLIENT_OWNER_RESPONSIBLE_AMOUNT]),FILTER(DW_WO,
			DATE(YEAR(DW_WO[Closed Date_BOM]),MONTH(DW_WO[Closed Date_BOM]),1) = PM_BOM[BEG_OF_MONTH] &&
			(DW_WO[BILL_TO] = "Owner" || DW_WO[CLIENT_OWNER_RESPONSIBLE_AMOUNT]>0 )&&
			DW_WO[TICKET_TYPE] <> "PPI" &&
			DW_WO[TICKET_TYPE] <> "Turnkey" &&
			DW_WO[TICKET_TYPE] <> "Evictions" &&
			DW_WO[TICKET_TYPE] <> "Dispositions" &&
			DW_WO[VENDOR_ID] <> 12064 &&
			DW_WO[VENDOR_ID] <> 21376 &&
			DW_WO[ONGOING_90_DAY_SPEND] = 1 &&
			(DW_WO[INSURANCE_CLAIM] <> "Y" ||DW_WO[INSURANCE_CLAIM]=BLANK()) &&
			DW_WO[PROPERTY_KEY] = PM_BOM[PROP_KEY] ))
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 0bba3623-ba13-40ce-b3b4-a516c3cf7952
		summarizeBy: sum

		changedProperty = FormatString

		annotation SummarizationSetBy = Automatic

