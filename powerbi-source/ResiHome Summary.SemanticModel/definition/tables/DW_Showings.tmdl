	partition DW_Showings-96d5afb9-59c7-4283-b654-e82078a94a82 = m
		mode: import
		queryGroup: 'DW Sources'
		source =
				let
				    Source = Value.NativeQuery(Snowflake.Databases("ota12822.us-east-1.snowflakecomputing.com","DEVELOPER_WH",[Implementation="2.0"]){[Name="PROD_REPLICA"]}[Data], "/* =============================================================================#(lf)   SHOWINGS DATASET (Rently)#(lf)   -----------------------------------------------------------------------------#(lf)   Grain:   One row per lead-showing activity (anchor Rently LEAD_ACTIVITIES via#(lf)            SHOWINGS CTE), joined to the matched listing and post-viewing survey.#(lf)   CTE chain: RENTLY_CLEAN, SHOWINGS, SHOWING_LIST, SHOWINGS_OWNER -> final SELECT.#(lf)#(lf)   CLEANUP NOTES:#(lf)     [SYNC]  The single ORGANIZATION_KEY / ORGANIZATION_NAME CASE block (inside#(lf)             the SHOWINGS CTE) was updated from the two-group form#(lf)             (27,50,51,52 -> 'RB DRC') to the full six-group roll-up that mirrors#(lf)             the master PROPERTY script. The org columns surface via 'S.*' in the#(lf)             final SELECT. DELIBERATE OUTPUT CHANGE limited to organization cols.#(lf)     No CTEs or joins dropped.#(lf)#(lf)   ORG SYNC IMPACT (intended diff vs. original output):#(lf)        50,51,52 stay -> 27, now also 54,45,55,53,56,57,66 -> 27 / 'RB DRC'#(lf)        58,59                     -> 58 / 'Hudson Oak'#(lf)        62,63,64,65,68,69         -> 62 / 'Rocklyn Homes'#(lf)        61,70                     -> 61 / 'ROI Property Group'#(lf)        67                        -> 67 / 'Newstar'#(lf)   ============================================================================= */#(lf)#(lf)WITH RENTLY_CLEAN AS (#(lf)SELECT #(lf) MAX(ID) AS LEAD_ID #(lf),COALESCE(LA.LEAD, LA.LEAD_ID) AS LEAD#(lf),LA.TAG#(lf)FROM PROD_REPLICA.RENTLY.LEAD_ACTIVITIES LA#(lf)WHERE 1=1#(lf)AND TAG IS NOT NULL#(lf)AND TAG BETWEEN '000000' AND '999999'#(lf)GROUP BY#(lf)COALESCE(LA.LEAD, LA.LEAD_ID)#(lf),LA.TAG#(lf))#(lf)--********************************************************#(lf),SHOWINGS AS (#(lf)SELECT DISTINCT #(lf)COALESCE(LA.LEAD, LA.LEAD_ID) AS LEAD#(lf),to_date(LA.LEAD_CREATED_DATE::TEXT,'AUTO') RENTLY_LEAD_CREATED_DAT#(lf),LA.LEAD_STATUS#(lf),LA.NAME AS LEAD_NAME#(lf),LA.EMAIL AS LEAD_EMAIL#(lf),to_Date(LA.ACTIVITY_CREATED_AT::TEXT,'Auto')  ACTIVITY_CREATED_AT#(lf),LA.ACCESS#(lf),PVS.Improvement#(lf),PVS.Notes AS FEEDBACK #(lf),PVS.Interest_2 AS INTERESTED#(lf),PVS.PROPERTY_PROBLEM#(lf),PVS.ACCESS_PROBLEM#(lf)#(lf),P.Property_Key#(lf),P.HBPM_PROPERTY_ID#(lf),P.ENTITYID#(lf),R.REGION_NAME#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN -1#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 27#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 58#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 62#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 61#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 67#(lf)        ELSE P.ORGANIZATION_KEY#(lf)     END AS ORGANIZATION_KEY#(lf),CASE#(lf)        WHEN P.ORGANIZATION_KEY IN (-1,18,26,28,48)                   THEN 'RP SFR'#(lf)        WHEN P.ORGANIZATION_KEY IN (27,50,51,52,54,45,55,53,56,57,66) THEN 'RB DRC'#(lf)        WHEN P.ORGANIZATION_KEY IN (58,59)                            THEN 'Hudson Oak'#(lf)        WHEN P.ORGANIZATION_KEY IN (62,63,64,65,68,69)                THEN 'Rocklyn Homes'#(lf)        WHEN P.ORGANIZATION_KEY IN (61,70)                            THEN 'ROI Property Group'#(lf)        WHEN P.ORGANIZATION_KEY IN (67)                               THEN 'Newstar'#(lf)        ELSE O.ORGANIZATION_NAME#(lf)     END AS ORGANIZATION_NAME#(lf),PO.PORTFOLIO_NAME#(lf),P.ADDRESS || ', ' || CI.CITY_NAME || ', ' || S.STATE_NAME || ' ' || P.ZIPCODE AS Full_Address#(lf),P.ADDRESS#(lf),CI.CITY_NAME#(lf),S.STATE_NAME#(lf),S.STATE_CODE#(lf),P.ZIPCODE#(lf),CO.COUNTY_NAME#(lf),RANK () OVER( PARTITION BY LA.LEAD, P.PROPERTY_KEY, ACTIVITY_CREATED_AT ORDER BY LA.""_MODIFIED"" ) AS RANK_1#(lf)#(lf)FROM RENTLY_CLEAN RC#(lf)LEFT JOIN PROD_REPLICA.RENTLY.LEAD_ACTIVITIES LA ON COALESCE(LA.LEAD, LA.LEAD_ID) = RC.LEAD#(lf)--FROM PROD_REPLICA.RENTLY.LEAD_ACTIVITIES LA#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY P ON P.HBPM_PROPERTY_ID = TRY_TO_NUMERIC(LA.TAG) AND P.CURRENT_FLAG = 'Y'#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROPERTY_UNIT_SUMMARY PUS ON PUS.PROPERTY_KEY  = P.PROPERTY_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PORTFOLIO PO ON PO.PORTFOLIO_KEY = PUS.PORTFOLIO_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_CITY CI ON CI.CITY_KEY = PUS.CITY_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_STATE S ON S.STATE_KEY = PUS.STATE_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_COUNTY CO ON CO.COUNTY_KEY = PUS.COUNTY_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_REGION R ON R.REGION_KEY = PUS.REGION_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_SUBDIVISION SUB ON SUB.SUBDIVISION_KEY = PUS.SUBDIVISION_KEY #(lf)#(tab)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_OWNER_ORGANIZATION O ON O.ORGANIZATION_KEY = PUS.ORGANIZATION_KEY #(lf)#(lf)LEFT JOIN PROD_REPLICA.RENTLY.POST_VIEWING_SURVEY PVS ON COALESCE(PVS.LEAD_ACTIVITY, PVS.LEAD_ACTIVITY_ID) = LA.ID#(lf)#(lf)WHERE 1=1#(lf)AND LA.Access IN ('self_registered_viewing','controlled_showing','prelease_signup','self_registered_scheduling')#(lf)AND LA.TAG NOT IN ('943 Kenbar')#(lf)AND LA.TAG <> ''#(lf)--AND LA.LEAD  = 14015788#(lf)QUALIFY RANK_1 = 1#(lf))#(lf)#(lf)--****************************************************************************************#(lf),SHOWING_LIST AS (#(lf)#(lf)SELECT #(lf)SHOWINGS.LEAD#(lf),SHOWINGS.PROPERTY_KEY#(lf),SHOWINGS.ACTIVITY_CREATED_AT#(lf),Max(rlh.RENT_LIST_HIST_ID) RENT_LIST_HIST_KEY#(lf)#(lf)FROM SHOWINGS#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.DIM_PROPERTY dp ON SHOWINGS.HBPM_PROPERTY_ID = dp.HBPM_PROPERTY_ID#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST rlh ON dp.PROPERTY_KEY = rlh.PROPERTY_KEY #(lf)WHERE 1=1#(lf)AND to_date(RLH.LISTING_DATE_KEY::text,'yyyymmdd') <= DATEADD(DAY,10,ACTIVITY_CREATED_AT)#(lf)AND rlh.LISTING_STATUS <> 'Withdrawn'#(lf)#(lf)GROUP BY #(lf)SHOWINGS.LEAD#(lf),SHOWINGS.PROPERTY_KEY#(lf),SHOWINGS.ACTIVITY_CREATED_AT)#(lf)--****************************************************************************************#(lf),SHOWINGS_OWNER AS (#(lf)#(lf)SELECT DISTINCT #(lf) EMAIL AS CONTACT_EMAIL#(lf),CONTACT_OWNER #(lf),RANK () OVER( PARTITION BY EMAIL ORDER BY CREATED_DATE DESC ) AS RANK_1#(lf)#(lf)FROM PROD_ANALYTICS.DBT_RESICAP.DIM_LEAD #(lf)WHERE 1=1#(lf)AND EMAIL <> ''#(lf)QUALIFY RANK_1 = 1#(lf))#(lf)--******************************************************************************************#(lf)#(lf)SELECT #(lf)S.*#(lf),date_trunc('month',S.ACTIVITY_CREATED_AT) AS SHOWING_BOM#(lf),RLH.RENT_LIST_HIST_ID AS RENT_LIST_HIST_ID#(lf),To_DATE(RLH.LISTING_DATE_KEY::TEXT,'yyyymmdd') AS LISTING_DATE#(lf),RLH.LISTING_STATUS AS LISTING_STATUS#(lf),CASE WHEN INTERESTED IN ('apply','interested') THEN 1 ELSE NULL END AS CAT_APPLY#(lf),CASE WHEN ACCESS_PROBLEM = 1 OR CONTAINS(FEEDBACK, 'access ')  THEN 1 ELSE NULL END AS CAT_ACCESS#(lf),CASE WHEN CONTAINS(PROPERTY_PROBLEM, 'cleanliness') OR CONTAINS(PROPERTY_PROBLEM, 'odor') OR CONTAINS(PROPERTY_PROBLEM, 'vandalism') OR  CONTAINS(IMPROVEMENT, 'Interior Condition') THEN 1 ELSE NULL END AS CAT_CLEAN#(lf),CASE WHEN CONTAINS(IMPROVEMENT, 'Landscaping') OR CONTAINS(FEEDBACK,'grass') THEN 1 ELSE NULL END AS CAT_LANDSCAPE#(lf),SO.CONTACT_OWNER#(lf)#(lf)FROM SHOWINGS S#(lf)LEFT JOIN SHOWING_LIST SL ON SL.LEAD = S.LEAD#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AND SL.PROPERTY_KEY = S.PROPERTY_KEY#(lf)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)#(tab)AND SL.ACTIVITY_CREATED_AT = S.ACTIVITY_CREATED_AT#(lf)#(lf)LEFT JOIN PROD_ANALYTICS.DBT_RESICAP.FCT_PROP_RENTAL_LISTING_HIST RLH ON RLH.RENT_LIST_HIST_ID = SL.RENT_LIST_HIST_KEY#(lf)LEFT JOIN SHOWINGS_OWNER SO ON SO.CONTACT_EMAIL = S.LEAD_EMAIL#(lf)WHERE S.ACTIVITY_CREATED_AT >= '1/1/2025'", null, [EnableFolding=true]),
				    #"Capitalized Each Word" = Table.TransformColumns(Source,{{"LEAD_NAME", Text.Proper, type text}})
				in
				    #"Capitalized Each Word"

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

