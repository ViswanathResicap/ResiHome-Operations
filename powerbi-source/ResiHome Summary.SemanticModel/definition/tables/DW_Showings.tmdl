table DW_Showings
	lineageTag: 6b387e4d-fff7-45b2-b259-ba62ba23e1a8

	measure 0_Showing_Count_Card = COUNT(DW_Showings[LEAD]) + 0
		formatString: #,0
		lineageTag: c012f6f7-f663-41e6-99f4-1430b9c2d4c7

		changedProperty = FormatString

	measure 0_Showing_Count = COUNT(DW_Showings[LEAD])
		formatString: #,0
		lineageTag: d0e1cef3-dd2c-4acf-9278-ac9f3c2c8ef7

		changedProperty = FormatString

	measure '0_Shows W/W' =
			IFERROR((CALCULATE(COUNT(DW_Showings[LEAD]),FILTER(DW_Showings,DW_Showings[ACTIVITY_CREATED_AT]>=(TODAY()-7)&&DW_Showings[ACTIVITY_CREATED_AT]<=(TODAY()-1))) + 0 )
			/
			CALCULATE(COUNT(DW_Showings[LEAD]),FILTER(DW_Showings,DW_Showings[ACTIVITY_CREATED_AT]>=(TODAY()-14)&&DW_Showings[ACTIVITY_CREATED_AT]<=(TODAY()-8)))
			
			-1,"N/A")
		formatString: 0.0%;-0.0%;0.0%
		lineageTag: e5ec1e5c-c4f2-40a3-990a-12d41294a52c

		changedProperty = FormatString

